{
  "kind": "collectionType",
  "collectionName": "pagos",
  "info": {
    "singularName": "pago",
    "pluralName": "pagos",
    "displayName": "Pago"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "reserva": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::reserva.reserva",
      "inversedBy": "pagos"
    },
    "proveedor": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "izipay",
        "paypal"
      ]
    },
    "metodo": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "tarjeta",
        "yape_qr",
        "paypal"
      ]
    },
    "moneda": {
      "type": "enumeration",
      "required": true,
      "default": "PEN",
      "enum": [
        "PEN",
        "USD",
        "EUR"
      ]
    },
    "monto": {
      "type": "decimal",
      "required": true
    },
    "estado": {
      "type": "enumeration",
      "required": true,
      "default": "pendiente",
      "enum": [
        "pendiente",
        "pagado",
        "fallido",
        "reembolsado"
      ]
    },
    "transaccion_id": {
      "type": "string",
      "required": false
    },
    "orden_id": {
      "type": "string",
      "required": false
    },
    "codigo_respuesta": {
      "type": "string",
      "required": false
    },
    "mensaje_respuesta": {
      "type": "string",
      "required": false
    },
    "qr_url": {
      "type": "text",
      "required": false
    },
    "qr_expiracion": {
      "type": "datetime",
      "required": false
    },
    "fecha_pago": {
      "type": "datetime",
      "required": false
    },
    "ip_cliente": {
      "type": "string",
      "required": false
    }
  }
}
