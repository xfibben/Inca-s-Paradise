        "i18n": {
          "localized": false
        }
      }
    },
    "tourType": {
      "type": "enumeration",
      "enum": [
        "tour",
        "small_trip",
        "package"
      ],
      "default": "tour",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "adultUnitPrice": {
      "type": "decimal",
