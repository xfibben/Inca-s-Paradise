      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "itineraryCollapseLabel": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "itineraryItems": {
      "type": "component",
      "repeatable": true,
      "component": "tours.itinerary-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "includedTitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
