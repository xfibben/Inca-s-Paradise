      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "highlightsCtaUrl": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "highlightsItems": {
      "type": "component",
      "repeatable": true,
      "component": "tours.highlight-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "featuredTitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "featuredImages": {
      "type": "component",
      "repeatable": true,
