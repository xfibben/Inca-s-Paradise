      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "showInStyles": {
      "type": "boolean",
      "default": false,
      "description": "Mostrar este tour en la sección de Small Trips de las páginas de estilos de viaje"
    },
    "tourType": {
      "type": "enumeration",
      "enum": [
        "tour",
        "small_trip",
        "package"
      ],
      "default": "tour",
      "description": "Tipo de tour: Tour, Small Trip o Paquete"
    },
    "precio_unitario_adulto": {
      "type": "decimal",
      "required": true,
      "min": 0,
      "description": "Precio base por adulto"
    },
    "precio_unitario_nino": {
      "type": "decimal",
      "required": true,
      "min": 0,
      "description": "Precio base por niño"
    },
    "descuento": {
      "type": "decimal",
      "required": false,
      "default": 0,
      "min": 0,
      "description": "Descuento opcional"
    },
    "duracion_dias": {
      "type": "integer",
      "required": false,
      "min": 1,
      "description": "Duración del tour en días"
    }
