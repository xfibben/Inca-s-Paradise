{
  "kind": "collectionType",
  "collectionName": "reservas",
  "info": {
    "singularName": "reserva",
    "pluralName": "reservas",
    "displayName": "Reserva"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "usuario": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "tour": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tour-detalle.tour-detalle",
      "inversedBy": "reservations"
    },
    "email": {
      "type": "email",
      "required": true
    },
    "telefono": {
      "type": "string",
      "required": true
    },
    "fecha_inicio": {
      "type": "datetime",
      "required": true
    },
    "fecha_fin": {
      "type": "datetime",
      "required": true
    },
    "cantidad_adultos": {
      "type": "integer",
      "required": true,
      "default": 1,
      "min": 1
    },
    "cantidad_ninos": {
      "type": "integer",
      "required": true,
      "default": 0,
      "min": 0
    },
    "descuento": {
      "type": "decimal",
      "required": false,
      "default": 0,
      "min": 0
    },
    "monto_subtotal": {
      "type": "decimal",
      "required": false
    },
    "igv_porcentaje": {
      "type": "decimal",
      "required": true,
      "default": 18,
      "min": 0,
      "max": 100
    },
    "monto_final": {
      "type": "decimal",
      "required": false
    },
    "estado": {
      "type": "enumeration",
      "required": true,
      "default": "pendiente",
      "enum": [
        "pendiente",
        "confirmada",
        "cancelada"
      ]
    },
    "notas": {
      "type": "text",
      "required": false
    },
    "ticket": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "tipo_documento": {
      "type": "enumeration",
      "required": true,
      "default": "dni",
      "enum": [
        "dni",
        "rut",
        "pasaporte"
      ]
    },
    "numero_documento": {
      "type": "string",
      "required": true
    },
    "nacionalidad": {
      "type": "string",
      "required": true
    }
  }
}
