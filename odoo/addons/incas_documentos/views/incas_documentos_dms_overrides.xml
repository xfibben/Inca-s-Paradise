<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_dms_file_multi_upload_wizard_form" model="ir.ui.view">
        <field name="name">incas.dms.file.multi.upload.wizard.form</field>
        <field name="model">incas.dms.file.multi.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Subir varios archivos">
                <sheet>
                    <group>
                        <field name="directory_id"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
                <footer>
                    <button
                        name="action_subir_archivos"
                        type="object"
                        string="Subir archivos"
                        class="btn btn-primary"
                    />
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_incas_dms_file_multi_upload_wizard" model="ir.actions.act_window">
        <field name="name">Subir varios archivos</field>
        <field name="res_model">incas.dms.file.multi.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_incas_dms_file_multi_upload_wizard_form"/>
        <field name="context">{'default_directory_id': context.get('default_directory_id')}</field>
    </record>

    <record id="dms.main_menu_dms" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="view_dms_file_kanban_incas_download" model="ir.ui.view">
        <field name="name">dms.file.kanban.incas.download</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//a[contains(@class, 'o_kanban_dms_file_preview')]" position="attributes">
                <attribute name="class">h-100 d-block incas_dms_file_preview</attribute>
                <attribute name="t-attf-href">/incas/dms/file/#{record.id.raw_value}/preview</attribute>
                <attribute name="target">_blank</attribute>
            </xpath>

            <xpath expr="//a[contains(@t-attf-href, '/web/content?id=#{record.id.raw_value}&amp;field=content&amp;model=dms.file&amp;filename_field=name&amp;download=true')]" position="attributes">
                <attribute name="t-attf-href">/incas/dms/file/#{record.id.raw_value}/content?download=true</attribute>
            </xpath>

            <xpath expr="//div[@role='menuitem'][a[@type='open']]" position="before">
                <div role="menuitem">
                    <a t-attf-href="/incas/dms/file/#{record.id.raw_value}/preview" target="_blank">
                        <i class="fa fa-eye" />
                        Vista previa
                    </a>
                </div>
            </xpath>

            <xpath expr="//a[@type='delete']" position="attributes">
                <attribute name="type"></attribute>
                <attribute name="name"></attribute>
                <attribute name="href">#</attribute>
                <attribute name="class" add=" incas_dms_delete" separator=" "/>
                <attribute name="t-att-data-record-id">record.id.raw_value</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_dms_file_new_form_incas_multi_upload" model="ir.ui.view">
        <field name="name">dms.file.new.form.incas.multi.upload</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_new_form"/>
        <field name="arch" type="xml">
            <xpath expr="//footer" position="inside">
                <button
                    type="action"
                    name="%(action_incas_dms_file_multi_upload_wizard)d"
                    string="Subir varios archivos"
                    context="{'default_directory_id': directory_id or context.get('default_directory_id')}"
                    class="btn btn-secondary"
                />
            </xpath>
        </field>
    </record>
</odoo>
