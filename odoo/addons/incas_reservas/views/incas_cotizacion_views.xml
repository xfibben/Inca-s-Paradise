<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_incas_cotizacion_list" model="ir.ui.view">
        <field name="name">incas.cotizacion.list</field>
        <field name="model">incas.cotizacion</field>
        <field name="arch" type="xml">
            <list string="Cotizaciones">
                <field name="name" />
                <field name="partner_id" />
                <field name="fecha_cotizacion" />
                <field name="fecha_viaje" />
                <field name="idioma" />
                <field name="servicio_nombre" />
                <field name="precio_adulto" />
                <field name="precio_nino" />
                <field name="descuento" />
                <field name="cantidad_adultos" />
                <field name="cantidad_ninos" />
                <field name="monto_total" />
                <field name="paquete_item_count" />
                <field name="moneda" />
                <field name="state" />
                <field name="responsable_id" />
            </list>
        </field>
    </record>

    <record id="view_incas_cotizacion_search" model="ir.ui.view">
        <field name="name">incas.cotizacion.search</field>
        <field name="model">incas.cotizacion</field>
        <field name="arch" type="xml">
            <search string="Buscar cotizaciones">
                <field name="name" />
                <field name="partner_id" />
                <field name="servicio_nombre" />
                <field name="state" />
                <field name="idioma" />
                <separator />
                <filter
                    name="filter_borrador"
                    string="Borrador"
                    domain="[('state', '=', 'borrador')]"
                />
                <filter
                    name="filter_aprobada"
                    string="Aprobada"
                    domain="[('state', '=', 'aprobada')]"
                />
                <separator />
                <filter
                    name="group_state"
                    string="Estado"
                    domain="[]"
                    context="{'group_by': 'state'}"
                />
                <filter
                    name="group_idioma"
                    string="Idioma"
                    domain="[]"
                    context="{'group_by': 'idioma'}"
                />
                <filter
                    name="group_responsable"
                    string="Responsable"
                    domain="[]"
                    context="{'group_by': 'responsable_id'}"
                />
            </search>
        </field>
    </record>

    <record id="view_incas_cotizacion_form" model="ir.ui.view">
        <field name="name">incas.cotizacion.form</field>
        <field name="model">incas.cotizacion</field>
        <field name="arch" type="xml">
            <form string="Cotización">
                <header>
                    <button
                        name="action_print_pdf"
                        type="object"
                        string="Exportar PDF"
                    />
                    <button
                        name="action_print_package_pdf"
                        type="object"
                        string="Exportar detalle paquete"
                    />
                    <button
                        name="action_marcar_enviada"
                        type="object"
                        string="Marcar enviada"
                        invisible="state != 'borrador'"
                    />
                    <button
                        name="action_marcar_aprobada"
                        type="object"
                        string="Aprobar"
                        invisible="state not in ['borrador', 'enviada']"
                    />
                    <button
                        name="action_marcar_rechazada"
                        type="object"
                        string="Rechazar"
                        invisible="state == 'rechazada'"
                    />
                    <button
                        name="action_cancelar"
                        type="object"
                        string="Cancelar"
                        invisible="state == 'cancelada'"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="borrador,enviada,aprobada,rechazada,cancelada"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" />
                            <field name="fecha_cotizacion" />
                            <field name="fecha_viaje" />
                            <field name="responsable_id" />
                        </group>
                        <group>
                            <field name="idioma" />
                            <field name="canal_venta" />
                            <field
                                name="precio_adulto_usd"
                                invisible="1"
                                force_save="1"
                            />
                            <field
                                name="precio_nino_usd"
                                invisible="1"
                                force_save="1"
                            />
                            <field
                                name="servicio_nombre"
                                readonly="1"
                                force_save="1"
                            />
                            <field
                                name="precio_adulto"
                                readonly="1"
                                force_save="1"
                            />
                            <field
                                name="precio_nino"
                                readonly="1"
                                force_save="1"
                            />
                            <field
                                name="descuento"
                                readonly="1"
                                force_save="1"
                            />
                            <field name="cantidad_adultos" />
                            <field name="cantidad_ninos" />
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="cantidad_pasajeros" readonly="1" />
                            <field name="monto_total" readonly="1" />
                            <field name="paquete_item_count" readonly="1" />
                            <field name="moneda" />
                        </group>
                        <group>
                            <field name="reserva_count" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Paquete">
                            <field name="paquete_linea_ids">
                                <list editable="bottom">
                                    <field name="servicio_id" />
                                    <field name="vehiculo_id" optional="hide" />
                                    <field name="fecha" />
                                    <field name="horario_id" />
                                    <button
                                        name="action_open_popup"
                                        type="object"
                                        icon="fa-pencil-square-o"
                                        string="Editar"
                                    />
                                    <field name="sequence" widget="handle" />
                                    <field name="moneda" readonly="1" />
                                    <field name="tipo_servicio" readonly="1" />
                                    <field
                                        name="tipo_tour"
                                        readonly="1"
                                        optional="hide"
                                    />
                                    <field
                                        name="estilo_transporte_id"
                                        readonly="1"
                                        optional="hide"
                                    />
                                    <field name="nombre" />
                                    <field name="precio_adulto" />
                                    <field name="precio_nino" />
                                    <field name="descuento" />
                                    <field
                                        name="precio_adulto_neto"
                                        readonly="1"
                                    />
                                    <field
                                        name="precio_nino_neto"
                                        readonly="1"
                                    />
                                    <field
                                        name="precio_adulto_usd"
                                        column_invisible="1"
                                        optional="hide"
                                    />
                                    <field
                                        name="precio_nino_usd"
                                        column_invisible="1"
                                        optional="hide"
                                    />
                                    <field
                                        name="precio_adulto_neto_usd"
                                        column_invisible="1"
                                        optional="hide"
                                    />
                                    <field
                                        name="precio_nino_neto_usd"
                                        column_invisible="1"
                                        optional="hide"
                                    />
                                </list>
                            </field>
                        </page>
                        <page string="Observaciones">
                            <field
                                name="observaciones"
                                placeholder="Detalle interno de la cotización"
                            />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="action_incas_cotizaciones" model="ir.actions.act_window">
        <field name="name">Cotizaciones</field>
        <field name="res_model">incas.cotizacion</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_cotizacion_search" />
    </record>

    <record id="view_incas_cotizacion_paquete_linea_form" model="ir.ui.view">
        <field name="name">incas.cotizacion.paquete.linea.form</field>
        <field name="model">incas.cotizacion.paquete.linea</field>
        <field name="arch" type="xml">
            <form string="Detalle del servicio">
                <sheet>
                    <group>
                        <group>
                            <field name="fecha" />
                            <field name="horario_id" />
                            <field name="cotizacion_id" readonly="1" />
                            <field name="servicio_id" readonly="1" />
                            <field
                                name="vehiculo_disponible_ids"
                                invisible="1"
                            />
                            <field
                                name="vehiculo_id"
                                invisible="tipo_servicio != 'transporte'"
                                domain="[('id', 'in', vehiculo_disponible_ids)]"
                            />
                            <field name="tipo_servicio" readonly="1" />
                            <field
                                name="tipo_tour"
                                readonly="1"
                                invisible="tipo_servicio != 'tour'"
                            />
                            <field
                                name="estilo_transporte_id"
                                readonly="1"
                                invisible="tipo_servicio != 'transporte'"
                            />
                            <field name="moneda" readonly="1" />
                            <field name="nombre" />
                        </group>
                        <group>
                            <field name="precio_adulto" />
                            <field name="precio_nino" />
                            <field name="descuento" />
                            <field name="precio_adulto_neto" readonly="1" />
                            <field name="precio_nino_neto" readonly="1" />
                            <field name="precio_adulto_usd" invisible="1" />
                            <field name="precio_nino_usd" invisible="1" />
                            <field
                                name="precio_adulto_neto_usd"
                                invisible="1"
                            />
                            <field name="precio_nino_neto_usd" invisible="1" />
                            <field name="slug" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Tour" invisible="tipo_servicio != 'tour'">
                            <group>
                                <group>
                                    <field name="destino_slug" />
                                    <field name="destinos_data" widget="text" />
                                    <field name="estilos_data" widget="text" />
                                    <field name="duration_days" />
                                    <field name="hero_title" />
                                    <field name="hero_description" />
                                    <field name="highlights_title" />
                                    <field name="highlights_lead" />
                                    <field
                                        name="highlights_items_data"
                                        widget="text"
                                    />
                                </group>
                                <group>
                                    <field name="itinerary_title" />
                                    <field
                                        name="itinerary_items_data"
                                        widget="text"
                                    />
                                    <field name="schedule_title" />
                                    <field
                                        name="schedule_items_data"
                                        widget="text"
                                    />
                                    <field name="included_title" />
                                    <field
                                        name="included_items_data"
                                        widget="text"
                                    />
                                    <field name="excluded_title" />
                                    <field
                                        name="excluded_items_data"
                                        widget="text"
                                    />
                                    <field name="faq_title" />
                                    <field
                                        name="faq_items_data"
                                        widget="text"
                                    />
                                </group>
                            </group>
                        </page>
                        <page
                            string="Transporte"
                            invisible="tipo_servicio != 'transporte'"
                        >
                            <group>
                                <group>
                                    <field
                                        name="destino_origen_data"
                                        widget="text"
                                    />
                                    <field
                                        name="destino_llegada_data"
                                        widget="text"
                                    />
                                    <field name="modelo_vehiculo" />
                                    <field name="duracion_viaje" />
                                    <field name="distancia" />
                                    <field name="descripcion_origen" />
                                    <field name="descripcion_llegada" />
                                    <field name="descripcion" />
                                </group>
                                <group>
                                    <field name="included_title" />
                                    <field
                                        name="included_items_data"
                                        widget="text"
                                    />
                                    <field name="excluded_title" />
                                    <field
                                        name="excluded_items_data"
                                        widget="text"
                                    />
                                    <field
                                        name="tipos_transporte_data"
                                        widget="text"
                                    />
                                    <field name="precios_data" widget="text" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="menu_incas_cotizaciones"
        name="Cotizaciones"
        parent="incas_core.menu_incas_reservas_root"
        action="action_incas_cotizaciones"
        sequence="10"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_reservas,incas_core.group_incas_core_gerencia"
    />
</odoo>
