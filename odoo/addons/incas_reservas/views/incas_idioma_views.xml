<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_idioma_list" model="ir.ui.view">
        <field name="name">incas.idioma.list</field>
        <field name="model">incas.idioma</field>
        <field name="arch" type="xml">
            <list string="Idiomas">
                <field name="sequence" widget="handle"/>
                <field name="nombre"/>
                <field name="codigo"/>
                <field name="por_defecto"/>
                <field name="activo"/>
            </list>
        </field>
    </record>

    <record id="view_incas_idioma_form" model="ir.ui.view">
        <field name="name">incas.idioma.form</field>
        <field name="model">incas.idioma</field>
        <field name="arch" type="xml">
            <form string="Idioma">
                <sheet>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="codigo"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="por_defecto"/>
                            <field name="activo"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_idioma" model="ir.actions.act_window">
        <field name="name">Idiomas</field>
        <field name="res_model">incas.idioma</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_incas_idioma"
        name="Idiomas"
        parent="incas_core.menu_incas_configuracion_root"
        action="action_incas_idioma"
        sequence="9"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
