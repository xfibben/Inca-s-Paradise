<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_catalogo_transporte_list" model="ir.ui.view">
        <field name="name">incas.catalogo.transporte.list</field>
        <field name="model">incas.catalogo.transporte</field>
        <field name="arch" type="xml">
            <list string="Catálogo de transportes">
                <field name="name"/>
                <field name="estilo_transporte_id"/>
                <field name="precio_adulto"/>
                <field name="precio_nino"/>
                <field name="descuento"/>
                <field name="slug"/>
                <field name="strapi_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_catalogo_transporte_search" model="ir.ui.view">
        <field name="name">incas.catalogo.transporte.search</field>
        <field name="model">incas.catalogo.transporte</field>
        <field name="arch" type="xml">
            <search string="Buscar transportes">
                <field name="name"/>
                <field name="estilo_transporte_id"/>
                <field name="slug"/>
                <filter name="group_estilo" string="Estilo de transporte" domain="[]" context="{'group_by': 'estilo_transporte_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_incas_catalogo_transporte_form" model="ir.ui.view">
        <field name="name">incas.catalogo.transporte.form</field>
        <field name="model">incas.catalogo.transporte</field>
        <field name="arch" type="xml">
            <form string="Transporte">
                <header>
                    <button name="action_sync_from_strapi" type="object" string="Sincronizar desde Strapi"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="estilo_transporte_id"/>
                            <field name="precio_adulto"/>
                            <field name="precio_nino"/>
                            <field name="descuento"/>
                            <field name="modelo_vehiculo"/>
                            <field name="duracion_viaje"/>
                            <field name="distancia"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="strapi_id"/>
                            <field name="strapi_document_id"/>
                            <field name="slug"/>
                            <field name="servicio_id" readonly="1"/>
                            <field name="seo_title"/>
                            <field name="seo_description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción">
                            <group>
                                <group>
                                    <field name="descripcion_origen"/>
                                    <field name="descripcion_llegada"/>
                                    <field name="descripcion"/>
                                </group>
                                <group>
                                    <field name="included_title"/>
                                    <field name="included_items_data" widget="text"/>
                                    <field name="excluded_title"/>
                                    <field name="excluded_items_data" widget="text"/>
                                </group>
                            </group>
                        </page>
                        <page string="Relaciones">
                            <group>
                                <field name="destino_origen_data" widget="text"/>
                                <field name="destino_llegada_data" widget="text"/>
                                <field name="tipos_transporte_data" widget="text"/>
                            </group>
                        </page>
                        <page string="Media y precios">
                            <group>
                                <field name="image_data" widget="text"/>
                                <field name="wallpaper_data" widget="text"/>
                                <field name="precios_data" widget="text"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_catalogo_transporte" model="ir.actions.act_window">
        <field name="name">Transportes</field>
        <field name="res_model">incas.catalogo.transporte</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_catalogo_transporte_search"/>
    </record>

    <menuitem
        id="menu_incas_catalogo_transporte"
        name="Transportes"
        parent="incas_core.menu_incas_configuracion_root"
        action="action_incas_catalogo_transporte"
        sequence="12"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
