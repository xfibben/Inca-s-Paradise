<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_catalogo_transporte_list" model="ir.ui.view">
        <field name="name">incas.catalogo.transporte.list</field>
        <field name="model">incas.catalogo.transporte</field>
        <field name="arch" type="xml">
            <list string="Catálogo de transportes">
                <field name="name"/>
                <field name="estilo_transporte_ids" widget="many2many_tags"/>
                <field name="slug"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_catalogo_transporte_search" model="ir.ui.view">
        <field name="name">incas.catalogo.transporte.search</field>
        <field name="model">incas.catalogo.transporte</field>
        <field name="arch" type="xml">
            <search string="Buscar transportes">
                <field name="name"/>
                <field name="estilo_transporte_ids"/>
                <field name="slug"/>
            </search>
        </field>
    </record>

    <record id="view_incas_catalogo_transporte_form" model="ir.ui.view">
        <field name="name">incas.catalogo.transporte.form</field>
        <field name="model">incas.catalogo.transporte</field>
        <field name="arch" type="xml">
            <form string="Transporte">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="estilo_transporte_ids" widget="many2many_tags"/>
                            <field name="duracion_viaje"/>
                            <field name="distancia"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="slug"/>
                            <field name="modelo_vehiculo"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="name"/>
                                <field name="descripcion" widget="html"/>
                                <field name="destino_origen_data" widget="text"/>
                                <field name="destino_llegada_data" widget="text"/>
                                <field name="seo_title"/>
                                <field name="seo_description"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="name_en"/>
                                <field name="descripcion_en" widget="html"/>
                                <field name="destino_origen_data_en" widget="text"/>
                                <field name="destino_llegada_data_en" widget="text"/>
                                <field name="seo_title_en"/>
                                <field name="seo_description_en"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="name_pt"/>
                                <field name="descripcion_pt" widget="html"/>
                                <field name="destino_origen_data_pt" widget="text"/>
                                <field name="destino_llegada_data_pt" widget="text"/>
                                <field name="seo_title_pt"/>
                                <field name="seo_description_pt"/>
                            </group>
                        </page>
                        <page string="Incluye">
                            <field name="incluye_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="texto"/>
                                    <field name="texto_en"/>
                                    <field name="texto_pt"/>
                                </list>
                                <form string="Incluye">
                                    <sheet>
                                        <group string="Español">
                                            <field name="texto"/>
                                        </group>
                                        <group string="English">
                                            <field name="texto_en"/>
                                        </group>
                                        <group string="Português">
                                            <field name="texto_pt"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="No incluye">
                            <field name="no_incluye_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="texto"/>
                                    <field name="texto_en"/>
                                    <field name="texto_pt"/>
                                </list>
                                <form string="No incluye">
                                    <sheet>
                                        <group string="Español">
                                            <field name="texto"/>
                                        </group>
                                        <group string="English">
                                            <field name="texto_en"/>
                                        </group>
                                        <group string="Português">
                                            <field name="texto_pt"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Tarifas">
                            <field name="tarifa_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="vehiculo_id"/>
                                    <field name="precio_adulto_usd"/>
                                    <field name="precio_nino_usd"/>
                                    <field name="descuento"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Imágenes">
                            <group>
                                <field name="image_data" widget="image" options="{'size': [256, 256]}"/>
                                <field name="wallpaper_data" widget="image" options="{'size': [512, 256]}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_catalogo_transporte" model="ir.actions.act_window">
        <field name="name">Transportes</field>
        <field name="res_model">incas.catalogo.transporte</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_catalogo_transporte_search"/>
    </record>

    <menuitem
        id="menu_incas_catalogo_transporte"
        name="Transportes"
        parent="incas_core.menu_incas_configuracion_root"
        action="action_incas_catalogo_transporte"
        sequence="12"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
