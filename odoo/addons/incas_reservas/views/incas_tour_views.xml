<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_tour_list" model="ir.ui.view">
        <field name="name">incas.tour.list</field>
        <field name="model">incas.tour</field>
        <field name="arch" type="xml">
            <list string="Tours">
                <field name="nombre"/>
                <field name="tipo_tour"/>
                <field name="slug"/>
                <field name="destino_ids" widget="many2many_tags"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_tour_search" model="ir.ui.view">
        <field name="name">incas.tour.search</field>
        <field name="model">incas.tour</field>
        <field name="arch" type="xml">
            <search string="Buscar tours">
                <field name="nombre"/>
                <field name="tipo_tour"/>
                <field name="slug"/>
                <field name="destino_ids"/>
            </search>
        </field>
    </record>

    <record id="view_incas_tour_form" model="ir.ui.view">
        <field name="name">incas.tour.form</field>
        <field name="model">incas.tour</field>
        <field name="arch" type="xml">
            <form string="Tour">
                <header>
                    <button name="action_copiar_imagenes_destacadas" type="object" string="Copiar featured images desde itinerary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_documentos" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Documentos</span>
                            </div>
                        </button>
                    </div>
                    <field name="documento_directory_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="tipo_tour"/>
                            <field name="estilo_ids" widget="many2many_tags"/>
                            <field name="destino_ids" widget="many2many_tags"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="imagen" widget="image" options="{'size': [256, 256]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="slug"/>
                                <field name="meta_titulo" widget="html"/>
                                <field name="meta_descripcion" widget="html"/>
                                <field name="destacados_titulo" widget="html"/>
                                <field name="destacados_lead" widget="html"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="slug_en"/>
                                <field name="meta_titulo_en" widget="html"/>
                                <field name="meta_descripcion_en" widget="html"/>
                                <field name="destacados_titulo_en" widget="html"/>
                                <field name="destacados_lead_en" widget="html"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="slug_pt"/>
                                <field name="meta_titulo_pt" widget="html"/>
                                <field name="meta_descripcion_pt" widget="html"/>
                                <field name="destacados_titulo_pt" widget="html"/>
                                <field name="destacados_lead_pt" widget="html"/>
                            </group>
                        </page>
                        <page string="Highlights items">
                            <field name="destacado_item_ids" nolabel="1">
                                <list editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="contenido"/>
                                    <field name="titulo_en"/>
                                    <field name="contenido_en"/>
                                    <field name="titulo_pt"/>
                                    <field name="contenido_pt"/>
                                </list>
                                <form string="Highlight item">
                                    <sheet>
                                        <group string="Español">
                                            <field name="titulo" widget="html"/>
                                            <field name="contenido" widget="html"/>
                                        </group>
                                        <group string="English">
                                            <field name="titulo_en" widget="html"/>
                                            <field name="contenido_en" widget="html"/>
                                        </group>
                                        <group string="Português">
                                            <field name="titulo_pt" widget="html"/>
                                            <field name="contenido_pt" widget="html"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Itinerary items">
                            <field name="itinerario_item_ids" nolabel="1">
                                <list editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="descripcion"/>
                                    <field name="titulo_en"/>
                                    <field name="descripcion_en"/>
                                    <field name="titulo_pt"/>
                                    <field name="descripcion_pt"/>
                                </list>
                                <form string="Itinerary item">
                                    <sheet>
                                        <group string="Español">
                                            <field name="titulo" widget="html"/>
                                            <field name="descripcion" widget="html"/>
                                        </group>
                                        <group string="English">
                                            <field name="titulo_en" widget="html"/>
                                            <field name="descripcion_en" widget="html"/>
                                        </group>
                                        <group string="Português">
                                            <field name="titulo_pt" widget="html"/>
                                            <field name="descripcion_pt" widget="html"/>
                                        </group>
                                        <group string="Imágenes">
                                            <field name="imagen_ids" nolabel="1">
                                                <list editable="bottom">
                                                    <field name="sequence" widget="handle"/>
                                                    <field name="imagen" widget="image" options="{'size': [128, 128]}"/>
                                                </list>
                                            </field>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Included">
                            <field name="incluye_item_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="titulo_en"/>
                                    <field name="titulo_pt"/>
                                </list>
                            </field>
                        </page>
                        <page string="Not included">
                            <field name="no_incluye_item_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="titulo_en"/>
                                    <field name="titulo_pt"/>
                                </list>
                            </field>
                        </page>
                        <page string="Horarios">
                            <field name="horario_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="horario_inicial"/>
                                    <field name="horario_final"/>
                                </list>
                            </field>
                        </page>
                        <page string="Featured images">
                            <field name="imagen_destacada_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="imagen" widget="image" options="{'size': [128, 128]}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_tour" model="ir.actions.act_window">
        <field name="name">Tours web</field>
        <field name="res_model">incas.tour</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_tour_search"/>
    </record>

    <menuitem
        id="menu_incas_tour"
        name="Tours web"
        parent="incas_core.menu_incas_configuracion_root"
        action="action_incas_tour"
        sequence="13"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
