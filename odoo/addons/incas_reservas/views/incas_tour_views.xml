<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_tour_list" model="ir.ui.view">
        <field name="name">incas.tour.list</field>
        <field name="model">incas.tour</field>
        <field name="arch" type="xml">
            <list string="Tours">
                <field name="nombre"/>
                <field name="observacion" widget="badge" decoration-danger="observacion == 'corregir'" decoration-warning="observacion == 'arreglar_imagenes'" decoration-success="observacion == 'perfecto'"/>
                <field name="ultimo_editor_id"/>
                <field name="tipo_tour"/>
                <field name="ip"/>
                <field name="slug"/>
                <field name="destino_ids" widget="many2many_tags"/>
                <field name="subcategoria_destino_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_tour_search" model="ir.ui.view">
        <field name="name">incas.tour.search</field>
        <field name="model">incas.tour</field>
        <field name="arch" type="xml">
            <search string="Buscar tours">
                <field name="nombre"/>
                <field name="tipo_tour"/>
                <field name="ip"/>
                <field name="slug"/>
                <field name="destino_ids"/>
                <field name="subcategoria_destino_id"/>
            </search>
        </field>
    </record>

    <record id="view_incas_tour_form" model="ir.ui.view">
        <field name="name">incas.tour.form</field>
        <field name="model">incas.tour</field>
        <field name="arch" type="xml">
            <form string="Tour">
                <header>
                    <button name="action_copiar_imagenes_destacadas" type="object" string="Copiar imagenes destacadas desde itinerario"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_documentos" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Documentos</span>
                            </div>
                        </button>
                    </div>
                    <field name="documento_directory_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="servicio_id" readonly="1"/>
                            <field name="tipo_tour"/>
                            <field name="ip"/>
                            <field name="precio_adulto"/>
                            <field name="precio_nino"/>
                            <field name="descuento"/>
                            <field name="dias"/>
                            <field name="estilo_ids" widget="many2many_tags"/>
                            <field name="destino_ids" widget="many2many_tags"/>
                            <field name="subcategoria_destino_id" domain="[('destino_id', 'in', destino_ids)]"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="imagen" widget="image" options="{'size': [256, 256]}"/>
                            <field name="observacion"/>
                            <field name="ultimo_editor_id" readonly="1"/>
                            <field name="comentario" placeholder="Notas internas sobre el estado del tour"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="nombre"/>
                                <field name="slug"/>
                                <field name="meta_titulo"/>
                                <field name="meta_descripcion"/>
                                <field name="destacados_titulo" widget="html"/>
                                <field name="destacados_lead" widget="html"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="nombre_en"/>
                                <field name="slug_en"/>
                                <field name="meta_titulo_en"/>
                                <field name="meta_descripcion_en"/>
                                <field name="destacados_titulo_en" widget="html"/>
                                <field name="destacados_lead_en" widget="html"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="nombre_pt"/>
                                <field name="slug_pt"/>
                                <field name="meta_titulo_pt"/>
                                <field name="meta_descripcion_pt"/>
                                <field name="destacados_titulo_pt" widget="html"/>
                                <field name="destacados_lead_pt" widget="html"/>
                            </group>
                        </page>
                        <page string="Items destacados">
                            <field name="destacado_item_ids" nolabel="1">
                                <list editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="contenido"/>
                                    <field name="titulo_en"/>
                                    <field name="contenido_en"/>
                                    <field name="titulo_pt"/>
                                    <field name="contenido_pt"/>
                                </list>
                                <form string="Item destacado">
                                    <sheet>
                                        <group string="Español">
                                            <field name="titulo" widget="html"/>
                                            <field name="contenido" widget="html"/>
                                        </group>
                                        <group string="English">
                                            <field name="titulo_en" widget="html"/>
                                            <field name="contenido_en" widget="html"/>
                                        </group>
                                        <group string="Português">
                                            <field name="titulo_pt" widget="html"/>
                                            <field name="contenido_pt" widget="html"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Items itinerario">
                            <field name="itinerario_item_ids" nolabel="1">
                                <list editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="descripcion"/>
                                    <field name="titulo_en"/>
                                    <field name="descripcion_en"/>
                                    <field name="titulo_pt"/>
                                    <field name="descripcion_pt"/>
                                </list>
                                <form string="Item itinerario">
                                    <sheet>
                                        <group string="Español">
                                            <field name="titulo" widget="html"/>
                                            <field name="descripcion" widget="html"/>
                                        </group>
                                        <group string="English">
                                            <field name="titulo_en" widget="html"/>
                                            <field name="descripcion_en" widget="html"/>
                                        </group>
                                        <group string="Português">
                                            <field name="titulo_pt" widget="html"/>
                                            <field name="descripcion_pt" widget="html"/>
                                        </group>
                                        <group string="Imagenes">
                                            <field name="imagen_ids" nolabel="1" mode="kanban,list">
                                                <kanban>
                                                    <templates>
                                                        <t t-name="card">
                                                            <div class="d-flex align-items-center gap-3 p-2">
                                                                <field name="imagen" widget="image" options="{'size': [96, 96]}"/>
                                                                <div class="flex-grow-1">
                                                                    <div class="fw-bold">
                                                                        <field name="nombre_display"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </t>
                                                    </templates>
                                                </kanban>
                                                <list editable="bottom" open_form_view="True">
                                                    <field name="sequence" widget="handle"/>
                                                    <field name="imagen" widget="image" options="{'size': [128, 128]}"/>
                                                    <field name="nombre_display" readonly="1"/>
                                                </list>
                                                <form string="Imagen de itinerario">
                                                    <sheet>
                                                        <group>
                                                            <field name="sequence"/>
                                                            <field name="nombre_display" readonly="1"/>
                                                            <field name="imagen" widget="image" options="{'size': [512, 512]}"/>
                                                        </group>
                                                    </sheet>
                                                </form>
                                            </field>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Incluidos">
                            <field name="incluye_item_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="titulo_en"/>
                                    <field name="titulo_pt"/>
                                </list>
                            </field>
                        </page>
                        <page string="No incluidos">
                            <field name="no_incluye_item_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="titulo_en"/>
                                    <field name="titulo_pt"/>
                                </list>
                            </field>
                        </page>
                        <page string="Horarios">
                            <field name="horario_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="horario_inicial"/>
                                    <field name="horario_final"/>
                                </list>
                            </field>
                        </page>
                        <page string="Imagenes destacadas">
                            <field name="imagen_destacada_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="imagen" widget="image" options="{'size': [128, 128]}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_tour" model="ir.actions.act_window">
        <field name="name">Tours</field>
        <field name="res_model">incas.tour</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_tour_search"/>
    </record>

    <menuitem
        id="menu_incas_tour"
        name="Tours"
        parent="menu_incas_catalogo_root"
        action="action_incas_tour"
        sequence="13"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
