<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_sostenibilidad_portada_wizard_form" model="ir.ui.view">
        <field name="name">incas.sostenibilidad.portada.wizard.form</field>
        <field name="model">incas.sostenibilidad.portada.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirmar reemplazo en portada">
                <group>
                    <field name="articulo_id" readonly="1"/>
                    <field name="articulo_antiguo_id" readonly="1"/>
                    <field name="mensaje" readonly="1" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_confirmar" type="object" string="Aceptar" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
