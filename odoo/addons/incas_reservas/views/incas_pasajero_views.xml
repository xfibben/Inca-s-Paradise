<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_pasajero_list" model="ir.ui.view">
        <field name="name">incas.pasajero.list</field>
        <field name="model">incas.pasajero</field>
        <field name="arch" type="xml">
            <list string="Pasajeros">
                <field name="name"/>
                <field name="reserva_id"/>
                <field name="tipo_documento"/>
                <field name="numero_documento"/>
                <field name="documento_file_count"/>
                <field
                    name="estado_documental"
                    widget="badge"
                    decoration-danger="estado_documental == 'pendiente'"
                    decoration-warning="estado_documental == 'parcial'"
                    decoration-success="estado_documental == 'completo'"
                />
                <field name="faltantes_documentales"/>
                <field name="nacionalidad"/>
                <field name="fecha_nacimiento"/>
                <field name="email"/>
                <field name="telefono"/>
            </list>
        </field>
    </record>

    <record id="view_incas_pasajero_search" model="ir.ui.view">
        <field name="name">incas.pasajero.search</field>
        <field name="model">incas.pasajero</field>
        <field name="arch" type="xml">
            <search string="Buscar pasajeros">
                <field name="name"/>
                <field name="reserva_id"/>
                <field name="numero_documento"/>
                <field name="nacionalidad"/>
                <field name="estado_documental"/>
                <separator/>
                <filter name="filter_documental_completo" string="Documentación completa" domain="[('estado_documental', '=', 'completo')]"/>
                <filter name="filter_documental_pendiente" string="Documentación pendiente" domain="[('estado_documental', '!=', 'completo')]"/>
                <separator/>
                <filter name="group_reserva" string="Reserva" domain="[]" context="{'group_by': 'reserva_id'}"/>
                <filter name="group_nacionalidad" string="Nacionalidad" domain="[]" context="{'group_by': 'nacionalidad'}"/>
                <filter name="group_estado_documental" string="Estado documental" domain="[]" context="{'group_by': 'estado_documental'}"/>
            </search>
        </field>
    </record>

    <record id="view_incas_pasajero_form" model="ir.ui.view">
        <field name="name">incas.pasajero.form</field>
        <field name="model">incas.pasajero</field>
        <field name="arch" type="xml">
            <form string="Pasajero">
                <header>
                    <button name="action_ver_documentos" type="object" string="Documentos"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_documentos" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <field name="documento_file_count" widget="statinfo" string="Documentos"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="reserva_id"/>
                            <field name="documento_directory_id" invisible="1"/>
                            <field name="nombres"/>
                            <field name="apellidos"/>
                            <field name="nacionalidad"/>
                            <field name="fecha_nacimiento"/>
                        </group>
                        <group>
                            <field name="tipo_documento"/>
                            <field name="numero_documento"/>
                            <field name="documento_entregado"/>
                            <field name="fecha_entrega_documento" readonly="not documento_entregado"/>
                            <field name="documento_file_count" readonly="1"/>
                            <field
                                name="estado_documental"
                                widget="badge"
                                decoration-danger="estado_documental == 'pendiente'"
                                decoration-warning="estado_documental == 'parcial'"
                                decoration-success="estado_documental == 'completo'"
                            />
                            <field name="email"/>
                            <field name="telefono"/>
                        </group>
                    </group>
                    <group>
                        <field name="faltantes_documentales" readonly="1"/>
                    </group>
                    <group>
                        <field name="observaciones" placeholder="Notas internas del pasajero"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_pasajeros" model="ir.actions.act_window">
        <field name="name">Pasajeros</field>
        <field name="res_model">incas.pasajero</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_pasajero_search"/>
    </record>

    <menuitem
        id="menu_incas_pasajeros"
        name="Pasajeros"
        parent="incas_core.menu_incas_reservas_root"
        action="action_incas_pasajeros"
        sequence="30"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_reservas,incas_core.group_incas_core_operaciones,incas_core.group_incas_core_gerencia"
    />
</odoo>
