<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_catalogo_vehiculo_list" model="ir.ui.view">
        <field name="name">incas.catalogo.vehiculo.list</field>
        <field name="model">incas.catalogo.vehiculo</field>
        <field name="arch" type="xml">
            <list string="Vehículos">
                <field name="nombre"/>
                <field name="numero_asientos"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_catalogo_vehiculo_form" model="ir.ui.view">
        <field name="name">incas.catalogo.vehiculo.form</field>
        <field name="model">incas.catalogo.vehiculo</field>
        <field name="arch" type="xml">
            <form string="Vehículo">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_documentos" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Documentos</span>
                            </div>
                        </button>
                    </div>
                    <field name="documento_directory_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="numero_asientos"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="nombre"/>
                                <field name="descripcion" widget="html"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="nombre_en"/>
                                <field name="descripcion_en" widget="html"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="nombre_pt"/>
                                <field name="descripcion_pt" widget="html"/>
                            </group>
                        </page>
                        <page string="Características">
                            <field name="caracteristica_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="titulo_en"/>
                                    <field name="titulo_pt"/>
                                </list>
                                <form string="Característica">
                                    <sheet>
                                        <group string="Español">
                                            <field name="titulo"/>
                                        </group>
                                        <group string="English">
                                            <field name="titulo_en"/>
                                        </group>
                                        <group string="Português">
                                            <field name="titulo_pt"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Media">
                            <group>
                                <field name="imagen" widget="image" options="{'size': [256, 256]}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_catalogo_vehiculo" model="ir.actions.act_window">
        <field name="name">Vehículos</field>
        <field name="res_model">incas.catalogo.vehiculo</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_incas_catalogo_vehiculo"
        name="Vehículos"
        parent="menu_incas_transporte_root"
        action="action_incas_catalogo_vehiculo"
        sequence="20"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
