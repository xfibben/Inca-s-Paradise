<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_nosotros_list" model="ir.ui.view">
        <field name="name">incas.nosotros.list</field>
        <field name="model">incas.nosotros</field>
        <field name="arch" type="xml">
            <list string="Nosotros">
                <field name="titulo"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_nosotros_search" model="ir.ui.view">
        <field name="name">incas.nosotros.search</field>
        <field name="model">incas.nosotros</field>
        <field name="arch" type="xml">
            <search string="Buscar nosotros">
                <field name="titulo"/>
                <filter name="filter_active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="filter_inactive" string="Inactivos" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="view_incas_nosotros_form" model="ir.ui.view">
        <field name="name">incas.nosotros.form</field>
        <field name="model">incas.nosotros</field>
        <field name="arch" type="xml">
            <form string="Nosotros">
                <sheet>
                    <group>
                        <group>
                            <field name="titulo"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="titulo"/>
                                <field name="descripcion" widget="html"/>
                                <field name="meta_titulo"/>
                                <field name="meta_descripcion"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="titulo_en"/>
                                <field name="descripcion_en" widget="html"/>
                                <field name="meta_titulo_en"/>
                                <field name="meta_descripcion_en"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="titulo_pt"/>
                                <field name="descripcion_pt" widget="html"/>
                                <field name="meta_titulo_pt"/>
                                <field name="meta_descripcion_pt"/>
                            </group>
                        </page>
                        <page string="Contenido">
                            <field name="seccion_ids">
                                <list editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="imagen" widget="image" options="{'size': [64, 64]}"/>
                                </list>
                                <form string="Sección">
                                    <group>
                                        <field name="sequence"/>
                                        <field name="imagen" widget="image" options="{'size': [256, 256]}"/>
                                    </group>
                                    <notebook>
                                        <page string="Español">
                                            <group>
                                                <field name="titulo"/>
                                                <field name="texto_html" widget="html"/>
                                            </group>
                                        </page>
                                        <page string="English">
                                            <group>
                                                <field name="titulo_en"/>
                                                <field name="texto_html_en" widget="html"/>
                                            </group>
                                        </page>
                                        <page string="Português">
                                            <group>
                                                <field name="titulo_pt"/>
                                                <field name="texto_html_pt" widget="html"/>
                                            </group>
                                        </page>
                                    </notebook>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_nosotros" model="ir.actions.act_window">
        <field name="name">Nosotros</field>
        <field name="res_model">incas.nosotros</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_nosotros_search"/>
    </record>

    <menuitem
        id="menu_incas_nosotros"
        name="Nosotros"
        parent="menu_incas_catalogo_catalogo_root"
        action="action_incas_nosotros"
        sequence="55"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
