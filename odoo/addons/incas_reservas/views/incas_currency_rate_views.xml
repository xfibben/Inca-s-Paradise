<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_currency_rate_list" model="ir.ui.view">
        <field name="name">res.currency.rate.incas.list</field>
        <field name="model">res.currency.rate</field>
        <field name="arch" type="xml">
            <list string="Tipos de cambio" editable="bottom" default_order="name desc,currency_id asc">
                <field name="name"/>
                <field name="currency_id"/>
                <field name="company_id"/>
                <field name="rate"/>
            </list>
        </field>
    </record>

    <record id="view_incas_currency_rate_search" model="ir.ui.view">
        <field name="name">res.currency.rate.incas.search</field>
        <field name="model">res.currency.rate</field>
        <field name="arch" type="xml">
            <search string="Buscar tipos de cambio">
                <field name="name"/>
                <field name="currency_id"/>
                <field name="company_id"/>
                <separator/>
                <filter name="filter_usd" string="USD" domain="[('currency_id.name', '=', 'USD')]"/>
                <filter name="filter_pen" string="PEN" domain="[('currency_id.name', '=', 'PEN')]"/>
                <filter name="filter_eur" string="EUR" domain="[('currency_id.name', '=', 'EUR')]"/>
                <separator/>
                <filter name="group_fecha" string="Fecha" domain="[]" context="{'group_by': 'name'}"/>
                <filter name="group_moneda" string="Moneda" domain="[]" context="{'group_by': 'currency_id'}"/>
                <filter name="group_empresa" string="Compañía" domain="[]" context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_incas_currency_rate" model="ir.actions.act_window">
        <field name="name">Tipo de cambio</field>
        <field name="res_model">res.currency.rate</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_currency_rate_search"/>
        <field name="domain">[('currency_id.name', 'in', ['USD', 'PEN', 'EUR'])]</field>
        <field name="context">{'search_default_group_fecha': 1}</field>
    </record>

    <menuitem
        id="menu_incas_currency_rate"
        name="Tipo de cambio"
        parent="incas_core.menu_incas_configuracion_root"
        action="action_incas_currency_rate"
        sequence="20"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
