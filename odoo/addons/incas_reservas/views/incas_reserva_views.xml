<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_reserva_list" model="ir.ui.view">
        <field name="name">incas.reserva.list</field>
        <field name="model">incas.reserva</field>
        <field name="arch" type="xml">
            <list string="Reservas">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="fecha_reserva"/>
                <field name="fecha_viaje"/>
                <field name="servicio_nombre"/>
                <field name="precio_adulto"/>
                <field name="precio_nino"/>
                <field name="descuento"/>
                <field name="cantidad_adultos"/>
                <field name="cantidad_ninos"/>
                <field name="cantidad_pasajeros"/>
                <field name="hotel_nombre"/>
                <field name="cantidad_noches"/>
                <field name="monto_hotel"/>
                <field name="extra_nombre"/>
                <field name="cantidad_extra"/>
                <field name="monto_extra"/>
                <field name="estado_reserva"/>
                <field name="estado_pago"/>
                <field
                    name="estado_documental"
                    widget="badge"
                    decoration-muted="estado_documental == 'sin_pasajeros'"
                    decoration-danger="estado_documental == 'pendiente'"
                    decoration-warning="estado_documental == 'parcial'"
                    decoration-success="estado_documental == 'completo'"
                />
                <field name="pasajeros_documentos_pendientes"/>
                <field name="saldo_pendiente"/>
                <field name="responsable_id"/>
            </list>
        </field>
    </record>

    <record id="view_incas_reserva_search" model="ir.ui.view">
        <field name="name">incas.reserva.search</field>
        <field name="model">incas.reserva</field>
        <field name="arch" type="xml">
            <search string="Buscar reservas">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="servicio_nombre"/>
                <field name="estado_reserva"/>
                <field name="estado_pago"/>
                <field name="estado_documental"/>
                <field name="fecha_viaje"/>
                <separator/>
                <filter name="filter_pagado" string="Pagado" domain="[('estado_pago', '=', 'pagado')]"/>
                <filter name="filter_pendiente" string="Pendiente" domain="[('estado_pago', '=', 'pendiente')]"/>
                <filter name="filter_documental_completo" string="Documentación completa" domain="[('estado_documental', '=', 'completo')]"/>
                <filter name="filter_documental_pendiente" string="Documentación pendiente" domain="[('estado_documental', 'in', ['pendiente', 'parcial'])]"/>
                <separator/>
                <filter name="group_estado_reserva" string="Estado de reserva" domain="[]" context="{'group_by': 'estado_reserva'}"/>
                <filter name="group_estado_pago" string="Estado de pago" domain="[]" context="{'group_by': 'estado_pago'}"/>
                <filter name="group_estado_documental" string="Estado documental" domain="[]" context="{'group_by': 'estado_documental'}"/>
                <filter name="group_fecha_viaje" string="Fecha de viaje" domain="[]" context="{'group_by': 'fecha_viaje'}"/>
            </search>
        </field>
    </record>

    <record id="view_incas_reserva_form" model="ir.ui.view">
        <field name="name">incas.reserva.form</field>
        <field name="model">incas.reserva</field>
        <field name="arch" type="xml">
            <form string="Reserva">
                <header>
                    <button name="action_nuevo_pago" type="object" string="Crear pago"/>
                    <button name="action_solicitar_cambio" type="object" string="Solicitar cambio"/>
                    <button name="action_ver_documentos" type="object" string="Documentos"/>
                    <button name="action_print_pdf" type="object" string="Exportar PDF"/>
                    <field
                        name="estado_pago"
                        widget="badge"
                        decoration-warning="estado_pago == 'pendiente'"
                        decoration-success="estado_pago == 'pagado'"
                        decoration-info="estado_pago == 'parcial'"
                        decoration-danger="estado_pago == 'reembolsado'"
                    />
                    <field
                        name="estado_documental"
                        widget="badge"
                        decoration-muted="estado_documental == 'sin_pasajeros'"
                        decoration-danger="estado_documental == 'pendiente'"
                        decoration-warning="estado_documental == 'parcial'"
                        decoration-success="estado_documental == 'completo'"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_pagos" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="pago_count" widget="statinfo" string="Pagos"/>
                        </button>
                        <button name="action_ver_cambios" type="object" class="oe_stat_button" icon="fa-random">
                            <field name="cambio_count" widget="statinfo" string="Cambios"/>
                        </button>
                        <button name="action_ver_documentos" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <span class="o_stat_text">Documentos</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="nombre"/>
                            <field name="email"/>
                            <field name="telefono"/>
                            <field name="tipo_documento"/>
                            <field name="numero_documento"/>
                            <field name="nacionalidad"/>
                            <field name="cotizacion_id"/>
                            <field name="documento_directory_id" invisible="1"/>
                            <field name="ticket" readonly="1"/>
                            <field name="fecha_reserva"/>
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                            <field name="fecha_viaje"/>
                            <field name="hotel_id" invisible="1"/>
                            <field name="hotel_tarifa_id" invisible="1"/>
                            <field name="fecha_check_in" invisible="1"/>
                            <field name="fecha_check_out" invisible="1"/>
                            <field name="cantidad_habitaciones" invisible="1"/>
                            <field name="extra_id" invisible="1"/>
                            <field name="extra_tarifa_id" invisible="1"/>
                            <field name="cantidad_extra" invisible="1"/>
                            <field name="vehiculo_disponible_ids" invisible="1"/>
                            <field name="vehiculo_id" invisible="tipo_servicio != 'transporte'" domain="[('id', 'in', vehiculo_disponible_ids)]"/>
                            <field name="vehiculo_seleccionado" invisible="1"/>
                            <field name="origen_web"/>
                            <field name="responsable_id"/>
                        </group>
                        <group>
                            <field name="idioma"/>
                            <field name="canal_venta"/>
                            <field name="precio_adulto_usd" invisible="1" force_save="1"/>
                            <field name="precio_nino_usd" invisible="1" force_save="1"/>
                            <field name="servicio_nombre" readonly="1" force_save="1"/>
                            <field name="precio_adulto" readonly="1" force_save="1"/>
                            <field name="precio_nino" readonly="1" force_save="1"/>
                            <field name="descuento" readonly="1" force_save="1"/>
                            <field name="cantidad_adultos"/>
                            <field name="cantidad_ninos"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="estado_reserva"/>
                            <field name="cantidad_pasajeros" readonly="1"/>
                            <field name="pasajeros_documentos_pendientes" readonly="1"/>
                            <field name="cantidad_noches" readonly="1" invisible="1"/>
                            <field name="hotel_nombre" readonly="1" force_save="1" invisible="1"/>
                            <field name="extra_nombre" readonly="1" force_save="1" invisible="1"/>
                            <field name="extra_unidad" readonly="1" force_save="1" invisible="1"/>
                        </group>
                        <group>
                            <field name="hotel_precio_noche" readonly="1" force_save="1" invisible="1"/>
                            <field name="hotel_descuento" readonly="1" force_save="1" invisible="1"/>
                            <field name="monto_hotel" readonly="1"/>
                            <field name="extra_precio_unitario" readonly="1" force_save="1" invisible="1"/>
                            <field name="extra_descuento" readonly="1" force_save="1" invisible="1"/>
                            <field name="monto_extra" readonly="1"/>
                            <field name="monto_total" readonly="1"/>
                            <field name="precio_tour" readonly="1"/>
                            <field name="precio_adulto_web"/>
                            <field name="precio_nino_web"/>
                            <field name="monto_web" readonly="1"/>
                            <field name="monto_final" readonly="1"/>
                            <field name="monto_pagado" readonly="1"/>
                            <field name="saldo_pendiente" readonly="1"/>
                            <field name="moneda"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Paquete">
                            <field name="paquete_linea_ids" readonly="1">
                                <list>
                                    <field name="fecha"/>
                                    <field name="horario_id"/>
                                    <button name="action_open_popup" type="object" icon="fa-pencil-square-o" string="Editar"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="servicio_id"/>
                                    <field name="vehiculo_disponible_ids" column_invisible="1"/>
                                    <field
                                        name="vehiculo_id"
                                        invisible="tipo_servicio != 'transporte'"
                                        domain="[('id', 'in', vehiculo_disponible_ids)]"
                                    />
                                    <field name="moneda" readonly="1"/>
                                    <field name="tipo_servicio" readonly="1"/>
                                    <field name="tipo_tour" readonly="1" optional="hide"/>
                                    <field name="estilo_transporte_id" readonly="1" optional="hide"/>
                                    <field name="nombre"/>
                                    <field name="precio_adulto"/>
                                    <field name="precio_nino"/>
                                    <field name="descuento"/>
                                    <field name="precio_adulto_neto" readonly="1"/>
                                    <field name="precio_nino_neto" readonly="1"/>
                                    <field name="precio_adulto_usd" column_invisible="1" optional="hide"/>
                                    <field name="precio_nino_usd" column_invisible="1" optional="hide"/>
                                    <field name="precio_adulto_neto_usd" column_invisible="1" optional="hide"/>
                                    <field name="precio_nino_neto_usd" column_invisible="1" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Hoteles">
                            <field name="hotel_linea_ids" readonly="1">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="hotel_id"/>
                                    <field name="hotel_tarifa_id"/>
                                    <field name="fecha_check_in"/>
                                    <field name="fecha_check_out"/>
                                    <field name="cantidad_noches"/>
                                    <field name="cantidad_habitaciones"/>
                                    <field name="moneda" readonly="1"/>
                                    <field name="hotel_nombre"/>
                                    <field name="hotel_precio_noche"/>
                                    <field name="hotel_descuento"/>
                                    <field name="monto_hotel"/>
                                </list>
                            </field>
                        </page>
                        <page string="Extras">
                            <field name="extra_linea_ids" readonly="1">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="extra_id"/>
                                    <field name="extra_tarifa_id"/>
                                    <field name="extra_nombre"/>
                                    <field name="extra_unidad"/>
                                    <field name="cantidad_extra"/>
                                    <field name="moneda" readonly="1"/>
                                    <field name="extra_precio_unitario"/>
                                    <field name="extra_descuento"/>
                                    <field name="monto_extra"/>
                                </list>
                            </field>
                        </page>
                        <page string="Pagos">
                            <field name="pago_ids" context="{'default_reserva_id': id, 'default_moneda': moneda, 'default_monto': saldo_pendiente}">
                                <list editable="bottom">
                                    <field name="proveedor"/>
                                    <field name="metodo"/>
                                    <field name="moneda"/>
                                    <field name="monto"/>
                                    <field name="estado"/>
                                    <field name="transaccion_id"/>
                                    <field name="orden_id"/>
                                    <field name="fecha_pago"/>
                                </list>
                            </field>
                        </page>
                        <page string="Pasajeros">
                            <field name="pasajero_ids">
                                <list editable="bottom">
                                    <button name="action_ver_documentos" type="object" string="Documentos" icon="fa-folder-open"/>
                                    <field name="nombres"/>
                                    <field name="apellidos"/>
                                    <field name="tipo_documento"/>
                                    <field name="numero_documento"/>
                                    <field name="documento_entregado"/>
                                    <field name="fecha_entrega_documento"/>
                                    <field name="documento_file_count" readonly="1"/>
                                    <field
                                        name="estado_documental"
                                        widget="badge"
                                        decoration-danger="estado_documental == 'pendiente'"
                                        decoration-warning="estado_documental == 'parcial'"
                                        decoration-success="estado_documental == 'completo'"
                                    />
                                    <field name="faltantes_documentales"/>
                                    <field name="nacionalidad"/>
                                    <field name="fecha_nacimiento"/>
                                </list>
                            </field>
                        </page>
                        <page string="Observaciones">
                            <field name="observaciones" placeholder="Coordinaciones, cambios y notas internas"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_incas_reserva_calendar" model="ir.ui.view">
        <field name="name">incas.reserva.calendar</field>
        <field name="model">incas.reserva</field>
        <field name="arch" type="xml">
            <calendar string="Calendario de reservas" date_start="fecha_viaje" color="responsable_id">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="estado_reserva"/>
            </calendar>
        </field>
    </record>

    <record id="action_incas_reservas" model="ir.actions.act_window">
        <field name="name">Reservas</field>
        <field name="res_model">incas.reserva</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="search_view_id" ref="view_incas_reserva_search"/>
    </record>

    <menuitem
        id="menu_incas_reservas"
        name="Reservas"
        parent="incas_core.menu_incas_reservas_root"
        action="action_incas_reservas"
        sequence="20"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_reservas,incas_core.group_incas_core_operaciones,incas_core.group_incas_core_gerencia"
    />
</odoo>
