<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_catalogo_destino_list" model="ir.ui.view">
        <field name="name">incas.catalogo.destino.list</field>
        <field name="model">incas.catalogo.destino</field>
        <field name="arch" type="xml">
            <list string="Destinos">
                <field name="orden_visual"/>
                <field name="nombre"/>
                <field name="slug"/>
                <field name="cantidad_inicial_catalogo"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_catalogo_destino_search" model="ir.ui.view">
        <field name="name">incas.catalogo.destino.search</field>
        <field name="model">incas.catalogo.destino</field>
        <field name="arch" type="xml">
            <search string="Buscar destinos">
                <field name="nombre"/>
                <field name="slug"/>
                <filter name="group_orden_visual" string="Orden visual" domain="[]" context="{'group_by': 'orden_visual'}"/>
            </search>
        </field>
    </record>

    <record id="view_incas_catalogo_destino_form" model="ir.ui.view">
        <field name="name">incas.catalogo.destino.form</field>
        <field name="model">incas.catalogo.destino</field>
        <field name="arch" type="xml">
            <form string="Destino">
                <sheet>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="orden_visual"/>
                            <field name="cantidad_inicial_catalogo"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="slug"/>
                                <field name="descripcion" widget="html"/>
                                <field name="titulo_intro" widget="html"/>
                                <field name="contenido_intro" widget="html"/>
                                <field name="cinta_principal" widget="html"/>
                                <field name="seo_titulo" widget="html"/>
                                <field name="seo_descripcion" widget="html"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="slug_en"/>
                                <field name="descripcion_en" widget="html"/>
                                <field name="titulo_intro_en" widget="html"/>
                                <field name="contenido_intro_en" widget="html"/>
                                <field name="cinta_principal_en" widget="html"/>
                                <field name="seo_titulo_en" widget="html"/>
                                <field name="seo_descripcion_en" widget="html"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="slug_pt"/>
                                <field name="descripcion_pt" widget="html"/>
                                <field name="titulo_intro_pt" widget="html"/>
                                <field name="contenido_intro_pt" widget="html"/>
                                <field name="cinta_principal_pt" widget="html"/>
                                <field name="seo_titulo_pt" widget="html"/>
                                <field name="seo_descripcion_pt" widget="html"/>
                            </group>
                        </page>
                        <page string="Iconos">
                            <field name="icono_item_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                    <field name="titulo_en"/>
                                    <field name="titulo_pt"/>
                                    <field name="imagen" widget="image" options="{'size': [128, 128]}"/>
                                </list>
                                <form string="Icono">
                                    <sheet>
                                        <group>
                                            <field name="sequence"/>
                                            <field name="imagen" widget="image" options="{'size': [256, 256]}"/>
                                        </group>
                                        <group string="Español">
                                            <field name="titulo" widget="html"/>
                                        </group>
                                        <group string="English">
                                            <field name="titulo_en" widget="html"/>
                                        </group>
                                        <group string="Português">
                                            <field name="titulo_pt" widget="html"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Media">
                            <group>
                                <field name="imagen" widget="image" options="{'size': [256, 256]}"/>
                                <field name="imagen_fondo" widget="image" options="{'size': [256, 128]}"/>
                            </group>
                        </page>
                        <page string="Relaciones">
                            <group>
                                <field name="tour_ids" widget="many2many_tags"/>
                            </group>
                            <field name="subcategoria_tour_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="nombre"/>
                                    <field name="tour_ids" widget="many2many_tags"/>
                                    <field name="active"/>
                                </list>
                                <form string="Subcategoría de tour">
                                    <sheet>
                                        <group>
                                            <field name="sequence"/>
                                            <field name="nombre"/>
                                            <field name="tour_ids" widget="many2many_tags"/>
                                            <field name="active"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_catalogo_destino" model="ir.actions.act_window">
        <field name="name">Destinos</field>
        <field name="res_model">incas.catalogo.destino</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_catalogo_destino_search"/>
    </record>

    <menuitem
        id="menu_incas_catalogo_destino"
        name="Destinos"
        parent="menu_incas_catalogo_root"
        action="action_incas_catalogo_destino"
        sequence="12"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
