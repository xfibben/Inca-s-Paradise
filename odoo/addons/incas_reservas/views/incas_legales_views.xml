<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_politica_list" model="ir.ui.view">
        <field name="name">incas.politica.list</field>
        <field name="model">incas.politica</field>
        <field name="arch" type="xml">
            <list string="Políticas">
                <field name="titulo"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_politica_search" model="ir.ui.view">
        <field name="name">incas.politica.search</field>
        <field name="model">incas.politica</field>
        <field name="arch" type="xml">
            <search string="Buscar políticas">
                <field name="titulo"/>
                <filter name="filter_active" string="Activos" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="view_incas_politica_form" model="ir.ui.view">
        <field name="name">incas.politica.form</field>
        <field name="model">incas.politica</field>
        <field name="arch" type="xml">
            <form string="Políticas">
                <sheet>
                    <group>
                        <group>
                            <field name="titulo"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="titulo"/>
                                <field name="descripcion" widget="html"/>
                                <field name="meta_titulo"/>
                                <field name="meta_descripcion"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="titulo_en"/>
                                <field name="descripcion_en" widget="html"/>
                                <field name="meta_titulo_en"/>
                                <field name="meta_descripcion_en"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="titulo_pt"/>
                                <field name="descripcion_pt" widget="html"/>
                                <field name="meta_titulo_pt"/>
                                <field name="meta_descripcion_pt"/>
                            </group>
                        </page>
                        <page string="Contenido">
                            <field name="seccion_ids">
                                <list editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                </list>
                                <form string="Sección">
                                    <notebook>
                                        <page string="Español">
                                            <group>
                                                <field name="sequence"/>
                                                <field name="titulo"/>
                                                <field name="contenido" widget="html"/>
                                            </group>
                                        </page>
                                        <page string="English">
                                            <group>
                                                <field name="titulo_en"/>
                                                <field name="contenido_en" widget="html"/>
                                            </group>
                                        </page>
                                        <page string="Português">
                                            <group>
                                                <field name="titulo_pt"/>
                                                <field name="contenido_pt" widget="html"/>
                                            </group>
                                        </page>
                                    </notebook>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_politica" model="ir.actions.act_window">
        <field name="name">Políticas</field>
        <field name="res_model">incas.politica</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_politica_search"/>
    </record>

    <record id="view_incas_cancelacion_list" model="ir.ui.view">
        <field name="name">incas.cancelacion.list</field>
        <field name="model">incas.cancelacion</field>
        <field name="arch" type="xml">
            <list string="Cancelaciones">
                <field name="titulo"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_cancelacion_search" model="ir.ui.view">
        <field name="name">incas.cancelacion.search</field>
        <field name="model">incas.cancelacion</field>
        <field name="arch" type="xml">
            <search string="Buscar cancelaciones">
                <field name="titulo"/>
                <filter name="filter_active" string="Activos" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="view_incas_cancelacion_form" model="ir.ui.view">
        <field name="name">incas.cancelacion.form</field>
        <field name="model">incas.cancelacion</field>
        <field name="arch" type="xml">
            <form string="Cancelaciones">
                <header>
                    <button
                        name="action_importar_desde_csv"
                        type="object"
                        string="Importar CSV"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="titulo"/>
                            <field name="active"/>
                            <field name="archivo_importacion_csv" filename="archivo_importacion_csv_nombre" widget="binary"/>
                            <field name="archivo_importacion_csv_nombre" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="titulo"/>
                                <field name="descripcion" widget="html"/>
                                <field name="meta_titulo"/>
                                <field name="meta_descripcion"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="titulo_en"/>
                                <field name="descripcion_en" widget="html"/>
                                <field name="meta_titulo_en"/>
                                <field name="meta_descripcion_en"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="titulo_pt"/>
                                <field name="descripcion_pt" widget="html"/>
                                <field name="meta_titulo_pt"/>
                                <field name="meta_descripcion_pt"/>
                            </group>
                        </page>
                        <page string="Contenido">
                            <field name="seccion_ids">
                                <list editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="titulo"/>
                                </list>
                                <form string="Sección">
                                    <notebook>
                                        <page string="Español">
                                            <group>
                                                <field name="sequence"/>
                                                <field name="titulo"/>
                                                <field name="contenido" widget="html"/>
                                            </group>
                                        </page>
                                        <page string="English">
                                            <group>
                                                <field name="titulo_en"/>
                                                <field name="contenido_en" widget="html"/>
                                            </group>
                                        </page>
                                        <page string="Português">
                                            <group>
                                                <field name="titulo_pt"/>
                                                <field name="contenido_pt" widget="html"/>
                                            </group>
                                        </page>
                                    </notebook>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_cancelacion" model="ir.actions.act_window">
        <field name="name">Cancelaciones</field>
        <field name="res_model">incas.cancelacion</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_cancelacion_search"/>
