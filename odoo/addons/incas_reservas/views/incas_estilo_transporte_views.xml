<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem
        id="menu_incas_transporte_root"
        name="Transporte"
        parent="incas_core.menu_incas_configuracion_root"
        sequence="11"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />

    <record id="view_incas_estilo_transporte_list" model="ir.ui.view">
        <field name="name">incas.estilo.transporte.list</field>
        <field name="model">incas.estilo.transporte</field>
        <field name="arch" type="xml">
            <list string="Tipos de transporte">
                <field name="nro_orden"/>
                <field name="name"/>
                <field name="slug"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_estilo_transporte_form" model="ir.ui.view">
        <field name="name">incas.estilo.transporte.form</field>
        <field name="model">incas.estilo.transporte</field>
        <field name="arch" type="xml">
            <form string="Tipo de transporte">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="slug"/>
                            <field name="nro_orden"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="name"/>
                                <field name="descripcion" widget="html"/>
                                <field name="seo_title"/>
                                <field name="seo_description"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="name_en"/>
                                <field name="descripcion_en" widget="html"/>
                                <field name="seo_title_en"/>
                                <field name="seo_description_en"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="name_pt"/>
                                <field name="descripcion_pt" widget="html"/>
                                <field name="seo_title_pt"/>
                                <field name="seo_description_pt"/>
                            </group>
                        </page>
                        <page string="Transportes">
                            <field name="transporte_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Media">
                            <group>
                                <field name="image_data" widget="image" options="{'size': [256, 256]}"/>
                                <field name="wallpaper_data" widget="image" options="{'size': [512, 256]}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_estilo_transporte" model="ir.actions.act_window">
        <field name="name">Tipos de transporte</field>
        <field name="res_model">incas.estilo.transporte</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_incas_estilo_transporte"
        name="Tipos de transporte"
        parent="menu_incas_transporte_root"
        action="action_incas_estilo_transporte"
        sequence="10"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
