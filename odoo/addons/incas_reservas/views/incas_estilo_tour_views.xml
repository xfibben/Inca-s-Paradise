<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_estilo_tour_list" model="ir.ui.view">
        <field name="name">incas.estilo.tour.list</field>
        <field name="model">incas.estilo.tour</field>
        <field name="arch" type="xml">
            <list string="Estilos de tour">
                <field name="nombre"/>
                <field name="slug"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_estilo_tour_form" model="ir.ui.view">
        <field name="name">incas.estilo.tour.form</field>
        <field name="model">incas.estilo.tour</field>
        <field name="arch" type="xml">
            <form string="Estilo de tour">
                <sheet>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="slug"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Español">
                            <group>
                                <field name="nombre"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="nombre_en"/>
                            </group>
                        </page>
                        <page string="Português">
                            <group>
                                <field name="nombre_pt"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_estilo_tour" model="ir.actions.act_window">
        <field name="name">Estilos de tour</field>
        <field name="res_model">incas.estilo.tour</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_incas_estilo_tour"
        name="Estilos de tour"
        parent="incas_core.menu_incas_configuracion_root"
        action="action_incas_estilo_tour"
        sequence="12"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
