<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_estilo_viaje_list" model="ir.ui.view">
        <field name="name">incas.estilo.viaje.list</field>
        <field name="model">incas.estilo.viaje</field>
        <field name="arch" type="xml">
            <list string="Estilos de viaje">
                <field name="display_order"/>
                <field name="name"/>
                <field name="slug"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_estilo_viaje_form" model="ir.ui.view">
        <field name="name">incas.estilo.viaje.form</field>
        <field name="model">incas.estilo.viaje</field>
        <field name="arch" type="xml">
            <form string="Estilo de viaje">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_documentos" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Documentos</span>
                            </div>
                        </button>
                    </div>
                    <field name="documento_directory_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="slug"/>
                            <field name="display_order"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image" widget="image" options="{'size': [256, 256]}"/>
                            <field name="wallpaper" widget="image" options="{'size': [256, 128]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Espanol">
                            <group>
                                <field name="name"/>
                                <field name="slug"/>
                                <field name="description" widget="html"/>
                                <field name="middle_title" widget="html"/>
                                <field name="middle_description" widget="html"/>
                                <field name="seo_title"/>
                                <field name="seo_description"/>
                            </group>
                        </page>
                        <page string="English">
                            <group>
                                <field name="name_en"/>
                                <field name="slug_en"/>
                                <field name="description_en" widget="html"/>
                                <field name="middle_title_en" widget="html"/>
                                <field name="middle_description_en" widget="html"/>
                                <field name="seo_title_en"/>
                                <field name="seo_description_en"/>
                            </group>
                        </page>
                        <page string="Portugues">
                            <group>
                                <field name="name_pt"/>
                                <field name="slug_pt"/>
                                <field name="description_pt" widget="html"/>
                                <field name="middle_title_pt" widget="html"/>
                                <field name="middle_description_pt" widget="html"/>
                                <field name="seo_title_pt"/>
                                <field name="seo_description_pt"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incas_estilo_viaje" model="ir.actions.act_window">
        <field name="name">Estilos de viaje</field>
        <field name="res_model">incas.estilo.viaje</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_incas_estilo_viaje"
        name="Estilos de viaje"
        parent="menu_incas_catalogo_root"
        action="action_incas_estilo_viaje"
        sequence="12"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
