<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_incas_reserva" model="ir.actions.report">
        <field name="name">Reserva PDF</field>
        <field name="model">incas.reserva</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">incas_reservas.report_incas_reserva_document</field>
        <field name="report_file">incas_reservas.report_incas_reserva_document</field>
        <field name="print_report_name">'Reserva - %s' % (object.ticket or object.name)</field>
        <field name="binding_model_id" ref="model_incas_reserva"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_incas_common_styles">
        <style>
            .incas-page {
                font-family: Arial, sans-serif;
                color: #1f2937;
                font-size: 13px;
            }
            .incas-title {
                color: #1aa093;
                font-size: 24px;
                font-weight: 700;
                margin-bottom: 4px;
            }
            .incas-subtitle {
                font-size: 15px;
                color: #374151;
                margin-bottom: 16px;
            }
            .incas-ticket-box {
                border: 1px solid #1aa093;
                background: #f5f8f7;
                padding: 12px 16px;
                text-align: center;
                margin-bottom: 18px;
            }
            .incas-ticket-label {
                font-size: 11px;
                color: #64748b;
                margin-bottom: 4px;
            }
            .incas-ticket-value {
                font-size: 18px;
                font-weight: 700;
                color: #1aa093;
            }
            .incas-section {
                margin-top: 14px;
                margin-bottom: 14px;
            }
            .incas-section-title {
                background: #1aa093;
                color: #ffffff;
                padding: 8px 12px;
                font-weight: 700;
                font-size: 12px;
            }
            .incas-table {
                width: 100%;
                border-collapse: collapse;
            }
            .incas-table td {
                border: 1px solid #d1d5db;
                padding: 8px 10px;
                vertical-align: top;
            }
            .incas-label {
                background: #f8fafc;
                color: #475569;
                font-weight: 700;
                width: 38%;
            }
        </style>
    </template>

    <template id="report_incas_reserva_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page incas-page">
                        <t t-call="incas_reservas.report_incas_common_styles"/>
                        <div class="incas-title">Inca's Paradise</div>
                        <div class="incas-subtitle">Comprobante de reserva de <t t-esc="'Tour' if o.tipo_servicio == 'tour' else 'Transporte'"/></div>
                        <div class="incas-ticket-box">
                            <div class="incas-ticket-label">TICKET</div>
                            <div class="incas-ticket-value"><span t-field="o.ticket"/></div>
                        </div>

                        <div class="incas-section">
                            <div class="incas-section-title">DATOS DEL PASAJERO</div>
                            <table class="incas-table">
                                <tr><td class="incas-label">Cliente principal</td><td><span t-field="o.partner_id"/></td></tr>
                                <tr><td class="incas-label">Idioma</td><td><span t-field="o.idioma"/></td></tr>
                                <tr><td class="incas-label">Canal</td><td><span t-field="o.canal_venta"/></td></tr>
                                <tr><td class="incas-label">Responsable</td><td><span t-field="o.responsable_id"/></td></tr>
                            </table>
                        </div>

                        <div class="incas-section">
                            <div class="incas-section-title">DETALLES DE LA RESERVA</div>
                            <table class="incas-table">
                                <tr><td class="incas-label">Tipo de servicio</td><td><span t-field="o.tipo_tour" t-if="o.tipo_servicio == 'tour'"/><span t-field="o.estilo_transporte_id" t-if="o.tipo_servicio == 'transporte'"/></td></tr>
                                <tr><td class="incas-label"><t t-esc="'Nombre del tour' if o.tipo_servicio == 'tour' else 'Nombre del transporte'"/></td><td><span t-field="o.servicio_nombre"/></td></tr>
                                <tr><td class="incas-label">Fecha de reserva</td><td><span t-field="o.fecha_reserva"/></td></tr>
                                <tr><td class="incas-label">Fecha de viaje</td><td><span t-field="o.fecha_viaje"/></td></tr>
                                <tr><td class="incas-label">Adultos</td><td><span t-field="o.cantidad_adultos"/></td></tr>
                                <tr><td class="incas-label">Niños</td><td><span t-field="o.cantidad_ninos"/></td></tr>
                                <tr><td class="incas-label">Observaciones</td><td><span t-field="o.observaciones"/></td></tr>
                                <tr><td class="incas-label">Estado de reserva</td><td><span t-field="o.estado_reserva"/></td></tr>
                                <tr><td class="incas-label">Estado de pago</td><td><span t-field="o.estado_pago"/></td></tr>
                            </table>
                        </div>

                        <div class="incas-section">
                            <div class="incas-section-title">RESUMEN DE PAGO</div>
                            <table class="incas-table">
                                <tr><td class="incas-label">Moneda</td><td><span t-field="o.moneda"/></td></tr>
                                <tr><td class="incas-label">Precio grupal</td><td><span t-field="o.precio_grupal"/></td></tr>
                                <tr><td class="incas-label">Descuento</td><td><t t-esc="'%.2f%%' % (o.descuento or 0.0)"/></td></tr>
                                <tr><td class="incas-label">Precio total del servicio</td><td><span t-field="o.precio_tour"/></td></tr>
                                <tr><td class="incas-label">Monto pagado en web</td><td><span t-field="o.monto_web"/></td></tr>
                                <tr><td class="incas-label">Precio web adultos</td><td><span t-field="o.precio_adulto_web"/></td></tr>
                                <tr><td class="incas-label">Precio web niños</td><td><span t-field="o.precio_nino_web"/></td></tr>
                                <tr><td class="incas-label">Saldo pendiente</td><td><span t-field="o.saldo_pendiente"/></td></tr>
                                <tr><td class="incas-label">Monto final registrado</td><td><span t-field="o.monto_final"/></td></tr>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
