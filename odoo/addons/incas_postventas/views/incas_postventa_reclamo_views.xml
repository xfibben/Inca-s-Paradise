<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_postventa_reclamo_list" model="ir.ui.view">
        <field name="name">incas.postventa.reclamo.list</field>
        <field name="model">incas.postventa.reclamo</field>
        <field name="arch" type="xml">
            <list string="Reclamos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="reserva_id"/>
                <field name="tipo"/>
                <field name="motivo"/>
                <field name="canal"/>
                <field name="prioridad"/>
                <field name="estado"/>
                <field name="fecha_registro"/>
                <field name="fecha_limite"/>
                <field name="responsable_id"/>
            </list>
        </field>
    </record>

    <record id="view_incas_postventa_reclamo_search" model="ir.ui.view">
        <field name="name">incas.postventa.reclamo.search</field>
        <field name="model">incas.postventa.reclamo</field>
        <field name="arch" type="xml">
            <search string="Buscar reclamos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="reserva_id"/>
                <field name="tipo"/>
                <field name="motivo"/>
                <field name="estado"/>
                <separator/>
                <filter name="filter_abiertos" string="Abiertos" domain="[('estado', 'not in', ['resuelto', 'cerrado'])]"/>
                <filter name="filter_criticos" string="Criticos" domain="[('prioridad', '=', 'critica')]"/>
                <filter name="filter_vencidos" string="Vencidos" domain="[('fecha_limite', '&lt;', context_today()), ('estado', 'not in', ['resuelto', 'cerrado'])]"/>
                <separator/>
                <filter name="group_estado" string="Estado" domain="[]" context="{'group_by': 'estado'}"/>
                <filter name="group_motivo" string="Motivo" domain="[]" context="{'group_by': 'motivo'}"/>
                <filter name="group_prioridad" string="Prioridad" domain="[]" context="{'group_by': 'prioridad'}"/>
            </search>
        </field>
    </record>

    <record id="view_incas_postventa_reclamo_form" model="ir.ui.view">
        <field name="name">incas.postventa.reclamo.form</field>
        <field name="model">incas.postventa.reclamo</field>
        <field name="arch" type="xml">
            <form string="Reclamo">
                <header>
                    <button name="action_evaluar" type="object" string="Evaluar" invisible="estado != 'nuevo'"/>
                    <button name="action_procesar" type="object" string="Pasar a proceso" invisible="estado not in ['nuevo', 'evaluacion']"/>
                    <button name="action_resolver" type="object" string="Resolver" invisible="estado not in ['evaluacion', 'proceso']"/>
                    <button name="action_cerrar" type="object" string="Cerrar" invisible="estado != 'resuelto'"/>
                    <button name="action_crear_accion_correctiva" type="object" string="Crear accion correctiva" invisible="estado == 'cerrado'"/>
                    <field
                        name="estado"
                        widget="badge"
                        decoration-warning="estado == 'nuevo'"
                        decoration-info="estado in ['evaluacion', 'proceso']"
                        decoration-success="estado in ['resuelto', 'cerrado']"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="caso_id"/>
                            <field name="partner_id"/>
                            <field name="reserva_id"/>
                            <field name="tipo"/>
                            <field name="motivo"/>
                            <field name="canal"/>
                        </group>
                        <group>
                            <field name="prioridad"/>
                            <field name="responsable_id"/>
                            <field name="fecha_registro"/>
                            <field name="fecha_limite"/>
                            <field name="fecha_cierre"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripcion">
                            <field name="descripcion"/>
                        </page>
                        <page string="Respuesta">
                            <field name="respuesta_dada"/>
                        </page>
                        <page string="Acciones">
                            <field name="accion_ids" context="{'default_reclamo_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="tipo"/>
                                    <field name="responsable_id"/>
                                    <field name="fecha_compromiso"/>
                                    <field name="estado"/>
                                    <field name="resultado"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_incas_postventa_reclamos" model="ir.actions.act_window">
        <field name="name">Reclamos / Libro de reclamaciones</field>
        <field name="res_model">incas.postventa.reclamo</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_postventa_reclamo_search"/>
    </record>
</odoo>
