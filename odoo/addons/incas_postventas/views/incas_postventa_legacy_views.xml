<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_postventa_legacy_list" model="ir.ui.view">
        <field name="name">incas.postventa.legacy.list</field>
        <field name="model">incas.postventa</field>
        <field name="arch" type="xml">
            <list string="Postventas">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="reserva_id"/>
                <field name="servicio_nombre"/>
                <field name="tipo"/>
                <field name="prioridad"/>
                <field name="estado"/>
                <field name="fecha_apertura"/>
                <field name="fecha_limite"/>
                <field name="responsable_id"/>
            </list>
        </field>
    </record>

    <record id="view_incas_postventa_legacy_form" model="ir.ui.view">
        <field name="name">incas.postventa.legacy.form</field>
        <field name="model">incas.postventa</field>
        <field name="arch" type="xml">
            <form string="Postventa legado">
                <header>
                    <button name="action_abrir_caso_nuevo" type="object" string="Abrir caso post viaje"/>
                    <field name="estado" widget="badge"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="caso_id"/>
                            <field name="partner_id"/>
                            <field name="reserva_id"/>
                            <field name="ticket_reserva"/>
                            <field name="servicio_nombre"/>
                            <field name="responsable_id"/>
                        </group>
                        <group>
                            <field name="tipo"/>
                            <field name="prioridad"/>
                            <field name="fecha_apertura"/>
                            <field name="fecha_limite"/>
                            <field name="fecha_cierre"/>
                            <field name="satisfaccion"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Detalle">
                            <field name="descripcion"/>
                        </page>
                        <page string="Solucion">
                            <field name="solucion"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_incas_postventa_legacy_search" model="ir.ui.view">
        <field name="name">incas.postventa.legacy.search</field>
        <field name="model">incas.postventa</field>
        <field name="arch" type="xml">
            <search string="Buscar postventas">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="reserva_id"/>
                <field name="servicio_nombre"/>
                <field name="tipo"/>
                <field name="prioridad"/>
                <field name="estado"/>
                <filter name="group_estado" string="Estado" domain="[]" context="{'group_by': 'estado'}"/>
            </search>
        </field>
    </record>

    <record id="action_incas_postventas" model="ir.actions.act_window">
        <field name="name">Postventas legado</field>
        <field name="res_model">incas.postventa</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_postventa_legacy_search"/>
    </record>
</odoo>
