<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_postventa_caso_list" model="ir.ui.view">
        <field name="name">incas.postventa.caso.list</field>
        <field name="model">incas.postventa.caso</field>
        <field name="arch" type="xml">
            <list string="Casos post viaje">
                <field name="name"/>
                <field name="reserva_id"/>
                <field name="partner_id"/>
                <field name="servicio_nombre"/>
                <field name="fecha_viaje"/>
                <field name="canal_venta"/>
                <field name="estado"/>
                <field name="responsable_id"/>
            </list>
        </field>
    </record>

    <record id="view_incas_postventa_caso_search" model="ir.ui.view">
        <field name="name">incas.postventa.caso.search</field>
        <field name="model">incas.postventa.caso</field>
        <field name="arch" type="xml">
            <search string="Buscar casos post viaje">
                <field name="name"/>
                <field name="reserva_id"/>
                <field name="partner_id"/>
                <field name="servicio_nombre"/>
                <field name="estado"/>
                <separator/>
                <filter name="filter_pendientes" string="Pendientes" domain="[('estado', '=', 'pendiente')]"/>
                <filter name="filter_revision" string="En revision" domain="[('estado', '=', 'en_revision')]"/>
                <filter name="filter_abiertos" string="Abiertos" domain="[('estado', '!=', 'cerrado')]"/>
                <separator/>
                <filter name="group_estado" string="Estado" domain="[]" context="{'group_by': 'estado'}"/>
                <filter name="group_responsable" string="Responsable" domain="[]" context="{'group_by': 'responsable_id'}"/>
                <filter name="group_servicio" string="Servicio" domain="[]" context="{'group_by': 'servicio_nombre'}"/>
            </search>
        </field>
    </record>

    <record id="view_incas_postventa_caso_form" model="ir.ui.view">
        <field name="name">incas.postventa.caso.form</field>
        <field name="model">incas.postventa.caso</field>
        <field name="arch" type="xml">
            <form string="Caso post viaje">
                <header>
                    <button name="action_enviar_encuesta" type="object" string="Enviar encuesta" invisible="estado in ['encuesta_enviada', 'encuesta_respondida', 'cerrado']"/>
                    <button name="action_crear_reclamo" type="object" string="Crear reclamo" invisible="estado == 'cerrado'"/>
                    <button name="action_cerrar" type="object" string="Cerrar" invisible="estado == 'cerrado'"/>
                    <field
                        name="estado"
                        widget="badge"
                        decoration-warning="estado == 'pendiente'"
                        decoration-info="estado in ['encuesta_enviada', 'en_revision']"
                        decoration-success="estado in ['encuesta_respondida', 'cerrado']"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_encuestas" type="object" class="oe_stat_button" icon="fa-check-square-o">
                            <field name="encuesta_count" widget="statinfo" string="Encuestas"/>
                        </button>
                        <button name="action_ver_reclamos" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
                            <field name="reclamo_count" widget="statinfo" string="Reclamos"/>
                        </button>
                        <button name="action_ver_acciones" type="object" class="oe_stat_button" icon="fa-tasks">
                            <field name="accion_count" widget="statinfo" string="Acciones"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="reserva_id"/>
                            <field name="partner_id"/>
                            <field name="servicio_nombre"/>
                            <field name="canal_venta"/>
                            <field name="responsable_id"/>
                        </group>
                        <group>
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                            <field name="fecha_viaje"/>
                            <field name="fecha_apertura"/>
                            <field name="fecha_cierre"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observaciones">
                            <field name="observaciones" placeholder="Comentarios internos del seguimiento post viaje"/>
                        </page>
                        <page string="Encuestas">
                            <field name="encuesta_ids" context="{'default_caso_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="estado"/>
                                    <field name="fecha_envio"/>
                                    <field name="fecha_respuesta"/>
                                    <field name="nps"/>
                                    <field name="satisfaccion_general"/>
                                </list>
                            </field>
                        </page>
                        <page string="Reclamos">
                            <field name="reclamo_ids" context="{'default_caso_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="tipo"/>
                                    <field name="motivo"/>
                                    <field name="prioridad"/>
                                    <field name="estado"/>
                                    <field name="fecha_limite"/>
                                </list>
                            </field>
                        </page>
                        <page string="Acciones">
                            <field name="accion_ids" context="{'default_caso_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="tipo"/>
                                    <field name="responsable_id"/>
                                    <field name="fecha_compromiso"/>
                                    <field name="estado"/>
                                    <field name="resultado"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_incas_postventa_casos" model="ir.actions.act_window">
        <field name="name">Casos post viaje</field>
        <field name="res_model">incas.postventa.caso</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incas_postventa_caso_search"/>
    </record>
</odoo>
