<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_incas_rrhh_trabajadores_kanban" model="ir.ui.view">
        <field name="name">res.users.incas.rrhh.trabajadores.kanban</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <kanban string="Trabajadores">
                <field name="image_128"/>
                <field name="name"/>
                <field name="login"/>
                <field name="email"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <main class="d-flex gap-3 align-items-start">
                            <aside>
                                <field name="image_128" widget="image" class="rounded"/>
                            </aside>
                            <section class="flex-grow-1">
                                <div class="fw-bold fs-5">
                                    <field name="name"/>
                                </div>
                                <div class="text-muted">
                                    <field name="login"/>
                                </div>
                                <div t-if="record.email.raw_value">
                                    <field name="email"/>
                                </div>
                                <div class="mt-2">
                                    <field
                                        name="active"
                                        widget="boolean_toggle"
                                    />
                                </div>
                            </section>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_incas_rrhh_trabajadores_list" model="ir.ui.view">
        <field name="name">res.users.incas.rrhh.trabajadores.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Trabajadores">
                <field name="name"/>
                <field name="login"/>
                <field name="email"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_incas_rrhh_trabajadores_search" model="ir.ui.view">
        <field name="name">res.users.incas.rrhh.trabajadores.search</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <search string="Buscar trabajadores">
                <field name="name"/>
                <field name="login"/>
                <field name="email"/>
                <field name="company_id"/>
                <separator/>
                <filter name="filter_activos" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="filter_inactivos" string="Inactivos" domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="group_company" string="Compañía" domain="[]" context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_incas_rrhh_trabajadores" model="ir.actions.act_window">
        <field name="name">Trabajadores</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('share', '=', False)]</field>
        <field name="search_view_id" ref="view_incas_rrhh_trabajadores_search"/>
    </record>

    <record id="action_incas_rrhh_trabajadores_kanban_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_incas_rrhh_trabajadores_kanban"/>
        <field name="act_window_id" ref="action_incas_rrhh_trabajadores"/>
    </record>

    <record id="action_incas_rrhh_trabajadores_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_incas_rrhh_trabajadores_list"/>
        <field name="act_window_id" ref="action_incas_rrhh_trabajadores"/>
    </record>

    <menuitem
        id="menu_incas_rrhh_root"
        name="RRHH"
        parent="incas_core.menu_incas_root"
        sequence="40"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />

    <menuitem
        id="menu_incas_rrhh_trabajadores"
        name="Trabajadores"
        parent="menu_incas_rrhh_root"
        action="action_incas_rrhh_trabajadores"
        sequence="10"
        groups="base.group_system,incas_core.group_incas_core_admin,incas_core.group_incas_core_gerencia"
    />
</odoo>
