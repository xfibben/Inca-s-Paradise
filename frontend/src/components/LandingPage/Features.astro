---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<!-- Features Section -->
<section class="bg-gray-100 px-4 py-12 md:py-16 lg:py-20 flex items-center">
  <div class="max-w-7xl mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 md:gap-12 lg:gap-16">
      <!-- Left Column: Title and Description (2/3 width) -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl md:text-3xl lg:text-4xl text-gray-900 leading-tight mb-6" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 300;">
          {t.features.title}
        </h2>
        
        <p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed text-justify">
          {t.features.description}
        </p>
      </div>

      <!-- Right Column: Three Features (1/3 width) -->
      <div class="grid grid-cols-3 gap-4 md:gap-6 lg:gap-8">
        <!-- Feature 1: Responsible Travel -->
        <div class="flex flex-col items-center text-center">
          <svg class="w-12 h-12 md:w-16 md:h-16 lg:w-20 lg:h-20 mb-2 md:mb-4" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M256 30.72L50 112.64V245.76C50 364.544 140.288 450.56 256 481.28C371.712 450.56 462 364.544 462 245.76V112.64L256 30.72Z" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"/>
            
            <circle cx="256" cy="275" r="140" stroke="currentColor" stroke-width="8"/>
            <ellipse cx="256" cy="275" rx="60" ry="140" stroke="currentColor" stroke-width="6" stroke-opacity="0.6"/>
            <ellipse cx="256" cy="275" rx="110" ry="80" stroke="currentColor" stroke-width="6" stroke-opacity="0.6" transform="rotate(90 256 275)"/>

            <circle cx="256" cy="275" r="95" stroke="currentColor" stroke-width="12" fill="white"/>
            <path d="M256 185V210M256 340V365M166 275H191M321 275H346" stroke="currentColor" stroke-width="8" stroke-linecap="round"/>
            
            <path d="M250 165H260M256 165V175" stroke="currentColor" stroke-width="4"/> 
            <path d="M250 385H260C260 385 260 395 250 395H260" stroke="currentColor" stroke-width="4"/> 
            <path d="M148 275L152 271V279L148 275Z" stroke="currentColor" stroke-width="3"/> 
            <path d="M358 275L354 271V279L358 275Z" stroke="currentColor" stroke-width="3"/> 
            <path d="M256 225L235 275H277L256 225Z" fill="currentColor"/>
            <path d="M256 325L277 275H235L256 325Z" fill="#B0C4DE"/>

            <path d="M256 160C256 160 216 120 216 100C216 80 231.8 70 256 95C280.2 70 296 80 296 100C296 120 256 160 256 160Z" stroke="currentColor" stroke-width="15" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M190 90C170 100 160 120 170 140M322 90C342 100 352 120 342 140" stroke="currentColor" stroke-width="10" stroke-linecap="round"/>
          </svg>
          <h3 class="text-sm md:text-base lg:text-lg font-semibold text-gray-800">
            {t.features.responsibleTravel}
          </h3>
        </div>

        <!-- Feature 2: 5-Star Reviews -->
        <div class="flex flex-col items-center text-center">
          <div class="mb-2 md:mb-4">
            <svg class="w-12 h-12 md:w-16 md:h-16 lg:w-20 lg:h-20" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="100" height="100" fill="#003B5C" rx="4"/>
              <text x="50" y="35" font-size="24" font-weight="bold" fill="white" text-anchor="middle" font-family="Arial">★★★★★</text>
              <text x="50" y="70" font-size="10" fill="white" text-anchor="middle" font-family="Arial">TRUSTPILOT</text>
            </svg>
          </div>
          <h3 class="text-sm md:text-base lg:text-lg font-semibold text-gray-800">
            {t.features.fiveStarReviews}
          </h3>
        </div>

        <!-- Feature 3: Easy Bookings -->
        <div class="flex flex-col items-center text-center">
          <svg class="w-16 h-16 md:w-24 md:h-24 lg:w-32 lg:h-32 mb-0 -mt-2 md:-mt-3 lg:-mt-4" viewBox="0 0 90 110" xmlns="http://www.w3.org/2000/svg">
            <!-- Celular -->
            <g id="phone">
              <!-- Cuerpo del teléfono -->
              <rect x="22" y="12" width="42" height="75" rx="5" fill="white" stroke="#000" stroke-width="2.8"/>
              <!-- Pantalla -->
              <rect x="27" y="20" width="32" height="57" rx="2" fill="white" stroke="#000" stroke-width="1.8"/>
              <!-- Círculo verde alrededor del check -->
              <circle cx="43" cy="40" r="14" fill="none" stroke="#16a34a" stroke-width="3"/>
              <!-- Check en la pantalla (en verde) -->
              <g id="checkmark">
                <!-- Línea vertical del check -->
                <path d="M 37 38 L 41 45" stroke="#16a34a" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- Línea diagonal del check -->
                <path d="M 41 45 L 52 31" stroke="#16a34a" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <!-- Marco inferior (botón home) -->
              <circle cx="43" cy="88" r="1.8" fill="#000"/>
            </g>

            <!-- Símbolo de seguridad (candado grande) -->
            <g id="security-badge">
              <rect x="63" y="20" width="18" height="20" rx="2" fill="white" stroke="#000" stroke-width="2.3"/>
              <path d="M 68 20 L 68 15 Q 68 11 72 11 Q 76 11 76 15 L 76 20" stroke="#000" stroke-width="1.8" fill="none" stroke-linecap="round"/>
              <circle cx="72" cy="30" r="1.5" fill="#000"/>
              <path d="M 72 30 L 72 36" stroke="#000" stroke-width="1.4" stroke-linecap="round"/>
            </g>
          </svg>
          <h3 class="text-sm md:text-base lg:text-lg font-semibold text-gray-800 -mt-2 md:-mt-3 lg:-mt-4">
            {t.features.easyBookings}
          </h3>
        </div>
      </div>
    </div>
  </div>
</section>
