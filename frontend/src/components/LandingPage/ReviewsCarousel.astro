---
interface Props {
  t: any;
}

const { t } = Astro.props;

// Configuración de tamaños para las imágenes trip.webp por año
// Modifica los valores según el tamaño real de cada imagen
const tripImageSizes: Record<number, { mobile: string; tablet: string; desktop: string }> = {
  2017: { mobile: 'h-48', tablet: 'md:h-72', desktop: 'lg:h-96' },
  2018: { mobile: 'h-48', tablet: 'md:h-72', desktop: 'lg:h-96' },
  2019: { mobile: 'h-48', tablet: 'md:h-72', desktop: 'lg:h-96' },
  2020: { mobile: 'h-80', tablet: 'md:h-[28rem]', desktop: 'lg:h-[36rem]' },
  2023: { mobile: 'h-48', tablet: 'md:h-72', desktop: 'lg:h-96' },
  2024: { mobile: 'h-80', tablet: 'md:h-[28rem]', desktop: 'lg:h-[36rem]' },
};

function getImageSizeClass(year: number): string {
  const sizes = tripImageSizes[year];
  return sizes 
    ? `${sizes.mobile} ${sizes.tablet} ${sizes.desktop}` 
    : 'h-56 md:h-80 lg:h-96';
}
---

<!-- Reviews Carousel -->
<section class="w-full relative overflow-hidden" style="height: 600px;">
  {t.reviews.reviews.map((review: any, index: number) => (
    <div
      class={`review-slide absolute inset-0 w-full h-full transition-opacity duration-2000 ${
        index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'
      }`}
      data-index={index}
    >
      <!-- Background Image - Full Screen -->
      <div
        class="absolute inset-0 w-full h-full bg-cover bg-center"
        style={{
          backgroundImage: `url(/landing%20page%20images/reviews/${review.year}.jpg)`
        }}
      >
        <div class="absolute inset-0 bg-black/60"></div>
      </div>

      <!-- Content Container - Divided Layout -->
      <div class="absolute inset-0 w-full h-full flex">
        <!-- Left Side - Logo (mobile 1/3, desktop 1/2) -->
        <div class="w-1/3 md:w-1/2 h-full flex items-center justify-center">
          <img 
            src={`/landing%20page%20images/reviews/${review.year}trip.webp`}
            alt="Trip Logo"
            width="120" height="120"
            class={`w-auto brightness-0 invert ${getImageSizeClass(review.year)}`}
            loading="lazy"
            fetchpriority="low"
          />
        </div>

        <!-- Right Side - Content (mobile 2/3, desktop 1/2) -->
        <div class="w-2/3 md:w-1/2 h-full flex items-center justify-start pr-6 md:pr-12 lg:pr-20">
          <div class="w-full text-white">
            <!-- Review Title -->
            <h3 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-6 leading-tight">
              {review.title}
            </h3>

            <!-- Green Dots with Rating -->
            <div class="flex items-center gap-4 mb-8">
              <span class="text-lg md:text-base ">4.9</span>
              <div class="flex gap-2">
                <div class="w-5 h-5 rounded-full bg-[#00852f]"></div>
                <div class="w-5 h-5 rounded-full bg-[#00852f]"></div>
                <div class="w-5 h-5 rounded-full bg-[#00852f]"></div>
                <div class="w-5 h-5 rounded-full bg-[#00852f]"></div>
                <div class="w-5 h-5 rounded-full bg-[#00852f]"></div>
              </div>
              <span class="text-sm md:text-base text-gray-300">(151 opiniones)</span>
            </div>

            <!-- Review Opinion -->
            <div class="max-h-56 md:max-h-72 overflow-y-auto pr-4 mb-8">
              <p class="text-base md:text-lg lg:text-xl text-gray-100 leading-relaxed text-justify">
                {review.opinion}
              </p>
            </div>

            <!-- Year + Button -->
            <div class="flex items-center gap-4">
              <span class="text-sm font-semibold bg-white/20 px-4 py-2 rounded-full border border-white/30">
                {review.year}
              </span>
              <a
                href={review.url}
                target="_blank"
                rel="noopener noreferrer"
                class="px-6 py-2 bg-[#00852f] hover:bg-[#006b27] text-white font-bold rounded transition duration-3000"
              >
                {t.buttons.goToComment}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const slides = document.querySelectorAll('.review-slide');
    let currentIndex = 0;
    const slideInterval = 3000; // 3 seconds

    function showSlide(index) {
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.classList.remove('opacity-0');
          slide.classList.remove('z-0');
          slide.classList.add('opacity-100');
          slide.classList.add('z-10');
        } else {
          slide.classList.add('opacity-0');
          slide.classList.add('z-0');
          slide.classList.remove('opacity-100');
          slide.classList.remove('z-10');
        }
      });
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % slides.length;
      showSlide(currentIndex);
    }

    // Initialize
    if (slides.length > 0) {
      showSlide(currentIndex);
      setInterval(nextSlide, slideInterval);
    }
  });
</script>
