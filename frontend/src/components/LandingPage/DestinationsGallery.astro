---
import { fetchOdooWebJson, getOdooMediaUrl, getOdooWebLang } from "../../utils/odooWeb";

interface Props {
  t: any;
  currentLang?: string;
}

const { t, currentLang = "es" } = Astro.props;

let destinations: any[] = [];
try {
  const json = await fetchOdooWebJson(`/incas/api/web/destinos?lang=${getOdooWebLang(currentLang)}`);
  destinations = json?.data ?? [];
} catch (error) {
  console.log("[DestinationsGallery] fetch exception:", error);
}
---

<style>
  .destinations-grid {
    height: auto;
  }
</style>

<section id="destinos" class="bg-white w-screen px-0 py-0 flex items-center justify-center min-h-screen">
  <div class="w-screen">
    <div class="destinations-grid grid gap-px grid-cols-1 md:grid-cols-3 lg:grid-cols-4 w-screen">
      {destinations.map((dest: any) => {
        const title = dest.title;
        const slug = dest.slug;
        const href = `/${currentLang}/destinos/${slug}`;
        const cardSrc = getOdooMediaUrl(dest.galleryThumbnail) || getOdooMediaUrl(dest.heroSlideImages?.[0]) || "";
        const tours = Array.isArray(dest.tours) ? dest.tours : [];
        return (
          <article class="relative group block w-full overflow-hidden h-60 md:h-auto md:aspect-square">
            <a href={href} class="absolute inset-0 block" aria-label={title}>
              {cardSrc ? (
                <img
                  src={cardSrc}
                  sizes="(max-width: 768px) 100vw, (max-width: 1024px) 33vw, 25vw"
                  alt={title}
                  width="500"
                  height="500"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="w-full h-full bg-stone-300" />
              )}
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300"></div>
            </a>
            <div class="pointer-events-none absolute inset-0 flex flex-col justify-center items-center text-center p-4 text-white">
              <h3 class="text-md transition-transform duration-300 group-hover:-translate-y-3 font-s['Roboto',sans-serif]">{title}</h3>
              <div class="pointer-events-auto absolute opacity-0 group-hover:opacity-100 group-hover:scale-105 transition-opacity duration-300 flex flex-col space-y-2 md:space-y-3 items-center w-full bottom-0 left-0 right-0 p-4">
                <ul>
                  {tours.map((tour: any) => (
                    <li key={tour.slug}>
                      <a href={`/${currentLang}/tours/${tour.slug}`} class="flex items-center space-x-2">
                        {getOdooMediaUrl(tour.heroSlideImages?.[0]) ? (
                          <img src={getOdooMediaUrl(tour.heroSlideImages?.[0])!} alt={tour.title} class="w-8 h-8 object-cover rounded" />
                        ) : null}
                        <span>{tour.title}</span>
                      </a>
                    </li>
                  ))}
                </ul>
                <a href={href} class="px-3 py-1.5 sm:px-4 sm:py-2 border border-white text-white text-xs sm:text-sm font-semibold hover:bg-white hover:border-white hover:text-gray-900 transition">
                  {t.buttons.explore}
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
