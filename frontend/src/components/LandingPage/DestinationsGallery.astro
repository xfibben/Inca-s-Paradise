---
interface Props {
  t: any;
  currentLang?: string;
}

const { t, currentLang = 'es' } = Astro.props;

const strapiLocale = currentLang === 'pt' ? 'pt-BR' : currentLang === 'es' ? 'es-PE' : currentLang;
const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://backend:1337';
const STRAPI_PUBLIC_URL = import.meta.env.PUBLIC_STRAPI_URL || 'http://localhost:1337';

function toSlug(name: string): string {
  return name
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-');
}

function normalizeRow(row: any) {
  return row?.attributes ?? row ?? null;
}

function toMediaObject(value: any) {
  if (!value) return null;
  const source = value?.data ?? value;
  return source?.attributes ?? source ?? null;
}

function toAbsoluteMediaUrl(value: any) {
  const media = toMediaObject(value);
  const rawUrl =
    media?.formats?.medium?.url ??
    media?.formats?.small?.url ??
    media?.formats?.thumbnail?.url ??
    media?.url ??
    (typeof value === 'string' ? value : '');
  if (!rawUrl) return '';
  if (/^https?:\/\//i.test(rawUrl)) return rawUrl;
  const normalizedBase = String(STRAPI_PUBLIC_URL).replace(/\/$/, '');
  const normalizedPath = String(rawUrl).startsWith('/') ? String(rawUrl) : `/${rawUrl}`;
  return `${normalizedBase}${normalizedPath}`;
}

function getCardImageUrl(destination: any) {
  const row = normalizeRow(destination) ?? {};

  const thumbnailUrl = toAbsoluteMediaUrl(row.galleryThumbnail);
  if (thumbnailUrl) return thumbnailUrl;

  const heroSlideMediaRows = Array.isArray(row.heroSlideImages?.data)
    ? row.heroSlideImages.data
    : Array.isArray(row.heroSlideImages)
      ? row.heroSlideImages
      : [];
  const heroMediaUrl = toAbsoluteMediaUrl(heroSlideMediaRows[0]);
  if (heroMediaUrl) return heroMediaUrl;

  const heroSlides = Array.isArray(row.heroSlides) ? row.heroSlides : [];
  const heroJsonUrl = toAbsoluteMediaUrl(heroSlides[0]?.image);
  if (heroJsonUrl) return heroJsonUrl;

  return '';
}

let destinations: any[] = [];
try {
  const url =
    `${STRAPI_URL}/api/destino-detalles?locale=${strapiLocale}&status=published&` +
    `populate[galleryThumbnail][fields][0]=url&` +
    `populate[galleryThumbnail][fields][1]=alternativeText&` +
    `populate[galleryThumbnail][fields][2]=formats&` +
    `populate[heroSlideImages][fields][0]=url&` +
    `populate[heroSlideImages][fields][1]=alternativeText&` +
    `populate[heroSlideImages][fields][2]=formats`;
  const res = await fetch(url);
  if (res.ok) {
    const json = await res.json();
    destinations = json.data ?? [];
  }
} catch (e) {
  // no-op: keep empty gallery if Strapi is unreachable
}
---

<style>
  .destinations-grid {
    height: 180vh;
  }

  @media (min-width: 1024px) {
    .destinations-grid {
      height: 150vh;
    }
  }
</style>

<!-- Destinations Gallery Section -->
<section class="bg-white w-screen px-0 py-0 flex items-center justify-center min-h-screen">
  <div class="w-screen">
    <div class="destinations-grid grid gap-px grid-cols-1 md:grid-cols-3 lg:grid-cols-4 w-screen" style="grid-auto-rows: 1fr;">
      
      {destinations.map((dest: any) => {
        const row = normalizeRow(dest) ?? {};
        const imageUrl = getCardImageUrl(row) || null;
        const title = row.title;
        const slug = row.slug || toSlug(title || '');
        const description = row.description;

        return (
          <a href={`/${currentLang}/destinos/${slug}`} class="group relative overflow-hidden cursor-pointer block">
            {imageUrl && (
              <img 
                src={imageUrl}
                alt={title} 
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
              />
            )}
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300"></div>
            <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-4 text-white">
              <h3 class="text-md  transition-transform duration-300 group-hover:-translate-y-3 font-s['Roboto' ,sans-serif] ">{title}</h3>
              <div class="absolute opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col space-y-2 md:space-y-3 items-center w-full bottom-0 left-0 right-0 p-4">
                <p class="text-xs sm:text-sm md:text-base leading-relaxed hidden sm:block max-w-xs">
                  {description}
                </p>
                <span class="px-3 py-1.5 sm:px-4 sm:py-2 border border-white text-white text-xs sm:text-sm font-semibold hover:bg-white hover:border-white hover:text-gray-900 transition">
                  {t.buttons.explore}
                </span>
              </div>
            </div>
          </a>
        );
      })}

    </div>
  </div>
</section>
