---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="bg-white px-4 md:px-8 py-12 md:py-16 lg:py-20 flex items-center" style="min-height: calc(100vh - 6rem);">
  <div class="max-w-7xl mx-auto w-full">
    <!-- Main Title -->
    <h2 class="text-3xl md:text-4xl lg:text-5xl text-gray-900 text-center mb-12 md:mb-16" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">
      {t.sustainability.title}
    </h2>

    <!-- Flex Container with Dynamic Widths -->
    <div class="flex gap-4 h-[500px] md:h-[600px]">
      <!-- Card 1: Fair Tourism (Active by default) -->
      <div class="sustainability-card active flex-1 transition-all duration-500 ease-out cursor-pointer" data-card="0" style="flex: 2;">
        <div class="h-full flex flex-col">
          <!-- Title -->
          <h3 class="text-xl md:text-2xl font-semibold text-gray-900 mb-3 md:mb-4 flex-shrink-0">
            {t.sustainability.fairTourism.name}
          </h3>
          
          <!-- Description (only visible when active) -->
          <p class="description text-base md:text-lg text-gray-700 leading-relaxed mb-4 md:mb-6 flex-shrink-0">
            {t.sustainability.fairTourism.description}
          </p>
          
          <!-- Image -->
          <div class="flex-1 overflow-hidden rounded-lg">
            <img
              src={t.sustainability.images.fairTourism.startsWith('landing page images')
                ? `/${t.sustainability.images.fairTourism}`
                : t.sustainability.images.fairTourism}
              alt={t.sustainability.fairTourism.name}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Card 2: Sustainability -->
      <div class="sustainability-card flex-1 transition-all duration-500 ease-out cursor-pointer" data-card="1">
        <div class="h-full flex flex-col">
          <!-- Title -->
          <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3 flex-shrink-0">
            {t.sustainability.sustainability.name}
          </h3>
          
          <!-- Description (only visible when active) -->
          <p class="description text-sm md:text-base text-gray-700 leading-relaxed mb-3 md:mb-4 flex-shrink-0 hidden">
            {t.sustainability.sustainability.description}
          </p>
          
          <!-- Image -->
          <div class="flex-1 overflow-hidden rounded-lg">
            <img
              src={t.sustainability.images.sustainability.startsWith('landing page images')
                ? `/${t.sustainability.images.sustainability}`
                : t.sustainability.images.sustainability}
              alt={t.sustainability.sustainability.name}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>

      <!-- Card 3: Social Projects -->
      <div class="sustainability-card flex-1 transition-all duration-500 ease-out cursor-pointer" data-card="2">
        <div class="h-full flex flex-col">
          <!-- Title -->
          <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3 flex-shrink-0">
            {t.sustainability.socialProjects.name}
          </h3>
          
          <!-- Description (only visible when active) -->
          <p class="description text-sm md:text-base text-gray-700 leading-relaxed mb-3 md:mb-4 flex-shrink-0 hidden">
            {t.sustainability.socialProjects.description}
          </p>
          
          <!-- Image -->
          <div class="flex-1 overflow-hidden rounded-lg">
            <img
              src={t.sustainability.images.socialProjects.startsWith('landing page images')
                ? `/${t.sustainability.images.socialProjects}`
                : t.sustainability.images.socialProjects}
              alt={t.sustainability.socialProjects.name}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Sustainability Card Expansion Logic
  const cards = document.querySelectorAll('.sustainability-card');
  
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const cardIndex = card.getAttribute('data-card');
      
      cards.forEach((c) => {
        const index = c.getAttribute('data-card');
        const description = c.querySelector('.description');
        
        if (index === cardIndex) {
          // Expand active card
          c.style.flex = '2';
          c.classList.add('active');
          // Show description
          if (description) {
            description.classList.remove('hidden');
          }
        } else {
          // Shrink inactive cards
          c.style.flex = '1';
          c.classList.remove('active');
          // Hide description
          if (description) {
            description.classList.add('hidden');
          }
        }
      });
    });
  });

  // Initial state: first card expanded, others collapsed
  if (cards.length > 0) {
    cards[0].style.flex = '2';
    cards[0].classList.add('active');
    
    // Show description for first card
    const firstDescription = cards[0].querySelector('.description');
    if (firstDescription) {
      firstDescription.classList.remove('hidden');
    }
    
    // Hide descriptions for other cards
    for (let i = 1; i < cards.length; i++) {
      cards[i].style.flex = '1';
      const description = cards[i].querySelector('.description');
      if (description) {
        description.classList.add('hidden');
      }
    }
  }
</script>

