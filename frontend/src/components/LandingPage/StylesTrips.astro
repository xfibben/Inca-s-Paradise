---
import { fetchOdooWebJson, getOdooMediaUrl, getOdooWebLang } from "../../utils/odooWeb";

interface Props {
  t: any;
  currentLang?: string;
}

const { currentLang = "es" } = Astro.props;

let styleTrips: any[] = [];
try {
  const json = await fetchOdooWebJson(`/incas/api/web/estilos-viaje?lang=${getOdooWebLang(currentLang)}`);
  styleTrips = json?.data ?? [];
} catch (error) {
  console.log("[StylesTrips] fetch exception:", error);
}
---

<style>
  @media (max-width: 768px) {
    section {
      height: auto !important;
      min-height: auto !important;
      padding: 1rem 0;
    }

    .styles-grid {
      height: auto !important;
      gap: 0.25rem;
    }

    .styles-grid > div {
      min-height: 240px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .styles-grid > :nth-child(4) {
      grid-column: 2 / 3;
    }
    .styles-grid > :nth-child(5) {
      grid-column: 3 / 4;
    }
  }
</style>

<section class="bg-white px-2 w-full flex items-center justify-center" style="height: calc(100vh - 6rem);">
  <div class="w-full h-full">
    <div class="styles-grid grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-1 w-full h-full" style="grid-auto-rows: 1fr;">
      {styleTrips.map((item: any) => {
        const imageUrl = getOdooMediaUrl(item.image);
        return (
          <div class="group relative overflow-hidden cursor-pointer transition-transform duration-300 group-hover:scale-x-125 group-hover:z-20">
            {imageUrl && (
              <img
                src={imageUrl}
                alt={item.name}
                width="600"
                height="900"
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            )}

            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300"></div>

            <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-4 text-white">
              <a href={`/${currentLang}/style-trips/${item.slug}`} class="text-md md:text-xl lg:text-xl font-bold transition-transform duration-300 group-hover:-translate-y-3 hover:opacity-80" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">
                {item.name}
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
