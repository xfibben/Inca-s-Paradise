---
interface Props {
  tipos: any[];
  publicStrapiUrl: string;
  lang: string;
  t: any;
}

const { tipos, publicStrapiUrl, lang, t } = Astro.props;

/* Obtiene la URL absoluta de la imagen */
function getImageUrl(media: any): string | null {
  if (!media) return null;
  const url = media?.formats?.large?.url ?? media?.formats?.medium?.url ?? media?.url;
  if (!url) return null;
  return url.startsWith('http') ? url : `${publicStrapiUrl}${url}`;
}
---

<!-- Sección grid de tipos de transporte -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado de sección -->
    <div class="text-center mb-16">
      <p class="text-[#1AA093] uppercase tracking-widest text-sm font-medium mb-3">{t.transporte?.gridLabel ?? "Movilidad"}</p>
      <h2
        class="text-4xl md:text-5xl text-stone-800"
        style="font-family: 'Playfair Display', serif; font-style: italic;"
      >
        {t.transporte?.gridTitle ?? "Nuestros Transportes"}
      </h2>
    </div>

    <!-- Grid 4 columnas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {tipos.map((tipo) => {
        const imgUrl = getImageUrl(tipo.image);
        const slug = tipo.slug;

        return (
          <a
            href={slug ? `/${lang}/tipo-transporte/${slug}` : '#'}
            class="group relative rounded-2xl overflow-hidden bg-stone-100 shadow-md hover:shadow-xl transition-shadow duration-300 min-h-105 flex flex-col"
          >
            <!-- Imagen de fondo -->
            {imgUrl ? (
              <img
                src={imgUrl}
                alt={tipo.nombre}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            ) : (
              <div class="absolute inset-0 bg-linear-to-br from-stone-300 to-stone-500" />
            )}

            <!-- Overlay degradado -->
            <div class="absolute inset-0 bg-linear-to-t from-black/75 via-black/20 to-transparent" />

            <!-- Título al fondo -->
            <div class="relative mt-auto p-6 text-white text-center">
              <h3
                class="text-2xl font-medium leading-snug"
                style="font-family: 'Playfair Display', serif; font-style: italic;"
              >
                {tipo.nombre}
              </h3>
            </div>
          </a>
        );
      })}

      <!-- Placeholders si hay menos de 4 tipos en el backend -->
      {Array.from({ length: Math.max(0, 4 - tipos.length) }).map(() => (
        <article class="relative rounded-2xl overflow-hidden bg-stone-100 shadow-md min-h-105 flex flex-col">
          <div class="absolute inset-0 bg-linear-to-br from-stone-200 to-stone-400" />
          <div class="relative mt-auto p-6 text-white/50 text-center">
            <h3
              class="text-2xl font-medium"
              style="font-family: 'Playfair Display', serif; font-style: italic;"
            >
              {t.transporte?.proximamente ?? "Próximamente"}
            </h3>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
