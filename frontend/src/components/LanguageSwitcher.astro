---
import { getLanguagesSync } from '../i18n/index';

interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;

// Get languages synchronously (uses cached or fallback)
const languagesMap = getLanguagesSync();

const languages = Object.entries(languagesMap).map(([code, name]) => ({
  code,
  name,
}));

const currentLanguage = languages.find(lang => lang.code === currentLang) || languages[0];
const otherLanguages = languages.filter(lang => lang.code !== currentLang);
---

<div id="lang-switcher" class="relative">
  <!-- Language Button -->
  <button id="lang-button" class="flex items-center space-x-2 px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg transition text-white text-sm font-semibold border border-white/30">
    <span>{currentLanguage.name}</span>
    <svg id="lang-arrow" class="w-4 h-4 transition transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </button>

  <!-- Dropdown Menu - will be populated by Navbar script from backend -->
  <div id="lang-dropdown" class="absolute hidden top-full right-0 mt-2 bg-black/80 backdrop-blur-md rounded-lg border border-white/30 overflow-hidden z-50">
    <!-- Languages will be added by Navbar script -->
  </div>
</div>

<script>
  console.log('LanguageSwitcher: Script loaded');
  
  const langSwitcher = document.getElementById('lang-switcher');
  if (!langSwitcher) {
    console.error('LanguageSwitcher: Could not find lang-switcher element');
  }

  // Just setup button toggle - Navbar will handle the language links
  function setupButton() {
    if (!langSwitcher) return;
    
    const langButton = langSwitcher.querySelector('#lang-button');
    const langDropdown = langSwitcher.querySelector('#lang-dropdown');
    const langArrow = langSwitcher.querySelector('#lang-arrow');

    if (!langButton || !langDropdown) {
      console.log('LanguageSwitcher: Missing button or dropdown, retrying...');
      setTimeout(setupButton, 100);
      return;
    }

    console.log('LanguageSwitcher: Setting up button');

    langButton.addEventListener('click', (e) => {
      console.log('LanguageSwitcher: Button clicked');
      e.stopPropagation();
      langDropdown.classList.toggle('hidden');
      langArrow?.classList.toggle('rotate-180');
    });
  }

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (langSwitcher && !langSwitcher.contains(e.target)) {
      const dropdown = langSwitcher.querySelector('#lang-dropdown');
      const arrow = langSwitcher.querySelector('#lang-arrow');
      if (dropdown && !dropdown.classList.contains('hidden')) {
        dropdown.classList.add('hidden');
        arrow?.classList.remove('rotate-180');
      }
    }
  });

  setupButton();
</script>
