---
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  t: any;
  currentLang: string;
}

const { t, currentLang } = Astro.props;

const STRAPI_URL = import.meta.env.STRAPI_URL;
const STRAPI_PUBLIC_URL = import.meta.env.PUBLIC_STRAPI_URL;
// const strapiLocale = currentLang === 'pt' ? 'pt-BR' : currentLang === 'es' ? 'es-PE' : currentLang;
  const strapiLocale = currentLang === 'pt' ? 'pt' : currentLang === 'es' ? 'es-PE' : currentLang;

  // Soporte para portugués en destinos
  function getDestTitle(dest: any) {
    return dest.title || dest.name || dest.titulo || dest.titulo_pt || dest.titulo_en || dest.titulo_es || '';
  }
function toSlug(name: string): string {
  return name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
}

let navStyleTrips: any[] = [];
let navDestinations: any[] = [];
try {
  const styleUrl = `${STRAPI_URL}/api/style-trips?populate=*&locale=${strapiLocale}&status=published`;
  const destUrl = `${STRAPI_URL}/api/destino-detalles?locale=${strapiLocale}` +
    `&fields[0]=title` +
    `&fields[1]=slug` +
    `&populate[ogImage][fields][0]=url` +
    `&populate[ogImage][fields][1]=alternativeText` +
    `&populate[tours][fields][0]=title` +
    `&populate[tours][fields][1]=slug` +
    `&populate[tours][populate][heroSlideImages][fields][0]=url` +
    `&populate[tours][populate][heroSlideImages][fields][1]=alternativeText`;
  console.log('[Navbar] Fetching:', { styleUrl, destUrl });
  const [styleRes, destRes] = await Promise.all([
    fetch(styleUrl),
    fetch(destUrl)
  ]);
  console.log('[Navbar] Style Response:', styleRes.status);
  console.log('[Navbar] Dest Response:', destRes.status);
  if (styleRes.ok) {
    const json = await styleRes.json();
    navStyleTrips = json.data ?? [];
    console.log('[Navbar] Style Trips Count:', navStyleTrips.length);
    console.log('[Navbar] Style Trips Data:', navStyleTrips);
  }
  if (destRes.ok) {
    const json = await destRes.json();
    navDestinations = json.data ?? [];
    console.log('[Navbar] Destinations Count:', navDestinations.length);
    console.log('[Navbar] Destinations Data:', navDestinations);
  }
} catch (e) {
  console.error('[Navbar] Fetch error:', e);
}
---

<style>
  /* Cuando el menú móvil está abierto, navbar siempre blanco */
  #navbar.menu-open {
    background-color: white !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1) !important;
  }

  /* Force black text in all dropdowns by default */
  #megamenu-dropdown,
  #styles-dropdown,
  #sustainability-dropdown {
    color: #000 !important;
  }

  /* Avoid overriding white text elements */
  #megamenu-dropdown *:not(#megamenu-dest-name):not(.style-item-grid h3),
  #styles-dropdown *:not(.style-item-grid h3),
  #sustainability-dropdown * {
    color: inherit !important;
  }

  /* Ensure specific elements remain dark/readable */
  #megamenu-dropdown a,
  #styles-dropdown a,
  #sustainability-dropdown a {
    color: #1f2937 !important;
  }

  #megamenu-dropdown h3,
  #sustainability-dropdown h3 {
    color: #111827 !important;
  }

  /* White text for style items inside images */
  #styles-dropdown .style-item-grid h3 {
    color: #ffffff !important;
  }

  #megamenu-dropdown p,
  #styles-dropdown p:not(#styles-menu-footer),
  #sustainability-dropdown p {
    color: #374151 !important;
  }

  /* White text for destination name in megamenu - HIGHEST PRIORITY */
  #megamenu-dropdown #megamenu-dest-name,
  p#megamenu-dest-name {
    color: #ffffff !important;
    font-weight: bold !important;
  }

  /* White text for styles menu footer - OVERRIDE ALL */
  #styles-menu-footer {
    color: #ffffff !important;
  }
</style>

<!-- Navbar -->
<nav id="navbar" class="fixed top-0 w-full bg-transparent transition-all duration-300 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={`/${currentLang}/`}>
          <img src="/landing page images/incasparadiselogo.png" alt="Inca's Paradise Logo" class="h-20 w-auto" />
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-8 h-24">
        <!-- Destinations with Megamenu -->
        <div class="relative h-full flex items-center" id="megamenu-container">
          <a href="#" class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.destinations}</a>
          
          <!-- Megamenu -->
          <div id="megamenu-dropdown" class="fixed left-0 right-0 top-24 pt-0 hidden z-50 w-full">
            <div class="bg-white shadow-2xl overflow-hidden" style="height: 50vh;">
              <!-- Megamenu Container -->
              <div class="flex h-full">
                <!-- Column 1: Destinations List with Vertical Slider -->
                <div class="w-1/3 bg-gray-50 border-r border-gray-200 flex flex-col relative">
                  <!-- Scroll Up Button -->
                  <button id="scroll-up" class="bg-white/90 hover:bg-white p-2 border-b border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                    </svg>
                  </button>
                  
                  <!-- Destinations scroll container -->
                  <div id="destinations-scroll" class="flex-1 overflow-y-auto overflow-x-hidden scroll-smooth">
                    {navDestinations.map((dest: any) => (
                      <a
                        href={`/${currentLang}/destinos/${dest.slug || toSlug(getDestTitle(dest))}`}
                        class="destination-item w-full px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition border-b border-gray-100 whitespace-normal block"
                        title={getDestTitle(dest)}
                        data-dest={dest.slug}
                      >
                        {getDestTitle(dest)}
                      </a>
                    ))}
                  </div>
                  
                  <!-- Scroll Down Button -->
                  <button id="scroll-down" class="bg-white/90 hover:bg-white p-2 border-t border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                    </svg>
                  </button>
                </div>

                <!-- Column 2: Tours -->
                <div class="w-1/3 bg-white p-6 border-r border-gray-200 overflow-y-auto">
                  <div id="megamenu-tours" class="space-y-3">
                    {(() => {
                      // Mostrar tours relacionados del destino activo
                      const activeDest = navDestinations.length > 0 ? navDestinations[0] : null;
                      if (!activeDest || !activeDest.tours || !Array.isArray(activeDest.tours.data)) return null;
                      return activeDest.tours.data.map((tour: any) => {
                        const attrs = tour.attributes || tour;
                        return (
                          <div class="pb-3 border-b border-gray-100 last:border-0">
                            <a href={`/${currentLang}/tours/${attrs.slug}`} class="font-semibold text-gray-800 text-sm hover:text-blue-600 transition">
                              {attrs.title}
                            </a>
                          </div>
                        );
                      });
                    })()}
                  </div>
                </div>

                <!-- Column 3: Image and Destination Name -->
                <div class="w-1/3 bg-gray-100 overflow-hidden relative">
                  {/**
                   * La imagen se actualizará por JS al hacer hover/click en un destino,
                   * pero el src inicial debe ser ogImage del primer destino (si existe)
                   */}
                  {(() => {
                    let imgUrl = '';
                    if (navDestinations.length > 0 && navDestinations[0].ogImage && navDestinations[0].ogImage.url) {
                      imgUrl = `${STRAPI_PUBLIC_URL}${navDestinations[0].ogImage.url}`;
                    }
                    return (
                      <img
                        id="megamenu-image"
                        src={imgUrl || "https://images.unsplash.com/photo-1587595431973-160550652147?w=400&h=400&fit=crop"}
                        alt="Destination"
                        class="w-full h-full object-cover"
                      />
                    );
                  })()}
                  <div class="absolute inset-0 bg-black/30"></div>
                  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black to-transparent p-4">
                    <p id="megamenu-dest-name" class="text-white font-bold text-lg">{navDestinations.length > 0 ? getDestTitle(navDestinations[0]) : 'CHACHAPOYAS'}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Trip Styles with Megamenu -->
        <div class="relative h-full flex items-center" id="styles-container">
          <a href="#" class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.tripStyles}</a>
          
          <!-- Styles Megamenu - Sidebar + Grid Layout -->
          <div id="styles-dropdown" class="fixed left-0 right-0 top-24 pt-0 hidden z-50 w-full">
            <div class="bg-white shadow-2xl overflow-hidden" style="height: 58vh;">
              <!-- Container for sidebar + grid -->
              <div class="flex h-full">
                <!-- Sidebar - 1/6 width -->
                <div class="w-1/6 bg-gray-50 border-r border-gray-200 flex flex-col">
                  <button class="styles-menu-btn w-full px-4 py-4 text-left text-sm font-medium text-blue-600 hover:bg-blue-50 transition border-b-2 border-blue-600" data-menu="travelStyles">
                    {t.stylesMenu.travelStyles.name}
                  </button>
                  <button class="styles-menu-btn w-full px-4 py-4 text-left text-sm font-medium text-gray-700 hover:bg-blue-50 transition border-b-2 border-transparent" data-menu="smallTrips">
                    {t.stylesMenu.smallTrips.name}
                  </button>
                  <button class="styles-menu-btn w-full px-4 py-4 text-left text-sm font-medium text-gray-700 hover:bg-blue-50 transition border-b-2 border-transparent" data-menu="packages">
                    {t.stylesMenu.packages.name}
                  </button>

                  <!-- Menu Footer with Image and Description -->
                  <div class="mt-2 ml-auto mr-auto mb-2 bg-white relative w-full h-80 overflow-hidden">
                    <img id="styles-footer-image" src="" alt="Menu" class="w-full h-full object-cover" />
                    <div class="absolute inset-0 bg-black/10"></div>
                    <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-3">
                      <p id="styles-menu-footer" class="text-xs leading-tight" style="color: white !important;">
                        <!-- Will be populated by JavaScript -->
                      </p>
                    </div>
                  </div>
                </div>

                <!-- Content Area - 5/6 width -->
                <div class="w-5/6 bg-white overflow-hidden h-full">
                  <!-- Travel Styles Grid (default) -->
                  <div class="styles-menu-content h-full" id="content-travelStyles">
                    <div class="grid grid-cols-5 gap-2 h-full w-full px-2 py-2">
                      {navStyleTrips.map((item: any) => {
                        const navImg = Array.isArray(item.image) ? item.image[0] : item.image;
                        const imgUrl = navImg?.formats?.medium?.url
                          ? `${STRAPI_PUBLIC_URL}${navImg.formats.medium.url}`
                          : navImg?.url
                          ? `${STRAPI_PUBLIC_URL}${navImg.url}`
                          : null;
                        return (
                          <a
                            href={`/${currentLang}/style-trips/${toSlug(item.name)}`}
                            class="style-item-grid group relative overflow-hidden cursor-pointer transition-all duration-300 hover:z-20"
                          >
                            {imgUrl && (
                              <img src={imgUrl} alt={item.name} class="w-full h-full object-cover" />
                            )}
                            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300"></div>
                            <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-4 text-white border-b-2 border-transparent group-hover:border-white">
                              <h3 class="text-xs lg:text-sm font-bold transition-colors duration-300" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">
                                {item.name}
                              </h3>
                            </div>
                          </a>
                        );
                      })}
                    </div>
                  </div>

                  <!-- Small Trips (empty) -->
                  <div class="styles-menu-content hidden" id="content-smallTrips">
                    <div class="h-full flex items-center justify-center text-gray-400">
                      <p class="text-lg">{t.stylesMenu.smallTrips.name} - {t.nav.comingSoon}</p>
                    </div>
                  </div>

                  <!-- Packages (empty) -->
                  <div class="styles-menu-content hidden" id="content-packages">
                    <div class="h-full flex items-center justify-center text-gray-400">
                      <p class="text-lg">{t.stylesMenu.packages.name} - {t.nav.comingSoon}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sustainability with Megamenu -->
        <div class="relative h-full flex items-center" id="sustainability-container">
          <a href="#" class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.sustainability}</a>
          
          <!-- Sustainability Megamenu -->
          <div id="sustainability-dropdown" class="fixed left-0 right-0 top-24 pt-0 hidden z-50 w-full">
            <div class="bg-white shadow-2xl overflow-hidden" style="height: 50vh;">
              <!-- Megamenu Container -->
              <div class="flex h-full">
                <!-- Column 1: Sustainability Items List with Vertical Slider -->
                <div class="w-1/3 bg-gray-50 border-r border-gray-200 flex flex-col relative">
                  <!-- Scroll Up Button -->
                  <button id="scroll-up-sustainability" class="bg-white/90 hover:bg-white p-2 border-b border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                    </svg>
                  </button>
                  
                  <!-- Sustainability scroll container -->
                  <div id="sustainability-scroll" class="flex-1 overflow-y-auto overflow-x-hidden scroll-smooth">
                    {Object.entries(t.sustainability).filter(([key]: [string, any]) => !['title', 'images'].includes(key)).map(([key, item]: [string, any]) => {
                      const itemObj = item as { name: string; description: string };
                      return (
                        <button
                          class="sustainability-item w-full px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition border-b border-gray-100 whitespace-normal"
                          data-sustainability={key}
                          data-name={itemObj.name}
                          data-image={(t.sustainability as any).images[key]}
                          data-description={itemObj.description}
                        >
                          {itemObj.name}
                        </button>
                      );
                    })}
                  </div>
                  
                  <!-- Scroll Down Button -->
                  <button id="scroll-down-sustainability" class="bg-white/90 hover:bg-white p-2 border-t border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                    </svg>
                  </button>
                </div>

                <!-- Column 2: Description -->
                <div class="w-1/3 bg-white p-6 border-r border-gray-200 overflow-y-auto">
                  <div id="sustainability-description">
                    <p class="text-sm text-gray-600"></p>
                  </div>
                </div>

                <!-- Column 3: Image -->
                <div class="w-1/3 bg-gray-100 overflow-hidden relative">
                  <img
                    id="sustainability-image"
                    src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&h=400&fit=crop"
                    alt="Sustainability"
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute inset-0 bg-black/30"></div>
                  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black to-transparent p-4">
                    <p id="sustainability-name" class="text-white font-bold text-lg">SOSTENIBILIDAD</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <a href="#" class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.transport}</a>
        <a href="#" class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.blog}</a>
      </div>

      <!-- Language Switcher + Contact Button -->
      <div class="hidden md:flex items-center space-x-4">
        <LanguageSwitcher currentLang={currentLang} />
        <a
          id="contact-btn"
          href="https://wa.me/51953556680?text=Hola%20Inca's%20Paradise!%20Estoy%20interesado%20en%20saber%20más%20sobre%20sus%20tours."
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg transition text-white text-sm font-semibold border border-white/30"
        >
          <img src="/landing page images/footer/whatsapp logo.svg" alt="WhatsApp" class="w-5 h-5" />
          {t.nav.contactUs}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <button id="mobile-menu-btn" class="text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 space-y-3 backdrop-blur-md rounded-lg">
      <!-- Destinations Mobile -->
      <div class="relative">
        <button id="mobile-destinations-btn" class="block w-full text-left px-4 py-2 text-white text-sm hover:text-gray-300 transition bg-white/10 rounded">
          {t.nav.destinations} ▼
        </button>
        <div id="mobile-destinations-menu" class="hidden rounded mt-1 max-h-96 overflow-y-auto">
          <div id="mobile-destinations-list" class="flex flex-col">
            <div class="flex flex-col gap-1 p-1">
              {navDestinations.slice(0, 6).map((dest: any) => {
                // Usar ogImage como principal, fallback a heroSlides
                let imgUrl = '';
                if (dest.ogImage && dest.ogImage.url) {
                  imgUrl = `${STRAPI_PUBLIC_URL}${dest.ogImage.url}`;
                } else {
                  const slides = dest.heroSlides && Array.isArray(dest.heroSlides) ? dest.heroSlides : [];
                  if (slides.length > 0 && slides[0]?.image?.url) {
                    imgUrl = `${STRAPI_PUBLIC_URL}${slides[0].image.url}`;
                  }
                }
                return (
                  <a href={`/${currentLang}/destinos/${dest.slug || toSlug(dest.title)}`} class="mobile-destination-item relative h-16 overflow-hidden rounded block">
                    {imgUrl && <img src={imgUrl} alt={dest.title} class="w-full h-full object-cover" />}
                    <div class="absolute inset-0 bg-black/50"></div>
                    <span class="absolute inset-0 flex items-center justify-center text-white text-xs font-bold text-center px-1" style="font-family: 'Playfair Display', serif; font-style: italic;">{dest.title}</span>
                  </a>
                );
              })}
            </div>
            <!-- Hidden remaining destinations -->
            <div id="mobile-destinations-extra" class="hidden flex flex-col gap-1 px-1 pb-1">
              {navDestinations.slice(6).map((dest: any) => {
                // Usar ogImage como principal, fallback a heroSlides
                let imgUrl = '';
                if (dest.ogImage && dest.ogImage.url) {
                  imgUrl = `${STRAPI_PUBLIC_URL}${dest.ogImage.url}`;
                } else {
                  const slides = dest.heroSlides && Array.isArray(dest.heroSlides) ? dest.heroSlides : [];
                  if (slides.length > 0 && slides[0]?.image?.url) {
                    imgUrl = `${STRAPI_PUBLIC_URL}${slides[0].image.url}`;
                  }
                }
                return (
                  <a href={`/${currentLang}/destinos/${dest.slug || toSlug(dest.title)}`} class="mobile-destination-item relative h-16 overflow-hidden rounded block">
                    {imgUrl && <img src={imgUrl} alt={dest.title} class="w-full h-full object-cover" />}
                    <div class="absolute inset-0 bg-black/50"></div>
                    <span class="absolute inset-0 flex items-center justify-center text-white text-xs font-bold text-center px-1" style="font-family: 'Playfair Display', serif; font-style: italic;">{dest.title}</span>
                  </a>
                );
              })}
            </div>
            <!-- Show all button -->
            <button id="mobile-destinations-show-all" class="mx-1 mb-1 py-2 text-xs text-blue-600 font-medium bg-blue-50 hover:bg-blue-100 rounded transition text-center">
              Ver todos los destinos ▼
            </button>
          </div>
          <div id="mobile-destinations-details" class="hidden border-t border-gray-200 p-4">
            <button id="mobile-dest-back" class="text-blue-600 text-sm hover:text-blue-800 mb-2 font-medium">← Atrás</button>
            <h3 id="mobile-dest-name" class="font-bold text-gray-800 mb-3 text-sm"></h3>
            <div id="mobile-dest-tours" class="space-y-2">
              <!-- Tours will be inserted here -->
            </div>
          </div>
        </div>
      </div>

      <!-- Trip Styles Mobile -->
      <div class="relative">
        <button id="mobile-styles-btn" class="block w-full text-left px-4 py-2 text-white text-sm hover:text-gray-300 transition bg-white/10 rounded">
          {t.nav.tripStyles} ▼
        </button>
        <div id="mobile-styles-menu" class="hidden rounded mt-1 max-h-72 overflow-y-auto">
          <!-- Main Menu Options -->
          <div id="mobile-styles-list" class="flex flex-col gap-1 p-1">
            {navStyleTrips.map((item: any) => {
              let imgUrl = '';
              if (item.image) {
                const navImg = Array.isArray(item.image) ? item.image[0] : item.image;
                if (navImg?.formats?.medium?.url) {
                  imgUrl = `${STRAPI_PUBLIC_URL}${navImg.formats.medium.url}`;
                } else if (navImg?.url) {
                  imgUrl = `${STRAPI_PUBLIC_URL}${navImg.url}`;
                }
              }
              return (
                <button class="mobile-styles-option relative h-16 overflow-hidden rounded" data-option={item.slug || toSlug(item.name)} data-name={item.name}>
                  {imgUrl ? (
                    <img src={imgUrl} alt={item.name} class="w-full h-full object-cover" />
                  ) : (
                    <div class="w-full h-full bg-gray-400"></div>
                  )}
                  <div class="absolute inset-0 bg-black/50"></div>
                  <span class="absolute inset-0 flex items-center justify-center text-white text-xs font-bold text-center px-1" style="font-family: 'Playfair Display', serif; font-style: italic;">{item.name}</span>
                </button>
              );
            })}
          </div>
          <!-- Subitems Details -->
          <div id="mobile-styles-details" class="hidden border-t border-gray-200 p-1">
            <div class="flex items-center gap-2 p-2">
              <button id="mobile-styles-back" class="text-blue-600 text-sm hover:text-blue-800 font-medium">← Atrás</button>
              <h3 id="mobile-style-name" class="font-bold text-gray-800 text-sm"></h3>
            </div>
            <div id="mobile-style-subitems" class="p-0">
              <!-- Subitems will be inserted here -->
            </div>
          </div>
        </div>
      </div>

      <!-- Other Links -->
      <a href="#" class="block text-white text-sm hover:text-gray-300 transition px-4 py-2">{t.nav.transport}</a>
      
      <!-- Sustainability Mobile -->
      <div class="relative">
        <button id="mobile-sustainability-btn" class="block w-full text-left px-4 py-2 text-white text-sm hover:text-gray-300 transition bg-white/10 rounded">
          {t.nav.sustainability} ▼
