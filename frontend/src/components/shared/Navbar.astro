---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { languages } from '../../i18n';

interface Props {
  t: any;
  currentLang: string;
  whatsappTourName?: string;
}

const { t, currentLang, whatsappTourName } = Astro.props;

const pathname = Astro.url.pathname;

function humanizeSlug(slug: string): string {
  return slug
    .split("-")
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}

const tourPathMatch = pathname.match(/^\/[a-z]{2}\/tours\/([^/]+)\/?$/i);
const tourSlugFromPath = tourPathMatch?.[1] ?? "";
const inferredTourName =
  (typeof whatsappTourName === "string" ? whatsappTourName.trim() : "") ||
  (tourSlugFromPath ? humanizeSlug(decodeURIComponent(tourSlugFromPath)) : "");

const hasTourContext = Boolean(inferredTourName);

const whatsappMessageByLang: Record<string, string> = {
  es: hasTourContext
    ? `Hola Inca's Paradise! Quiero informacion sobre el tour "${inferredTourName}".`
    : "Hola Inca's Paradise! Quiero informacion sobre sus tours.",
  en: hasTourContext
    ? `Hi Inca's Paradise! I want information about the tour "${inferredTourName}".`
    : "Hi Inca's Paradise! I want information about your tours.",
  pt: hasTourContext
    ? `Ola Inca's Paradise! Quero informacoes sobre o tour "${inferredTourName}".`
    : "Ola Inca's Paradise! Quero informacoes sobre os seus tours.",
  fr: hasTourContext
    ? `Bonjour Inca's Paradise ! Je souhaite des informations sur le tour "${inferredTourName}".`
    : "Bonjour Inca's Paradise ! Je souhaite des informations sur vos tours.",
  it: hasTourContext
    ? `Ciao Inca's Paradise! Vorrei informazioni sul tour "${inferredTourName}".`
    : "Ciao Inca's Paradise! Vorrei informazioni sui vostri tour.",
};

const whatsappText =
  whatsappMessageByLang[currentLang] ?? whatsappMessageByLang.en;

const desktopWhatsappHref = `https://wa.me/51953556680?text=${encodeURIComponent(
  whatsappText
)}`;
const mobileWhatsappHref = `https://wa.me/51984434547?text=${encodeURIComponent(
  whatsappText
)}`;

const STRAPI_URL = import.meta.env.STRAPI_URL;
const STRAPI_PUBLIC_URL = import.meta.env.PUBLIC_STRAPI_URL;
// const strapiLocale = currentLang === 'pt' ? 'pt-BR' : currentLang === 'es' ? 'es-PE' : currentLang;
  const strapiLocale = currentLang === 'pt' ? 'pt' : currentLang === 'es' ? 'es-PE' : currentLang;

const NAV_CACHE_TTL_MS = 5 * 60 * 1000;
const NAV_CACHE_KEY = '__incas_nav_cache_v1__';
type NavCacheEntry = { expiresAt: number; value: any };
const navCache: Map<string, NavCacheEntry> =
  ((globalThis as any)[NAV_CACHE_KEY] as Map<string, NavCacheEntry> | undefined) ?? new Map();
(globalThis as any)[NAV_CACHE_KEY] = navCache;

async function fetchJsonCached(url: string) {
  const now = Date.now();
  const cached = navCache.get(url);
  if (cached && cached.expiresAt > now) return cached.value;

  const response = await fetch(url);
  if (!response.ok) throw new Error(`[Navbar] HTTP ${response.status} for ${url}`);
  const json = await response.json();
  navCache.set(url, { value: json, expiresAt: now + NAV_CACHE_TTL_MS });
  return json;
}

  // Soporte para portugués en destinos
  function getDestTitle(dest: any) {
    return dest.title || dest.name || dest.titulo || dest.titulo_pt || dest.titulo_en || dest.titulo_es || '';
  }
function toSlug(name: string): string {
  return name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
}

function normalizeRelatedTours(value: any) {
  return Array.isArray(value?.data) ? value.data : Array.isArray(value) ? value : [];
}

function normalizeSubcategorias(value: any) {
  return Array.isArray(value?.data) ? value.data : Array.isArray(value) ? value : [];
}

function sortSubcategoriasAlphabetically(rows: any[]) {
  return [...rows].sort((a: any, b: any) => {
    const left = a?.attributes || a;
    const right = b?.attributes || b;
    return String(left?.nombre ?? "").localeCompare(String(right?.nombre ?? ""), undefined, {
      sensitivity: "base"
    });
  });
}

function sortToursAlphabetically(rows: any[]) {
  return [...rows].sort((a: any, b: any) => {
    const left = a?.attributes || a;
    const right = b?.attributes || b;
    return String(left?.title ?? "").localeCompare(String(right?.title ?? ""), undefined, {
      sensitivity: "base"
    });
  });
}

let navStyleTrips: any[] = [];
let navDestinations: any[] = [];
let navTipoTransportes: any[] = [];
try {
  const tipoTransporteUrl = `${STRAPI_URL}/api/tipo-transportes?locale=${strapiLocale}&status=published` +
    `&fields[0]=nombre&fields[1]=slug&fields[2]=nroOrden&populate[image][fields][0]=url&populate[image][fields][1]=formats` +
    `&sort=nroOrden:asc`;
  const json = await fetchJsonCached(tipoTransporteUrl);
  navTipoTransportes = json.data ?? [];
} catch (e) {
  console.error('[Navbar] Error tipo-transportes:', e);
}
try {
  const styleUrl = `${STRAPI_URL}/api/style-trips?populate=*&locale=${strapiLocale}&status=published`;
  const destUrl = `${STRAPI_URL}/api/destino-detalles?locale=${strapiLocale}` +
    `&fields[0]=title` +
    `&fields[1]=slug` +
    `&populate[galleryThumbnail][fields][0]=url` +
    `&populate[galleryThumbnail][fields][1]=alternativeText` +
    `&populate[tours][fields][0]=title` +
    `&populate[tours][fields][1]=slug` +
    `&populate[tours][populate][heroSlideImages][fields][0]=url` +
    `&populate[tours][populate][heroSlideImages][fields][1]=alternativeText`;
  const [styleJson, destJson] = await Promise.all([
    fetchJsonCached(styleUrl),
    fetchJsonCached(destUrl)
  ]);
  navStyleTrips = styleJson.data ?? [];
  navDestinations = destJson.data ?? [];
} catch (e) {
  console.error('[Navbar] Fetch error:', e);
}
---

<style>
  /* Páginas sin hero: navbar sólido desde el primer render, sin esperar a JS */
  body[data-navbar-solid] #navbar {
    background-color: white;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
  }

  /* Links oscuros en páginas sin hero */
  body[data-navbar-solid] #navbar a:not(#lang-dropdown a),
  body[data-navbar-solid] #navbar button:not(#lang-dropdown button) {
    color: #111827 !important;
  }

  /* Botón de contacto oscuro en páginas sin hero */
  body[data-navbar-solid] #contact-btn {
    background-color: #f3f4f6 !important;
    border-color: #d1d5db !important;
    color: #111827 !important;
  }
  body[data-navbar-solid] #contact-btn:hover {
    background-color: #e5e7eb !important;
  }

  /* Cuando el menú móvil está abierto, navbar siempre blanco */
  #navbar.menu-open {
    background-color: white !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1) !important;
  }

  /* Hamburger oscuro en páginas sin hero (data-navbar-solid) o con navbar blanco */
  body[data-navbar-solid] #mobile-menu-btn,
  #navbar:not(.bg-transparent) #mobile-menu-btn {
    color: #111827 !important;
  }

  /* Hamburger blanco solo cuando navbar es transparente en páginas con hero */
  body:not([data-navbar-solid]) #navbar.bg-transparent #mobile-menu-btn {
    color: white !important;
  }

  /* Force black text in all dropdowns by default */
  #megamenu-dropdown,
  #styles-dropdown,
  #sustainability-dropdown {
    color: #000 !important;
  }

  /* Avoid overriding white text elements */
  #megamenu-dropdown *:not(#megamenu-dest-name):not(.style-item-grid h3),
  #styles-dropdown *:not(.style-item-grid h3),
  #sustainability-dropdown * {
    color: inherit !important;
  }

  /* Ensure specific elements remain dark/readable */
  #megamenu-dropdown a,
  #styles-dropdown a,
  #sustainability-dropdown a {
    color: #1f2937 !important;
  }

  #megamenu-dropdown h3,
  #sustainability-dropdown h3 {
    color: #111827 !important;
  }

  /* White text for style items inside images */
  #styles-dropdown .style-item-grid h3 {
    color: #ffffff !important;
  }

  #megamenu-dropdown p,
  #styles-dropdown p:not(#styles-menu-footer),
  #sustainability-dropdown p {
    color: #374151 !important;
  }

  /* White text for destination name in megamenu - HIGHEST PRIORITY */
  #megamenu-dropdown #megamenu-dest-name,
  p#megamenu-dest-name {
    color: #ffffff !important;
    font-weight: bold !important;
  }

  /* White text for styles menu footer - OVERRIDE ALL */
  #styles-menu-footer {
    color: #ffffff !important;
  }

  /* Transporte dropdown — texto negro por defecto */
  #transport-dropdown {
    color: #000 !important;
  }
  /* Texto blanco sobre las cards de imagen */
  #transport-dropdown .transport-item-grid h3 {
    color: #ffffff !important;
  }
</style>

<!-- Navbar -->
<nav id="navbar" class="fixed top-0 w-full bg-transparent transition-all duration-300 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={`/${currentLang}/`}>
          <img src="/landing page images/incasparadiselogo.webp" alt="Inca's Paradise Logo" class="h-20 w-auto" />
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-8 h-24">
        <!-- Destinations with Megamenu -->
        <div class="relative h-full flex items-center" id="megamenu-container">
          <a href={`/${currentLang}/destinos/`} class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.destinations}</a>
          
          <!-- Megamenu -->
          <div id="megamenu-dropdown" class="fixed left-0 right-0 top-24 pt-0 hidden z-50 w-full">
            <div class="bg-white shadow-2xl overflow-hidden" style="height: 50vh;">
              <!-- Megamenu Container -->
              <div class="flex h-full">
                <!-- Column 1: Destinations List with Vertical Slider -->
                <div class="w-1/3 bg-gray-50 border-r border-gray-200 flex flex-col relative">
                  <!-- Scroll Up Button -->
                  <button id="scroll-up" class="bg-white/90 hover:bg-white p-2 border-b border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                    </svg>
                  </button>
                  
                  <!-- Destinations scroll container -->
                  <div id="destinations-scroll" class="flex-1 overflow-y-auto overflow-x-hidden scroll-smooth">
                    {navDestinations.map((dest: any) => (
                      <a
                        href={`/${currentLang}/destinos/${dest.slug || toSlug(getDestTitle(dest))}`}
                        class="destination-item w-full px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-[#e0f7f5] hover:text-[#1AA093] transition border-b border-gray-100 whitespace-normal block"
                        title={getDestTitle(dest)}
                        data-dest={dest.slug}
                      >
                        {getDestTitle(dest)}
                      </a>
                    ))}
                  </div>
                  
                  <!-- Scroll Down Button -->
                  <button id="scroll-down" class="bg-white/90 hover:bg-white p-2 border-t border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                    </svg>
                  </button>
                </div>

                <!-- Column 2: Tours -->
                <div class="w-2/3 bg-white p-6 overflow-y-auto">
                  <div id="megamenu-tours" class="columns-2 gap-8 space-y-3">
                    {(() => {
                      const activeDest = navDestinations.length > 0 ? navDestinations[0] : null;
                      if (!activeDest) return null;

                      const subcategorias = sortSubcategoriasAlphabetically(normalizeSubcategorias(activeDest.subcategorias_tour));
                      const toursSueltos = sortToursAlphabetically(normalizeRelatedTours(activeDest.tours));

                      return (
                        <>
                          {subcategorias.map((subcategoria: any) => {
                            const attrs = subcategoria.attributes || subcategoria;
                            const tours = sortToursAlphabetically(normalizeRelatedTours(attrs.tours));
                            if (!attrs.nombre || tours.length === 0) return null;

                            return (
                              <div class="break-inside-avoid pb-3 border-b border-gray-100 last:border-0">
                                <p class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-gray-500">{attrs.nombre}</p>
                                <div class="space-y-2">
                                  {tours.map((tour: any) => {
                                    const tourAttrs = tour.attributes || tour;
                                    return (
                                      <a href={`/${currentLang}/tours/${tourAttrs.slug || toSlug(tourAttrs.title)}`} class="block font-semibold text-gray-800 text-sm hover:text-[#1AA093] transition">
                                        {tourAttrs.title}
                                      </a>
                                    );
                                  })}
                                </div>
                              </div>
                            );
                          })}

                          {toursSueltos.map((tour: any) => {
                            const attrs = tour.attributes || tour;
                            return (
                              <div class="break-inside-avoid pb-3 border-b border-gray-100 last:border-0">
                                <a href={`/${currentLang}/tours/${attrs.slug || toSlug(attrs.title)}`} class="font-semibold text-gray-800 text-sm hover:text-[#1AA093] transition">
                                  {attrs.title}
                                </a>
                              </div>
                            );
                          })}
                        </>
                      );
                    })()}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Trip Styles with Megamenu -->
        <div class="relative h-full flex items-center" id="styles-container">
          <a href="#" class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.tripStyles}</a>
          
          <!-- Styles Megamenu - Sidebar + Grid Layout -->
          <div id="styles-dropdown" class="fixed left-0 right-0 top-24 pt-0 hidden z-50 w-full">
            <div class="bg-white shadow-2xl overflow-hidden" style="height: 58vh;">
              <!-- Container for sidebar + grid -->
              <div class="flex h-full">
                <!-- Sidebar - 1/6 width -->
                <div class="w-1/6 bg-gray-50 border-r border-gray-200 flex flex-col">
                  <button class="styles-menu-btn w-full px-4 py-4 text-left text-sm font-medium text-[#1AA093] hover:bg-[#e0f7f5] transition border-b-2 border-[#1AA093]" data-menu="travelStyles">
                    {t.stylesMenu.travelStyles.name}
                  </button>
                  <button class="styles-menu-btn w-full px-4 py-4 text-left text-sm font-medium text-gray-700 hover:bg-[#e0f7f5] transition border-b-2 border-transparent" data-menu="smallTrips">
                    {t.stylesMenu.smallTrips.name}
                  </button>
                  <button class="styles-menu-btn w-full px-4 py-4 text-left text-sm font-medium text-gray-700 hover:bg-[#e0f7f5] transition border-b-2 border-transparent" data-menu="packages">
                    {t.stylesMenu.packages.name}
                  </button>

                  <!-- Menu Footer with Image and Description -->
                  <div class="mt-2 ml-auto mr-auto mb-2 bg-white relative w-full h-80 overflow-hidden">
                    <img id="styles-footer-image" src="" alt="Menu" class="w-full h-full object-cover" />
                    <div class="absolute inset-0 bg-black/10"></div>
                    <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-3">
                      <p id="styles-menu-footer" class="text-xs leading-tight" style="color: white !important;">
                        <!-- Will be populated by JavaScript -->
                      </p>
                    </div>
                  </div>
                </div>

                <!-- Content Area - 5/6 width -->
                <div class="w-5/6 bg-white overflow-hidden h-full">
                  <!-- Travel Styles Grid (default) -->
                  <div class="styles-menu-content h-full" id="content-travelStyles">
                    <div class="grid grid-cols-5 gap-2 h-full w-full px-2 py-2">
                      {navStyleTrips.map((item: any) => {
                        const navImg = Array.isArray(item.image) ? item.image[0] : item.image;
                        const imgUrl = navImg?.formats?.small?.url
                          ? `${STRAPI_PUBLIC_URL}${navImg.formats.small.url}`
                          : navImg?.formats?.medium?.url
                          ? `${STRAPI_PUBLIC_URL}${navImg.formats.medium.url}`
                          : navImg?.url
                          ? `${STRAPI_PUBLIC_URL}${navImg.url}`
                          : null;
                        return (
                          <a
                            href={`/${currentLang}/style-trips/${item.slug || toSlug(item.name)}`}
                            class="style-item-grid group relative overflow-hidden cursor-pointer transition-all duration-300 hover:z-20"
                          >
                            {imgUrl && (
                              <img src={imgUrl} alt={item.name} class="w-full h-full object-cover" />
                            )}
                            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300"></div>
                            <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-4 text-white border-b-2 border-transparent group-hover:border-white">
                              <h3 class="text-xs lg:text-sm font-bold transition-colors duration-300" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;">
                                {item.name}
                              </h3>
                            </div>
                          </a>
                        );
                      })}
                    </div>
                  </div>

                  <!-- Small Trips (empty) -->
                  <div class="styles-menu-content hidden" id="content-smallTrips">
                    <div class="h-full flex items-center justify-center text-gray-400">
                      <p class="text-lg">{t.stylesMenu.smallTrips.name} - {t.nav.comingSoon}</p>
                    </div>
                  </div>

                  <!-- Packages (empty) -->
                  <div class="styles-menu-content hidden" id="content-packages">
                    <div class="h-full flex items-center justify-center text-gray-400">
                      <p class="text-lg">{t.stylesMenu.packages.name} - {t.nav.comingSoon}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sustainability with Megamenu -->
        <div class="relative h-full flex items-center" id="sustainability-container">
          <a href="#" class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.sustainability}</a>
          
          <!-- Sustainability Megamenu -->
          <div id="sustainability-dropdown" class="fixed left-0 right-0 top-24 pt-0 hidden z-50 w-full">
            <div class="bg-white shadow-2xl overflow-hidden" style="height: 50vh;">
              <!-- Megamenu Container -->
              <div class="flex h-full">
                <!-- Column 1: Sustainability Items List with Vertical Slider -->
                <div class="w-1/3 bg-gray-50 border-r border-gray-200 flex flex-col relative">
                  <!-- Scroll Up Button -->
                  <button id="scroll-up-sustainability" class="bg-white/90 hover:bg-white p-2 border-b border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                    </svg>
                  </button>
                  
                  <!-- Sustainability scroll container -->
                  <div id="sustainability-scroll" class="flex-1 overflow-y-auto overflow-x-hidden scroll-smooth">
                    {Object.entries(t.sustainability).filter(([key]: [string, any]) => !['title', 'images'].includes(key)).map(([key, item]: [string, any]) => {
                      const itemObj = item as { name: string; description: string };
                      return (
                        <button
                          class="sustainability-item w-full px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-[#e0f7f5] hover:text-[#1AA093] transition border-b border-gray-100 whitespace-normal"
                          data-sustainability={key}
                          data-name={itemObj.name}
                          data-image={(t.sustainability as any).images[key]}
                          data-description={itemObj.description}
                        >
                          {itemObj.name}
                        </button>
                      );
                    })}
                  </div>
                  
                  <!-- Scroll Down Button -->
                  <button id="scroll-down-sustainability" class="bg-white/90 hover:bg-white p-2 border-t border-gray-200 transition">
                    <svg class="w-4 h-4 text-gray-700 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                    </svg>
                  </button>
                </div>

                <!-- Column 2: Description -->
                <div class="w-1/3 bg-white p-6 border-r border-gray-200 overflow-y-auto">
                  <div id="sustainability-description">
                    <p class="text-sm text-gray-600"></p>
                  </div>
                </div>

                <!-- Column 3: Image -->
                <div class="w-1/3 bg-gray-100 overflow-hidden relative">
                  <img
                    id="sustainability-image"
                    src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&h=400&fit=crop"
                    alt="Sustainability"
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute inset-0 bg-black/30"></div>
                  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black to-transparent p-4">
                    <p id="sustainability-name" class="text-white font-bold text-lg">SOSTENIBILIDAD</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Transporte con Megamenu -->
        <div class="relative h-full flex items-center" id="transport-container">
          <a href={`/${currentLang}/tipo-transporte/`} class="text-white text-sm lg:text-base hover:text-gray-300 transition py-8">{t.nav.transport}</a>

          <!-- Dropdown transporte — grid de 4 (igual a estilos de viaje) -->
          <div id="transport-dropdown" class="fixed left-0 right-0 top-24 pt-0 hidden z-50 w-full">
            <div class="bg-white shadow-2xl overflow-hidden" style="height: 50vh;">
              <div class="grid grid-cols-4 gap-0 h-full w-full">
                {navTipoTransportes.map((item: any) => {
                  const navImg = Array.isArray(item.image) ? item.image[0] : item.image;
                  const imgUrl = navImg?.formats?.medium?.url
                    ? `${STRAPI_PUBLIC_URL}${navImg.formats.medium.url}`
                    : navImg?.url
                    ? `${STRAPI_PUBLIC_URL}${navImg.url}`
                    : null;
                  return (
                    <a
                      href={item.slug ? `/${currentLang}/tipo-transporte/${item.slug}` : `/${currentLang}/tipo-transporte/`}
                      class="transport-item-grid group relative overflow-hidden cursor-pointer transition-all duration-300 hover:z-20"
                    >
                      {imgUrl ? (
                        <img src={imgUrl} alt={item.nombre} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                      ) : (
                        <div class="w-full h-full bg-stone-400" />
                      )}
                      <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300" />
                      <div class="absolute inset-0 flex flex-col justify-center items-center text-center p-4 text-white border-b-2 border-transparent group-hover:border-white transition-all duration-300">
                        <h3 class="text-sm lg:text-base font-medium" style="font-family: 'Playfair Display', serif; font-style: italic;">
                          {item.nombre}
                        </h3>
                      </div>
                    </a>
                  );
                })}
                {/* Placeholders si aún no hay 4 registros */}
                {Array.from({ length: Math.max(0, 4 - navTipoTransportes.length) }).map(() => (
                  <div class="relative overflow-hidden bg-stone-200">
                    <div class="absolute inset-0 flex items-center justify-center">
