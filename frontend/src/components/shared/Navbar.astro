<!-- Lógica del navbar en archivo separado -->
<script src="./navbar.js"></script>

<!-- Initialize dynamic languages -->
<script>
  const _w = window as any;

  function buildLanguageUrl(languageCode: string): string {
    const slugs = _w.__langSlugs as Record<string, string> | undefined;
    const basePath = _w.__slugBasePath as string | undefined;
    const onSlugPage = basePath && window.location.pathname.includes(basePath);
    if (slugs && onSlugPage && slugs[languageCode]) {
      return `/${languageCode}${basePath}${slugs[languageCode]}`;
    }

    const tourSlugs = _w.__tourSlugs as Record<string, string> | undefined;
    const tourMatch = window.location.pathname.match(/^\/[a-z]{2}\/tours\/[^/]+/);
    if (tourSlugs && tourMatch) {
      const slug = tourSlugs[languageCode];
      if (slug) return `/${languageCode}/tours/${slug}`;
    }

    const tipoTransporteSlugs = _w.__tipoTransporteSlugs as Record<string, string> | undefined;
    const tipoTransporteMatch = window.location.pathname.match(/^\/[a-z]{2}\/tipo-transporte\/[^/]+/);
    if (tipoTransporteSlugs && tipoTransporteMatch) {
      const slug = tipoTransporteSlugs[languageCode];
      if (slug) return `/${languageCode}/tipo-transporte/${slug}`;
    }

    const transporteSlugs = _w.__transporteSlugs as Record<string, string> | undefined;
    const transporteMatch = window.location.pathname.match(/^\/[a-z]{2}\/transporte\/[^/]+/);
    if (transporteSlugs && transporteMatch) {
      const slug = transporteSlugs[languageCode];
      if (slug) return `/${languageCode}/transporte/${slug}`;
    }

    const currentPath = window.location.pathname;
    const pathMatch = currentPath.match(/^\/[a-z]{2}(.*)/);
    const relativePath = pathMatch ? pathMatch[1] : '/';
    return `/${languageCode}${relativePath}`;
  }

  function initializeLanguages() {
    const languages = _w.__navbarLanguages;
    if (languages) {
      updateLanguageSwitchers(languages);
      if (_w.updateLanguageSwitcherDesktop) {
        _w.updateLanguageSwitcherDesktop(languages);
      }
    }
  }

  function updateLanguageSwitchers(languages: any) {
    // Detect current language from URL
    const pathMatch = window.location.pathname.match(/^\/([a-z]{2})\//);
    const currentLangCode = pathMatch ? pathMatch[1] : 'es';
    
    // Update ALL lang-switcher instances
    const langSwitchers = document.querySelectorAll('#lang-switcher');

    langSwitchers.forEach((switcher, switcherIndex) => {
      
      const button = switcher.querySelector('#lang-button');
      const dropdown = switcher.querySelector('#lang-dropdown');
      const langArrow = switcher.querySelector('#lang-arrow');
      
      if (!button || !dropdown) {
        return;
      }

      // Update button text
      const buttonSpan = button.querySelector('span');
      if (buttonSpan && languages[currentLangCode]) {
        buttonSpan.textContent = languages[currentLangCode];
      }

      // Clear dropdown completely
      dropdown.innerHTML = '';

      const flagMap: Record<string, string> = { es: 'es', en: 'us', pt: 'br', fr: 'fr', it: 'it' };

      // Add all language links with event listeners
      for (const [code, name] of Object.entries(languages)) {
        if (code === currentLangCode) {
          continue;
        }

        const flagCode = flagMap[code] || code;
        const link = document.createElement('a');
        link.href='#';
        link.className = 'relative flex items-center gap-3 px-4 py-3 transition text-white text-sm cursor-pointer whitespace-nowrap overflow-hidden';
        link.style.cssText = `background-image: url(https://flagcdn.com/w80/${flagCode}.png); background-size: cover; background-position: center;`;

        const overlay = document.createElement('div');
        overlay.className = 'absolute inset-0 bg-black/50';
        overlay.style.pointerEvents = 'none';
        link.appendChild(overlay);

        const span = document.createElement('span');
        span.className = 'relative z-10 font-semibold';
        span.textContent = name as string;
        link.appendChild(span);

        // Attach click handler IMMEDIATELY
        link.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          
          const url = buildLanguageUrl(code);
          
          dropdown.classList.add('hidden');
          langArrow?.classList.remove('rotate-180');
          
          window.location.href = url;
        });

        dropdown.appendChild(link);
      }
    });

  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeLanguages);
  } else {
    initializeLanguages();
  }

  // Fallback: Establecer idiomas por defecto
  if (!_w.__navbarLanguages) {
    _w.__navbarLanguages = {
      es: 'Spanish',
      en: 'English',
      pt: 'Portuguese',
      fr: 'French',
      it: 'Italian'
    };
    if (_w.updateLanguageSwitcherDesktop) {
      _w.updateLanguageSwitcherDesktop(_w.__navbarLanguages);
    }
  }
</script>
