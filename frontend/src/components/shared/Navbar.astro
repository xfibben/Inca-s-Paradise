<!-- Lógica del navbar en archivo separado -->
<script src="./navbar.js"></script>

<!-- Initialize dynamic languages -->
<script>
  console.log('Navbar: Language script loaded');

  function buildLanguageUrl(languageCode) {
    const currentPath = window.location.pathname;
    const pathMatch = currentPath.match(/^\/[a-z]{2}(.*)/);
    const relativePath = pathMatch ? pathMatch[1] : '/';
    return `/${languageCode}${relativePath}`;
  }

  async function initializeLanguages() {
    try {
      const backendUrl = (import.meta.env.PUBLIC_BACKEND_URL);
      console.log('Navbar: Fetching languages from', backendUrl);
      
      const response = await fetch(`${backendUrl}/api/locales`);
      const data = await response.json();
      
      if (data.success && Array.isArray(data.data)) {
        console.log('Navbar: Languages from backend:', data.data);
        
        const languages = {};
        data.data.forEach((locale) => {
          const shortCode = locale.code.split('-')[0];
          languages[shortCode] = locale.name;
        });
        
        console.log('Navbar: Mapped languages:', languages);
        window.__navbarLanguages = languages;
        updateLanguageSwitchers(languages);
        // Llamar a updateLanguageSwitcherDesktop si existe (para actualizar dropdown)
        if (window.updateLanguageSwitcherDesktop) {
          window.updateLanguageSwitcherDesktop(languages);
        }
      }
    } catch (error) {
      console.warn('Navbar: Failed to fetch languages:', error);
    }
  }

  function updateLanguageSwitchers(languages) {
    // Detect current language from URL
    const pathMatch = window.location.pathname.match(/^\/([a-z]{2})\//);
    const currentLangCode = pathMatch ? pathMatch[1] : 'es';
    
    console.log('Navbar: Current language:', currentLangCode);
    console.log('Navbar: Updating switchers with languages:', Object.keys(languages));

    // Update ALL lang-switcher instances
    const langSwitchers = document.querySelectorAll('#lang-switcher');
    console.log('Navbar: Found', langSwitchers.length, 'switchers');

    langSwitchers.forEach((switcher, switcherIndex) => {
      console.log(`Navbar: Updating switcher ${switcherIndex}`);
      
      const button = switcher.querySelector('#lang-button');
      const dropdown = switcher.querySelector('#lang-dropdown');
      const langArrow = switcher.querySelector('#lang-arrow');
      
      if (!button || !dropdown) {
        console.log(`Navbar: Switcher ${switcherIndex} missing button or dropdown`);
        return;
      }

      // Update button text
      const buttonSpan = button.querySelector('span');
      if (buttonSpan && languages[currentLangCode]) {
        buttonSpan.textContent = languages[currentLangCode];
      }

      // Clear dropdown completely
      dropdown.innerHTML = '';

      // Add all language links with event listeners
      for (const [code, name] of Object.entries(languages)) {
        if (code === currentLangCode) {
          console.log(`Navbar: Skipping current language ${code}`);
          continue;
        }

        const link = document.createElement('a');
        link.className = 'flex items-center space-x-3 px-4 py-3 hover:bg-white/10 transition text-white text-sm cursor-pointer';
        
        const span = document.createElement('span');
        span.textContent = name;
        link.appendChild(span);

        // Attach click handler IMMEDIATELY
        link.addEventListener('click', (e) => {
          console.log('Navbar: Language link clicked:', code);
          e.preventDefault();
          e.stopPropagation();
          
          const url = buildLanguageUrl(code);
          console.log('Navbar: Navigating to:', url);
          
          dropdown.classList.add('hidden');
          langArrow?.classList.remove('rotate-180');
          
          window.location.href = url;
        });

        dropdown.appendChild(link);
        console.log(`Navbar: Added link for ${code}: ${name}`);
      }
    });

    console.log('Navbar: Update complete');
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeLanguages);
  } else {
    initializeLanguages();
  }

  // Fallback: Establecer idiomas por defecto
  if (!window.__navbarLanguages) {
    window.__navbarLanguages = {
      es: 'Spanish',
      en: 'English',
      pt: 'Portuguese',
      fr: 'French',
      it: 'Italian'
    };
    if (window.updateLanguageSwitcherDesktop) {
      window.updateLanguageSwitcherDesktop(window.__navbarLanguages);
    }
  }
</script>
