---

interface Props {
  currentLang?: string;
  t?: any;
}

const { currentLang = 'es', t } = Astro.props;

const footerLabels = t?.footer ?? {
  terms: 'Términos y condiciones',
  offers: 'Ofertas',
  about: 'Nosotros',
  policies: 'Políticas',
  cancellations: 'Cancelaciones',
  faq: 'Preguntas frecuentes',
};

// Social media links — fill in the URLs here
const socialLinks = {
  facebook:  "https://www.facebook.com/IncasParadise",
  instagram: "https://www.instagram.com/incasparadise_/",
  tiktok:    "https://www.tiktok.com/@incasparadise_",
  x:         "https://twitter.com/IncasParadise",
  youtube:   "https://www.youtube.com/@incasparadise",
};
---

<footer class="bg-gradient-to-b from-slate-900 to-slate-800 py-12">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Column 1 — Contacost -->
      <div class="flex flex-col items-center gap-1 text-slate-300 text-center pt-10">
        <!-- Email -->
        <a href="mailto:booking@incasparadise.com" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75a2.25 2.25 0 0 0-2.25-2.25H4.5a2.25 2.25 0 0 0-2.25 2.25v10.5a2.25 2.25 0 0 0 2.25 2.25h15a2.25 2.25 0 0 0 2.25-2.25V6.75Zm-16.5 0 7.5 5.25 7.5-5.25" />
          </svg>
          <span class="text-sm">booking@incasparadise.com</span>
        </a>

        <!-- Phone -->
        <a href="tel:+51953556680" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
          </svg>
          <span class="text-sm">+51 953 556 680</span>
        </a>

        <!-- Address -->
        <a href="https://www.google.com.pe/maps/place/INCA'S+PARADISE+TRAVEL+AGENCY/@-15.8391353,-70.0285459,19z/data=!3m1!4b1!4m5!3m4!1s0x915d69ebfac73669:0x3388c6d135bc5d35!8m2!3d-15.8391353!4d-70.0279987?dcr=0" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <span class="text-sm">Jr. Grau 460 - Puno</span>
        </a>

        <!-- Social Media Links -->
        <div class="mt-4 flex items-center justify-center gap-4">
          <a href={socialLinks.facebook} target="_blank" rel="noopener noreferrer" class="opacity-70 hover:opacity-100 transition-opacity">
            <img src="/landing page images/footer/facebooklogo.svg" alt="Facebook" class="w-10 h-10 brightness-0 invert" loading="lazy" />
          </a>
          <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" class="opacity-70 hover:opacity-100 transition-opacity">
            <img src="/landing page images/footer/instagramlogo.svg" alt="Instagram" class="w-6 h-6 brightness-0 invert" loading="lazy" />
          </a>
          <a href={socialLinks.tiktok} target="_blank" rel="noopener noreferrer" class="opacity-70 hover:opacity-100 transition-opacity">
            <img src="/landing page images/footer/tiktoklogo.svg" alt="TikTok" class="w-6 h-6 brightness-0 invert" loading="lazy" />
          </a>
          <a href={socialLinks.x} target="_blank" rel="noopener noreferrer" class="opacity-70 hover:opacity-100 transition-opacity">
            <img src="/landing page images/footer/xlogo.svg" alt="X" class="w-12 h-12" loading="lazy" />
          </a>
          <a href={socialLinks.youtube} target="_blank" rel="noopener noreferrer" class="opacity-70 hover:opacity-100 transition-opacity">
            <img src="/landing page images/footer/youtubelogo.svg" alt="YouTube" class="w-6 h-6 brightness-0 invert" loading="lazy" />
          </a>
        </div>
      </div>
      <!-- Column 2 -->
      <div class="flex flex-col items-center justify-center">
        <button id="protegeme-btn" class="cursor-pointer hover:scale-105 transition-transform">
          <img src="/landing page images/footer/protegeme.png" alt="Protégeme" class="w-68 h-auto rounded-lg shadow-md" loading="lazy" />
        </button>
      </div>

      <!-- Modal afiche-protegeme -->
      <div id="protegeme-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70">
        <div class="relative max-w-xl w-full mx-4">
          <button id="protegeme-close" class="absolute -top-4 -right-4 w-9 h-9 rounded-full bg-white text-slate-900 flex items-center justify-center shadow-lg hover:bg-slate-200 transition-colors text-xl font-bold leading-none">
            &times;
          </button>
          <img src="/landing page images/footer/afiche-progeteme.jpg" alt="Afiche Protégeme" class="w-full h-auto rounded-lg shadow-2xl" loading="lazy" />
        </div>
      </div>

      <!-- Column 3 — Reclamaciones -->
      <div class="flex flex-col items-center justify-center">
        <a href={`/${currentLang}/claims`} class="hover:scale-105 transition-transform block">
          <img src="/landing page images/footer/reclamaciones.jpg" alt="Reclamaciones" class="w-52 h-auto rounded-lg shadow-md" loading="lazy" />
        </a>
      </div>

      <!-- Column 4 -->
      <div class="flex flex-col items-start gap-3 text-slate-300 text-left pl-25">
        <!-- Términos y condiciones -->
        <a href="#" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
          <span class="text-sm">{footerLabels.terms}</span>
        </a>

        <!-- Ofertas -->
        <a href="#" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
          </svg>
          <span class="text-sm">{footerLabels.offers}</span>
        </a>

        <!-- Nosotros -->
        <a href="#" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
          </svg>
          <span class="text-sm">{footerLabels.about}</span>
        </a>

        <!-- Políticas -->
        <a href="#" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <span class="text-sm">{footerLabels.policies}</span>
        </a>

        <!-- Cancelaciones -->
        <a href="#" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-sm">{footerLabels.cancellations}</span>
        </a>

        <!-- Preguntas frecuentes -->
        <a href="#" class="flex items-center gap-3 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
          </svg>
          <span class="text-sm">{footerLabels.faq}</span>
        </a>
      </div>

    </div>

    <!-- Bottom bar — Payment methods -->
    <div class="mt-10 pt-6 border-t border-slate-700 flex items-center justify-center gap-5 flex-wrap">
      <img src="/landing page images/footer/visa.png" alt="Visa" class="h-8 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" />
      <img src="/landing page images/footer/mastercard.png" alt="Mastercard" class="h-8 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" />
      <img src="/landing page images/footer/amex.png" alt="American Express" class="h-8 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" />
      <img src="/landing page images/footer/dinnersclub.png" alt="Diners Club" class="h-8 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity" />
    </div>
  </div>
</footer>

<script>
  const btn = document.getElementById('protegeme-btn');
  const modal = document.getElementById('protegeme-modal');
  const closeBtn = document.getElementById('protegeme-close');

  btn?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  });

  const closeModal = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  };

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
</script>
