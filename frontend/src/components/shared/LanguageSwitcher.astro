---
interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;

const languages = [
  { code: 'es', name: 'Español', flag: '🇪🇸' },
  { code: 'en', name: 'English', flag: '🇺🇸' },
  { code: 'pt', name: 'Português', flag: '🇧🇷' }
];

const currentLanguage = languages.find(lang => lang.code === currentLang);
const otherLanguages = languages.filter(lang => lang.code !== currentLang);
---

<div id="lang-switcher" class="relative">
  <!-- Language Button -->
  <button id="lang-button" class="flex items-center space-x-2 px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg transition text-white text-sm font-semibold border border-white/30">
    <span>{currentLanguage?.flag}</span>
    <span>{currentLanguage?.name}</span>
    <svg id="lang-arrow" class="w-4 h-4 transition transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </button>

  <!-- Dropdown Menu -->
  <div id="lang-dropdown" class="absolute hidden top-full right-0 mt-2 bg-black/80 backdrop-blur-md rounded-lg border border-white/30 overflow-hidden z-50">
    {otherLanguages.map((lang) => (
      <a
        href={`/${lang.code}/`}
        class="flex items-center space-x-3 px-4 py-3 hover:bg-white/10 transition text-white text-sm"
      >
        <span>{lang.flag}</span>
        <span>{lang.name}</span>
      </a>
    ))}
  </div>
</div>

<script>
  const langButton = document.getElementById('lang-button');
  const langDropdown = document.getElementById('lang-dropdown');
  const langArrow = document.getElementById('lang-arrow');
  const langSwitcher = document.getElementById('lang-switcher');

  // Toggle dropdown on button click
  langButton?.addEventListener('click', () => {
    langDropdown?.classList.toggle('hidden');
    langArrow?.classList.toggle('rotate-180');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!langSwitcher?.contains(e.target)) {
      langDropdown?.classList.add('hidden');
      langArrow?.classList.remove('rotate-180');
    }
  });

  // Close dropdown when clicking on a link
  const langLinks = langDropdown?.querySelectorAll('a');
  langLinks?.forEach(link => {
    link.addEventListener('click', () => {
      langDropdown?.classList.add('hidden');
      langArrow?.classList.remove('rotate-180');
    });
  });
</script>
