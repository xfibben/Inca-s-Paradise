---
interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;

const languages = [
  { code: 'es', name: 'Español',   flag: 'es' },
  { code: 'en', name: 'English',   flag: 'us' },
  { code: 'pt', name: 'Português', flag: 'br' },
  { code: 'fr', name: 'Français',  flag: 'fr' },
  { code: 'it', name: 'Italiano',  flag: 'it' },
];
---

<!-- Mobile: botones con bandera de fondo -->
<div class="flex md:hidden items-center gap-2 justify-center flex-wrap w-full">
  {languages.map((lang) => (
    <a
      href={`/${lang.code}/`}
      data-lang-code={lang.code}
      class={`lang-mobile-btn relative w-12 h-12 flex items-center justify-center rounded-full overflow-hidden transition border-2 ${
        lang.code === currentLang ? 'border-white scale-110' : 'border-transparent opacity-80 hover:opacity-100'
      }`}
      style={`background-image: url(https://flagcdn.com/w80/${lang.flag}.png); background-size: cover; background-position: center;`}
    >
      <div class="absolute inset-0 bg-black/20"></div>
      <span class="relative z-10 text-xs font-bold text-white tracking-wide">{lang.code.toUpperCase()}</span>
    </a>
  ))}
</div>

<!-- Desktop: Dropdown desplegable -->
<div id="lang-switcher" class="hidden md:flex relative">
  <button id="lang-button" class="flex items-center space-x-2 px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg transition text-white text-sm font-semibold border border-white/30">
    <span id="lang-name">Idioma</span>
    <svg id="lang-arrow" class="w-4 h-4 transition transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </button>

  <!-- Dropdown: cada item tiene bandera de fondo -->
  <div id="lang-dropdown" class="absolute hidden top-full right-0 mt-2 rounded-lg border border-white/30 overflow-hidden z-50 min-w-28">
  </div>
</div>

<script>
  console.log('LanguageSwitcher: Initialized');

  const FLAG_MAP: Record<string, string> = { es: 'pe', en: 'gb', pt: 'br', fr: 'fr', it: 'it' };

  function makeFlagItem(code: string, name: string, href: string): HTMLAnchorElement {
    const flagCode = FLAG_MAP[code] ?? code;
    const link = document.createElement('a');
    link.href = href;
    link.className = 'relative flex items-center gap-2 px-3 py-2 transition text-white text-sm whitespace-nowrap overflow-hidden';
    link.style.cssText = `background-image: url(https://flagcdn.com/w80/${flagCode}.png); background-size: cover; background-position: center;`;

    const overlay = document.createElement('div');
    overlay.className = 'absolute inset-0 bg-black/50 hover:bg-black/30 transition-colors';
    overlay.style.pointerEvents = 'none';

    const span = document.createElement('span');
    span.className = 'relative z-10 font-semibold';
    span.textContent = name;

    link.appendChild(overlay);
    link.appendChild(span);
    return link;
  }

  function setupDesktopDropdown() {
    const langSwitcher = document.getElementById('lang-switcher');
    if (!langSwitcher) return;

    const langButton = langSwitcher.querySelector('#lang-button') as HTMLButtonElement | null;
    const langDropdown = langSwitcher.querySelector('#lang-dropdown') as HTMLElement | null;
    const langArrow = langSwitcher.querySelector('#lang-arrow') as HTMLElement | null;

    if (!langButton || !langDropdown) return;

    langButton.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown.classList.toggle('hidden');
      langArrow?.classList.toggle('rotate-180');
    });

    document.addEventListener('click', (e) => {
      if (!langSwitcher.contains(e.target as Node)) {
        langDropdown.classList.add('hidden');
        langArrow?.classList.remove('rotate-180');
      }
    });

    langDropdown.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) {
        langDropdown.classList.add('hidden');
        langArrow?.classList.remove('rotate-180');
      }
    });
  }

  function fixMobileLangLinks() {
    document.querySelectorAll<HTMLAnchorElement>('a.lang-mobile-btn').forEach((el) => {
      const code = el.dataset.langCode;
      if (code) el.href = buildLangUrl(code);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { setupDesktopDropdown(); fixMobileLangLinks(); });
  } else {
    setupDesktopDropdown();
    fixMobileLangLinks();
  }

  function buildLangUrl(code: string): string {
    const langSlugs = (window as any).__langSlugs as Record<string, string> | undefined;
    const slugBasePath = (window as any).__slugBasePath as string | undefined;
    const onSlugPage = slugBasePath && window.location.pathname.includes(slugBasePath);
    if (langSlugs && onSlugPage && langSlugs[code]) {
      return `/${code}${slugBasePath}${langSlugs[code]}`;
    }

    const tourSlugs = (window as any).__tourSlugs as Record<string, string> | undefined;
    const tourMatch = window.location.pathname.match(/^\/[a-z]{2}\/tours\/[^/]+/);
    if (tourSlugs && tourMatch) {
      const slug = tourSlugs[code];
      if (slug) return `/${code}/tours/${slug}`;
    }

    const tipoTransporteSlugs = (window as any).__tipoTransporteSlugs as Record<string, string> | undefined;
    const tipoTransporteMatch = window.location.pathname.match(/^\/[a-z]{2}\/tipo-transporte\/[^/]+/);
    if (tipoTransporteSlugs && tipoTransporteMatch) {
      const slug = tipoTransporteSlugs[code];
      if (slug) return `/${code}/tipo-transporte/${slug}`;
    }

    const transporteSlugs = (window as any).__transporteSlugs as Record<string, string> | undefined;
    const transporteMatch = window.location.pathname.match(/^\/[a-z]{2}\/transporte\/[^/]+/);
    if (transporteSlugs && transporteMatch) {
      const slug = transporteSlugs[code];
      if (slug) return `/${code}/transporte/${slug}`;
    }

    const pathMatch = window.location.pathname.match(/^\/[a-z]{2}(.*)/);
    const rest = pathMatch ? pathMatch[1] : '/';
    return `/${code}${rest}`;
  }

</script>
