---
const measurementId = String(
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? ""
).trim();
const enabled = import.meta.env.PROD && Boolean(measurementId);
---

{
  enabled ? (
    <script is:inline define:vars={{ measurementId }}>
      (() => {
        if (typeof window === "undefined" || !measurementId) return;

        window.__ga4State = window.__ga4State || {};

        const ensureGtagScript = () => {
          const existing = document.querySelector(
            `script[data-ga4-id="${measurementId}"]`
          );
          if (existing) return;

          const script = document.createElement("script");
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
          script.setAttribute("data-ga4-id", measurementId);
          document.head.appendChild(script);
        };

        ensureGtagScript();

        window.dataLayer = window.dataLayer || [];
        window.gtag =
          window.gtag ||
          function gtag() {
            window.dataLayer.push(arguments);
          };

        if (!window.__ga4State.initialized) {
          window.gtag("js", new Date());
          window.gtag("config", measurementId, {
            send_page_view: false,
            anonymize_ip: true,
          });
          window.__ga4State.initialized = true;
        }

        if (!window.__ga4State.trackPageView) {
          window.__ga4State.trackPageView = () => {
            window.gtag("event", "page_view", {
              page_title: document.title,
              page_location: window.location.href,
              page_path: `${window.location.pathname}${window.location.search}`,
            });
          };
        }

        if (!window.trackEvent) {
          window.trackEvent = (eventName, params = {}) => {
            if (!eventName || typeof window.gtag !== "function") return;
            window.gtag("event", eventName, params);
          };
        }

        if (!window.__ga4State.pageLoadListenerAdded) {
          document.addEventListener("astro:page-load", () => {
            window.__ga4State.trackPageView();
          });
          window.__ga4State.pageLoadListenerAdded = true;
        }

        window.__ga4State.trackPageView();
      })();
    </script>
  ) : null
}
