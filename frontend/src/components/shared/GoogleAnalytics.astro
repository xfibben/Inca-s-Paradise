---
const gtmId = String(import.meta.env.PUBLIC_GTM_ID ?? "").trim();
const gaMeasurementId = String(
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? ""
).trim();
const isProd = Boolean(import.meta.env.PROD);
---

{
  isProd && gtmId ? (
    <script is:inline define:vars={{ gtmId }}>
      (() => {
        if (typeof window === "undefined" || !gtmId) return;

        window.__trackingState = window.__trackingState || {};
        window.dataLayer = window.dataLayer || [];

        const ensureGtmScript = () => {
          const existing = document.querySelector(`script[data-gtm-id="${gtmId}"]`);
          if (existing) return;

          window.dataLayer.push({
            "gtm.start": new Date().getTime(),
            event: "gtm.js",
          });

          const script = document.createElement("script");
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtm.js?id=${gtmId}`;
          script.setAttribute("data-gtm-id", gtmId);
          document.head.appendChild(script);
        };

        const trackPageView = () => {
          window.dataLayer.push({
            event: "astro_page_view",
            page_title: document.title,
            page_location: window.location.href,
            page_path: `${window.location.pathname}${window.location.search}`,
          });
        };

        ensureGtmScript();

        if (!window.__trackingState.pageLoadListenerAdded) {
          document.addEventListener("astro:page-load", trackPageView);
          window.__trackingState.pageLoadListenerAdded = true;
        }

        if (!window.trackEvent) {
          window.trackEvent = (eventName, params = {}) => {
            if (!eventName) return;
            window.dataLayer.push({
              event: eventName,
              ...params,
            });
          };
        }

        trackPageView();
      })();
    </script>
  ) : isProd && gaMeasurementId ? (
    <script is:inline define:vars={{ gaMeasurementId }}>
      (() => {
        if (typeof window === "undefined" || !gaMeasurementId) return;

        window.__trackingState = window.__trackingState || {};

        const ensureGtagScript = () => {
          const existing = document.querySelector(
            `script[data-ga4-id="${gaMeasurementId}"]`
          );
          if (existing) return;

          const script = document.createElement("script");
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`;
          script.setAttribute("data-ga4-id", gaMeasurementId);
          document.head.appendChild(script);
        };

        ensureGtagScript();

        window.dataLayer = window.dataLayer || [];
        window.gtag =
          window.gtag ||
          function gtag() {
            window.dataLayer.push(arguments);
          };

        if (!window.__trackingState.gaInitialized) {
          window.gtag("js", new Date());
          window.gtag("config", gaMeasurementId, {
            send_page_view: false,
            anonymize_ip: true,
          });
          window.__trackingState.gaInitialized = true;
        }

        const trackPageView = () => {
          window.gtag("event", "page_view", {
            page_title: document.title,
            page_location: window.location.href,
            page_path: `${window.location.pathname}${window.location.search}`,
          });
        };

        if (!window.__trackingState.pageLoadListenerAdded) {
          document.addEventListener("astro:page-load", trackPageView);
          window.__trackingState.pageLoadListenerAdded = true;
        }

        if (!window.trackEvent) {
          window.trackEvent = (eventName, params = {}) => {
            if (!eventName || typeof window.gtag !== "function") return;
            window.gtag("event", eventName, params);
          };
        }

        trackPageView();
      })();
    </script>
  ) : null
}
