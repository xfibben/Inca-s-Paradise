---
interface Props {
    image: string;
    alt: string;
    title: string;
    description: string;
    walkTime: string;
    difficulty: string;
    href?: string;
}

const {
    image,
    alt,
    title,
    description,
    walkTime,
    difficulty,
    href = "#",
} = Astro.props;
---

<a href={href} class="tour-card">
    <img src={image} alt={alt} class="tour-card__img" />

    <div class="tour-card__overlay">
        <h3 class="tour-card__title">{title}</h3>
        <p class="tour-card__description">{description}</p>

        <div class="tour-card__meta">
            <span class="tour-card__meta-item">
                <!-- Clock icon -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
                Tiempo de caminata: {walkTime}
            </span>
            <span class="tour-card__meta-item tour-card__meta-item--fire">
                <!-- Flame icon -->
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C8.5 7.5 5 9.5 5 14.5a7 7 0 0014 0C19 9.5 15.5 7.5 12 2z"/>
                    <path d="M12 8c-1.5 3-3 4-3 6.5a3 3 0 006 0C15 12 13.5 11 12 8z" fill="white" opacity="0.3"/>
                </svg>
                Dificultad: {difficulty}
            </span>
        </div>

        <button class="tour-card__btn">Ver más</button>
    </div>
</a>

<style>
    .tour-card {
        position: relative;
        display: block;
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        aspect-ratio: 3 / 4;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .tour-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 32px rgba(0, 0, 0, 0.28);
    }

    .tour-card__img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transition: transform 0.4s;
    }

    .tour-card:hover .tour-card__img {
        transform: scale(1.05);
    }

    /* Gradient overlay: transparent on top, dark from the middle down */
    .tour-card__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0)      0%,
            rgba(0, 0, 0, 0)      38%,
            rgba(0, 0, 0, 0.55)   55%,
            rgba(0, 0, 0, 0.82)   75%,
            rgba(0, 0, 0, 0.92)   100%
        );
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 24px 22px;
        gap: 8px;
    }

    .tour-card__title {
        font-size: 1.45rem;
        font-weight: 800;
        color: #ffffff;
        line-height: 1.2;
        margin: 0;
    }

    .tour-card__description {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.5;
        margin: 0;
    }

    .tour-card__meta {
        display: flex;
        flex-direction: column;
        gap: 5px;
        padding: 10px 0 4px;
        border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    .tour-card__meta-item {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.92);
        font-weight: 500;
    }

    .tour-card__meta-item svg {
        width: 17px;
        height: 17px;
        flex-shrink: 0;
        stroke: rgba(255, 255, 255, 0.85);
    }

    .tour-card__meta-item--fire svg {
        stroke: none;
        fill: #f97316;
        width: 16px;
        height: 16px;
    }

    .tour-card__btn {
        margin-top: 6px;
        width: 100%;
        padding: 12px 0;
        background-color: #1e4db7;
        color: #ffffff;
        font-size: 1rem;
        font-weight: 700;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background-color 0.25s;
    }

    .tour-card__btn:hover {
        background-color: #163a8a;
    }
</style>
