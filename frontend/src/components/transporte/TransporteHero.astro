---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<style>
  .transporte-hero {
    height: 40vh;
  }
  @media (min-width: 768px) {
    .transporte-hero {
      height: 50vh;
    }
  }
</style>

<!-- Hero Section - Transporte -->
<section class="transporte-hero relative w-full overflow-hidden">
  <!-- Imagen de fondo -->
  <img
    src="/landing page images/ubicacion-choquequirao-full.webp"
    alt="Transporte en Perú - Inca's Paradise"
    class="absolute inset-0 w-full h-full object-cover"
    width="2000"
    height="1333"
    fetchpriority="high"
    loading="eager"
    decoding="async"
  />

  <!-- Overlay oscuro -->
  <div class="absolute inset-0 bg-black/50"></div>

  <!-- Contenido centrado -->
  <div class="relative h-full flex flex-col justify-center items-center text-center px-4">
    <p class="text-white/70 uppercase tracking-[0.3em] text-xs md:text-sm mb-2 md:mb-4 font-light">
      {t.transporte?.eyebrow ?? "Movilidad & Aventura"}
    </p>
    <h1
      class="text-2xl md:text-4xl lg:text-5xl text-white leading-tight mb-2 md:mb-4 max-w-4xl"
      style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;"
    >
      {t.transporte?.heroTitle ?? "Viaja a tu manera"}
    </h1>
    <p class="text-sm md:text-lg text-white/85 max-w-2xl leading-relaxed">
      {t.transporte?.heroSubtitle ?? "Descubre las opciones de transporte para explorar los destinos más increíbles del Perú"}
    </p>
  </div>

  <!-- Indicador de scroll (solo desktop) -->
  <div class="hidden md:flex absolute bottom-6 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-white/60">
    <span class="text-xs uppercase tracking-widest">Explorar</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
