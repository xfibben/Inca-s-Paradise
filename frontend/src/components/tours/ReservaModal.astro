---
interface Props {
  tourTitle: string;
  tourSlug: string;
  precioUnitarioAdulto: number;
  precioUnitarioNino: number;
  descuento: number;
  duracionDias: number;
  lang: "es" | "en";
}

const {
  tourTitle,
  tourSlug,
  precioUnitarioAdulto,
  precioUnitarioNino,
  descuento,
  duracionDias,
  lang
} = Astro.props;

const translations = {
  es: {
    title: "Reservar Tour",
    name: "Nombre Completo",
    email: "Correo Electrónico",
    phone: "Teléfono",
    adults: "Cantidad de Adultos",
    children: "Cantidad de Niños",
    startDate: "Fecha de Inicio",
    endDate: "Fecha de Fin",
    pricePerAdult: "Precio por Adulto",
    pricePerChild: "Precio por Niño",
    subtotal: "Subtotal",
    discount: "Descuento",
    total: "Total",
    reserve: "Confirmar Reserva",
    close: "Cerrar",
    selectDate: "Seleccionar fecha",
    notes: "Notas especiales",
    terms: "Acepto los términos y condiciones"
  },
  en: {
    title: "Book Tour",
    name: "Full Name",
    email: "Email Address",
    phone: "Phone Number",
    adults: "Number of Adults",
    children: "Number of Children",
    startDate: "Start Date",
    endDate: "End Date",
    pricePerAdult: "Price per Adult",
    pricePerChild: "Price per Child",
    subtotal: "Subtotal",
    discount: "Discount",
    total: "Total",
    reserve: "Confirm Booking",
    close: "Close",
    selectDate: "Select date",
    notes: "Special notes",
    terms: "I accept the terms and conditions"
  }
};

const t = translations[lang] || translations.es;
const priceFinal = (precioUnitarioAdulto + precioUnitarioNino) / 2 - descuento;
---

<div
  id="reserva-modal"
  class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  data-reserva-modal
>
  <div class="w-full max-w-2xl bg-white rounded-lg shadow-2xl max-h-[90vh] overflow-y-auto">
    <!-- Header -->
    <div class="sticky top-0 flex items-center justify-between border-b border-gray-200 bg-[#f6f8fb] px-6 py-4">
      <h2 class="text-2xl font-bold text-gray-900">{t.title}</h2>
      <button
        type="button"
        class="text-gray-500 hover:text-gray-700 transition"
        data-close-modal
        aria-label={t.close}
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Body -->
    <form id="reserva-form" class="p-6 space-y-6" data-reserva-form>
      <!-- Tour Info -->
      <div class="bg-[#f5f0e9] p-4 rounded border border-[#e2e8f0]">
        <p class="text-sm text-gray-600">{tourTitle}</p>
        <p class="text-lg font-semibold text-gray-900">{duracionDias} {lang === "es" ? "días" : "days"}</p>
      </div>

      <!-- Personal Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.name} <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="nombre"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            placeholder="John Doe"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.email} <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            placeholder="john@example.com"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.phone} <span class="text-red-500">*</span>
          </label>
          <input
            type="tel"
            name="telefono"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            placeholder="+51 987 654 321"
          />
        </div>
      </div>

      <!-- Passengers -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.adults} <span class="text-red-500">*</span>
          </label>
          <input
            type="number"
            name="cantidad_adultos"
            required
            min="1"
            value="1"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            data-adultos
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.children}
          </label>
          <input
            type="number"
            name="cantidad_ninos"
            min="0"
            value="0"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            data-ninos
          />
        </div>
      </div>

      <!-- Dates -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.startDate} <span class="text-red-500">*</span>
          </label>
          <input
            type="date"
            name="fecha_inicio"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            data-start-date
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.endDate} <span class="text-red-500">*</span>
          </label>
          <input
            type="date"
            name="fecha_fin"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            data-end-date
          />
        </div>
      </div>

      <!-- Special Notes -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          {t.notes}
        </label>
        <textarea
          name="notas"
          rows="3"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent resize-none"
          placeholder="Alergias, preferencias especiales, etc."
        ></textarea>
      </div>

      <!-- Price Breakdown -->
      <div class="bg-[#f5f0e9] p-4 rounded border border-[#e2e8f0] space-y-3">
        <div class="flex justify-between text-sm">
          <span class="text-gray-700">{t.pricePerAdult}:</span>
          <span class="font-medium text-gray-900">
            ${precioUnitarioAdulto.toFixed(0)}
          </span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-gray-700">{t.pricePerChild}:</span>
          <span class="font-medium text-gray-900">
            ${precioUnitarioNino.toFixed(0)}
          </span>
        </div>
        <div class="border-t border-gray-300 pt-3 flex justify-between">
          <span class="text-gray-700 font-medium">{t.total}:</span>
          <span class="text-xl font-bold text-orange-600" data-total-price>
            $0
          </span>
        </div>
      </div>

      <!-- Terms -->
      <div class="flex items-start gap-3">
        <input
          type="checkbox"
          id="terms"
          name="terms"
          required
          class="mt-1 h-4 w-4 rounded border-gray-300 text-orange-600 focus:ring-orange-500"
        />
        <label for="terms" class="text-sm text-gray-700">
          {t.terms}
        </label>
      </div>

      <!-- Actions -->
      <div class="flex gap-3 pt-4 border-t border-gray-200">
        <button
          type="button"
          data-close-modal
          class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition"
        >
          {t.close}
        </button>
        <button
          type="submit"
          class="flex-1 px-4 py-2 bg-orange-600 rounded-lg text-white font-medium hover:bg-orange-700 transition"
          data-submit-btn
        >
          {t.reserve}
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Success Modal -->
<div
  id="success-modal"
  class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  data-success-modal
>
  <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-6 text-center">
    <!-- Success Icon -->
    <div class="mb-4 flex justify-center">
      <div class="h-16 w-16 rounded-full bg-green-100 flex items-center justify-center">
        <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>

    <!-- Title -->
    <h2 class="text-2xl font-bold text-gray-900 mb-2">
      {lang === "es" ? "¡Felicidades!" : "Congratulations!"}
    </h2>
    <p class="text-gray-600 mb-6">
      {lang === "es" 
        ? "Tu reserva ha sido creada exitosamente." 
        : "Your booking has been created successfully."}
    </p>

    <!-- Ticket Section -->
    <div class="bg-[#f5f0e9] p-4 rounded-lg border-2 border-orange-500 mb-6">
      <p class="text-sm text-gray-600 mb-2">
        {lang === "es" ? "Número de Ticket:" : "Ticket Number:"}
      </p>
      <p class="text-2xl font-bold text-orange-600 font-mono break-all" data-ticket-number>
        TICKET-00000000-00000
      </p>
    </div>

    <!-- Info Message -->
    <p class="text-sm text-gray-700 mb-6">
      {lang === "es" 
        ? "Guarda este número para hacer tu seguimiento. Nos contactaremos pronto con los detalles de tu reserva." 
        : "Save this number to track your booking. We will contact you soon with booking details."}
    </p>

    <!-- Action Buttons -->
    <div class="flex gap-3">
      <button
        type="button"
        onclick="document.querySelector('[data-success-modal]').classList.add('hidden')"
        class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition"
      >
        {lang === "es" ? "Cerrar" : "Close"}
      </button>
      <button
        type="button"
        data-copy-ticket
        class="flex-1 px-4 py-2 bg-orange-600 rounded-lg text-white font-medium hover:bg-orange-700 transition"
      >
        {lang === "es" ? "Copiar Ticket" : "Copy Ticket"}
      </button>
    </div>
  </div>
</div>

<script define:vars={{ precioUnitarioAdulto, precioUnitarioNino, descuento }}>
  (() => {
    const modal = document.querySelector("[data-reserva-modal]");
    const form = document.querySelector("[data-reserva-form]");
    const closeButtons = document.querySelectorAll("[data-close-modal]");
    const adultosInput = form?.querySelector("[data-adultos]");
    const ninosInput = form?.querySelector("[data-ninos]");
    const totalPriceEl = form?.querySelector("[data-total-price]");
    const startDateInput = form?.querySelector("[data-start-date]");
    const endDateInput = form?.querySelector("[data-end-date]");

    // Update total price when passenger counts change
    const updateTotalPrice = () => {
      const adults = parseInt(adultosInput?.value || 0);
      const children = parseInt(ninosInput?.value || 0);
      const total = (adults * precioUnitarioAdulto + children * precioUnitarioNino) - descuento;
      if (totalPriceEl) {
        totalPriceEl.textContent = `$${total.toFixed(0)}`;
      }
    };

    // Set minimum date to today
    const today = new Date().toISOString().split("T")[0];
    if (startDateInput) startDateInput.min = today;
    if (endDateInput) endDateInput.min = today;

    // Update end date minimum when start date changes
    if (startDateInput) {
      startDateInput.addEventListener("change", () => {
        if (startDateInput.value && endDateInput) {
          endDateInput.min = startDateInput.value;
          if (endDateInput.value < startDateInput.value) {
            endDateInput.value = startDateInput.value;
          }
        }
      });
    }

    // Listen to passenger count changes
    adultosInput?.addEventListener("change", updateTotalPrice);
    adultosInput?.addEventListener("input", updateTotalPrice);
    ninosInput?.addEventListener("change", updateTotalPrice);
    ninosInput?.addEventListener("input", updateTotalPrice);

    // Close modal handlers
    closeButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        modal?.classList.add("hidden");
      });
    });

    // Close on outside click
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) {
        modal.classList.add("hidden");
      }
    });

    // Form submission
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      // Validate dates
      if (new Date(data.fecha_fin) <= new Date(data.fecha_inicio)) {
        alert("La fecha de fin debe ser posterior a la fecha de inicio");
        return;
      }

      // Get tour ID from page data
      const tourData = window.__tourData;
      if (!tourData?.numericId) {
        alert("Error: Tour no encontrado. Recarga la página.");
        console.error("Tour data:", tourData);
        return;
      }

      // Build reserva payload for Strapi 5
      const reservaData = {
        data: {
          email: data.email,
          telefono: data.telefono,
          cantidad_adultos: parseInt(data.cantidad_adultos),
          cantidad_ninos: parseInt(data.cantidad_ninos),
          fecha_inicio: data.fecha_inicio,
          fecha_fin: data.fecha_fin,
          notas: data.notas || null,
          tour: tourData.numericId,  // Use numeric ID for relation
          descuento: 0,
          igv_porcentaje: 18,
          estado: "pendiente"
        }
      };

      console.log("Enviando reserva:", reservaData);

      try {
        const submitBtn = form.querySelector("[data-submit-btn]");
        submitBtn.disabled = true;
        submitBtn.textContent = "Enviando...";

        const response = await fetch("http://localhost:1337/api/reservas", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(reservaData)
        });

        const responseText = await response.text();
        console.log("Response status:", response.status);
        console.log("Response:", responseText);

        if (!response.ok) {
          let errorMsg = "Error al crear la reserva";
          try {
            const errorData = JSON.parse(responseText);
            errorMsg = errorData.error?.message || errorMsg;
            console.error("Error details:", errorData.error);
          } catch {}
          throw new Error(errorMsg);
        }

        const result = JSON.parse(responseText);
        const ticket = result?.data?.ticket || "TICKET-00000000-00000";
        
        // Show success modal with ticket
        const successModal = document.querySelector("[data-success-modal]");
        const ticketEl = successModal?.querySelector("[data-ticket-number]");
        if (ticketEl) ticketEl.textContent = ticket;
        successModal?.classList.remove("hidden");
        
        modal?.classList.add("hidden");
        form.reset();
        updateTotalPrice();

        submitBtn.disabled = false;
        submitBtn.textContent = "Confirmar Reserva";
      } catch (error) {
        console.error("Error completo:", error);
        alert("Error al crear la reserva:\n" + error.message);
        const submitBtn = form.querySelector("[data-submit-btn]");
        submitBtn.disabled = false;
        submitBtn.textContent = "Confirmar Reserva";
      }
    });

    // Expose open function globally
    window.openReservaModal = () => {
      modal?.classList.remove("hidden");
      updateTotalPrice();
    };

    // Success modal handlers
    const successModal = document.querySelector("[data-success-modal]");
    if (successModal) {
      // Copy button functionality
      const copyBtn = successModal.querySelector("[data-copy-ticket]");
      copyBtn?.addEventListener("click", () => {
        const ticketText = successModal.querySelector("[data-ticket-number]")?.textContent || "";
        navigator.clipboard.writeText(ticketText).then(() => {
          const originalText = copyBtn.textContent;
          copyBtn.textContent = "✓ Copiado";
          setTimeout(() => {
            copyBtn.textContent = originalText;
          }, 2000);
        }).catch(() => {
          alert("Error al copiar");
        });
      });
      
      // Close on outside click
      successModal.addEventListener("click", (e) => {
        if (e.target === successModal) {
          successModal.classList.add("hidden");
        }
      });
    }

    // Initial price calculation
    updateTotalPrice();
  })();
</script>
