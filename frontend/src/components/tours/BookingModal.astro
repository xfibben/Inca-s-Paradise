---

<!-- Modal de reserva -->
<div
  id="booking-modal"
  class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  data-booking-modal
>
  <div class="w-full max-w-2xl bg-white rounded-lg shadow-2xl max-h-[90vh] overflow-y-auto">

    <!-- Header -->
    <div class="sticky top-0 flex items-center justify-between border-b border-gray-200 bg-[#f6f8fb] px-6 py-4">
      <h2 class="text-2xl font-bold text-gray-900" data-modal-title>{t.title}</h2>
      <button type="button" class="text-gray-500 hover:text-gray-700 transition" data-close-modal aria-label={t.close}>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Formulario -->
    <form id="booking-form" class="p-6 space-y-6" data-booking-form>

      <!-- Info del tour -->
      <div class="bg-[#f5f0e9] p-4 rounded border border-[#e2e8f0]">
        <p class="text-sm font-semibold text-gray-800">{tourTitle}</p>
        <div class="mt-1 flex gap-4 text-sm text-gray-600">
          <span>{t.startDate}: <strong data-modal-fecha-inicio-label>{t.noDate}</strong></span>
          <span>{t.endDate}: <strong data-modal-fecha-fin-label>{t.noDate}</strong></span>
        </div>
        <!-- Inputs ocultos para las fechas y descuento USD (vienen del calendario/BookingCard) -->
        <input type="hidden" name="fecha_inicio" data-modal-fecha-inicio />
        <input type="hidden" name="fecha_fin" data-modal-fecha-fin />
        <input type="hidden" name="descuento_usd" data-modal-descuento-usd value="0" />
      </div>

      <!-- Datos personales -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.name} <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="nombre"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent"
            placeholder="John Doe"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.email} <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent"
            placeholder="john@example.com"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.phone} <span class="text-red-500">*</span>
          </label>
          <input
            type="tel"
            name="telefono"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent"
            placeholder="+51 987 654 321"
          />
        </div>
      </div>

      {scheduleOptions.length > 0 ? (
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.schedule} <span class="text-red-500">*</span>
          </label>
          <select
            name="turno"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent bg-white"
          >
            <option value="" selected disabled>{t.schedulePlaceholder}</option>
            {scheduleOptions.map((option) => (
              <option value={option}>{option}</option>
            ))}
          </select>
        </div>
      ) : null}

      <!-- Documento e identidad -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.docType} <span class="text-red-500">*</span>
          </label>
          <select
            name="tipo_documento"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent bg-white"
            data-doc-type
          >
            <option value="dni">{t.docDni}</option>
            <option value="rut">{t.docRut}</option>
            <option value="pasaporte">{t.docPassport}</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.docNumber} <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="numero_documento"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent"
            placeholder="12345678"
            data-doc-number
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            {t.nationality} <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="nacionalidad"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent"
            placeholder={t.nationalityPlaceholder}
          />
        </div>
      </div>

      <!-- Pasajeros (solo lectura, vienen del BookingCard) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{t.adults}</label>
          <div class="w-full px-4 py-2 border border-gray-200 rounded-lg bg-gray-50 text-gray-900 font-semibold" data-modal-adultos-label>1</div>
          <input type="hidden" name="cantidad_adultos" data-modal-adultos value="1" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{t.children}</label>
          <div class="w-full px-4 py-2 border border-gray-200 rounded-lg bg-gray-50 text-gray-900 font-semibold" data-modal-ninos-label>0</div>
          <input type="hidden" name="cantidad_ninos" data-modal-ninos value="0" />
        </div>
      </div>

      <!-- Notas -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{t.notes}</label>
        <textarea
          name="notas"
          rows="3"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#1AA093] focus:border-transparent resize-none"
          placeholder={t.notesPlaceholder}
        ></textarea>
      </div>

      <!-- Desglose de precios (dinámico, viene del BookingCard) -->
      <div class="bg-[#f5f0e9] p-4 rounded border border-[#e2e8f0] space-y-2">
        <div class="flex justify-between text-sm">
          <span class="text-gray-700">{t.pricePerAdult}:</span>
          <span class="font-medium text-gray-900" data-modal-precio-adulto>—</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-gray-700">{t.pricePerChild}:</span>
          <span class="font-medium text-gray-900" data-modal-precio-nino>—</span>
        </div>
        <div class="hidden justify-between text-sm text-green-700" id="modal-descuento-row">
          <span>{t.discount}:</span>
          <span class="font-medium" data-modal-descuento>—</span>
        </div>
        <div class="border-t border-gray-300 pt-2 flex justify-between">
          <span class="text-gray-700 font-medium">{t.total}:</span>
          <span class="text-xl font-bold text-[#1AA093]" data-modal-total>—</span>
        </div>
      </div>

      <!-- Información de pago -->
      <div class="bg-[#e0f7f5] rounded-lg p-4 my-4 border border-[#1AA093]">
        <p class="text-sm text-[#1AA093] font-medium">
          <span class="font-semibold">{t.infoReserva}</span>
          <span class="font-bold text-[#1AA093]">{t.infoReservaPercent}</span>
          <span>{t.infoReservaRest}</span>
        </p>
      </div>

      <!-- Términos -->
      <div class="flex items-start gap-3">
        <input
          type="checkbox"
          id="booking-terms"
          name="terms"
          required
          class="mt-1 h-4 w-4 rounded border-gray-300 text-[#1AA093] focus:ring-[#1AA093]"
        />
        <label for="booking-terms" class="text-sm text-gray-700">{t.terms}</label>
      </div>

      <!-- Acciones -->
      <div class="flex gap-3 pt-4 border-t border-gray-200">
        <button
          type="button"
          data-close-modal
          class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition"
        >
          {t.close}
        </button>
        <button
          type="submit"
          class="flex-1 bg-[#1AA093] rounded-lg text-white font-medium hover:bg-[#0e8a7e] transition py-3 px-4"
          data-submit-btn
        >
          <div class="flex flex-col items-center justify-center gap-1">
            <span class="text-sm font-medium">{t.reserve}</span>
            <div class="flex items-center gap-2 text-sm font-bold">
              <span class="badge-30pct px-2 py-0.5 bg-white/30 rounded text-xs">30%</span>
              <span data-btn-price>—</span>
            </div>
            <span class="text-xs text-white/70">(Total: <span data-btn-total>—</span>)</span>
          </div>
        </button>
      </div>
    </form>

    <!-- Paso 2: Método de pago -->
    <div id="payment-step" class="hidden p-6 space-y-5">

      <!-- Resumen del total -->
      <div class="bg-[#e0f7f5] rounded-lg p-4 flex items-center justify-between">
        <span class="text-sm text-gray-700 font-medium">Total a pagar</span>
        <span class="text-2xl font-bold text-[#1AA093]" data-pago-total>—</span>
      </div>

      <!-- Selector de porcentaje de pago (fijo 30%) -->
      <div class="hidden">
        <button type="button" class="pago-pct-btn selected" data-pct="30"></button>
      </div>
      <!-- Información del porcentaje fijo -->
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm text-amber-800">
        <span class="font-semibold">30%</span> de adelanto — el 70% restante se abona al momento del recojo.
      </div>
      <div class="grid grid-cols-3 gap-3">
        <button type="button" class="metodo-tab flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-gray-200 hover:border-[#1AA093] transition" data-metodo="paypal">
          <!-- Logo PayPal simplificado -->
          <svg class="h-7 w-auto" viewBox="0 0 80 24" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="18" font-family="Arial" font-weight="bold" font-size="14" fill="#003087">Pay</text>
            <text x="28" y="18" font-family="Arial" font-weight="bold" font-size="14" fill="#009cde">Pal</text>
          </svg>
          <span class="text-xs font-medium text-gray-700">PayPal</span>
        </button>

        <button type="button" class="metodo-tab flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-gray-200 hover:border-[#6c3bbd] transition" data-metodo="yape_qr">
          <div class="h-7 w-7 rounded-full bg-[#6c3bbd] flex items-center justify-center">
            <span class="text-white font-bold text-xs">Y</span>
          </div>
          <span class="text-xs font-medium text-gray-700">Yape QR</span>
        </button>

        <button type="button" class="metodo-tab flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-gray-200 hover:border-[#1AA093] transition" data-metodo="tarjeta">
          <svg class="h-7 w-7 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
          <span class="text-xs font-medium text-gray-700">{t.cardNumber.split(" ")[0]}</span>
        </button>
      </div>

      <!-- Panel PayPal -->
      <div id="panel-paypal" class="metodo-panel hidden space-y-3">
        <p class="text-sm text-gray-600">{t.pagoPaypalDesc}</p>
        <!-- El SDK de PayPal renderiza aquí su botón oficial -->
        <div id="paypal-button-container" class="min-h-12.5"></div>
        <p id="paypal-loading" class="text-center text-sm text-gray-400">Cargando PayPal...</p>
      </div>

      <!-- Panel Yape QR -->
      <div id="panel-yape_qr" class="metodo-panel hidden space-y-3">
        <p class="text-sm text-gray-600">{t.pagoYapeDesc}</p>
        <div class="flex flex-col items-center gap-3">
          <div id="qr-container" class="w-44 h-44 bg-gray-100 rounded-xl flex items-center justify-center border-2 border-dashed border-gray-300">
            <span class="text-xs text-gray-400 text-center px-4" id="qr-placeholder">El QR aparecerá aquí</span>
            <!-- TODO: Insertar imagen QR de IziPay Vpos aquí -->
          </div>
          <!-- TODO: Conectar con IziPay Vpos para generar QR y polling de estado -->
          <button type="button" id="btn-generar-qr" class="w-full py-3 rounded-lg bg-[#6c3bbd] text-white font-bold text-sm hover:bg-[#5b32a0] transition">
            {t.generarQr}
          </button>
        </div>
      </div>

      <!-- Panel Tarjeta -->
      <div id="panel-tarjeta" class="metodo-panel hidden space-y-3">
        <p class="text-sm text-gray-600">{t.pagoTarjetaDesc}</p>
        <!-- TODO: Reemplazar con IziPay Hosted Fields para tokenización segura -->
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">{t.cardNumber}</label>
            <input id="card-number" type="text" maxlength="19" placeholder="1234 5678 9012 3456"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#1AA093] focus:border-transparent" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">{t.cardExpiry}</label>
              <input id="card-expiry" type="text" maxlength="5" placeholder="MM/AA"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#1AA093] focus:border-transparent" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">{t.cardCvv}</label>
              <input id="card-cvv" type="text" maxlength="4" placeholder="123"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#1AA093] focus:border-transparent" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">{t.cardName}</label>
            <input id="card-name" type="text" placeholder="JOHN DOE"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#1AA093] focus:border-transparent" />
          </div>
          <button type="button" id="btn-pagar-tarjeta" class="w-full py-3 rounded-lg bg-[#1AA093] text-white font-bold text-sm hover:bg-[#0e8a7e] transition" data-pago-btn data-proveedor="izipay" data-metodo-pago="tarjeta">
            {t.pagarBtn}
          </button>
        </div>
      </div>

      <!-- Error de pago -->
      <div id="pago-error" class="hidden p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

      <!-- Botón volver -->
      <div class="pt-2 border-t border-gray-200">
        <button type="button" id="btn-volver-reserva" class="w-full py-2 border border-gray-300 rounded-lg text-gray-700 text-sm font-medium hover:bg-gray-50 transition flex items-center justify-center gap-2">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t.volver}
        </button>
      </div>
    </div>

  </div>
</div>

<!-- Modal de éxito -->
<div
  id="success-modal"
  class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
  data-success-modal
>
  <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-6 text-center">
    <div class="mb-4 flex justify-center">
      <div class="h-16 w-16 rounded-full bg-[#e0f7f5] flex items-center justify-center">
        <svg class="h-8 w-8 text-[#1AA093]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>
    <h2 class="text-2xl font-bold text-gray-900 mb-2">{t.successTitle}</h2>
    <p class="text-gray-600 mb-6">{t.successMsg}</p>
    <div class="bg-[#f5f0e9] p-4 rounded-lg border-2 border-[#1AA093] mb-6">
      <p class="text-sm text-gray-600 mb-2">{t.ticketLabel}</p>
      <p class="text-2xl font-bold text-[#1AA093] font-mono break-all" data-ticket-number>
        TICKET-00000000-00000
      </p>
    </div>
    <p class="text-sm text-gray-700 mb-6">{t.ticketInfo}</p>
    <div class="flex flex-col gap-3">
      <button
        type="button"
        data-download-voucher
        class="w-full px-4 py-2 bg-[#1AA093] rounded-lg text-white font-medium hover:bg-[#0e8a7e] transition flex items-center justify-center gap-2"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
        {t.downloadVoucher}
      </button>
      <div class="flex gap-3">
        <button
          type="button"
          data-close-success
          class="flex-1 px-4 py-2 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition"
        >
          {t.close}
        </button>
        <button
          type="button"
          data-copy-ticket
          class="flex-1 px-4 py-2 border border-[#1AA093] rounded-lg text-[#1AA093] font-medium hover:bg-[#e0f7f5] transition"
        >
          {t.copyTicket}
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ strapiUrl: import.meta.env.PUBLIC_STRAPI_URL || 'http://localhost:1337', odooUrl: import.meta.env.PUBLIC_ODOO_URL || 'http://localhost:8069', pagoTituloText: t.pagoTitulo, bookingTituloText: t.title, paypalClientId: import.meta.env.PUBLIC_PAYPAL_CLIENT_ID || '', tourTitleVar: tourTitle, tourSlugVar: tourSlug, langVar: lang }}>
  window.__strapiUrl = strapiUrl;
  window.__odooUrl = odooUrl;
  window.__pagoTituloText = pagoTituloText;
  window.__bookingTituloText = bookingTituloText;
  window.__paypalClientId = paypalClientId;
  window.__tourTitle = tourTitleVar;
  window.__tourSlug = tourSlugVar;
  window.__lang = langVar;
</script>

<script>
  interface BookingData {
    adultos?: number;
    ninos?: number;
    precioAdultoUsd?: number;
    precioNinoUsd?: number;
    precioAdultoLabel?: string;
    precioNinoLabel?: string;
    tasaCambio?: number;
    simboloMoneda?: string;
    decimalesMoneda?: number;
    descuento?: number;
    discountMode?: "amount" | "percent";
    fechaInicio?: string | null;
    fechaFin?: string | null;
  }

  // Datos de la reserva pendiente en memoria (sin redirect)
  interface PendingBooking {
    nombre: string; email: string; telefono: string;
    cantidad_adultos: number; cantidad_ninos: number;
    fecha_inicio: string; fecha_fin: string;
    notas: string | null; tipo_documento: string;
    numero_documento: string; nacionalidad: string; turno: string | null;
    vehiculo_seleccionado?: string | null;
    tourDocumentId: string | null; tourNumericId: number | null;
    transporteDocumentId: string | null; transporteNumericId: number | null;
    descuento_usd: number; monto_total: number; moneda: string;
    simbolo_moneda: string; decimales_moneda: number;
    porcentaje_pago: number; // Porcentaje a pagar: 30, 50 o 100
    monto_original: number; // Monto total sin aplicar porcentaje
    precio_adulto_web: number; // 30% del precio unitario adulto en moneda elegida
    precio_nino_web: number;   // 30% del precio unitario niño en moneda elegida
    tourNombre: string;
  }

  declare global {
    interface Window {
      __tourData?: { numericId: number | null; documentId: string | null };
      __transporteData?: { numericId: number | null; documentId: string | null };
      __strapiUrl?: string;
      __odooUrl?: string;
      __pendingBooking?: PendingBooking;
      __lastCompletedBooking?: PendingBooking; // copia persistente para el comprobante PDF
      __lastCompletedBookingVoucherUrl?: string;
      __tourTitle?: string;
      __tourSlug?: string;
      __lang?: string;
      __selectedVehicleName?: string;
      __pagoTituloText?: string;
      __bookingTituloText?: string;
      __paypalClientId?: string;
      trackEvent?: (eventName: string, params?: Record<string, unknown>) => void;
      dataLayer?: Array<Record<string, unknown>>;
      openBookingModal?: (data?: BookingData) => void;
    }
  }

  (() => {
    const modal = document.querySelector("[data-booking-modal]");
    const form = document.querySelector("[data-booking-form]") as HTMLFormElement | null;
    const paymentStep = document.getElementById("payment-step");
    const modalTitle = document.querySelector("[data-modal-title]");
    const closeButtons = document.querySelectorAll("[data-close-modal]");

    const emitBookingTicketCreated = (
      ticket: string,
      provider: string,
      method: string,
      booking?: PendingBooking
    ) => {
      const payload = {
        ticket_id: ticket,
        tour_slug: window.__tourSlug ?? "",
        tour_title: window.__tourTitle ?? booking?.tourNombre ?? "",
        lang: window.__lang ?? "es",
        payment_provider: provider,
        payment_method: method,
        currency: booking?.moneda ?? "USD",
        value: Number(booking?.monto_total ?? 0),
        adults: Number(booking?.cantidad_adultos ?? 0),
        children: Number(booking?.cantidad_ninos ?? 0),
        schedule: booking?.turno ?? "",
      };

      if (typeof window.trackEvent === "function") {
        window.trackEvent("booking_ticket_created", payload);
        return;
      }

      if (Array.isArray(window.dataLayer)) {
        window.dataLayer.push({
          event: "booking_ticket_created",
          ...payload,
        });
      }
    };

    // ── Cierre del modal ──
    const cerrarModal = () => {
      modal?.classList.add("hidden");
      // Vuelve al paso 1 para la próxima apertura
      form?.classList.remove("hidden");
      paymentStep?.classList.add("hidden");
    };
    modal?.addEventListener("click", (e) => { if (e.target === modal) cerrarModal(); });
    closeButtons.forEach((btn) => btn.addEventListener("click", cerrarModal));

    // ── Paso 1: submit del formulario → ir a pago ──
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      const raw = Object.fromEntries(new FormData(form));
      const str = (v: FormDataEntryValue) => (typeof v === "string" ? v : "");

      const tourData = window.__tourData;
      const transporteData = window.__transporteData;
      if (!tourData?.documentId && !tourData?.numericId && !transporteData?.documentId && !transporteData?.numericId) {
        alert("Error: Servicio no encontrado. Recarga la página.");
        return;
      }

      const monedaMap: Record<string, string> = { "S/": "PEN", "$": "USD", "€": "EUR" };
      const pricing = (window as any).__currentPricing ?? {};

      // Guardar datos en memoria (sin redirect ni sessionStorage)
      window.__pendingBooking = {
        nombre: str(raw.nombre),
        email: str(raw.email),
        telefono: str(raw.telefono),
        cantidad_adultos: parseInt(str(raw.cantidad_adultos)) || 1,
        cantidad_ninos: parseInt(str(raw.cantidad_ninos)) || 0,
        fecha_inicio: str(raw.fecha_inicio),
        fecha_fin: str(raw.fecha_fin),
        notas: str(raw.notas) || null,
        tipo_documento: str(raw.tipo_documento),
        numero_documento: str(raw.numero_documento),
        nacionalidad: str(raw.nacionalidad),
        turno: (str(raw.turno) || null),
        vehiculo_seleccionado: window.__selectedVehicleName ?? null,
        tourDocumentId: tourData?.documentId ?? null,
        tourNumericId: tourData?.numericId ?? null,
        transporteDocumentId: transporteData?.documentId ?? null,
        transporteNumericId: transporteData?.numericId ?? null,
        descuento_usd: parseFloat(str(raw.descuento_usd)) || 0,
        monto_total: (pricing.totalConvertido ?? 0) * 0.3,
        moneda: monedaMap[pricing.simboloMoneda ?? "$"] ?? "USD",
        simbolo_moneda: pricing.simboloMoneda ?? "$",
        decimales_moneda: pricing.decimalesMoneda ?? 2,
        porcentaje_pago: 30,
        monto_original: pricing.totalConvertido ?? 0,
        // precio_adulto_web y precio_nino_web = precio unitario × 30% × cantidad
        precio_adulto_web: parseFloat(((pricing.precioAdultoConvertido ?? 0) * 0.3 * (parseInt(str(raw.cantidad_adultos)) || 1)).toFixed(pricing.decimalesMoneda ?? 2)),
        precio_nino_web:   parseFloat(((pricing.precioNinoConvertido   ?? 0) * 0.3 * (parseInt(str(raw.cantidad_ninos))   || 0)).toFixed(pricing.decimalesMoneda ?? 2)),
        tourNombre: window.__tourTitle ?? "",
      };

      // Mostrar total en el panel de pago y actualizar botón
      // Ejecutar con un pequeño delay para asegurar que los elementos existan en el DOM
      setTimeout(() => {
        actualizarMontoPago();
      }, 0);

      // Transición al paso 2
      form.classList.add("hidden");
      paymentStep?.classList.remove("hidden");
      if (modalTitle) modalTitle.textContent = (window as any).__pagoTituloText ?? "Método de pago";
    });

    // ── Volver al paso 1 ──
    document.getElementById("btn-volver-reserva")?.addEventListener("click", () => {
      paymentStep?.classList.add("hidden");
      form?.classList.remove("hidden");
      if (modalTitle) modalTitle.textContent = (window as any).__bookingTituloText ?? "Reservar Tour";
      // Limpiar selección de método
      document.querySelectorAll(".metodo-tab").forEach((b) => b.classList.remove("border-[#1AA093]", "border-[#6c3bbd]", "bg-[#e0f7f5]"));
      document.querySelectorAll(".metodo-panel").forEach((p) => p.classList.add("hidden"));
      // Reiniciar porcentaje al 30%
      if (window.__pendingBooking) {
        window.__pendingBooking.porcentaje_pago = 30;
        actualizarMontoPago();
      }
    });

    // ── Tabs de método de pago ──
    document.querySelectorAll<HTMLButtonElement>(".metodo-tab").forEach((btn) => {
      btn.addEventListener("click", () => {
        const metodo = btn.dataset.metodo!;
        // Resaltar tab activo
        document.querySelectorAll(".metodo-tab").forEach((b) => b.classList.remove("border-[#1AA093]", "border-[#6c3bbd]", "bg-[#e0f7f5]", "bg-[#f3eeff]"));
        const esYape = metodo === "yape_qr";
        btn.classList.add(esYape ? "border-[#6c3bbd]" : "border-[#1AA093]", esYape ? "bg-[#f3eeff]" : "bg-[#e0f7f5]");
        // Mostrar panel
        document.querySelectorAll(".metodo-panel").forEach((p) => p.classList.add("hidden"));
        document.getElementById(`panel-${metodo}`)?.classList.remove("hidden");

        // Cargar el SDK de PayPal al seleccionar ese tab
        if (metodo === "paypal") renderizarBotonesPayPal();
      });
    });

    // ── Selector de porcentaje de pago ──
    function actualizarMontoPago() {
      const b = window.__pendingBooking;
      if (!b) {
          return;
      }

      // Calcular monto según porcentaje (fijo 30%)
      const montoCalculado = (b.monto_original * b.porcentaje_pago) / 100;
      b.monto_total = parseFloat(montoCalculado.toFixed(b.decimales_moneda));

      // Actualizar display en panel de pago
      const pagoTotalEl = document.querySelector("[data-pago-total]");
      if (pagoTotalEl) {
        pagoTotalEl.textContent = `${b.simbolo_moneda}${b.monto_total.toFixed(b.decimales_moneda)}`;
      }

      // Actualizar botón de reserva
      const btnPriceEl = document.querySelector("[data-btn-price]");
      const btnTotalEl = document.querySelector("[data-btn-total]");

      if (btnPriceEl) {
        btnPriceEl.textContent = `${b.simbolo_moneda}${b.monto_total.toFixed(b.decimales_moneda)}`;
      }
      if (btnTotalEl) {
        btnTotalEl.textContent = `${b.simbolo_moneda}${b.monto_original.toFixed(b.decimales_moneda)}`;
      }
    }

    document.querySelectorAll<HTMLButtonElement>(".pago-pct-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const pct = parseInt(btn.dataset.pct ?? "100");
        
        // Actualizar selección visual
        document.querySelectorAll(".pago-pct-btn").forEach((b) => {
          b.classList.remove("border-[#1AA093]", "bg-[#e0f7f5]", "selected");
        });
        btn.classList.add("border-[#1AA093]", "bg-[#e0f7f5]", "selected");

        // Guardar porcentaje en memoria
        if (window.__pendingBooking) {
          window.__pendingBooking.porcentaje_pago = pct;
          actualizarMontoPago();
        }
      });
    });

    // ── Función que crea la reserva en Strapi ──
    async function crearReserva(metodoPago: string, proveedorPago: string): Promise<{ ticket: string; voucherUrl?: string }> {
      const b = window.__pendingBooking;
      if (!b) throw new Error("Sin datos de reserva");

      const odooUrl = window.__odooUrl ?? "http://localhost:8069";
      const toDatetime = (val: string) => val ? `${val}T00:00:00.000Z` : null;

      const res = await fetch(`${odooUrl}/incas/api/reservas`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          reservaData: {
            nombre: b.nombre, email: b.email, telefono: b.telefono,
            cantidad_adultos: b.cantidad_adultos, cantidad_ninos: b.cantidad_ninos,
            fecha_inicio: toDatetime(b.fecha_inicio), fecha_fin: toDatetime(b.fecha_fin),
            notas: b.notas || null,
            tipo_documento: b.tipo_documento, numero_documento: b.numero_documento,
            nacionalidad: b.nacionalidad,
            vehiculo_seleccionado: b.vehiculo_seleccionado ?? null,
            turno: b.turno,
            idioma: window.__lang ?? "es",
            tourDocumentId: b.tourDocumentId,
            tourNumericId: b.tourNumericId,
            transporteDocumentId: b.transporteDocumentId,
            transporteNumericId: b.transporteNumericId,
            precio_tour: b.monto_original,
            precio_adulto_web: b.precio_adulto_web,
            precio_nino_web: b.precio_nino_web,
            descuento: b.descuento_usd,
            monto_total: b.monto_total,
            monto_original: b.monto_original,
            moneda: b.moneda,
          },
          pagoData: {
            proveedor: proveedorPago,
            metodo: metodoPago,
            moneda: b.moneda,
            monto: b.monto_total,
            estado: "pagado",
          }
        }),
      });

      const txt = await res.text();
      if (!res.ok) {
        let msg = "Error al crear la reserva";
        try { msg = JSON.parse(txt).error?.message || msg; } catch {}
        throw new Error(msg);
      }

      const json = JSON.parse(txt);
      return {
        ticket: json?.ticket ?? "TICKET-00000000-00000",
        voucherUrl: json?.voucher_url,
      };
    }

    // ── Manejador genérico de botones de pago ──
    async function procesarPago(btn: HTMLButtonElement) {
      const metodoPago = btn.dataset.metodoPago ?? "tarjeta";
      const proveedor = btn.dataset.proveedor ?? "izipay";
      btn.disabled = true;
      const orig = btn.textContent ?? "";
      btn.textContent = "Procesando...";
      const errorEl = document.getElementById("pago-error");
      if (errorEl) errorEl.classList.add("hidden");
      try {
        const resultado = await crearReserva(metodoPago, proveedor);
        const ticket = resultado.ticket;
        const completedBooking = window.__pendingBooking
          ? { ...window.__pendingBooking }
          : undefined;
        // Mostrar ticket en el modal de éxito
        const successModal = document.querySelector("[data-success-modal]");
        const ticketEl = successModal?.querySelector("[data-ticket-number]");
        if (ticketEl) ticketEl.textContent = ticket;
        paymentStep?.classList.add("hidden");
        modal?.classList.add("hidden");
        successModal?.classList.remove("hidden");
        form?.reset();
        // Guardar copia antes de borrar para el comprobante PDF
        if (completedBooking) window.__lastCompletedBooking = completedBooking;
        window.__lastCompletedBookingVoucherUrl = resultado.voucherUrl;
        emitBookingTicketCreated(ticket, proveedor, metodoPago, completedBooking);
        window.__pendingBooking = undefined;
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = err instanceof Error ? err.message : String(err);
          errorEl.classList.remove("hidden");
        }
      } finally {
        btn.disabled = false;
        btn.textContent = orig;
      }
    }

    // ── PayPal JS SDK ──
    let paypalSDKCargado = false;
    let paypalBotonesRendered = false;

    async function cargarPaypalSDK(): Promise<void> {
      if (paypalSDKCargado) return;
      const clientId = window.__paypalClientId;
      if (!clientId) throw new Error("PUBLIC_PAYPAL_CLIENT_ID no configurado en .env");

      return new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = `https://www.paypal.com/sdk/js?client-id=${clientId}&currency=USD`;
        script.onload = () => { paypalSDKCargado = true; resolve(); };
        script.onerror = () => reject(new Error("No se pudo cargar el SDK de PayPal"));
        document.head.appendChild(script);
      });
    }

    async function renderizarBotonesPayPal() {
      if (paypalBotonesRendered) return;
      const loading = document.getElementById("paypal-loading");

      try {
        await cargarPaypalSDK();
        if (loading) loading.classList.add("hidden");

        const errorEl = document.getElementById("pago-error");

        (window as any).paypal.Buttons({
          // Paso 1: crear la orden en el backend
          createOrder: async () => {
            const b = window.__pendingBooking;
            if (!b) throw new Error("Sin datos de reserva");

            // PayPal solo acepta USD — convertir desde la moneda seleccionada usando tasaCambio
            const tasaCambio = (window as any).__currentPricing?.tasaCambio ?? 1;
            const monedaPaypal = "USD";
            const montoPaypal = parseFloat((b.monto_total / tasaCambio).toFixed(2));

            const payload = { proveedor: "paypal", monto: montoPaypal, moneda: monedaPaypal };
            const odooUrl = window.__odooUrl ?? "http://localhost:8069";

            // Guard: evitar llamar al backend con monto inválido
            if (!montoPaypal || montoPaypal <= 0) {
              throw new Error("El monto de pago es inválido. Recarga la página e intenta nuevamente.");
            }

            console.log("[PayPal] Enviando payload:", payload);
            console.log("[PayPal] URL:", odooUrl);

            const res = await fetch(`${odooUrl}/incas/api/pagos/iniciar`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });

            if (!res.ok) {
              const txt = await res.text();
              console.error("[PayPal] Error response:", txt);
              throw new Error(JSON.parse(txt)?.error?.message ?? "Error al iniciar pago");
            }

            const { orderID } = await res.json();
            return orderID;
          },

          // Paso 2: usuario aprobó — capturar y crear la reserva
          onApprove: async (data: { orderID: string }) => {
            const b = window.__pendingBooking;
            if (!b) throw new Error("Sin datos de reserva");
            if (errorEl) errorEl.classList.add("hidden");

            const res = await fetch(`${window.__odooUrl}/incas/api/pagos/confirmar`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                proveedor: "paypal",
                token: data.orderID,
                reservaData: {
                  nombre: b.nombre,
                  email: b.email,
                  telefono: b.telefono,
                  cantidad_adultos: b.cantidad_adultos,
                  cantidad_ninos: b.cantidad_ninos,
                  fecha_inicio: b.fecha_inicio ? `${b.fecha_inicio}T00:00:00.000Z` : null,
                  fecha_fin: b.fecha_fin ? `${b.fecha_fin}T00:00:00.000Z` : null,
                  notas: b.notas,
                  tipo_documento: b.tipo_documento,
                  numero_documento: b.numero_documento,
                  nacionalidad: b.nacionalidad,
                  vehiculo_seleccionado: b.vehiculo_seleccionado ?? null,
                  turno: b.turno,
                  idioma: window.__lang ?? "es",
                  tourDocumentId: b.tourDocumentId,
                  tourNumericId: b.tourNumericId,
                  transporteDocumentId: b.transporteDocumentId,
                  transporteNumericId: b.transporteNumericId,
                  monto_total: b.monto_total,
                  monto_original: b.monto_original,
                  precio_tour:       b.monto_original,
                  precio_adulto_web: b.precio_adulto_web,
                  precio_nino_web:   b.precio_nino_web,
                  descuento: b.descuento_usd,
                  moneda: b.moneda,
                  metodo: "paypal",
                },
              }),
            });

            if (!res.ok) {
              const txt = await res.text();
              const msg = JSON.parse(txt)?.error?.message ?? "Error al confirmar la reserva";
              if (errorEl) { errorEl.textContent = msg; errorEl.classList.remove("hidden"); }
              return;
            }

            const { ticket, voucher_url } = await res.json();
            const completedBooking = window.__pendingBooking
              ? { ...window.__pendingBooking }
              : undefined;

            // Mostrar modal de éxito con el ticket
            const successModal = document.querySelector("[data-success-modal]");
            const ticketEl = successModal?.querySelector("[data-ticket-number]");
            if (ticketEl) ticketEl.textContent = ticket;
            paymentStep?.classList.add("hidden");
            modal?.classList.add("hidden");
            successModal?.classList.remove("hidden");
            form?.reset();
            paypalBotonesRendered = false; // resetear para la próxima reserva
            // Guardar copia antes de borrar para el comprobante PDF
            if (completedBooking) window.__lastCompletedBooking = completedBooking;
            window.__lastCompletedBookingVoucherUrl = voucher_url;
            emitBookingTicketCreated(ticket, "paypal", "paypal", completedBooking);
            window.__pendingBooking = undefined;
          },

          onError: (err: Error) => {
            if (errorEl) {
              errorEl.textContent = `Error en PayPal: ${err.message ?? "intenta nuevamente"}`;
              errorEl.classList.remove("hidden");
            }
          },

          onCancel: () => {
            if (errorEl) {
              errorEl.textContent = "Pago cancelado. Puedes intentarlo de nuevo.";
              errorEl.classList.remove("hidden");
            }
          },
        }).render("#paypal-button-container");

        paypalBotonesRendered = true;

      } catch (err) {
        if (loading) loading.textContent = `Error al cargar PayPal: ${err instanceof Error ? err.message : ""}`;
      }
    }

    // ── Yape QR ──
    // TODO: Integrar IziPay Vpos: POST token → mostrar QR → polling de estado → procesarPago(...)
    document.getElementById("btn-generar-qr")?.addEventListener("click", (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Generando QR...";
      const placeholder = document.getElementById("qr-placeholder");
      if (placeholder) placeholder.textContent = "QR generado — esperando pago";
      // Al recibir confirmación de IziPay, llamar:
      // procesarPago(btn_pago_yape);
      setTimeout(() => { btn.disabled = false; btn.textContent = "QR generado"; }, 1000);
    });

    // ── Tarjeta (IziPay) ──
    // TODO: Reemplazar inputs con IziPay Hosted Fields + tokenización
    document.getElementById("btn-pagar-tarjeta")?.addEventListener("click", (e) => {
      procesarPago(e.currentTarget as HTMLButtonElement);
    });

    // ── Modal de éxito ──
    const successModal = document.querySelector("[data-success-modal]");
    const closeAllModals = () => {
      successModal?.classList.add("hidden");
      modal?.classList.add("hidden");
      form?.classList.remove("hidden");
      paymentStep?.classList.add("hidden");
      document.querySelectorAll(".metodo-panel").forEach((p) => p.classList.add("hidden"));
      document.querySelectorAll(".metodo-tab").forEach((b) => b.classList.remove("border-[#1AA093]", "border-[#6c3bbd]", "bg-[#e0f7f5]", "bg-[#f3eeff]"));
      const mobileCard = document.getElementById("booking-card-content");
      const mobileBackdrop = document.getElementById("mobile-booking-backdrop");
      mobileCard?.classList.add("hidden");
      mobileBackdrop?.classList.add("hidden");
      document.body.style.overflow = "";
      window.__lastCompletedBookingVoucherUrl = undefined;
    };
    successModal?.querySelector("[data-close-success]")?.addEventListener("click", closeAllModals);
    successModal?.addEventListener("click", (e) => { if (e.target === successModal) closeAllModals(); });

    // Copiar ticket
    const copyBtn = successModal?.querySelector("[data-copy-ticket]") as HTMLButtonElement | null;
    copyBtn?.addEventListener("click", () => {
      const text = successModal?.querySelector("[data-ticket-number]")?.textContent || "";
      navigator.clipboard.writeText(text).then(() => {
        const orig = copyBtn.textContent || "";
        copyBtn.textContent = "✓ Copiado";
        setTimeout(() => { copyBtn.textContent = orig; }, 2000);
      }).catch(() => alert("Error al copiar"));
    });

    // ── Descargar comprobante en PDF ──
    const downloadVoucherBtn = successModal?.querySelector("[data-download-voucher]") as HTMLButtonElement | null;
    downloadVoucherBtn?.addEventListener("click", async () => {
      const ticket = successModal?.querySelector("[data-ticket-number]")?.textContent?.trim() || "TICKET";
      const voucherUrl = window.__lastCompletedBookingVoucherUrl;
      if (voucherUrl) {
        window.open(voucherUrl, "_blank", "noopener,noreferrer");
        return;
      }
      const booking = window.__lastCompletedBooking;
      const { generarVoucherPDF } = await import("./voucher-pdf");
      await generarVoucherPDF(ticket, booking);
    });

    // Placeholder del documento
    const docTypeSelect = form?.querySelector("[data-doc-type]") as HTMLSelectElement | null;
    const docNumberInput = form?.querySelector("[data-doc-number]") as HTMLInputElement | null;
    const placeholders: Record<string, string> = { dni: "12345678", rut: "12.345.678-9", pasaporte: "AB123456" };
    docTypeSelect?.addEventListener("change", (e) => {
      const val = (e.target as HTMLSelectElement).value;
      if (docNumberInput) docNumberInput.placeholder = placeholders[val] || "";
    });

    // ── Función global que llama BookingCard ──
    window.openBookingModal = ({
      adultos = 1, ninos = 0,
      precioAdultoUsd = 0, precioNinoUsd = 0,
      precioAdultoLabel = "", precioNinoLabel = "",
      tasaCambio = 1, simboloMoneda = "$", decimalesMoneda = 2,
      descuento = 0, discountMode = "amount", fechaInicio = null, fechaFin = null,
    }: BookingData = {}) => {
      // Pasajeros
      const adultoHidden = form?.querySelector("[data-modal-adultos]") as HTMLInputElement | null;
      const ninoHidden = form?.querySelector("[data-modal-ninos]") as HTMLInputElement | null;
      if (adultoHidden) adultoHidden.value = String(adultos);
      if (ninoHidden) ninoHidden.value = String(ninos);
      const adultoLabel = form?.querySelector("[data-modal-adultos-label]");
      const ninoLabel = form?.querySelector("[data-modal-ninos-label]");
      if (adultoLabel) adultoLabel.textContent = String(adultos);
      if (ninoLabel) ninoLabel.textContent = String(ninos);

      // Fechas
      const fechaInicioHidden = form?.querySelector("[data-modal-fecha-inicio]") as HTMLInputElement | null;
      const fechaFinHidden = form?.querySelector("[data-modal-fecha-fin]") as HTMLInputElement | null;
      if (fechaInicioHidden) fechaInicioHidden.value = fechaInicio || "";
      if (fechaFinHidden) fechaFinHidden.value = fechaFin || "";
      const fechaInicioLabel = form?.querySelector("[data-modal-fecha-inicio-label]");
      const fechaFinLabel = form?.querySelector("[data-modal-fecha-fin-label]");
      if (fechaInicioLabel) fechaInicioLabel.textContent = fechaInicio || "—";
      if (fechaFinLabel) fechaFinLabel.textContent = fechaFin || "—";

      // Descuento
      const descuentoHidden = form?.querySelector("[data-modal-descuento-usd]") as HTMLInputElement | null;
      if (descuentoHidden) descuentoHidden.value = String(descuento);

      // Precios
      const bruto = (adultos * precioAdultoUsd + ninos * precioNinoUsd) * tasaCambio;
      const descuentoConvertido = discountMode === "percent"
        ? bruto * (Math.max(0, descuento) / 100)
        : descuento * tasaCambio;
      const totalConvertido = Math.max(0, bruto - descuentoConvertido);
      const totalFormateado = `${simboloMoneda}${totalConvertido.toFixed(decimalesMoneda)}`;

      const precioAdultoEl = form?.querySelector("[data-modal-precio-adulto]");
      const precioNinoEl = form?.querySelector("[data-modal-precio-nino]");
      const totalEl = form?.querySelector("[data-modal-total]");
      if (precioAdultoEl) precioAdultoEl.textContent = precioAdultoLabel || `$${precioAdultoUsd.toFixed(0)}`;
      if (precioNinoEl) precioNinoEl.textContent = precioNinoLabel || `$${precioNinoUsd.toFixed(0)}`;
      if (totalEl) totalEl.textContent = totalFormateado;

      // Actualizar botón del paso 1 con el 30% del total
      const monto30 = totalConvertido * 0.3;
      const btnPriceEl = form?.querySelector("[data-btn-price]");
      const btnTotalEl = form?.querySelector("[data-btn-total]");
      if (btnPriceEl) btnPriceEl.textContent = `${simboloMoneda}${monto30.toFixed(decimalesMoneda)}`;
      if (btnTotalEl) btnTotalEl.textContent = totalFormateado;

      // Guardar pricing para el paso 2
      (window as any).__currentPricing = {
        totalConvertido, tasaCambio, simboloMoneda, decimalesMoneda,
        precioAdultoConvertido: precioAdultoUsd * tasaCambio,
        precioNinoConvertido:   precioNinoUsd   * tasaCambio,
      };

      // Descuento row
      const descuentoRow = document.getElementById("modal-descuento-row");
      const descuentoEl = form?.querySelector("[data-modal-descuento]");
      if (descuentoRow && descuentoEl) {
        if (descuento > 0) {
          descuentoRow.classList.remove("hidden"); descuentoRow.classList.add("flex");
          descuentoEl.textContent = discountMode === "percent"
            ? `-${descuento.toFixed(0)}%`
            : `-${simboloMoneda}${descuentoConvertido.toFixed(decimalesMoneda)}`;
        } else {
          descuentoRow.classList.add("hidden"); descuentoRow.classList.remove("flex");
        }
      }

      // Asegurar que el paso 1 esté visible al abrir
      form?.classList.remove("hidden");
      paymentStep?.classList.add("hidden");
      if (modalTitle) (window as any).__bookingTituloText = modalTitle.textContent;

      modal?.classList.remove("hidden");
    };

  })();
</script>
