---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<!-- Destinations Gallery Section -->
<section class="bg-white px-0 py-0 flex flex-col" style="height: calc(100vh - 6rem);">
  <div class="w-full h-full flex flex-col">
    <div class="w-full grid gap-0" style="grid-template-columns: repeat(auto-fit, minmax(calc(100% / 6), 1fr)); height: 100%; grid-auto-rows: 1fr;">
      
      {t.megamenu.destinos.map((dest: any) => (
        <div class="group relative overflow-hidden cursor-pointer">
          <img 
            src={dest.image.startsWith('landing page images') ? `/${dest.image}` : `https://images.unsplash.com/${dest.image}?w=600&h=600&fit=crop`}
            alt={dest.name} 
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300"></div>
          <div class="absolute inset-0 flex flex-col justify-between p-3 sm:p-4 md:p-6 text-white">
            <h3 class="text-lg sm:text-xl md:text-2xl lg:text-3xl font-italic">{dest.name}</h3>
            <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col space-y-2 md:space-y-4">
              <p class="text-xs sm:text-sm md:text-base leading-relaxed hidden sm:block">
                {t.destinations[dest.key].description}
              </p>
              <button class="w-full px-3 py-1.5 sm:px-4 sm:py-2 border border-white text-white text-xs sm:text-sm font-semibold hover:bg-orange-500 hover:border-orange-500 hover:text-white transition">
                {t.buttons.explore}
              </button>
            </div>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>
