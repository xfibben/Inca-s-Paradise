---
import { defaultLanguage, getTranslation, languages } from "../../../i18n";
import "../../../styles/global.css";
import GoogleAnalytics from "../../../components/shared/GoogleAnalytics.astro";
import Navbar from "../../../components/shared/Navbar.astro";
import Footer from "../../../components/shared/Footer.astro";
import { fetchOdooWebJson, getOdooMediaUrl, getOdooWebLang } from "../../../utils/odooWeb";
import { normalizeOdooHtml, richContentToHtml } from "../../../utils/richContent";

export function getStaticPaths() {
  return [];
}

const rawLang = (Astro.params.lang ?? defaultLanguage).toLowerCase();
const lang = Object.keys(languages).includes(rawLang) ? rawLang : defaultLanguage;
const blogSlug = String(Astro.params.blog ?? "").toLowerCase();
const t = getTranslation(lang);

if (rawLang !== lang) {
  return Astro.redirect(`/${lang}/blog/${blogSlug}`);
}

let article: any = null;
try {
  const json = await fetchOdooWebJson(
    `/incas/api/web/sostenibilidad/${encodeURIComponent(blogSlug)}?lang=${getOdooWebLang(lang)}`
  );
  article = json?.data ?? null;
} catch (error) {
  console.error("[blog] Error:", error);
}

if (!article) {
  return Astro.redirect(`/${lang}/`);
}

const stripHtml = (value: string) => value.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
const seoTitle = String(article.seoTitle || article.title || "").trim() || "Blog";
const seoDescription =
  String(article.seoDescription || "").trim() ||
  stripHtml(normalizeOdooHtml(article.contentHtml || ""));
const siteOrigin = (Astro.site?.origin ?? "https://incasparadise.com").replace(/\/$/, "");
const canonical = `${siteOrigin}/${lang}/blog/${article.slug || blogSlug}`;
const heroImage = getOdooMediaUrl(article.image);
const contentHtml = richContentToHtml(article.contentHtml);
const tags = Array.isArray(article.tags) ? article.tags.filter(Boolean) : [];
const destinations = Array.isArray(article.destinations) ? article.destinations.filter(Boolean) : [];
const relatedTours = Array.isArray(article.relatedTours) ? article.relatedTours.filter(Boolean) : [];
const publishedAt = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString(
      lang === "en" ? "en-US" : lang === "pt" ? "pt-BR" : lang === "fr" ? "fr-FR" : lang === "it" ? "it-IT" : "es-PE",
      { year: "numeric", month: "long", day: "numeric" }
    )
  : "";
const articleSlugs = article.slugs ?? { [lang]: article.slug || blogSlug };
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonical} />
    {heroImage ? <meta property="og:image" content={heroImage} /> : null}
    <meta name="twitter:card" content={heroImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    {heroImage ? <meta name="twitter:image" content={heroImage} /> : null}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: seoTitle,
      description: seoDescription,
      url: canonical,
      ...(heroImage ? { image: heroImage } : {}),
      ...(article.publishedAt ? { datePublished: article.publishedAt } : {}),
      publisher: {
        "@type": "Organization",
        name: "Inca's Paradise",
        url: "https://incasparadise.com"
      }
    })} />
    <GoogleAnalytics />
  </head>
  <body class="min-h-screen bg-white text-gray-900" data-navbar-solid>
    <Navbar {t} currentLang={lang} />
    <script is:inline define:vars={{ langSlugs: articleSlugs }}>
      window.__langSlugs = langSlugs;
      window.__slugBasePath = "/blog/";
    </script>
    <main>
      <section class="relative overflow-hidden">
        {heroImage ? <img src={heroImage} alt={article.title} class="absolute inset-0 h-full w-full object-cover" /> : <div class="absolute inset-0 bg-stone-300" />}
        <div class="absolute inset-0 bg-black/45" />
        <div class="relative z-10 mx-auto max-w-5xl px-6 py-28 md:py-36 text-white">
          <p class="text-xs font-semibold uppercase tracking-[0.26em] text-white/80">
            {lang === "en" ? "Sustainability Blog" : lang === "pt" ? "Blog de Sustentabilidade" : "Blog de sostenibilidad"}
          </p>
          <h1 class="mt-4 text-4xl leading-tight md:text-6xl" style="font-family: 'Playfair Display', serif; font-style: italic;">
            {article.title}
          </h1>
          {publishedAt ? <p class="mt-4 text-sm text-white/80">{publishedAt}</p> : null}
          {tags.length > 0 ? (
            <div class="mt-6 flex flex-wrap gap-2">
              {tags.map((tag: string) => (
                <span class="rounded-full border border-white/40 px-3 py-1 text-xs font-semibold tracking-[0.14em] text-white/90">
                  {tag}
                </span>
              ))}
            </div>
          ) : null}
        </div>
      </section>

      <section class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-[minmax(0,1fr)_320px]">
        <article class="min-w-0">
          <div class="prose prose-stone max-w-none text-justify prose-p:leading-8 prose-img:rounded-lg prose-img:shadow-sm" set:html={contentHtml} />
        </article>

        <aside class="space-y-10">
          {destinations.length > 0 ? (
            <section>
              <h2 class="text-2xl text-stone-900" style="font-family: 'Playfair Display', serif; font-style: italic;">
                {lang === "en" ? "Destinations" : lang === "pt" ? "Destinos" : "Destinos"}
              </h2>
              <div class="mt-4 space-y-3">
                {destinations.map((destination: any) => (
                  <a href={`/${lang}/destinos/${destination.slug}`} class="flex items-center gap-3 rounded-lg border border-stone-200 p-3 transition hover:border-[#1AA093] hover:bg-[#f8fdfa]">
                    {getOdooMediaUrl(destination.galleryThumbnail) ? (
                      <img src={getOdooMediaUrl(destination.galleryThumbnail) || ""} alt={destination.title} class="h-16 w-16 rounded object-cover" />
                    ) : (
                      <div class="h-16 w-16 rounded bg-stone-200" />
                    )}
                    <span class="text-sm font-semibold text-stone-800">{destination.title}</span>
                  </a>
                ))}
              </div>
            </section>
          ) : null}

          {relatedTours.length > 0 ? (
            <section>
              <h2 class="text-2xl text-stone-900" style="font-family: 'Playfair Display', serif; font-style: italic;">
                {lang === "en" ? "Related tours" : lang === "pt" ? "Tours relacionados" : "Tours relacionados"}
              </h2>
              <div class="mt-4 space-y-4">
                {relatedTours.map((tour: any) => {
                  const imageUrl = getOdooMediaUrl(tour.heroSlideImages?.[0]);
                  return (
                    <a href={`/${lang}/tours/${tour.slug}`} class="block overflow-hidden rounded-lg border border-stone-200 transition hover:border-[#1AA093] hover:shadow-sm">
                      {imageUrl ? <img src={imageUrl} alt={tour.title} class="h-44 w-full object-cover" /> : <div class="h-44 w-full bg-stone-200" />}
                      <div class="p-4">
                        <h3 class="text-lg text-stone-900" style="font-family: 'Playfair Display', serif; font-style: italic;">
                          {tour.title}
                        </h3>
                      </div>
                    </a>
                  );
                })}
              </div>
            </section>
          ) : null}
        </aside>
      </section>
    </main>
    <Footer currentLang={lang} {t} />
  </body>
</html>
