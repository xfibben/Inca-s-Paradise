---
import Navbar from '../../../components/shared/Navbar.astro';
import Footer from '../../../components/shared/Footer.astro';
import { getTranslation, languages } from '../../../i18n';
import '../../../styles/global.css';
import GoogleAnalytics from '../../../components/shared/GoogleAnalytics.astro';
import SEOHead from '../../../components/SEO/SEOHead.astro';

const { lang } = Astro.params;
const currentLang = Object.keys(languages).includes(lang as string) ? (lang as string) : 'es';
const t = getTranslation(currentLang);

const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://backend:1337';
const STRAPI_PUBLIC_URL = import.meta.env.PUBLIC_STRAPI_URL || 'http://localhost:1337';
const strapiLocale =
  currentLang === 'pt' ? 'pt'
  : currentLang === 'es' ? 'es-PE'
  : currentLang === 'it' ? 'it'
  : currentLang === 'fr' ? 'fr'
  : currentLang;

let data: any = null;
try {
  const res = await fetch(
    `${STRAPI_URL}/api/terminos-condiciones?populate[sections]=*&locale=${strapiLocale}&status=published`
  );
  if (res.ok) {
    const json = await res.json();
    data = json.data ?? null;
  }
} catch (e) {
  // no-op
}

const title = data?.title ?? (currentLang === 'es' ? 'Términos y Condiciones' : 'Terms & Conditions');
const description = data?.description ?? '';
const seoTitle = data?.seoTitle ?? title;

const fallbackDescriptions: Record<string, string> = {
  es: "Consulta los términos y condiciones de Inca's Paradise para reservas de tours y transporte en Cusco, Puno y Machu Picchu.",
  en: "Read the terms and conditions of Inca's Paradise for tour and transport bookings in Cusco, Puno, and Machu Picchu.",
  pt: "Leia os termos e condições da Inca's Paradise para reservas de tours e transporte em Cusco, Puno e Machu Picchu.",
  fr: "Consultez les termes et conditions d'Inca's Paradise pour les réservations de circuits et transport à Cusco, Puno et Machu Picchu.",
  it: "Leggi i termini e condizioni di Inca's Paradise per prenotazioni di tour e trasporto a Cusco, Puno e Machu Picchu.",
};
const seoDescription = data?.seoDescription || description || fallbackDescriptions[currentLang] || fallbackDescriptions.es;
const sections: Array<{ title: string; text: string }> = Array.isArray(data?.sections) ? data.sections : [];

const siteOrigin = (Astro.site?.origin ?? 'https://incasparadise.com').replace(/\/$/, '');
const canonical = `${siteOrigin}/${currentLang}/terminos`;
const alternateLanguages = [
  { lang: 'es', url: `${siteOrigin}/es/terminos` },
  { lang: 'en', url: `${siteOrigin}/en/terminos` },
  { lang: 'pt', url: `${siteOrigin}/pt/terminos` },
  { lang: 'fr', url: `${siteOrigin}/fr/terminos` },
  { lang: 'it', url: `${siteOrigin}/it/terminos` },
];

const terminosSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": seoTitle,
  "description": seoDescription,
  "url": canonical,
  "inLanguage": currentLang === 'es' ? 'es-PE' : currentLang,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Inca's Paradise",
    "url": siteOrigin,
  },
  ...(sections.length > 0 && {
    "hasPart": sections.map((s, i) => ({
      "@type": "WebPageElement",
      "name": `${i + 1}. ${s.title}`,
    })),
  }),
};

---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{seoTitle}</title>
    <SEOHead
      title={seoTitle}
      description={seoDescription}
      canonical={canonical}
      currentLang={currentLang}
      alternateLanguages={alternateLanguages}
      xDefaultUrl={`${siteOrigin}/es/terminos`}
      structuredData={terminosSchema}
    />
    <GoogleAnalytics />
    <style>
      h1, h2 {
        font-family: 'Playfair Display', serif;
        font-weight: 500;
        font-style: italic;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col text-gray-900" data-navbar-solid>
    <Navbar {t} currentLang={currentLang} />

    <main class="flex-1 pt-24 pb-16 bg-white">
      <div class="mx-auto max-w-5xl px-4">

        <!-- Header -->
        <div class="mb-10 border-b border-gray-200 pb-8">
          <h1 class="mb-4">
            {title}
          </h1>
          {description && (
            <p class="text-base text-gray-600 leading-relaxed text-justify">{description}</p>
          )}
        </div>

        <!-- Sections -->
        {sections.length > 0 ? (
          <div class="space-y-10">
            {sections.map((section, i) => (
              <div>
                <h2 class="mb-3 text-2xl">
                  {i + 1}. {section.title}
                </h2>
                <div
                  class="prose prose-gray max-w-none text-gray-700 leading-relaxed text-justify markdown-content"
                  data-markdown={typeof section.text === 'string' ? section.text : JSON.stringify(section.text)}
                />
              </div>
            ))}
          </div>
        ) : (
          <p class="text-gray-400 italic">
            {currentLang === 'es' ? 'Contenido prÃ³ximamente.' : 'Content coming soon.'}
          </p>
        )}

      </div>
    </main>

    <Footer {t} currentLang={currentLang} />

    <script src="https://cdn.jsdelivr.net/npm/markdown-it@10.0.0/dist/markdown-it.min.js"></script>
    <script is:inline>
      function processMarkdown() {
        if (typeof window.markdownit !== 'undefined') {
          const md = window.markdownit();
          document.querySelectorAll('.markdown-content').forEach(el => {
            const markdown = el.getAttribute('data-markdown');
            if (markdown) {
              el.innerHTML = md.render(markdown);
              el.removeAttribute('data-markdown');
            }
          });
        } else {
          setTimeout(processMarkdown, 100);
        }
      }
      processMarkdown();
    </script>
  </body>
</html>

