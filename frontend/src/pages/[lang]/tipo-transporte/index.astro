---
import { getTranslation, languages, defaultLanguage, type Language } from '../../../i18n';
import '../../../styles/global.css';
import GoogleAnalytics from '../../../components/shared/GoogleAnalytics.astro';
import Navbar from '../../../components/shared/Navbar.astro';
import Footer from '../../../components/shared/Footer.astro';
import SEOHead from '../../../components/SEO/SEOHead.astro';
import TipoTransporteHero from '../../../components/tipo-transporte/TipoTransporteHero.astro';
import TipoTransporteGrid from '../../../components/tipo-transporte/TipoTransporteGrid.astro';

const { lang } = Astro.params;

const currentLang = Object.keys(languages).includes(lang as string)
  ? (lang as Language)
  : defaultLanguage;

if (!Object.keys(languages).includes(lang as string)) {
  return Astro.redirect(`/${currentLang}/tipo-transporte/`);
}

const t = getTranslation(currentLang);

const metaDescriptions: Record<string, string> = {
  es: "Opciones de transporte para explorar los destinos más increíbles del Perú con Inca's Paradise.",
  en: "Transport options to explore the most incredible destinations in Peru with Inca's Paradise.",
  pt: "Opções de transporte para explorar os destinos mais incríveis do Peru com a Inca's Paradise.",
  fr: "Options de transport pour explorer les destinations les plus incroyables du Pérou avec Inca's Paradise.",
  it: "Opzioni di trasporto per esplorare le destinazioni più incredibili del Perù con Inca's Paradise.",
};
const metaDescription = metaDescriptions[currentLang] ?? metaDescriptions.es;

const metaTitles: Record<string, string> = {
  es: "Tipos de Transporte | Inca's Paradise",
  en: "Transport Types | Inca's Paradise",
  pt: "Tipos de Transporte | Inca's Paradise",
  fr: "Types de Transport | Inca's Paradise",
  it: "Tipi di Trasporto | Inca's Paradise",
};
const metaTitle = metaTitles[currentLang] ?? metaTitles.es;

const siteOrigin = (Astro.site?.origin ?? 'https://incasparadise.com').replace(/\/$/, '');
const canonical = `${siteOrigin}/${currentLang}/tipo-transporte`;
const alternateLanguages = [
  { lang: 'es', url: `${siteOrigin}/es/tipo-transporte` },
  { lang: 'en', url: `${siteOrigin}/en/tipo-transporte` },
  { lang: 'pt', url: `${siteOrigin}/pt/tipo-transporte` },
  { lang: 'fr', url: `${siteOrigin}/fr/tipo-transporte` },
  { lang: 'it', url: `${siteOrigin}/it/tipo-transporte` },
];

const STRAPI_URL = import.meta.env.STRAPI_URL;
const PUBLIC_STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;

const strapiLocale =
  currentLang === 'pt' ? 'pt'
  : currentLang === 'es' ? 'es-PE'
  : currentLang;

// Fetch de tipos de transporte
let tiposTransporte: any[] = [];

try {
  const res = await fetch(
    `${STRAPI_URL}/api/tipo-transportes?locale=${strapiLocale}` +
    `&fields[0]=nombre&fields[1]=slug&fields[2]=nroOrden` +
    `&populate[image]=*` +
    `&sort=nroOrden:asc`
  );
  if (res.ok) {
    const json = await res.json();
    tiposTransporte = json?.data ?? [];
  }
} catch (e) {
  console.error("Error al obtener tipos de transporte:", e);
}

const tipoTransporteSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": metaTitle,
  "description": metaDescription,
  "url": canonical,
  "inLanguage": currentLang === 'es' ? 'es-PE' : currentLang,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Inca's Paradise",
    "url": siteOrigin,
  },
  ...(tiposTransporte.length > 0 && {
    "hasPart": tiposTransporte.map((tipo: any) => {
      const d = tipo?.attributes ?? tipo;
      return {
        "@type": "WebPage",
        "name": d.nombre,
        "url": `${siteOrigin}/${currentLang}/tipo-transporte/${d.slug}`,
      };
    }),
  }),
};
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <title>{metaTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SEOHead
      title={metaTitle}
      description={metaDescription}
      canonical={canonical}
      currentLang={currentLang}
      alternateLanguages={alternateLanguages}
      xDefaultUrl={`${siteOrigin}/es/tipo-transporte`}
      structuredData={tipoTransporteSchema}
    />
    <link rel="preload" as="image" href="/landing page images/ubicacion-choquequirao-full.webp" fetchpriority="high" />
    <GoogleAnalytics />
  </head>

  <body class="bg-white text-stone-800 overflow-x-hidden flex flex-col min-h-screen">

    <Navbar t={t} currentLang={currentLang} />

    <main class="flex-1">
      <TipoTransporteHero t={t} />
      <TipoTransporteGrid
        tipos={tiposTransporte}
        publicStrapiUrl={PUBLIC_STRAPI_URL}
        lang={currentLang}
        t={t}
      />
    </main>

    <Footer currentLang={currentLang} t={t} />

  </body>
</html>

