---
import { getTranslation, languages, defaultLanguage, type Language } from '../../../i18n';
import '../../../styles/global.css';
import GoogleAnalytics from '../../../components/shared/GoogleAnalytics.astro';
import Navbar from '../../../components/shared/Navbar.astro';
import Footer from '../../../components/shared/Footer.astro';
import TipoTransporteTable from '../../../components/tipo-transporte/TipoTransporteTable.astro';
import { buildLocalizedSlugs, fetchOdooTransportJson, getOdooTransportLang } from '../../../utils/odooTransport';
import { richContentToHtml } from '../../../utils/richContent';

export function getStaticPaths() {
  return [];
}

const { lang, slug } = Astro.params;

const currentLang = Object.keys(languages).includes(lang as string)
  ? (lang as Language)
  : defaultLanguage;

const t = getTranslation(currentLang);

// Fallback de meta description por idioma cuando Strapi no tiene descripción
const metaDescriptionFallbacks: Record<string, string> = {
  es: (name: string) => `Conoce más sobre ${name} con Inca's Paradise.`,
  en: (name: string) => `Learn more about ${name} with Inca's Paradise.`,
  pt: (name: string) => `Saiba mais sobre ${name} com a Inca's Paradise.`,
  fr: (name: string) => `En savoir plus sur ${name} avec Inca's Paradise.`,
  it: (name: string) => `Scopri di più su ${name} con Inca's Paradise.`,
} as any;

// Estructuras de datos procesados para la tabla comparativa
interface VehiculoData {
  nombre: string;
  descripcion: string;
  imagenUrl: string | null;
  features: string[];
}

interface RutaData {
  id: string;
  nombre: string;
  precios: Record<string, { precio: number; original: number | null }>;
}

let tipoTransporte: any = null;

try {
  const json = await fetchOdooTransportJson(
    `/incas/api/web/tipo-transportes/${encodeURIComponent(slug as string)}?lang=${getOdooTransportLang(currentLang)}`
  );
  tipoTransporte = json?.data ?? null;
} catch (e) {
  console.error("Error al obtener tipo de transporte:", e);
}

if (!tipoTransporte) {
  return Astro.redirect(`/${currentLang}/tipo-transporte/`);
}

// Obtiene los slugs localizados para el cambio de idioma en la navbar
const ALL_LANGS = ['es', 'en', 'pt', 'fr', 'it'];
const tipoTransporteSlugs: Record<string, string> = tipoTransporte?.slugs ?? buildLocalizedSlugs(slug as string);

function getImageUrl(media: any): string | null {
  if (!media) return null;
  const url = media?.formats?.large?.url ?? media?.formats?.medium?.url ?? media?.url;
  if (!url) return null;
  return url.startsWith('http') ? url : url;
}

const wallpaperUrl = getImageUrl(tipoTransporte.wallpaper);

const transportes: any[] = tipoTransporte.transportes ?? [];

// Construir vehÃ­culos Ãºnicos y rutas para la tabla comparativa
const vehiculosMap = new Map<string, VehiculoData>();

for (const tp of transportes) {
  for (const precio of tp.precios ?? []) {
    for (const veh of precio.vehiculo ?? []) {
      if (!vehiculosMap.has(veh.nombre)) {
        vehiculosMap.set(veh.nombre, {
          nombre: veh.nombre,
          descripcion: veh.descripcion ?? '',
          imagenUrl: getImageUrl(veh.imagen),
          features: (veh.features ?? []).map((f: any) => f.text as string),
        });
      }
    }
  }
}

const vehiculos: VehiculoData[] = Array.from(vehiculosMap.values());
const descripcionHtml = richContentToHtml(tipoTransporte?.descripcion);

const rutas: RutaData[] = transportes.map((tp: any): RutaData => {
  const preciosMap: Record<string, { precio: number; original: number | null }> = {};
  for (const precio of tp.precios ?? []) {
    for (const veh of precio.vehiculo ?? []) {
      preciosMap[veh.nombre] = { precio: precio.precioAdulto ?? 0, original: null };
    }
  }
  return {
    id: tp.slug ?? String(tp.id),
    nombre: tp.nombre,
    precios: preciosMap,
  };
});
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <title>{tipoTransporte.nombre} — Inca's Paradise</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={tipoTransporte.seoDescription ?? (metaDescriptionFallbacks[currentLang] ?? metaDescriptionFallbacks.es)(tipoTransporte.nombre)} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Schema JSON-LD Service -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": tipoTransporte.nombre,
      "description": tipoTransporte.seoDescription ?? (metaDescriptionFallbacks as any)[currentLang]?.(tipoTransporte.nombre) ?? `${tipoTransporte.nombre} - Inca's Paradise`,
      "url": `${Astro.site}${currentLang}/tipo-transporte/${slug}`,
      "image": wallpaperUrl ?? undefined,
      "provider": {
        "@type": "TravelAgency",
        "name": "Inca's Paradise",
        "url": "https://incasparadise.com"
      }
    })} />
    {wallpaperUrl && <link rel="preload" as="image" href={wallpaperUrl} fetchpriority="high" />}
    <GoogleAnalytics />
  </head>

  <body class="bg-white text-stone-800 overflow-x-hidden flex flex-col min-h-screen">

    <Navbar t={t} currentLang={currentLang} />

    <main class="flex-1">

      <!-- Hero con wallpaper -->
      <section class="relative w-full overflow-hidden" style="height: 50vh;">
        {wallpaperUrl ? (
          <img
            src={wallpaperUrl}
            alt={tipoTransporte.nombre}
            class="absolute inset-0 w-full h-full object-cover"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="absolute inset-0 bg-linear-to-br from-stone-600 to-stone-900" />
        )}
        <div class="absolute inset-0 bg-black/50" />

        <div class="relative h-full flex flex-col justify-center items-center text-center px-4">
          <p class="text-white/70 uppercase tracking-widest text-xs mb-3">{t.transporte.tipoLabel}</p>
          <h1
            class="text-4xl md:text-6xl text-white leading-tight max-w-3xl"
            style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;"
          >
            {tipoTransporte.nombre}
          </h1>
        </div>
      </section>

      <!-- DescripciÃ³n -->
      {tipoTransporte.descripcion && (
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
          <div
            class="prose prose-stone max-w-none text-[#374151] text-justify"
            set:html={descripcionHtml}
          />
        </div>
      )}

      <!-- Tabla comparativa de precios por vehÃ­culo -->
      {vehiculos.length > 0 && rutas.length > 0 && (
        <TipoTransporteTable vehiculos={vehiculos} rutas={rutas} lang={currentLang} labelReservar={t.transporte?.reservar ?? 'Reservar'} />
      )}

      <!-- Contenido principal -->
      <section class="py-20 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">


        <!-- Carrusel de transportes -->
        {transportes.length > 0 && (
          <div>
            <div class="text-center mb-10">
              <p class="text-[#1AA093] uppercase tracking-widest text-sm font-medium mb-2">{t.transporte.disponibles}</p>
              <h2
                class="text-3xl md:text-4xl text-stone-800"
                style="font-family: 'Playfair Display', serif; font-style: italic;"
              >
                {t.transporte.enCategoria}
              </h2>
            </div>

            <div class="flex gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4" style="scrollbar-width: none;">
              {transportes.map((tp: any) => {
                const tpImg = getImageUrl(tp.image);
                const origen = tp.destino_origen?.[0]?.title ?? null;
                const llegada = tp.destino_llegada?.[0]?.title ?? null;
                return (
                  <a
                    href={tp.slug ? `/${currentLang}/transporte/${tp.slug}` : '#'}
                    class="shrink-0 w-72 h-112.5 relative overflow-hidden cursor-pointer group snap-start"
                  >
                    {tpImg ? (
                      <img
                        src={tpImg}
                        alt={tp.nombre}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full bg-stone-400" />
                    )}
                    <div class="absolute inset-0 bg-linear-to-b from-black/30 to-black/65 flex flex-col justify-between p-6 text-white">
                      <span class="flex items-center gap-1 text-xs font-semibold uppercase tracking-wider">
                        {origen ?? '—'}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                        {llegada ?? '—'}
                      </span>
                      <p class="text-lg font-bold leading-tight" style="font-family: 'Playfair Display', serif;">{tp.nombre}</p>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Volver -->
        <div class="mt-14 text-center">
          <a
            href={`/${currentLang}/tipo-transporte/`}
            class="inline-flex items-center gap-2 text-[#1AA093] hover:text-[#0e8a7e] text-sm font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            {t.transporte.verTodosTipos}
          </a>
        </div>

      </section>

    </main>

    <Footer currentLang={currentLang} t={t} />

    <script is:inline define:vars={{ tipoTransporteSlugs }}>
      window.__tipoTransporteSlugs = tipoTransporteSlugs;
    </script>


  </body>
</html>
