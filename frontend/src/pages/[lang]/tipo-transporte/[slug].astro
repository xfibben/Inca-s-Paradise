---
import { getTranslation, languages, defaultLanguage, type Language } from '../../../i18n';
import '../../../styles/global.css';
import Navbar from '../../../components/shared/Navbar.astro';
import Footer from '../../../components/shared/Footer.astro';

export function getStaticPaths() {
  return [];
}

const { lang, slug } = Astro.params;

const currentLang = Object.keys(languages).includes(lang as string)
  ? (lang as Language)
  : defaultLanguage;

const t = getTranslation(currentLang);

const STRAPI_URL = import.meta.env.STRAPI_URL;
const PUBLIC_STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;

const strapiLocale =
  currentLang === 'pt' ? 'pt'
  : currentLang === 'es' ? 'es-PE'
  : currentLang;

// Fetch del tipo de transporte por slug
let tipoTransporte: any = null;

try {
  const res = await fetch(
    `${STRAPI_URL}/api/tipo-transportes?filters[slug][$eq]=${slug}` +
    `&locale=${strapiLocale}&status=published` +
    `&populate[image]=*` +
    `&populate[wallpaper]=*` +
    `&populate[transportes]=*`
  );
  if (res.ok) {
    const json = await res.json();
    tipoTransporte = json?.data?.[0] ?? null;
  }
} catch (e) {
  console.error("Error al obtener tipo de transporte:", e);
}

if (!tipoTransporte) {
  return Astro.redirect(`/${currentLang}/tipo-transporte/`);
}

function getImageUrl(media: any): string | null {
  if (!media) return null;
  const url = media?.formats?.large?.url ?? media?.formats?.medium?.url ?? media?.url;
  if (!url) return null;
  return url.startsWith('http') ? url : `${PUBLIC_STRAPI_URL}${url}`;
}

const wallpaperUrl = getImageUrl(tipoTransporte.wallpaper);

const transportes: any[] = tipoTransporte.transportes ?? [];
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <title>{tipoTransporte.nombre} — Inca's Paradise</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={tipoTransporte.descripcion ?? `Conoce más sobre ${tipoTransporte.nombre} con Inca's Paradise.`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body class="bg-white text-stone-800 overflow-x-hidden flex flex-col min-h-screen">

    <Navbar t={t} currentLang={currentLang} />

    <main class="flex-1">

      <!-- Hero con wallpaper -->
      <section class="relative w-full overflow-hidden" style="height: 50vh;">
        {wallpaperUrl ? (
          <img
            src={wallpaperUrl}
            alt={tipoTransporte.nombre}
            class="absolute inset-0 w-full h-full object-cover"
            fetchpriority="high"
          />
        ) : (
          <div class="absolute inset-0 bg-linear-to-br from-stone-600 to-stone-900" />
        )}
        <div class="absolute inset-0 bg-black/50" />

        <div class="relative h-full flex flex-col justify-center items-center text-center px-4">
          <p class="text-white/70 uppercase tracking-widest text-xs mb-3">{t.transporte.tipoLabel}</p>
          <h1
            class="text-4xl md:text-6xl text-white leading-tight max-w-3xl"
            style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;"
          >
            {tipoTransporte.nombre}
          </h1>
        </div>
      </section>

      <!-- Descripción -->
      {tipoTransporte.descripcion && (
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
          <div
            class="prose prose-stone max-w-none text-[#374151] markdown-content text-justify"
            data-markdown={tipoTransporte.descripcion}
          />
        </div>
      )}

      <!-- Contenido principal -->
      <section class="py-20 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">


        <!-- Carrusel de transportes -->
        {transportes.length > 0 && (
          <div>
            <div class="text-center mb-10">
              <p class="text-amber-600 uppercase tracking-widest text-sm font-medium mb-2">{t.transporte.disponibles}</p>
              <h2
                class="text-3xl md:text-4xl text-stone-800"
                style="font-family: 'Playfair Display', serif; font-style: italic;"
              >
                {t.transporte.enCategoria}
              </h2>
            </div>

            <div class="flex gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4" style="scrollbar-width: none;">
              {transportes.map((tp: any) => {
                const tpImg = getImageUrl(tp.image);
                const origen = tp.destino_origen?.[0]?.title ?? null;
                const llegada = tp.destino_llegada?.[0]?.title ?? null;
                return (
                  <a
                    href={tp.slug ? `/${currentLang}/transporte/${tp.slug}` : '#'}
                    class="shrink-0 w-72 h-112.5 relative overflow-hidden cursor-pointer group snap-start"
                  >
                    {tpImg ? (
                      <img
                        src={tpImg}
                        alt={tp.nombre}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full bg-stone-400" />
                    )}
                    <div class="absolute inset-0 bg-linear-to-b from-black/30 to-black/65 flex flex-col justify-between p-6 text-white">
                      <span class="flex items-center gap-1 text-xs font-semibold uppercase tracking-wider">
                        {origen ?? '—'}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                        {llegada ?? '—'}
                      </span>
                      <p class="text-lg font-bold leading-tight" style="font-family: 'Playfair Display', serif;">{tp.nombre}</p>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Volver -->
        <div class="mt-14 text-center">
          <a
            href={`/${currentLang}/tipo-transporte/`}
            class="inline-flex items-center gap-2 text-amber-600 hover:text-amber-700 text-sm font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            {t.transporte.verTodosTipos}
          </a>
        </div>

      </section>

    </main>

    <Footer currentLang={currentLang} t={t} />

    <!-- Renderiza markdown en la descripción -->
    <script src="https://cdn.jsdelivr.net/npm/markdown-it@10.0.0/dist/markdown-it.min.js"></script>
    <script>
      function processMarkdown() {
        if (typeof (window as any).markdownit !== 'undefined') {
          const md = (window as any).markdownit();
          document.querySelectorAll('.markdown-content').forEach((el: Element) => {
            const raw = el.getAttribute('data-markdown');
            if (raw) {
              el.innerHTML = md.render(raw);
              el.removeAttribute('data-markdown');
            }
          });
        } else {
          setTimeout(processMarkdown, 50);
        }
      }
      document.addEventListener('DOMContentLoaded', processMarkdown);
    </script>

  </body>
</html>
