---
import { defaultLanguage, getTranslation, languages } from "../../../i18n";
import "../../../styles/global.css";
import GoogleAnalytics from "../../../components/shared/GoogleAnalytics.astro";
import Navbar from "../../../components/shared/Navbar.astro";
import Footer from "../../../components/shared/Footer.astro";
import BookingModal from "../../../components/tours/BookingModal.astro";
import BookingCard from "../../../components/tours/BookingCard.astro";
import Ribbon from "../../../components/shared/Ribbon.astro";
import { formatPrice } from "../../../utils/currency";
import { normalizeOdooHtml, richContentToHtml } from "../../../utils/richContent";
import { buildLocalizedSlugs, fetchOdooWebJson, getOdooMediaUrl, getOdooWebLang } from "../../../utils/odooWeb";

export function getStaticPaths() {
  return [];
}

const rawLang = (Astro.params.lang ?? defaultLanguage).toLowerCase();
const lang = Object.keys(languages).includes(rawLang) ? rawLang : defaultLanguage;
const tourSlug = String(Astro.params.tour ?? "").toLowerCase();
const t = getTranslation(lang);

if (rawLang !== lang) {
  return Astro.redirect(`/${lang}/tours/${tourSlug}`);
}

let sourceTour: any = null;
try {
  const json = await fetchOdooWebJson(
    `/incas/api/web/tours/${encodeURIComponent(tourSlug)}?lang=${getOdooWebLang(lang)}`
  );
  sourceTour = json?.data ?? null;
} catch (error) {
  console.error("[tour] Error:", error);
}

if (!sourceTour) {
  return Astro.redirect(`/${lang}/destinos`);
}

const cleanText = (value: any) => (typeof value === "string" ? value.trim() : "");
const toNumber = (value: any) => {
  const number = Number(value);
  return Number.isFinite(number) ? number : 0;
};
const toObjectList = (value: any) =>
  Array.isArray(value) ? value.filter((item: any) => item && typeof item === "object") : [];
const seoTitle =
  cleanText(sourceTour.seoTitle) ||
  cleanText(sourceTour.metaTitle) ||
  cleanText(sourceTour.title) ||
  (lang === "en" ? "Tour details" : "Detalle del tour");
const stripHtml = (value: string) => value.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
const seoDescription = stripHtml(normalizeOdooHtml(sourceTour.seoDescription) || normalizeOdooHtml(sourceTour.metaDescription));
const siteOrigin = (Astro.site?.origin ?? "https://incasparadise.com").replace(/\/$/, "");
const canonical = `${siteOrigin}/${lang}/tours/${sourceTour.slug || tourSlug}`;
const heroImages = toObjectList(sourceTour.heroSlideImages);
const heroImage = getOdooMediaUrl(heroImages[0]);
const featuredImages = toObjectList(sourceTour.featuredImages).map((item: any) => ({
  ...item,
  alt: stripHtml(normalizeOdooHtml(item?.alt || sourceTour.title)),
}));
const itineraryItems = toObjectList(sourceTour.itineraryItems).map((item: any, index: number) => ({
  ...item,
  titleHtml: richContentToHtml(item.title),
  descriptionHtml: richContentToHtml(item.description),
  imageAltText: stripHtml(normalizeOdooHtml(item.imageAlt || item.title || `${lang === "en" ? "Day" : "Dia"} ${index + 1}`)),
  images: toObjectList(item.images).map((image: any) => ({
    url: getOdooMediaUrl(image),
    alt: stripHtml(normalizeOdooHtml(item.imageAlt || item.title || `${lang === "en" ? "Day" : "Dia"} ${index + 1}`)),
  })).filter((image: any) => image.url),
}));
const scheduleItems = toObjectList(sourceTour.scheduleItems);
const includedItems = toObjectList(sourceTour.includedItems);
const excludedItems = toObjectList(sourceTour.excludedItems);
const faqItems = toObjectList(sourceTour.faqItems).map((item: any) => ({
  ...item,
  questionText: stripHtml(normalizeOdooHtml(item.question)),
  answerHtml: richContentToHtml(item.answer),
}));
const relatedTours = toObjectList(sourceTour.relatedTours);
const highlightItems = toObjectList(sourceTour.highlightsItems).map((item: any) => ({
  ...item,
  titleHtml: richContentToHtml(item.title),
  descriptionHtml: richContentToHtml(item.description),
}));
const tourSlugs = sourceTour.slugs ?? buildLocalizedSlugs(sourceTour.slug || tourSlug);
const destinationNames = toObjectList(sourceTour.destinos).map((item: any) => item.title).filter(Boolean);
const priceFromLabel =
  lang === "en" ? "From"
  : lang === "pt" ? "Desde"
  : lang === "fr" ? "Des"
  : lang === "it" ? "Da"
  : "Desde";
const bookingLang = (["es", "en", "pt", "fr", "it"].includes(lang) ? lang : "es") as "es" | "en" | "pt" | "fr" | "it";
const getDiscountedPrice = (price: number, discountPercent: number) =>
  Math.max(0, price - (price * Math.max(0, discountPercent)) / 100);
const nowPeru = new Date(new Date().toLocaleString("en-US", { timeZone: "America/Lima" }));
const calendarLocale = lang === "en" ? "en-US" : "es-PE";
const calendarStart = `${nowPeru.getFullYear()}-${String(nowPeru.getMonth() + 1).padStart(2, "0")}`;
const calendarMonth = nowPeru.toLocaleDateString(calendarLocale, { month: "long", year: "numeric", timeZone: "America/Lima" });
const weekdays = lang === "en"
  ? ["M", "T", "W", "Th", "F", "S", "S"]
  : ["L", "M", "X", "Ju", "V", "S", "D"];
const bookingTitle = lang === "en" ? "BOOK NOW" : "RESERVA AHORA";
const availability = lang === "en" ? "Real-time availability" : "Disponibilidad en tiempo real";
const durationDays = toNumber(sourceTour.durationDays) || 1;
const bookingDuration = `${durationDays} ${lang === "en" ? "day" : "dia"}${durationDays > 1 ? "s" : ""}`;
const highlightsTitle = stripHtml(normalizeOdooHtml(sourceTour.highlightsTitle));
const highlightsLead = richContentToHtml(sourceTour.highlightsLead);
const hasHighlightsSection = Boolean(highlightsTitle || highlightsLead || highlightItems.length || heroImage);
const itineraryTitle = stripHtml(normalizeOdooHtml(sourceTour.itineraryTitle)) || (lang === "en" ? "Itinerary" : "Itinerario");
const itineraryItemLabel = lang === "en" ? "Day" : "Dia";
const scheduleTitle = stripHtml(normalizeOdooHtml(sourceTour.scheduleTitle)) || (lang === "en" ? "Schedules" : "Horarios");
const includedTitle = stripHtml(normalizeOdooHtml(sourceTour.includedTitle)) || (lang === "en" ? "Included" : "Incluye");
const excludedTitle = stripHtml(normalizeOdooHtml(sourceTour.excludedTitle)) || (lang === "en" ? "Not Included" : "No incluye");
const galleryTitle = stripHtml(normalizeOdooHtml(sourceTour.featuredTitle)) || (lang === "en" ? "Gallery" : "Galeria");
const faqTitle = stripHtml(normalizeOdooHtml(sourceTour.faqTitle)) || "FAQ";
const primaryDestinationName = destinationNames[0] ?? "";
const moreToursRibbonText =
  primaryDestinationName
    ? `${lang === "en" ? "More tours in" : lang === "pt" ? "Mais tours em" : "Mas tours en"} ${primaryDestinationName}`
    : (lang === "en" ? "Related tours" : "Tours relacionados");
const tourDetailCtaLabel = lang === "en" ? "View tour" : "Ver tour";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonical} />
    {heroImage ? <meta property="og:image" content={heroImage} /> : null}
    <meta name="twitter:card" content={heroImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    {heroImage ? <meta name="twitter:image" content={heroImage} /> : null}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristTrip",
      "name": seoTitle,
      "description": seoDescription,
      "url": canonical,
      "provider": {
        "@type": "TravelAgency",
        "name": "Inca's Paradise",
        "url": "https://incasparadise.com"
      },
      ...(heroImage ? { image: heroImage } : {}),
      ...(sourceTour.adultUnitPrice ? {
        offers: {
          "@type": "Offer",
          price: toNumber(sourceTour.adultUnitPrice),
          priceCurrency: "USD",
          availability: "https://schema.org/InStock"
        }
      } : {}),
    })} />
    {heroImage && <link rel="preload" as="image" href={heroImage} fetchpriority="high" />}
    <GoogleAnalytics />
  </head>
  <body class="tour-detail min-h-screen bg-white text-gray-900" data-navbar-solid>
    <Navbar t={t} currentLang={lang} whatsappTourName={sourceTour.title} />
    <script is:inline define:vars={{ tourSlugs, serviceId: sourceTour.serviceId ?? null, destinoNombre: destinationNames[0] ?? null }}>
      window.__tourData = { serviceId, destinoNombre };
      window.__tourSlugs = tourSlugs;
    </script>

    <main>
      <section class="bg-[#f5f0e9]">
        <div class="grid w-full gap-10 px-4 pb-16 pt-24 lg:grid-cols-[minmax(0,1fr)_300px] lg:items-start lg:gap-6 lg:px-12 lg:pt-28">
          <div class="min-w-0">
            {hasHighlightsSection ? (
              <section class="pb-12 md:pb-14">
                <div class="grid gap-6 border border-[#e2e8f0] bg-white p-4 shadow-sm md:grid-cols-[240px_1fr] md:gap-8 md:p-6">
                  {heroImage ? (
                    <div class="overflow-hidden">
                      <img src={heroImage} alt={sourceTour.title} class="h-full min-h-[280px] w-full object-cover" fetchpriority="high" loading="eager" decoding="async" />
                    </div>
                  ) : null}
                  <div>
                    {destinationNames.length > 0 ? <p class="mb-3 text-xs font-semibold uppercase tracking-[0.24em] text-[#1AA093]">{destinationNames.join(" · ")}</p> : null}
                    {highlightsTitle ? <h1 class="text-3xl leading-tight text-[#1f2937] md:text-4xl" style="font-family: 'Playfair Display', serif; font-style: italic;">{highlightsTitle}</h1> : null}
                    {highlightsLead ? <div class="mt-3 text-sm leading-relaxed text-[#1f2937] text-justify md:text-base [&_p]:mb-3 [&_p:last-child]:mb-0" set:html={highlightsLead} /> : null}
                    <div class="mt-4 space-y-4">
                      {highlightItems.map((item: any, index: number) => (
                        <article class="flex items-start gap-3">
                          <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-green-600 text-green-600">{index + 1}</span>
                          <div>
                            {item.titleHtml ? <div class="text-lg font-normal text-[#111827] md:text-xl [&_p]:m-0" set:html={item.titleHtml} /> : null}
                            {item.descriptionHtml ? <div class="mt-1 text-sm leading-relaxed text-[#4b5563] text-justify md:text-base [&_p]:mb-2 [&_p:last-child]:mb-0" set:html={item.descriptionHtml} /> : null}
                          </div>
                        </article>
                      ))}
                    </div>
                  </div>
                </div>
              </section>
            ) : null}

            {itineraryItems.length > 0 ? (
              <section class="pb-16 md:pb-20">
                <h2 class="mb-8 text-2xl font-bold italic text-gray-900 md:text-3xl" style="font-family: 'Playfair Display', serif;">{itineraryTitle}</h2>
                <div class="border-t border-gray-300">
                  {itineraryItems.map((item: any, index: number) => {
                    const imageUrl = getOdooMediaUrl(item.image);
                    const galleryId = `itinerary-gallery-${index}`;
                    return (
                      <details class="border-b border-gray-200 py-4" open={index === 0}>
                        <summary class="flex cursor-pointer list-none items-start gap-4 text-left">
                          <span class="mt-0.5 inline-flex shrink-0 items-center gap-2 text-green-700">
                            <span class="text-base font-semibold">{itineraryItemLabel}</span>
                            <span class="inline-flex h-6 min-w-6 items-center justify-center rounded-full border border-green-600 px-1 text-xs font-bold leading-none">{index + 1}</span>
                          </span>
                          <span class="pt-0.5 text-base font-semibold text-gray-900 md:text-lg" set:html={item.titleHtml || `${itineraryItemLabel} ${index + 1}`} />
                        </summary>
                        <div class="mt-4 pl-0 md:pl-24">
                          {item.images.length > 0 ? (
                            <div class="mt-2">
                              <div class="mb-3 flex items-center justify-end gap-2">
                                <button
                                  type="button"
                                  class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#d1d5db] bg-white text-xl text-[#111827] transition hover:border-[#1AA093] hover:text-[#1AA093]"
                                  data-itinerary-gallery-prev
                                  data-gallery-target={galleryId}
                                  aria-label="Imagen anterior"
                                >
                                  &lsaquo;
                                </button>
                                <button
                                  type="button"
                                  class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#d1d5db] bg-white text-xl text-[#111827] transition hover:border-[#1AA093] hover:text-[#1AA093]"
                                  data-itinerary-gallery-next
                                  data-gallery-target={galleryId}
                                  aria-label="Imagen siguiente"
                                >
                                  &rsaquo;
                                </button>
                              </div>
                              <div id={galleryId} class="flex gap-3 overflow-x-auto pb-2 snap-x snap-mandatory" data-itinerary-gallery>
                                {item.images.map((image: any, imageIndex: number) => (
                                  <button
                                    type="button"
                                    class="group relative h-56 w-[82%] min-w-[82%] overflow-hidden snap-start md:h-64 md:max-w-2xl"
                                    data-itinerary-lightbox-open
                                    data-gallery-index={index}
                                    data-slide-index={imageIndex}
                                    data-src={image.url}
                                    data-alt={image.alt}
                                    aria-label="Ver imagen en grande"
                                  >
                                    <img src={image.url} alt={image.alt} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" />
                                  </button>
                                ))}
                              </div>
                            </div>
                          ) : imageUrl ? <img src={imageUrl} alt={item.imageAltText} class="mx-auto h-56 w-full max-w-2xl object-cover md:h-64" /> : null}
                          {item.descriptionHtml ? <div class="prose prose-sm md:prose-base mt-3 max-w-none text-black md:ml-6 md:mr-14 lg:ml-10 lg:mr-28 prose-p:mb-3 prose-p:leading-7 prose-p:text-justify prose-p:last:mb-0 prose-headings:text-black prose-strong:text-black prose-li:text-black prose-a:text-[#1AA093] prose-a:no-underline hover:prose-a:text-[#0e8a7e] [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:pl-6 [&_[style*='text-align:center']]:text-center [&_[style*='text-align:right']]:text-right [&_[style*='text-align:left']]:text-left [&_img]:my-3 [&_img]:mx-auto [&_img]:block [&_img]:h-auto [&_img]:w-full [&_img]:max-w-[560px] [&_img]:max-h-[340px] [&_img]:object-cover" set:html={item.descriptionHtml} /> : null}
                        </div>
                      </details>
                    );
                  })}
                </div>
              </section>
            ) : null}

            {scheduleItems.length > 0 ? (
              <section class="pb-16 md:pb-20">
                <h2 class="mb-6 text-2xl font-bold italic text-gray-900 md:text-3xl" style="font-family: 'Playfair Display', serif;">{scheduleTitle}</h2>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                  {scheduleItems.map((item: any) => (
                    <article class="border border-[#e2e8f0] bg-white p-5 md:p-6">
                      <h3 class="mb-3 text-base font-bold text-gray-900 md:text-lg">{[item.horaEntrada, item.horaSalida].filter(Boolean).join(" - ") || "--"}</h3>
                    </article>
                  ))}
                </div>
              </section>
            ) : null}

            {(includedItems.length > 0 || excludedItems.length > 0) ? (
              <section class="pb-16 md:pb-20">
                <div class="grid grid-cols-2 gap-3 lg:gap-6">
                  {includedItems.length > 0 ? (
                    <article class="border border-[#e2e8f0] bg-white p-3 md:p-8">
                      <h3 class="mb-4 text-base font-bold italic text-[#111827] md:text-2xl lg:text-3xl" style="font-family: 'Playfair Display', serif;"><span class="mr-2 text-green-700">✓</span>{includedTitle}</h3>
                      <div class="divide-y divide-[#e5e7eb]">
                        {includedItems.map((item: any) => (
                          <div class="flex items-start gap-2 py-1.5 md:py-2.5">
                            <span class="mt-0.5 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-green-700 text-xs text-green-700 md:h-5 md:w-5">{item.icon || "✓"}</span>
                            <p class="text-xs leading-snug text-[#374151] md:text-sm" set:html={richContentToHtml(item.text)} />
                          </div>
                        ))}
                      </div>
                    </article>
                  ) : null}
                  {excludedItems.length > 0 ? (
                    <article class="border border-[#e2e8f0] bg-white p-3 md:p-8">
                      <h3 class="mb-4 text-base font-bold italic text-[#111827] md:text-2xl lg:text-3xl" style="font-family: 'Playfair Display', serif;"><span class="mr-2 text-[#6b7280]">✕</span>{excludedTitle}</h3>
                      <div class="divide-y divide-[#e5e7eb]">
                        {excludedItems.map((item: any) => (
                          <div class="flex items-start gap-2 py-1.5 md:py-2.5">
                            <span class="mt-0.5 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-[#9ca3af] text-xs text-[#6b7280] md:h-5 md:w-5">{item.icon || "✕"}</span>
                            <p class="text-xs leading-snug text-[#374151] md:text-sm" set:html={richContentToHtml(item.text)} />
                          </div>
                        ))}
                      </div>
                    </article>
                  ) : null}
                </div>
              </section>
            ) : null}

            {featuredImages.length > 0 ? (
              <section class="pb-14 md:pb-20">
                <h2 class="mb-6 text-2xl font-bold italic text-gray-900 md:text-3xl" style="font-family: 'Playfair Display', serif;">{galleryTitle}</h2>
                <div class="grid grid-cols-2 gap-px md:grid-cols-4">
                  {featuredImages.map((item: any, index: number) => {
                    const imageUrl = getOdooMediaUrl(item.image);
                    return imageUrl ? (
                      <div class="relative group overflow-hidden aspect-square" key={index}>
                        <img src={imageUrl} alt={item.alt || sourceTour.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-300" />
                      </div>
                    ) : null;
                  })}
                </div>
              </section>
            ) : null}

            {relatedTours.length > 0 ? (
              <>
                <Ribbon
                  text={moreToursRibbonText}
                  backgroundClass="bg-white"
                  maxWidthClass="max-w-7xl"
                  paddingClass="py-6 md:py-8"
                  textClass="text-base md:text-xl lg:text-2xl text-gray-900 leading-relaxed"
                  accentClass="bg-orange-500"
                  sectionClass="mb-4 md:mb-6"
                />
                <section class="pt-1 pb-10 md:pt-2 md:pb-14">
                  <div class="mx-auto w-full max-w-7xl px-6">
                    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                      {relatedTours.map((tour: any) => {
                        const imageUrl = getOdooMediaUrl(tour.heroSlideImages?.[0]);
                        return (
                          <article class="flex h-full flex-col overflow-hidden border border-[#e2e8f0] bg-white">
                            <a href={`/${lang}/tours/${tour.slug}`} class="block" aria-label={tour.title || tourDetailCtaLabel}>
                              {imageUrl ? <img src={imageUrl} alt={tour.title} class="h-52 w-full object-cover" /> : <div class="h-52 w-full bg-gray-200" />}
                            </a>
                            <div class="flex flex-1 flex-col p-4 md:p-5">
                              {tour.title ? <h3 class="text-lg font-semibold text-gray-900">{tour.title}</h3> : null}
                              {tour.adultUnitPrice > 0 ? <p class="mt-2 text-sm leading-relaxed text-gray-600">{priceFromLabel} {formatPrice(getDiscountedPrice(tour.adultUnitPrice, tour.discount), lang)}</p> : null}
                              <a href={`/${lang}/tours/${tour.slug}`} class="mt-auto inline-flex w-fit self-start items-center justify-center border border-green-700 px-4 py-2 text-sm font-semibold text-green-700 transition hover:bg-green-700 hover:text-white">{tourDetailCtaLabel}</a>
                            </div>
                          </article>
                        );
                      })}
                    </div>
                  </div>
                </section>
              </>
            ) : null}
          </div>

          <aside class="mt-12 lg:mt-0">
            <BookingCard
              lang={bookingLang}
              titulo={bookingTitle}
              duracion={bookingDuration}
              disponibilidad={availability}
              precioAdultoUsd={toNumber(sourceTour.adultUnitPrice)}
              precioNinoUsd={toNumber(sourceTour.childUnitPrice)}
              descuentoUsd={toNumber(sourceTour.discount)}
              discountMode="percent"
              duracionDias={durationDays}
              calendarLocale={calendarLocale}
              calendarStart={calendarStart}
              calendarMonth={calendarMonth}
              weekdays={weekdays}
            />
          </aside>
        </div>
      </section>

      {faqItems.length > 0 ? (
        <section class="bg-white py-10 md:py-12">
          <div class="mx-auto w-full max-w-7xl px-6">
            <h3 class="mb-6 text-4xl font-semibold text-[#111827]">{faqTitle}</h3>
            <div class="divide-y divide-[#e5e7eb] border-y border-[#e5e7eb]">
              {faqItems.map((item: any) => (
                <details class="group py-4">
                  <summary class="flex cursor-pointer list-none items-center gap-4 text-2xl font-medium text-[#374151] marker:hidden">
                    <span class="text-3xl leading-none text-green-700 group-open:hidden">+</span>
                    <span class="hidden text-3xl leading-none text-green-700 group-open:inline">-</span>
                    <span>{item.questionText}</span>
                  </summary>
                  <div class="pl-10 pt-3 text-lg leading-relaxed text-[#4b5563] text-justify [&_p]:mb-3 [&_p:last-child]:mb-0" set:html={item.answerHtml} />
                </details>
              ))}
            </div>
          </div>
        </section>
      ) : null}

      <div class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 px-4" data-itinerary-lightbox>
        <button type="button" class="absolute right-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-2xl text-white transition hover:bg-white/20" data-itinerary-lightbox-close aria-label="Cerrar">&times;</button>
        <button type="button" class="absolute left-4 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-3xl text-white transition hover:bg-white/20" data-itinerary-lightbox-prev aria-label="Anterior">&lsaquo;</button>
        <div class="relative max-h-[90vh] max-w-[92vw]">
          <img src="" alt="" class="max-h-[90vh] max-w-[92vw] object-contain" data-itinerary-lightbox-img />
          <p class="absolute bottom-3 left-0 right-0 text-center text-sm text-white/75" data-itinerary-lightbox-counter></p>
        </div>
        <button type="button" class="absolute right-4 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-3xl text-white transition hover:bg-white/20" data-itinerary-lightbox-next aria-label="Siguiente">&rsaquo;</button>
      </div>
    </main>

    <BookingModal
      lang={bookingLang}
      tourTitle={sourceTour.title}
      tourSlug={sourceTour.slug || tourSlug}
      scheduleOptions={scheduleItems.map((item: any) => {
        const label = [item.horaEntrada, item.horaSalida].filter(Boolean).join(" - ");
        return { label: label || "Horario", value: label || "Horario" };
      })}
    />
    <Footer currentLang={lang} {t} />
    <script is:inline>
      (() => {
        const galleryState = new WeakMap();

        const stopAutoScroll = (gallery) => {
          const state = galleryState.get(gallery);
          if (!state) return;
          if (state.timerId) window.clearTimeout(state.timerId);
          state.timerId = 0;
        };

        const startAutoScroll = (gallery) => {
          if (!(gallery instanceof HTMLElement)) return;
          const slides = Array.from(gallery.children);
          if (slides.length <= 1) return;

          stopAutoScroll(gallery);

          const state = {
            timerId: 0,
          };

          const advance = () => {
            const currentLeft = gallery.scrollLeft;
            const positions = slides
              .map((slide) => slide instanceof HTMLElement ? slide.offsetLeft : 0)
              .sort((a, b) => a - b);
            const nextLeft = positions.find((position) => position > currentLeft + 8) ?? 0;

            gallery.scrollTo({ left: nextLeft, behavior: "smooth" });
            state.timerId = window.setTimeout(advance, 4200);
          };

          state.timerId = window.setTimeout(advance, 4200);
          galleryState.set(gallery, state);
        };

        document.querySelectorAll("[data-itinerary-gallery]").forEach((gallery) => {
          if (!(gallery instanceof HTMLElement)) return;
          startAutoScroll(gallery);
          gallery.addEventListener("mouseenter", () => stopAutoScroll(gallery));
          gallery.addEventListener("mouseleave", () => startAutoScroll(gallery));
          gallery.addEventListener("touchstart", () => stopAutoScroll(gallery), { passive: true });
          gallery.addEventListener("touchend", () => startAutoScroll(gallery), { passive: true });
        });

        document.querySelectorAll("[data-itinerary-gallery-prev], [data-itinerary-gallery-next]").forEach((button) => {
          button.addEventListener("click", () => {
            const targetId = button.getAttribute("data-gallery-target");
            if (!targetId) return;
            const gallery = document.getElementById(targetId);
            if (!gallery) return;
            stopAutoScroll(gallery);
            const step = Math.max(gallery.clientWidth * 0.85, 240);
            const direction = button.hasAttribute("data-itinerary-gallery-prev") ? -1 : 1;
            gallery.scrollBy({ left: step * direction, behavior: "smooth" });
            window.setTimeout(() => startAutoScroll(gallery), 2500);
          });
        });

        const lightbox = document.querySelector("[data-itinerary-lightbox]");
        const img = document.querySelector("[data-itinerary-lightbox-img]");
        const counter = document.querySelector("[data-itinerary-lightbox-counter]");
        if (!lightbox || !(img instanceof HTMLImageElement)) return;

        const buttons = Array.from(document.querySelectorAll("[data-itinerary-lightbox-open]"));
        const images = buttons.map((button) => ({
          src: button.getAttribute("data-src") || "",
          alt: button.getAttribute("data-alt") || "",
        })).filter((image) => image.src);
        if (!images.length) return;

        let current = 0;
        const render = (index) => {
          current = (index + images.length) % images.length;
          img.src = images[current].src;
          img.alt = images[current].alt;
          if (counter) counter.textContent = `${current + 1} / ${images.length}`;
        };
        const open = (index) => {
          render(index);
          lightbox.classList.remove("hidden");
          lightbox.classList.add("flex");
          document.body.style.overflow = "hidden";
        };
        const close = () => {
          lightbox.classList.add("hidden");
          lightbox.classList.remove("flex");
          document.body.style.overflow = "";
        };

        buttons.forEach((button, index) => button.addEventListener("click", () => open(index)));
        document.querySelector("[data-itinerary-lightbox-close]")?.addEventListener("click", close);
        document.querySelector("[data-itinerary-lightbox-prev]")?.addEventListener("click", () => render(current - 1));
        document.querySelector("[data-itinerary-lightbox-next]")?.addEventListener("click", () => render(current + 1));
        lightbox.addEventListener("click", (event) => {
          if (event.target === lightbox) close();
        });
        document.addEventListener("keydown", (event) => {
          if (lightbox.classList.contains("hidden")) return;
          if (event.key === "ArrowLeft") render(current - 1);
          if (event.key === "ArrowRight") render(current + 1);
          if (event.key === "Escape") close();
        });
      })();
    </script>
  </body>
</html>
