---
import { defaultLanguage, getTranslation, languages } from "../../../i18n";
import "../../../styles/global.css";
import GoogleAnalytics from "../../../components/shared/GoogleAnalytics.astro";
import Navbar from "../../../components/shared/Navbar.astro";
import Footer from "../../../components/shared/Footer.astro";
import BookingModal from "../../../components/tours/BookingModal.astro";
import BookingCard from "../../../components/tours/BookingCard.astro";
import { formatPrice } from "../../../utils/currency";
import { buildLocalizedSlugs, fetchOdooWebJson, getOdooMediaUrl, getOdooWebLang } from "../../../utils/odooWeb";

export function getStaticPaths() {
  return [];
}

const rawLang = (Astro.params.lang ?? defaultLanguage).toLowerCase();
const lang = Object.keys(languages).includes(rawLang) ? rawLang : defaultLanguage;
const tourSlug = String(Astro.params.tour ?? "").toLowerCase();
const t = getTranslation(lang);

if (rawLang !== lang) {
  return Astro.redirect(`/${lang}/tours/${tourSlug}`);
}

let sourceTour: any = null;
try {
  const json = await fetchOdooWebJson(
    `/incas/api/web/tours/${encodeURIComponent(tourSlug)}?lang=${getOdooWebLang(lang)}`
  );
  sourceTour = json?.data ?? null;
} catch (error) {
  console.error("[tour] Error:", error);
}

if (!sourceTour) {
  return Astro.redirect(`/${lang}/destinos`);
}

const cleanText = (value: any) => (typeof value === "string" ? value.trim() : "");
const toNumber = (value: any) => {
  const number = Number(value);
  return Number.isFinite(number) ? number : 0;
};
const toObjectList = (value: any) =>
  Array.isArray(value) ? value.filter((item: any) => item && typeof item === "object") : [];
const seoTitle =
  cleanText(sourceTour.seoTitle) ||
  cleanText(sourceTour.metaTitle) ||
  cleanText(sourceTour.title) ||
  (lang === "en" ? "Tour details" : "Detalle del tour");
const seoDescription = cleanText(sourceTour.seoDescription) || cleanText(sourceTour.metaDescription);
const siteOrigin = (Astro.site?.origin ?? "https://incasparadise.com").replace(/\/$/, "");
const canonical = `${siteOrigin}/${lang}/tours/${sourceTour.slug || tourSlug}`;
const heroImages = toObjectList(sourceTour.heroSlideImages);
const heroImage = getOdooMediaUrl(heroImages[0]);
const featuredImages = toObjectList(sourceTour.featuredImages);
const itineraryItems = toObjectList(sourceTour.itineraryItems);
const scheduleItems = toObjectList(sourceTour.scheduleItems);
const includedItems = toObjectList(sourceTour.includedItems);
const excludedItems = toObjectList(sourceTour.excludedItems);
const faqItems = toObjectList(sourceTour.faqItems);
const relatedTours = toObjectList(sourceTour.relatedTours);
const highlightItems = toObjectList(sourceTour.highlightsItems);
const tourSlugs = sourceTour.slugs ?? buildLocalizedSlugs(sourceTour.slug || tourSlug);
const destinationNames = toObjectList(sourceTour.destinos).map((item: any) => item.title).filter(Boolean);
const priceFromLabel =
  lang === "en" ? "From"
  : lang === "pt" ? "Desde"
  : lang === "fr" ? "Des"
  : lang === "it" ? "Da"
  : "Desde";
const bookingLang = (["es", "en", "pt", "fr", "it"].includes(lang) ? lang : "es") as "es" | "en" | "pt" | "fr" | "it";
const getDiscountedPrice = (price: number, discountPercent: number) =>
  Math.max(0, price - (price * Math.max(0, discountPercent)) / 100);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonical} />
    {heroImage ? <meta property="og:image" content={heroImage} /> : null}
    <meta name="twitter:card" content={heroImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    {heroImage ? <meta name="twitter:image" content={heroImage} /> : null}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristTrip",
      "name": seoTitle,
      "description": seoDescription,
      "url": canonical,
      "provider": {
        "@type": "TravelAgency",
        "name": "Inca's Paradise",
        "url": "https://incasparadise.com"
      },
      ...(heroImage ? { image: heroImage } : {}),
      ...(sourceTour.adultUnitPrice ? {
        offers: {
          "@type": "Offer",
          price: toNumber(sourceTour.adultUnitPrice),
          priceCurrency: "USD",
          availability: "https://schema.org/InStock"
        }
      } : {}),
    })} />
    {heroImage && <link rel="preload" as="image" href={heroImage} fetchpriority="high" />}
    <GoogleAnalytics />
  </head>
  <body class="bg-white text-stone-800 overflow-x-hidden flex flex-col min-h-screen">
    <Navbar t={t} currentLang={lang} whatsappTourName={sourceTour.title} />
    <script is:inline define:vars={{ tourSlugs, serviceId: sourceTour.serviceId ?? null, destinoNombre: destinationNames[0] ?? null }}>
      window.__tourData = { serviceId, destinoNombre };
      window.__tourSlugs = tourSlugs;
    </script>

    <main class="flex-1">
      <section class="relative min-h-[70vh] overflow-hidden">
        {heroImage ? <img src={heroImage} alt={sourceTour.title} class="absolute inset-0 w-full h-full object-cover" /> : <div class="absolute inset-0 bg-stone-300" />}
        <div class="absolute inset-0 bg-black/45" />
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 text-white">
          {destinationNames.length > 0 ? <p class="uppercase tracking-[0.25em] text-xs text-white/80 mb-4">{destinationNames.join(" · ")}</p> : null}
          <h1 class="text-4xl md:text-6xl max-w-4xl" style="font-family: 'Playfair Display', serif; font-style: italic;">{sourceTour.title}</h1>
          {sourceTour.highlightsLead ? <div class="mt-6 max-w-3xl text-lg text-white/90" set:html={sourceTour.highlightsLead} /> : null}
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_320px] lg:gap-10">
          <div class="space-y-12">
            {(sourceTour.highlightsTitle || highlightItems.length) && (
              <section>
                {sourceTour.highlightsTitle ? <h2 class="text-3xl text-stone-900 mb-6" style="font-family: 'Playfair Display', serif; font-style: italic;">{sourceTour.highlightsTitle}</h2> : null}
                <div class="grid gap-4 md:grid-cols-2">
                  {highlightItems.map((item: any) => (
                    <article class="border border-stone-200 p-5 bg-stone-50">
                      {item.title ? <h3 class="text-xl text-stone-900 mb-2" style="font-family: 'Playfair Display', serif; font-style: italic;">{item.title}</h3> : null}
                      {item.description ? <div class="text-stone-700" set:html={item.description} /> : null}
                    </article>
                  ))}
                </div>
              </section>
            )}

            {itineraryItems.length > 0 && (
              <section>
                <h2 class="text-3xl text-stone-900 mb-6" style="font-family: 'Playfair Display', serif; font-style: italic;">
                  {sourceTour.itineraryTitle || (lang === "en" ? "Itinerary" : "Itinerario")}
                </h2>
                <div class="space-y-8">
                  {itineraryItems.map((item: any, index: number) => {
                    const imageUrl = getOdooMediaUrl(item.image);
                    return (
                      <article class="grid gap-6 lg:grid-cols-[220px_minmax(0,1fr)] items-start">
                        {imageUrl ? <img src={imageUrl} alt={item.imageAlt || item.title || `Itinerary ${index + 1}`} class="w-full h-52 object-cover" /> : null}
                        <div>
                          {item.title ? <h3 class="text-2xl text-stone-900 mb-2" style="font-family: 'Playfair Display', serif; font-style: italic;">{item.title}</h3> : null}
                          {item.description ? <div class="text-stone-700 prose prose-stone max-w-none" set:html={item.description} /> : null}
                        </div>
                      </article>
                    );
                  })}
                </div>
              </section>
            )}

            {scheduleItems.length > 0 && (
              <section>
                <h2 class="text-3xl text-stone-900 mb-6" style="font-family: 'Playfair Display', serif; font-style: italic;">
                  {sourceTour.scheduleTitle || (lang === "en" ? "Schedules" : "Horarios")}
                </h2>
                <div class="grid gap-4 md:grid-cols-2">
                  {scheduleItems.map((item: any) => (
                    <div class="border border-stone-200 p-5 bg-white">
                      <p class="text-sm uppercase tracking-[0.2em] text-[#1AA093]">{item.horaEntrada || "--"} {item.horaSalida ? `- ${item.horaSalida}` : ""}</p>
                    </div>
                  ))}
                </div>
              </section>
            )}

            {(includedItems.length > 0 || excludedItems.length > 0) && (
              <section class="grid gap-8 md:grid-cols-2">
                {includedItems.length > 0 && (
                  <div>
                    <h2 class="text-3xl text-stone-900 mb-4" style="font-family: 'Playfair Display', serif; font-style: italic;">
                      {sourceTour.includedTitle || (lang === "en" ? "Included" : "Incluye")}
                    </h2>
                    <ul class="space-y-3">
                      {includedItems.map((item: any) => <li class="flex items-start gap-3"><span class="text-[#1AA093]">✓</span><span>{item.text}</span></li>)}
                    </ul>
                  </div>
                )}
                {excludedItems.length > 0 && (
                  <div>
                    <h2 class="text-3xl text-stone-900 mb-4" style="font-family: 'Playfair Display', serif; font-style: italic;">
                      {sourceTour.excludedTitle || (lang === "en" ? "Not Included" : "No incluye")}
                    </h2>
                    <ul class="space-y-3">
                      {excludedItems.map((item: any) => <li class="flex items-start gap-3"><span class="text-stone-500">✕</span><span>{item.text}</span></li>)}
                    </ul>
                  </div>
                )}
              </section>
            )}

            {featuredImages.length > 0 && (
              <section>
                <h2 class="text-3xl text-stone-900 mb-6" style="font-family: 'Playfair Display', serif; font-style: italic;">
                  {sourceTour.featuredTitle || (lang === "en" ? "Gallery" : "Galeria")}
                </h2>
                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                  {featuredImages.map((item: any) => {
                    const imageUrl = getOdooMediaUrl(item.image);
                    return imageUrl ? <img src={imageUrl} alt={item.alt || sourceTour.title} class="w-full h-64 object-cover" /> : null;
                  })}
                </div>
              </section>
            )}

            {faqItems.length > 0 && (
              <section>
                <h2 class="text-3xl text-stone-900 mb-6" style="font-family: 'Playfair Display', serif; font-style: italic;">
                  {sourceTour.faqTitle || "FAQ"}
                </h2>
                <div class="space-y-4">
                  {faqItems.map((item: any) => (
                    <details class="border border-stone-200 p-5">
                      <summary class="cursor-pointer font-semibold">{item.question}</summary>
                      <div class="mt-3 text-stone-700" set:html={item.answer} />
                    </details>
                  ))}
                </div>
              </section>
            )}
          </div>

          <aside class="mt-12 lg:mt-0">
            <div class="lg:sticky lg:top-28">
              <BookingCard
                lang={bookingLang}
                precioAdultoUsd={toNumber(sourceTour.adultUnitPrice)}
                precioNinoUsd={toNumber(sourceTour.childUnitPrice)}
                descuentoUsd={toNumber(sourceTour.discount)}
                discountMode="percent"
                duracionDias={toNumber(sourceTour.durationDays) || 1}
                scheduleOptions={scheduleItems.map((item: any) => {
                  const label = [item.horaEntrada, item.horaSalida].filter(Boolean).join(" - ");
                  return { label: label || "Horario", value: label || "Horario" };
                })}
              />
            </div>
          </aside>
        </div>
      </section>

      {relatedTours.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
          <h2 class="text-3xl text-stone-900 mb-8" style="font-family: 'Playfair Display', serif; font-style: italic;">
            {lang === "en" ? "Related Tours" : "Tours relacionados"}
          </h2>
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {relatedTours.map((tour: any) => {
              const imageUrl = getOdooMediaUrl(tour.heroSlideImages?.[0]);
              return (
                <a href={`/${lang}/tours/${tour.slug}`} class="group block bg-white shadow-sm hover:shadow-lg transition overflow-hidden">
                  {imageUrl ? <img src={imageUrl} alt={tour.title} class="w-full h-64 object-cover group-hover:scale-[1.02] transition-transform duration-500" /> : <div class="w-full h-64 bg-stone-300" />}
                  <div class="p-5">
                    <h3 class="text-2xl text-stone-900" style="font-family: 'Playfair Display', serif; font-style: italic;">{tour.title}</h3>
                    {tour.adultUnitPrice > 0 ? (
                      <p class="mt-3 text-sm text-[#1AA093] font-semibold">
                        {priceFromLabel} {formatPrice(getDiscountedPrice(tour.adultUnitPrice, tour.discount), lang)}
                      </p>
                    ) : null}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </main>

    <BookingModal
      lang={bookingLang}
      tourTitle={sourceTour.title}
      tourSlug={sourceTour.slug || tourSlug}
      scheduleOptions={scheduleItems.map((item: any) => {
        const label = [item.horaEntrada, item.horaSalida].filter(Boolean).join(" - ");
        return { label: label || "Horario", value: label || "Horario" };
      })}
    />
    <Footer currentLang={lang} {t} />
  </body>
</html>
