---
import { getTranslation, languages, defaultLanguage, type Language } from '../../i18n';
import '../../styles/global.css';
import GoogleAnalytics from '../../components/shared/GoogleAnalytics.astro';
import Navbar from '../../components/shared/Navbar.astro';
import Hero from '../../components/LandingPage/Hero.astro';
import Features from '../../components/LandingPage/Features.astro';
import DestinationsGallery from '../../components/LandingPage/DestinationsGallery.astro';
import StylesTrips from '../../components/LandingPage/StylesTrips.astro';
import SustainabilitySection from '../../components/LandingPage/SustainabilitySection.astro';
import ValuesSection from '../../components/LandingPage/ValuesSection.astro';
import ReviewsCarousel from '../../components/LandingPage/ReviewsCarousel.astro';
import CertificationsCarousel from '../../components/LandingPage/CertificationsCarousel.astro';
import CertificationsDetail from '../../components/LandingPage/CertificationsDetail.astro';
import Commitment from '../../components/LandingPage/Commitment.astro';
import Footer from '../../components/shared/Footer.astro';
import SEOHead from '../../components/SEO/SEOHead.astro';

// Función requerida para rutas dinámicas en Astro
export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang }
  }));
}

// Parámetro dinámico de la ruta
const { lang } = Astro.params;

// Validar que el idioma sea válido, si no redirigir al idioma por defecto
const validLang = Object.keys(languages).includes(lang as string) 
  ? (lang as Language)
  : defaultLanguage;

// Si el idioma no es válido, redirigir
if (!Object.keys(languages).includes(lang as string)) {
  return Astro.redirect(`/${validLang}/`);
}

const t = getTranslation(validLang);
const currentLang = validLang;

// SEO Configuration
const titles: Record<Language, string> = {
  es: "Inca's Paradise - Aventuras Personalizadas en Perú",
  en: "Inca's Paradise - Tailor-made Adventures in Peru",
  pt: "Inca's Paradise - Aventuras Personalizadas no Peru",
  fr: "Inca's Paradise - Aventures Sur Mesure au Pérou",
  it: "Inca's Paradise - Avventure Personalizzate in Perù"
};

const descriptions: Record<Language, string> = {
  es: "Viajes personalizados de lujo a Perú. Experimente el Camino Inca, Machu Picchu y aventuras sostenibles con guías expertos locales.",
  en: "Tailor-made luxury travel in Peru. Experience the Inca Trail, Machu Picchu, and sustainable adventures with expert local guides.",
  pt: "Viagens personalizadas de luxo no Peru. Experiencie a Trilha Inca, Machu Picchu e aventuras sustentáveis com guias locais especialistas.",
  fr: "Voyages de luxe sur mesure au Pérou. Découvrez le Chemin de l'Inca, Machu Picchu et des aventures durables avec des guides locaux experts.",
  it: "Viaggio di lusso su misura in Perù. Scopri il Sentiero Inca, Machu Picchu e avventure sostenibili con guide locali esperte."
};

// Alternate language links for hreflang
const alternateLanguages = Object.keys(languages).map(lang => ({
  lang: lang === 'es' ? 'es-PE' : lang === 'pt' ? 'pt-BR' : lang,
  url: `${Astro.site}${lang}/`
}));

// Schema.org Organization Structured Data
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "TravelAgency",
  "name": "Inca's Paradise",
  "description": descriptions[currentLang],
  "url": Astro.site,
  "logo": `${Astro.site}logo.png`,
  "image": `${Astro.site}og-image.jpg`,
  "sameAs": [
    "https://www.facebook.com/IncasParadise",
    "https://www.instagram.com/incasparadise_/",
    "https://www.tiktok.com/@incasparadise_"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jr. Grau 460",
    "addressLocality": "Puno",
    "addressCountry": "PE"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+51-953-556-680",
    "contactType": "Customer Service",
    "email": "booking@incasparadise.com"
  },
  "priceRange": "$$"
};

// Genera langNames dinámicamente desde los idiomas disponibles
const langNames: Record<string, string> = Object.keys(languages).reduce((acc: Record<string, string>, lang: string) => {
  acc[lang] = lang;
  return acc;
}, {});
---

<html lang={langNames[currentLang]}>
	<head>
		<meta charset="utf-8" />
		<title>{titles[currentLang]}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
    
		<!-- SEO Meta Tags -->
		<SEOHead
			title={titles[currentLang]}
			description={descriptions[currentLang]}
			canonical={`${Astro.site}${currentLang}/`}
			ogImage={`${Astro.site}og-image.jpg`}
			ogType="website"
			currentLang={currentLang}
			alternateLanguages={alternateLanguages}
			structuredData={organizationSchema}
		/>
		
		<link rel="preload" as="image" href="/landing page images/wallpaper1.jpeg" fetchpriority="high" />

		<style>
			h1, h2 {
				font-family: 'Playfair Display', serif;
				font-weight: 500;
				font-style: italic;
			}

			#styles-carousel {
				scroll-behavior: smooth;
				scrollbar-width: thin;
				scrollbar-color: rgba(255, 255, 255, 0.3) transparent;
			}

			#styles-carousel::-webkit-scrollbar {
				height: 6px;
			}

			#styles-carousel::-webkit-scrollbar-track {
				background: transparent;
			}

			#styles-carousel::-webkit-scrollbar-thumb {
				background: rgba(255, 255, 255, 0.3);
				border-radius: 3px;
			}

			#styles-carousel::-webkit-scrollbar-thumb:hover {
				background: rgba(255, 255, 255, 0.5);
			}

			.style-card {
				transition: width 0.3s ease;
			}
		</style>
	  <GoogleAnalytics />
  </head>
	<body>
		<script is:inline defer src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
		
		<Navbar {t} {currentLang} />
		<Hero {t} />
		<Features {t} />
    <Commitment {t} />
		<DestinationsGallery {t} {currentLang} />
    <CertificationsDetail lang={currentLang} />
		<StylesTrips {t} {currentLang} />
		<SustainabilitySection {t} />
		<ValuesSection {t} />
		<ReviewsCarousel {t} />
    <CertificationsCarousel />
    <Footer {currentLang} {t} />
	</body>
</html>

