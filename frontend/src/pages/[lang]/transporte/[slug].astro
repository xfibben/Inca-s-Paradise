---
import { getTranslation, languages, defaultLanguage, type Language } from '../../../i18n';
import '../../../styles/global.css';
import GoogleAnalytics from '../../../components/shared/GoogleAnalytics.astro';
import Navbar from '../../../components/shared/Navbar.astro';
import Footer from '../../../components/shared/Footer.astro';
import BookingCard from '../../../components/tours/BookingCard.astro';
import BookingModal from '../../../components/tours/BookingModal.astro';
import { buildLocalizedSlugs, fetchOdooTransportJson, getOdooTransportLang } from '../../../utils/odooTransport';
import { richContentToHtml } from '../../../utils/richContent';

export function getStaticPaths() {
  // SSR: rutas generadas dinámicamente; retornamos array vacío
  return [];
}

const { lang, slug } = Astro.params;

const currentLang = Object.keys(languages).includes(lang as string)
  ? (lang as Language)
  : defaultLanguage;

const t = getTranslation(currentLang);

const metaDescriptionFallbacks: Record<string, (name: string) => string> = {
  es: (name) => `Conoce más sobre ${name} con Inca's Paradise.`,
  en: (name) => `Learn more about ${name} with Inca's Paradise.`,
  pt: (name) => `Saiba mais sobre ${name} com a Inca's Paradise.`,
  fr: (name) => `En savoir plus sur ${name} avec Inca's Paradise.`,
  it: (name) => `Scopri di più su ${name} con Inca's Paradise.`,
};

// Fetch del transporte por slug
let transporte: any = null;

try {
  const json = await fetchOdooTransportJson(
    `/incas/api/web/transportes/${encodeURIComponent(slug as string)}?lang=${getOdooTransportLang(currentLang)}`
  );
  transporte = json?.data ?? null;
} catch (e) {
  console.error("Error al obtener transporte:", e);
}

// Si no existe el transporte, redirigir al listado
if (!transporte) {
  return Astro.redirect(`/${currentLang}/tipo-transporte/`);
}

// Slugs localizados para el cambio de idioma en la navbar
const transporteSlugs: Record<string, string> = transporte?.slugs ?? buildLocalizedSlugs(slug as string);

function getImageUrl(media: any): string | null {
  if (!media) return null;
  const url = media?.formats?.large?.url ?? media?.formats?.medium?.url ?? media?.url;
  if (!url) return null;
  return url.startsWith('http') ? url : url;
}

// Variables para el BookingCard
type SupportedLang = "es" | "en" | "pt" | "fr" | "it";
const bookingLang: SupportedLang = (["es","en","pt","fr","it"].includes(currentLang) ? currentLang : "es") as SupportedLang;
const nowPeru = new Date(new Date().toLocaleString("en-US", { timeZone: "America/Lima" }));
const calendarLocale = currentLang === "en" ? "en-US" : "es-PE";
const calendarStart = `${nowPeru.getFullYear()}-${String(nowPeru.getMonth() + 1).padStart(2, "0")}`;
const calendarMonth = nowPeru.toLocaleDateString(calendarLocale, { month: "long", year: "numeric", timeZone: "America/Lima" });
const weekdays = currentLang === "en"
  ? ["M","T","W","Th","F","S","S"]
  : ["L","M","X","Ju","V","S","D"];
const bookingTitle = currentLang === "en" ? "BOOK NOW" : "RESERVA AHORA";
const availability = currentLang === "en" ? "Real-time availability" : "Disponibilidad en tiempo real";

// Procesamiento de precios por vehículo para el selector
interface PrecioVehiculoData {
  nombre: string;
  imagenUrl: string | null;
  precioAdulto: number;
  precioNino: number;
  descuento: number;
  nroAsientos: number | null;
}

const preciosConVehiculo: PrecioVehiculoData[] = [];
for (const precio of transporte.precios ?? []) {
  for (const veh of precio.vehiculo ?? []) {
    preciosConVehiculo.push({
      nombre: veh.nombre,
      imagenUrl: getImageUrl(veh.imagen),
      precioAdulto: precio.precioAdulto ?? 0,
      precioNino: precio.precioNino ?? 0,
      descuento: precio.descuento ?? 0,
      nroAsientos: veh.nro_asientos ?? null,
    });
  }
}

// Vehículo inicial desde query param o el primero disponible
const vehiculoParam = Astro.url.searchParams.get('vehiculo');
const selectedPrecio = vehiculoParam
  ? (preciosConVehiculo.find((p) => p.nombre === vehiculoParam) ?? preciosConVehiculo[0])
  : preciosConVehiculo[0];

const selectedVehiculoNombre = selectedPrecio?.nombre ?? null;
const displayImageUrl = selectedPrecio?.imagenUrl ?? getImageUrl(transporte.image);

// Precios y descripción
const adultPrice = selectedPrecio?.precioAdulto ?? 0;
const childPrice = selectedPrecio?.precioNino ?? 0;
const discountPrice = selectedPrecio?.descuento ?? 0;
const descripcionHtml = richContentToHtml(transporte.descripcion ?? '');

// Incluye / No incluye
const includedItems = Array.isArray(transporte.includedItems)
  ? transporte.includedItems
      .map((i: any) => ({
        text: typeof i.text === 'string' ? i.text.trim() : '',
        icon: typeof i.icon === 'string' ? i.icon.trim() : ''
      }))
      .filter((i: any) => i.text)
  : [];
const excludedItems = Array.isArray(transporte.excludedItems)
  ? transporte.excludedItems
      .map((i: any) => ({
        text: typeof i.text === 'string' ? i.text.trim() : '',
        icon: typeof i.icon === 'string' ? i.icon.trim() : ''
      }))
      .filter((i: any) => i.text)
  : [];
const hasIncludedBlock = Boolean(includedItems.length);
const hasExcludedBlock = Boolean(excludedItems.length);
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <title>{transporte.seoTitle || transporte.nombre} — Inca's Paradise</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={transporte.seoDescription || (metaDescriptionFallbacks[currentLang] ?? metaDescriptionFallbacks.es)(transporte.nombre)} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Schema JSON-LD Service -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify((() => {
      const schema: Record<string, any> = {
        "@context": "https://schema.org",
        "@type": "Service",
        "name": transporte.seoTitle || transporte.nombre,
        "description": transporte.seoDescription || (metaDescriptionFallbacks[currentLang] ?? metaDescriptionFallbacks.es)(transporte.nombre),
        "url": `${Astro.site}${currentLang}/transporte/${slug}`,
        "provider": {
          "@type": "TravelAgency",
          "name": "Inca's Paradise",
          "url": "https://incasparadise.com"
        }
      };
      if (displayImageUrl) schema["image"] = displayImageUrl;
      if (adultPrice) schema["offers"] = {
        "@type": "Offer",
        "price": adultPrice,
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      };
      return schema;
    })())} />
    <GoogleAnalytics />
  </head>

  <body class="bg-white text-stone-800 overflow-x-hidden flex flex-col min-h-screen" data-navbar-solid>

    <Navbar t={t} currentLang={currentLang} />

    <main class="flex-1">

      <!-- Título -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-0">
        <h1
          class="text-4xl md:text-6xl text-stone-900 leading-tight max-w-3xl"
          style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500;"
        >
          {transporte.nombre}
        </h1>
      </div>

      <!-- Detalle -->
      <section class="pt-6 pb-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_300px] lg:gap-10 lg:items-start">
        <div class="flex flex-col gap-6">

            <!-- Tipos de transporte asociados -->
            {transporte.tipos_transporte?.length > 0 && (
              <div>
                <p class="text-[#1AA093] uppercase tracking-widest text-xs mb-2">{t.transporte.tipos}</p>
                <div class="flex flex-wrap gap-2">
                  {transporte.tipos_transporte.map((tt: any) => (
                    <span class="px-3 py-1 bg-stone-100 text-stone-700  text-sm">
                      {tt.nombre}
                    </span>
                  ))}
                </div>
              </div>
            )}

            <!-- Datos del vehículo -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              {selectedPrecio?.nroAsientos != null && (
                <div class="bg-stone-50 p-4 flex flex-col items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#1AA093]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20H7a2 2 0 01-2-2V9a2 2 0 012-2h1V6a3 3 0 016 0v1h1a2 2 0 012 2v9a2 2 0 01-2 2z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6M9 16h6"/>
                  </svg>
                  <!-- Valor y etiqueta actualizados dinámicamente por el selector -->
                  <p id="nro-asientos-valor" class="text-stone-800 font-semibold text-lg leading-none">{selectedPrecio.nroAsientos}</p>
                  <p id="nro-asientos-label" class="text-[#1AA093] uppercase tracking-widest text-xs text-center">{selectedPrecio.nombre}</p>
                </div>
              )}
              {transporte.modelo_vehiculo && (
                <div class="bg-stone-50  p-4 flex flex-col items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#1AA093]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 17H5a2 2 0 01-2-2V9a2 2 0 012-2h1l2-3h6l2 3h1a2 2 0 012 2v6a2 2 0 01-2 2h-3"/>
                    <circle cx="7.5" cy="17.5" r="1.5" stroke-width="1.5"/>
                    <circle cx="16.5" cy="17.5" r="1.5" stroke-width="1.5"/>
                  </svg>
                  <p class="text-stone-800 font-semibold text-lg leading-none">{transporte.modelo_vehiculo}</p>
                  <p class="text-[#1AA093] uppercase tracking-widest text-xs text-center">{t.transporte.modeloVehiculo}</p>
                </div>
              )}
              {transporte.duracion_viaje && (
                <div class="bg-stone-50  p-4 flex flex-col items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#1AA093]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <circle cx="12" cy="12" r="9" stroke-width="1.5"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 7v5l3 3"/>
                  </svg>
                  <p class="text-stone-800 font-semibold text-lg leading-none">{transporte.duracion_viaje}</p>
                  <p class="text-[#1AA093] uppercase tracking-widest text-xs text-center">{t.transporte.duracionViaje}</p>
                </div>
              )}
              {transporte.distancia && (
                <div class="bg-stone-50  p-4 flex flex-col items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-[#1AA093]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                  </svg>
                  <p class="text-stone-800 font-semibold text-lg leading-none">{transporte.distancia}</p>
                  <p class="text-[#1AA093] uppercase tracking-widest text-xs text-center">{t.transporte.distancia}</p>
                </div>
              )}
            </div>

            <!-- Destinos -->
            <div class="flex flex-col sm:flex-row gap-6">
              {transporte.destino_origen?.length > 0 && (
                <div>
                  <p class="text-[#1AA093] uppercase tracking-widest text-xs mb-2">{t.transporte.origen}</p>
                  <div class="flex flex-wrap gap-2">
                    {transporte.destino_origen.map((d: any) => (
                      <span class="px-3 py-1 bg-stone-100 text-stone-700 text-sm">
                        {d.title}{transporte.descripcion_origen ? ` — ${transporte.descripcion_origen}` : ''}
                      </span>
                    ))}
                  </div>
                </div>
              )}
              {transporte.destino_llegada?.length > 0 && (
                <div>
                  <p class="text-[#1AA093] uppercase tracking-widest text-xs mb-2">{t.transporte.destino}</p>
                  <div class="flex flex-wrap gap-2">
                    {transporte.destino_llegada.map((d: any) => (
                      <span class="px-3 py-1 bg-stone-100 text-stone-700 text-sm">
                        {d.title}{transporte.descripcion_llegada ? ` — ${transporte.descripcion_llegada}` : ''}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <!-- Imagen del vehículo (full width) -->
            <div class="flex flex-col gap-3">
              {displayImageUrl && (
                <div class="overflow-hidden shadow-md">
                  <img
                    id="vehiculo-img"
                    src={displayImageUrl}
                    alt={selectedVehiculoNombre ?? transporte.nombre}
                    class="w-full h-72 sm:h-96 object-cover"
                    loading="lazy"
                  />
                </div>
              )}

              <!-- Selector de vehículo -->
              {preciosConVehiculo.length > 1 && (
                <div class="flex flex-wrap gap-2">
                  {preciosConVehiculo.map((pv) => (
                    <button
                      class={`vehiculo-selector-btn px-3 py-1.5 text-xs font-medium border transition-colors ${pv.nombre === selectedVehiculoNombre ? 'bg-[#1AA093] text-white border-[#1AA093]' : 'bg-white text-stone-700 border-stone-200 hover:border-[#1AA093]'}`}
                      data-nombre={pv.nombre}
                      data-imagen={pv.imagenUrl ?? ''}
                      data-precio-adulto={pv.precioAdulto}
                      data-precio-nino={pv.precioNino}
                      data-descuento={pv.descuento}
                      data-nro-asientos={pv.nroAsientos ?? ''}
                    >
                      {pv.nombre}
                    </button>
                  ))}
                </div>
              )}
            </div>

            <!-- Descripción -->
            {descripcionHtml && (
              <div
                class="prose prose-stone max-w-none text-[#374151] text-justify"
                set:html={descripcionHtml}
              />
            )}

            <!-- Incluye / No incluye -->
            {(hasIncludedBlock || hasExcludedBlock) && (
              <section class="pb-16 md:pb-20">
                <div class="grid grid-cols-2 gap-3 lg:gap-6">
                  {hasIncludedBlock && (
                    <article class="border border-[#e2e8f0] bg-white p-3 md:p-8">
                      <h3 class="mb-4 text-base md:text-2xl lg:text-3xl font-bold italic text-[#111827]" style="font-family: 'Playfair Display', serif;">
                        <span class="mr-2 text-green-700">✓</span>{t.transporte?.incluye ?? 'Incluye'}
                      </h3>
                      <div class="divide-y divide-[#e5e7eb]">
                        {includedItems.map((item: any) => (
                          <div class="flex items-start gap-2 py-2 md:py-4">
                            <span class="mt-0.5 inline-flex h-5 w-5 md:h-6 md:w-6 shrink-0 items-center justify-center rounded-full border border-green-700 text-xs md:text-sm text-green-700">
                              {item.icon || "✓"}
                            </span>
                            <p class="text-xs md:text-lg leading-snug text-[#374151]">{item.text}</p>
                          </div>
                        ))}
                      </div>
                    </article>
                  )}
                  {hasExcludedBlock && (
                    <article class="border border-[#e2e8f0] bg-white p-3 md:p-8">
                      <h3 class="mb-4 text-base md:text-2xl lg:text-3xl font-bold italic text-[#111827]" style="font-family: 'Playfair Display', serif;">
                        <span class="mr-2 text-[#6b7280]">✕</span>{t.transporte?.noIncluye ?? 'No incluye'}
                      </h3>
                      <div class="divide-y divide-[#e5e7eb]">
                        {excludedItems.map((item: any) => (
                          <div class="flex items-start gap-2 py-2 md:py-4">
                            <span class="mt-0.5 inline-flex h-5 w-5 md:h-6 md:w-6 shrink-0 items-center justify-center rounded-full border border-[#9ca3af] text-xs md:text-sm text-[#6b7280]">
                              {item.icon || "✕"}
                            </span>
                            <p class="text-xs md:text-lg leading-snug text-[#374151]">{item.text}</p>
                          </div>
                        ))}
                      </div>
                    </article>
                  )}
                </div>
              </section>
            )}

            <!-- Volver al listado -->
            <a
              href={`/${currentLang}/tipo-transporte/`}
              class="mt-4 inline-flex items-center gap-2 text-[#1AA093] hover:text-[#158a7e] text-sm font-medium transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
              {t.transporte.verTodos}
            </a>

        </div>

          <div class="mt-6">
          <BookingCard
            lang={bookingLang}
            titulo={bookingTitle}
            duracion={transporte.duracion_viaje ?? ''}
            disponibilidad={availability}
            precioAdultoUsd={adultPrice}
            precioNinoUsd={childPrice}
            descuentoUsd={discountPrice}
            discountMode="percent"
            duracionDias={1}
            calendarLocale={calendarLocale}
            calendarStart={calendarStart}
            calendarMonth={calendarMonth}
            weekdays={weekdays}
          />
          </div>
        </div>
      </section>

    </main>

    <BookingModal lang={bookingLang} tourTitle={transporte.nombre} tourSlug={transporte.slug} />
    <Footer currentLang={currentLang} t={t} />

    <!-- Inyecta datos del transporte para el BookingModal -->
    <script is:inline define:vars={{ transporteDocumentId: transporte.documentId, transporteNumericId: transporte.id, transporteSlug: transporte.slug, selectedVehiculoNombre }}>
      window.__transporteData = { documentId: transporteDocumentId, numericId: transporteNumericId, slug: transporteSlug };
      window.__selectedVehicleName = selectedVehiculoNombre;
    </script>


    <!-- Selector de vehículo: actualiza imagen y precios del BookingCard -->
    <script is:inline>
      document.querySelectorAll('.vehiculo-selector-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var img = document.getElementById('vehiculo-img');
          var imgUrl = this.getAttribute('data-imagen');
          if (img && imgUrl) img.src = imgUrl;

          // Actualiza estado activo
          document.querySelectorAll('.vehiculo-selector-btn').forEach(function(b) {
            b.classList.remove('bg-[#1AA093]', 'text-white', 'border-[#1AA093]');
            b.classList.add('bg-white', 'text-stone-700', 'border-stone-200', 'hover:border-[#1AA093]');
          });
          this.classList.add('bg-[#1AA093]', 'text-white', 'border-[#1AA093]');
          this.classList.remove('bg-white', 'text-stone-700', 'border-stone-200');

          // Actualiza precios en BookingCard
          var precioAdulto = parseFloat(this.getAttribute('data-precio-adulto') || '0');
          var precioNino = parseFloat(this.getAttribute('data-precio-nino') || '0');
          var descuento = parseFloat(this.getAttribute('data-descuento') || '0');
          if (typeof window.updateBookingPrices === 'function') {
            window.updateBookingPrices(precioAdulto, precioNino, descuento);
          }

          // Actualiza nro de asientos y label con el nombre del vehículo seleccionado
          var nroAsientos = this.getAttribute('data-nro-asientos');
          var nombreVehiculo = this.getAttribute('data-nombre');
          window.__selectedVehicleName = nombreVehiculo || '';
          var valorEl = document.getElementById('nro-asientos-valor');
          var labelEl = document.getElementById('nro-asientos-label');
          if (valorEl && labelEl) {
            if (nroAsientos) {
              valorEl.textContent = nroAsientos;
              labelEl.textContent = nombreVehiculo;
              valorEl.closest('.bg-stone-50').style.display = '';
            } else {
              // Oculta la tarjeta si el vehículo no tiene asientos definidos
              valorEl.closest('.bg-stone-50').style.display = 'none';
            }
          }
        });
      });
    </script>

    <script is:inline define:vars={{ transporteSlugs }}>
      window.__transporteSlugs = transporteSlugs;
    </script>

    <!-- Fija el BookingCard justo debajo del navbar (top-20 = 80px) -->
    <script is:inline>
      (() => {
        const cardEl = document.querySelector('#booking-card-content');
        const footer = document.querySelector('footer');
        if (!cardEl) return;

        const navbarH = 80;

        const updateTop = () => {
          if (window.innerWidth < 1024) { cardEl.style.top = ''; return; }
          const footerTop = footer ? footer.getBoundingClientRect().top : Infinity;
          const cardH = cardEl.offsetHeight;
          const maxTop = footerTop - cardH;
          cardEl.style.top = `${Math.min(navbarH, maxTop)}px`;
        };

        window.addEventListener('scroll', updateTop, { passive: true });
        window.addEventListener('resize', updateTop, { passive: true });
        updateTop();
      })();
    </script>

  </body>
</html>
