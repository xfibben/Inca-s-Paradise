---
import { getTranslation } from "../../../i18n";
import "../../../styles/global.css";
import GoogleAnalytics from "../../../components/shared/GoogleAnalytics.astro";
import Navbar from "../../../components/shared/Navbar.astro";
import Footer from "../../../components/shared/Footer.astro";
import Ribbon from "../../../components/shared/Ribbon.astro";
import { formatPrice } from "../../../utils/currency";
import { fetchOdooWebJson, getOdooMediaUrl, getOdooWebLang } from "../../../utils/odooWeb";
import { richContentToHtml } from "../../../utils/richContent";

type SupportedLang = "es" | "en" | "pt" | "it" | "fr";

export function getStaticPaths() {
  return [];
}

const rawLang = (Astro.params.lang ?? "es").toLowerCase();
const lang: SupportedLang = ["es", "en", "pt", "it", "fr"].includes(rawLang) ? (rawLang as SupportedLang) : "es";
const slugKey = String(Astro.params.slug ?? "").toLowerCase();
const t = getTranslation(lang);

if (rawLang !== lang) {
  return Astro.redirect(`/es/destinos/${slugKey}`);
}

let destination: any = null;
try {
  const json = await fetchOdooWebJson(`/incas/api/web/destinos/${encodeURIComponent(slugKey)}?lang=${getOdooWebLang(lang)}`);
  destination = json?.data ?? null;
} catch (error) {
  console.error("[destino] Error:", error);
}

if (!destination) {
  return Astro.redirect(`/${lang}/destinos`);
}

const pageTitle = destination.title ?? slugKey;
const pageDescription = richContentToHtml(destination.description);
const plainDescription = pageDescription.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
const siteOrigin = (Astro.site?.origin ?? "https://incasparadise.com").replace(/\/$/, "");
const canonical = `${siteOrigin}/${lang}/destinos/${destination.slug}`;
const seoTitle = String(destination?.seoTitle ?? "").trim() || pageTitle;
const seoDescription = String(destination?.seoDescription ?? "").trim() || plainDescription;
const heroSlides = Array.isArray(destination.heroSlideImages) ? destination.heroSlideImages : [];
const heroImage = getOdooMediaUrl(heroSlides[0]) || getOdooMediaUrl(destination.galleryThumbnail);
const iconItems = Array.isArray(destination.iconItems) ? destination.iconItems : [];
const tours = Array.isArray(destination.tours) ? destination.tours : [];
const introTitleHtml = richContentToHtml(destination.introTitle);
const introContentHtml = richContentToHtml(destination.introContent);
const smallTripItems = tours.filter((tour: any) => tour.tourType === "small_trip");
const packageItems = tours.filter((tour: any) => tour.tourType !== "small_trip");
const priceFromLabel =
  lang === "en" ? "From"
  : lang === "pt" ? "Desde"
  : lang === "fr" ? "Des"
  : lang === "it" ? "Da"
  : "Desde";
const getDiscountedPrice = (price: number, discountPercent: number) =>
  Math.max(0, price - (price * Math.max(0, discountPercent)) / 100);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonical} />
    {heroImage ? <meta property="og:image" content={heroImage} /> : null}
    <meta name="twitter:card" content={heroImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    {heroImage ? <meta name="twitter:image" content={heroImage} /> : null}
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristDestination",
      name: seoTitle,
      description: seoDescription,
      url: canonical,
      ...(heroImage ? { image: heroImage } : {}),
    })} />
    <GoogleAnalytics />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <Navbar {t} currentLang={lang} />
    <script is:inline define:vars={{ langSlugs: destination.slugs ?? { [lang]: destination.slug } }}>
      window.__langSlugs = langSlugs;
      window.__slugBasePath = "/destinos/";
    </script>
    <main>
      <section class="relative min-h-[60vh] overflow-hidden">
        {heroImage ? <img src={heroImage} alt={pageTitle} class="absolute inset-0 w-full h-full object-cover" /> : <div class="absolute inset-0 bg-stone-300" />}
        <div class="absolute inset-0 bg-black/45" />
        <div class="relative z-10 max-w-6xl mx-auto px-6 py-28 md:py-36 text-white">
          <h1 class="text-4xl md:text-6xl italic leading-tight" style="font-family: 'Playfair Display', serif;">
            {pageTitle}
          </h1>
          {pageDescription ? <div class="mt-6 max-w-3xl text-lg text-white/90 text-justify [&_p]:mb-3 [&_p:last-child]:mb-0" set:html={pageDescription} /> : null}
        </div>
      </section>

      {destination.primaryRibbon ? <Ribbon text={destination.primaryRibbon} maxWidthClass="max-w-6xl" /> : null}

      <section class="max-w-6xl mx-auto px-6 py-16">
        {(destination.introTitle || destination.introContent || iconItems.length > 0) && (
          <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] items-start">
            <div>
              {introTitleHtml ? <div class="text-3xl md:text-4xl italic text-stone-900 mb-6 [&_p]:m-0" style="font-family: 'Playfair Display', serif;" set:html={introTitleHtml} /> : null}
              {introContentHtml ? <div class="prose prose-stone max-w-none text-gray-700 text-justify" set:html={introContentHtml} /> : null}
            </div>
            {iconItems.length > 0 && (
              <div class="grid gap-4 sm:grid-cols-2">
                {iconItems.map((item: any) => {
                  const iconUrl = getOdooMediaUrl(item.icon);
                  return (
                    <article class="border border-stone-200 bg-stone-50 p-5 text-center">
                      {iconUrl ? <img src={iconUrl} alt={item.iconAlt || item.label} class="w-14 h-14 object-cover mx-auto mb-4" /> : null}
                      {item.label ? <h3 class="text-lg font-semibold text-stone-900">{item.label}</h3> : null}
                      {item.description ? <p class="mt-2 text-sm text-stone-600">{item.description}</p> : null}
                    </article>
                  );
                })}
              </div>
            )}
          </div>
        )}
      </section>

      {packageItems.length > 0 && (
        <section class="max-w-6xl mx-auto px-6 pb-10">
          <h2 class="text-3xl md:text-4xl italic text-stone-900 mb-8" style="font-family: 'Playfair Display', serif;">
            {lang === "en" ? "Packages" : "Paquetes"}
          </h2>
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {packageItems.map((tour: any) => {
              const imageUrl = getOdooMediaUrl(tour.heroSlideImages?.[0]);
              return (
                <a href={`/${lang}/tours/${tour.slug}`} class="group block bg-white shadow-sm hover:shadow-lg transition overflow-hidden">
                  {imageUrl ? <img src={imageUrl} alt={tour.title} class="w-full h-64 object-cover group-hover:scale-[1.02] transition-transform duration-500" /> : <div class="w-full h-64 bg-stone-300" />}
                  <div class="p-5">
                    <h3 class="text-2xl text-stone-900" style="font-family: 'Playfair Display', serif; font-style: italic;">{tour.title}</h3>
                    {tour.metaDescription ? <div class="mt-2 text-sm text-stone-600 line-clamp-3" set:html={richContentToHtml(tour.metaDescription)} /> : null}
                    {tour.adultUnitPrice > 0 ? <p class="mt-3 text-sm text-[#1AA093] font-semibold">{priceFromLabel} {formatPrice(getDiscountedPrice(tour.adultUnitPrice, tour.discount), lang)}</p> : null}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      {smallTripItems.length > 0 && (
        <section class="max-w-6xl mx-auto px-6 pb-20">
          <h2 class="text-3xl md:text-4xl italic text-stone-900 mb-8" style="font-family: 'Playfair Display', serif;">
            Small Trips
          </h2>
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {smallTripItems.map((tour: any) => {
              const imageUrl = getOdooMediaUrl(tour.heroSlideImages?.[0]);
              return (
                <a href={`/${lang}/tours/${tour.slug}`} class="relative overflow-hidden group min-h-[320px]">
                  {imageUrl ? <img src={imageUrl} alt={tour.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" /> : <div class="absolute inset-0 bg-stone-300" />}
                  <span class="absolute inset-0 bg-gradient-to-b from-black/10 to-black/70 flex flex-col justify-end p-6 text-white">
                    {tour.discount > 0 ? <span class="absolute top-4 left-4 bg-[#1AA093] px-3 py-1 text-xs font-bold text-white rounded-full shadow">-{tour.discount.toFixed(0)}%</span> : null}
                    <div class="text-2xl font-bold leading-tight" style="font-family: 'Playfair Display', serif; font-style: italic;">{tour.title}</div>
                    {tour.adultUnitPrice > 0 ? (
                      <div class="mt-3">
                        {tour.discount > 0 ? <p class="text-xs text-white/60 line-through">{formatPrice(tour.adultUnitPrice, lang)}</p> : null}
                        <p class="text-sm font-bold text-white">
                          {priceFromLabel} {formatPrice(getDiscountedPrice(tour.adultUnitPrice, tour.discount), lang)}
                        </p>
                      </div>
                    ) : null}
                  </span>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </main>
    <Footer currentLang={lang} {t} />
  </body>
</html>
