---
import { getTranslation } from "../../../i18n";
import "../../../styles/global.css";
import GoogleAnalytics from "../../../components/shared/GoogleAnalytics.astro";
import DestinationsGallery from "../../../components/LandingPage/DestinationsGallery.astro";
import Navbar from "../../../components/shared/Navbar.astro";
import Footer from "../../../components/shared/Footer.astro";
import SEOHead from "../../../components/SEO/SEOHead.astro";

type SupportedLang = "es" | "en" | "pt" | "it" | "fr";

export function getStaticPaths() {
  return ["es", "en", "pt", "it", "fr"].map((lang) => ({ params: { lang } }));
}

const rawLang = (Astro.params.lang ?? "es").toLowerCase();
const lang: SupportedLang = ["es", "en", "pt", "it", "fr"].includes(rawLang) ? (rawLang as SupportedLang) : "es";
const t = getTranslation(lang);

if (rawLang !== lang) {
  return Astro.redirect(`/${lang}/destinos`);
}

const siteOrigin = (Astro.site?.origin ?? "https://incasparadise.com").replace(/\/$/, "");
const canonical = `${siteOrigin}/${lang}/destinos`;
const seoTitle =
  lang === "en" ? "Destinations | Inca's Paradise" :
  lang === "pt" ? "Destinos | Inca's Paradise" :
  lang === "fr" ? "Destinations | Inca's Paradise" :
  lang === "it" ? "Destinazioni | Inca's Paradise" :
  "Destinos | Inca's Paradise";
const seoDescription =
  lang === "en"
    ? "Explore our destinations in Peru and discover tours crafted from Odoo content."
    : lang === "pt"
    ? "Explore nossos destinos no Peru e descubra tours gerenciados no Odoo."
    : lang === "fr"
    ? "Explorez nos destinations au Perou et decouvrez des tours geres depuis Odoo."
    : lang === "it"
    ? "Esplora le nostre destinazioni in Peru e scopri tour gestiti da Odoo."
    : "Explora nuestros destinos en Peru y descubre tours gestionados desde Odoo.";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{seoTitle}</title>
    <SEOHead
      title={seoTitle}
      description={seoDescription}
      canonical={canonical}
      ogImage={`${siteOrigin}/og-image.jpg`}
      ogType="website"
      currentLang={lang}
      alternateLanguages={[
        { lang: "es-PE", url: `${siteOrigin}/es/destinos` },
        { lang: "en", url: `${siteOrigin}/en/destinos` },
        { lang: "pt", url: `${siteOrigin}/pt/destinos` },
        { lang: "fr", url: `${siteOrigin}/fr/destinos` },
        { lang: "it", url: `${siteOrigin}/it/destinos` },
      ]}
      xDefaultUrl={`${siteOrigin}/es/destinos`}
    />
    <GoogleAnalytics />
  </head>
  <body class="min-h-screen bg-white text-gray-900" data-navbar-solid>
    <Navbar {t} currentLang={lang} />
    <main class="pt-24">
      <DestinationsGallery t={t} currentLang={lang} />
    </main>
    <Footer currentLang={lang} {t} />
  </body>
</html>
