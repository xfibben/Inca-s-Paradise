---
import Navbar from "../../../components/shared/Navbar.astro";
import Footer from "../../../components/shared/Footer.astro";
import { getTranslation, languages } from "../../../i18n";
import { formatPrice } from "../../../utils/currency";
import { fetchOdooWebJson, getOdooMediaUrl, getOdooWebLang } from "../../../utils/odooWeb";
import { richContentToHtml } from "../../../utils/richContent";
import "../../../styles/global.css";
import GoogleAnalytics from "../../../components/shared/GoogleAnalytics.astro";

export function getStaticPaths() {
  return [];
}

const { lang, slug } = Astro.params;
const currentLang = Object.keys(languages).includes(lang as string) ? (lang as string) : "es";
const t = getTranslation(currentLang);

const priceFromLabel =
  currentLang === "en" ? "From"
  : currentLang === "pt" ? "Desde"
  : currentLang === "fr" ? "Des"
  : currentLang === "it" ? "Da"
  : "Desde";

const getDiscountedPrice = (price: number, discountPercent: number) =>
  Math.max(0, price - (price * Math.max(0, discountPercent)) / 100);

let trip: any = null;
try {
  const json = await fetchOdooWebJson(
    `/incas/api/web/estilos-viaje/${encodeURIComponent(slug as string)}?lang=${getOdooWebLang(currentLang)}`
  );
  trip = json?.data ?? null;
} catch (error) {
  console.error("[style-trips] Error:", error);
}

if (!trip) {
  return Astro.redirect(`/${currentLang}/destinos`);
}

const langSlugs = trip.slugs ?? { [currentLang]: trip.slug };
const tours: any[] = Array.isArray(trip.tours) ? trip.tours : [];
const relatedTours = tours.filter((tour: any) => tour.tourType === "small_trip" && tour.showInStyles !== false);
const carouselTours = tours.filter((tour: any) => tour.tourType !== "small_trip");
const heroImageUrl = getOdooMediaUrl(trip.wallpaper) || getOdooMediaUrl(trip.image);
const descriptionHtml = richContentToHtml(trip.description);
const plainDescription = descriptionHtml.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim();
const middleTitleHtml = richContentToHtml(trip.middle_tittle);
const middleDescriptionHtml = richContentToHtml(trip.middle_description);
const siteOrigin = (Astro.site?.origin ?? "https://incasparadise.com").replace(/\/$/, "");
const canonical = `${siteOrigin}/${currentLang}/style-trips/${trip.slug}`;
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{trip?.seoTitle || trip?.name || "Style Trip"} — Inca's Paradise</title>
    <meta name="description" content={trip?.seoDescription || plainDescription || "Style Trip"} />
    <link rel="canonical" href={canonical} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristTrip",
      "name": trip?.seoTitle || trip?.name || "Style Trip",
      "description": trip?.seoDescription || plainDescription || "Style Trip",
      "url": canonical,
      "provider": {
        "@type": "TravelAgency",
        "name": "Inca's Paradise",
        "url": "https://incasparadise.com"
      }
    })} />
    {heroImageUrl && <link rel="preload" as="image" href={heroImageUrl} fetchpriority="high" />}
    <GoogleAnalytics />
  </head>
  <body>
    <Navbar {t} currentLang={currentLang} />
    <script is:inline define:vars={{ langSlugs }}>
      window.__langSlugs = langSlugs;
      window.__slugBasePath = "/style-trips/";
    </script>

    <header class="relative w-full overflow-hidden" style="height: 75vh;">
      {heroImageUrl && (
        <img
          src={heroImageUrl}
          alt={trip.name}
          class="absolute inset-0 w-full h-full object-cover"
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
      )}
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 flex flex-col items-center justify-center h-full text-white text-center px-4">
        <h1 class="text-4xl md:text-6xl font-bold mb-4" style="font-family: 'Playfair Display', serif; font-style: italic;">
          {trip?.name || "Style Trip"}
        </h1>
      </div>
    </header>

    <main class="bg-white pb-16 px-4 md:px-20 lg:px-32">
      <div class="pt-12 max-w-4xl mx-auto">
        {descriptionHtml && <div class="text-xl text-gray-700 leading-relaxed text-center text-justify [&_p]:mb-3 [&_p:last-child]:mb-0" set:html={descriptionHtml} />}
        {trip?.middle_tittle && (
          <div class="mt-12 text-3xl md:text-4xl text-gray-900 text-center [&_p]:m-0" style="font-family: 'Playfair Display', serif; font-style: italic;" set:html={middleTitleHtml} />
        )}
        {middleDescriptionHtml && <div class="prose prose-stone max-w-none mt-6 text-gray-700 text-justify" set:html={middleDescriptionHtml} />}
      </div>

      {relatedTours.length > 0 && (
        <>
          <div class="bg-white px-4 pt-12 pb-8 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800" style="font-family: 'Playfair Display', serif; font-style: italic;">
              Small Trips
            </h2>
          </div>
          <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 max-w-6xl mx-auto">
            {relatedTours.map((tour: any) => {
              const tourImageUrl = getOdooMediaUrl(tour.heroSlideImages?.[0]);
              return (
                <a href={`/${currentLang}/tours/${tour.slug}`} class="relative overflow-hidden group min-h-[320px]">
                  {tourImageUrl ? <img src={tourImageUrl} alt={tour.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" /> : <div class="absolute inset-0 bg-stone-300" />}
                  <span class="absolute inset-0 bg-gradient-to-b from-black/10 to-black/70 flex flex-col justify-end p-6 text-white">
                    {tour.discount > 0 ? <span class="absolute top-4 left-4 bg-[#1AA093] px-3 py-1 text-xs font-bold text-white rounded-full shadow">-{tour.discount.toFixed(0)}%</span> : null}
                    <div class="text-2xl font-bold leading-tight" style="font-family: 'Playfair Display', serif; font-style: italic;">{tour.title}</div>
                    {tour.adultUnitPrice > 0 ? (
                      <div class="mt-3">
                        {tour.discount > 0 ? <p class="text-xs text-white/60 line-through">{formatPrice(tour.adultUnitPrice, currentLang)}</p> : null}
                        <p class="text-sm font-bold text-white">
                          {priceFromLabel} {formatPrice(getDiscountedPrice(tour.adultUnitPrice, tour.discount), currentLang)}
                        </p>
                      </div>
                    ) : null}
                  </span>
                </a>
              );
            })}
          </section>
        </>
      )}

      {carouselTours.length > 0 && (
        <>
          <div class="bg-white px-4 pt-14 pb-8 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800" style="font-family: 'Playfair Display', serif; font-style: italic;">
              Tours
            </h2>
          </div>
          <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 max-w-6xl mx-auto">
            {carouselTours.map((tour: any) => {
              const tourImageUrl = getOdooMediaUrl(tour.heroSlideImages?.[0]);
              return (
                <a href={`/${currentLang}/tours/${tour.slug}`} class="group block bg-white shadow-sm hover:shadow-lg transition overflow-hidden">
                  {tourImageUrl ? <img src={tourImageUrl} alt={tour.title} class="w-full h-64 object-cover group-hover:scale-[1.02] transition-transform duration-500" /> : <div class="w-full h-64 bg-stone-300" />}
                  <div class="p-5">
                    <h3 class="text-2xl text-stone-900" style="font-family: 'Playfair Display', serif; font-style: italic;">{tour.title}</h3>
                    {tour.adultUnitPrice > 0 ? (
                      <p class="mt-3 text-sm text-[#1AA093] font-semibold">
                        {priceFromLabel} {formatPrice(getDiscountedPrice(tour.adultUnitPrice, tour.discount), currentLang)}
                      </p>
                    ) : null}
                  </div>
                </a>
              );
            })}
          </section>
        </>
      )}
    </main>

    <Footer currentLang={currentLang} {t} />
  </body>
</html>
