---
import Navbar from '../../../components/shared/Navbar.astro';
import Footer from '../../../components/shared/Footer.astro';
import { getTranslation, languages } from '../../../i18n';
import '../../../styles/global.css';
import GoogleAnalytics from '../../../components/shared/GoogleAnalytics.astro';
import SEOHead from '../../../components/SEO/SEOHead.astro';
import { fetchOdooWebJson, getOdooWebLang } from '../../../utils/odooWeb';

const { lang } = Astro.params;
const currentLang = Object.keys(languages).includes(lang as string) ? (lang as string) : 'es';
const t = getTranslation(currentLang);

let data: any = null;
try {
  const json = await fetchOdooWebJson(`/incas/api/web/politicas?lang=${getOdooWebLang(currentLang)}`);
  data = json.data ?? null;
} catch (e) {
}

const fallbackTitles: Record<string, string> = {
  es: 'Políticas',
  en: 'Policies',
  pt: 'Políticas',
  fr: 'Politiques',
  it: 'Politiche',
};

const fallbackDescriptions: Record<string, string> = {
  es: 'Consulta las políticas de Inca\'s Paradise para servicios turísticos, reservas y atención al viajero.',
  en: 'Review Inca\'s Paradise policies for tourism services, bookings, and traveler support.',
  pt: 'Consulte as políticas da Inca\'s Paradise para serviços turísticos, reservas e atendimento ao viajante.',
  fr: 'Consultez les politiques d\'Inca\'s Paradise pour les services touristiques, les réservations et l\'assistance aux voyageurs.',
  it: 'Consulta le politiche di Inca\'s Paradise per servizi turistici, prenotazioni e assistenza ai viaggiatori.',
};

const plainText = (value: string) => value.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const title = data?.titulo ?? fallbackTitles[currentLang] ?? fallbackTitles.es;
const description = typeof data?.descripcion === 'string' ? data.descripcion : '';
const seoTitle = data?.metaTitle ?? title;
const seoDescription = data?.metaDescription || plainText(description) || fallbackDescriptions[currentLang] || fallbackDescriptions.es;
const descriptionHtml = description;

const fallbackSecciones: Record<string, Array<{ titulo: string; contenido: string }>> = {
  es: [
    {
      titulo: 'Reservas y confirmaciones',
      contenido: 'Toda reserva está sujeta a disponibilidad y se considera confirmada una vez recibido el pago o anticipo correspondiente, según las condiciones del servicio contratado.'
    },
    {
      titulo: 'Cambios operativos',
      contenido: 'Nos reservamos el derecho de realizar ajustes razonables en itinerarios, horarios o servicios cuando existan causas operativas, climáticas o de seguridad.'
    },
    {
      titulo: 'Responsabilidad del viajero',
      contenido: 'Es responsabilidad del pasajero presentar documentación válida, llegar a tiempo a los puntos de encuentro y revisar la información importante de su reserva antes del viaje.'
    },
    {
      titulo: 'Servicios de terceros',
      contenido: 'Algunos servicios pueden ser operados por terceros. En esos casos, las condiciones específicas del proveedor también pueden resultar aplicables.'
    }
  ]
};

const secciones = Array.isArray(data?.secciones) && data.secciones.length > 0
  ? data.secciones.map((seccion: any) => ({
      titulo: seccion?.titulo ?? '',
      contenidoHtml: String(seccion?.contenido ?? '')
    }))
  : (fallbackSecciones[currentLang] ?? fallbackSecciones.es).map((seccion) => ({
      titulo: seccion.titulo,
      contenidoHtml: `<p>${seccion.contenido}</p>`
    }));

const siteOrigin = (Astro.site?.origin ?? 'https://incasparadise.com').replace(/\/$/, '');
const canonical = `${siteOrigin}/${currentLang}/politicas`;
const alternateLanguages = [
  { lang: 'es', url: `${siteOrigin}/es/politicas` },
  { lang: 'en', url: `${siteOrigin}/en/politicas` },
  { lang: 'pt', url: `${siteOrigin}/pt/politicas` },
  { lang: 'fr', url: `${siteOrigin}/fr/politicas` },
  { lang: 'it', url: `${siteOrigin}/it/politicas` },
];

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": seoTitle,
  "description": seoDescription,
  "url": canonical,
  "inLanguage": currentLang === 'es' ? 'es-PE' : currentLang,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Inca's Paradise",
    "url": siteOrigin,
  },
  ...(secciones.length > 0 && {
    "hasPart": secciones.map((seccion, index) => ({
      "@type": "WebPageElement",
      "name": `${index + 1}. ${seccion.titulo}`,
    })),
  }),
};
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{seoTitle}</title>
    <SEOHead
      title={seoTitle}
      description={seoDescription}
      canonical={canonical}
      currentLang={currentLang}
      alternateLanguages={alternateLanguages}
      xDefaultUrl={`${siteOrigin}/es/politicas`}
      structuredData={pageSchema}
    />
    <GoogleAnalytics />
    <style>
      h1, h2 {
        font-family: 'Playfair Display', serif;
        font-weight: 500;
        font-style: italic;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col text-gray-900" data-navbar-solid>
    <Navbar {t} currentLang={currentLang} />
    <main class="flex-1 pt-24 pb-16 bg-white">
      <div class="mx-auto max-w-5xl px-4">
        <div class="mb-6">
          <h1 class="mb-4 text-3xl md:text-4xl text-[#1AA093]">{title}</h1>
          {description && (
            <div
              class="prose prose-gray max-w-none text-black leading-7 text-justify prose-p:my-0 prose-p:leading-7 prose-headings:text-black prose-strong:text-black prose-li:text-black prose-blockquote:text-black prose-a:text-[#1AA093] prose-a:no-underline hover:prose-a:text-[#0e8a7e]"
              set:html={descriptionHtml}
            />
          )}
        </div>

        {secciones.length > 0 ? (
          <div class="border-t border-gray-200">
            {secciones.map((seccion, index) => (
              <section class="border-b border-gray-200 py-7 md:py-8">
                <div>
                  <div class="mb-3 flex items-center gap-3 md:gap-4">
                    <span class="block shrink-0 text-lg font-medium tracking-[0.18em] text-[#1AA093] md:text-xl">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <h2 class="text-xl text-[#1AA093] md:text-2xl">{seccion.titulo}</h2>
                  </div>
                  <div
                    class="prose prose-gray max-w-none text-black leading-7 text-justify prose-p:my-0 prose-p:leading-7 prose-headings:mt-0 prose-headings:mb-0 prose-headings:text-black prose-strong:text-black prose-li:text-black prose-blockquote:text-black prose-a:text-[#1AA093] prose-a:no-underline hover:prose-a:text-[#0e8a7e]"
                    set:html={seccion.contenidoHtml}
                  />
                </div>
              </section>
            ))}
          </div>
        ) : (
          <p class="text-gray-400 italic">
            {currentLang === 'es' ? 'Contenido próximamente.' : 'Content coming soon.'}
          </p>
        )}
      </div>
    </main>
    <Footer {t} currentLang={currentLang} />
  </body>
</html>
