---
import "../../../styles/global.css";
import fallbackEs from "../../../data/destinos.json";
import fallbackEn from "../../../data/destinos.en.json";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const STRAPI_URL =
  import.meta.env.PUBLIC_STRAPI_URL ??
  import.meta.env.STRAPI_INTERNAL_URL ??
  "http://backend:1337";

const { lang: rawLang } = Astro.params;
const lang = (rawLang ?? "es").toLowerCase();
const fallback = lang === "en" ? fallbackEn : fallbackEs;

const localeMap: Record<string, string> = {
  es: "es-PE",
  "es-pe": "es-PE",
  en: "en"
};
const apiLocale = localeMap[lang] ?? lang;

let title = fallback.data?.attributes?.title ?? "Destinos";
let description = fallback.data?.attributes?.description ?? "";
let ribbonText = fallback.data?.attributes?.ribbonText ?? "";

try {
  const res = await fetch(
    `${STRAPI_URL}/api/destino?locale=${apiLocale}&fields[0]=title&fields[1]=description&fields[2]=ribbonText`
  );

  if (res.ok) {
    const json = await res.json();
    const raw = json?.data ?? null;
    const attrs = raw?.attributes ?? raw ?? {};
    title = attrs.title ?? title;
    description = attrs.description ?? description;
    ribbonText = attrs.ribbonText ?? ribbonText;
  }
} catch {
  // Keep fallback content when Strapi is not reachable.
}

const canonical = `${Astro.url.origin}/destinos/${lang}`;

const packages = [
  {
    type: "card",
    title: "Puno Iconico",
    meta: "Dias: 6 | Desde: $320 por persona",
    description:
      "Lago Titicaca, Uros y Sillustani con tiempos flexibles y vistas abiertas.",
    image:
      "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Titicaca Esencial",
    meta: "Dias: 5 | Desde: $280 por persona",
    description:
      "Ruta corta con Taquile y Amantani, ideal para descubrir la vida lacustre.",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "quote",
    quote:
      "Todo salio perfecto. El equipo entendio lo que buscaba y cada detalle se sintio pensado para mi.",
    author: "Susana B."
  },
  {
    type: "card",
    title: "Altiplano Privado",
    meta: "Dias: 7 | Desde: $460 por persona",
    description:
      "Experiencia premium con guias locales y alojamientos boutique.",
    image:
      "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Sillustani y Lampa",
    meta: "Dias: 4 | Desde: $240 por persona",
    description:
      "Arqueologia, miradores y pueblos que conservan su esencia.",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Aventuras en Kayak",
    meta: "Dias: 5 | Desde: $350 por persona",
    description:
      "Rutas activas por el lago con tardes libres para explorar.",
    image:
      "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Sabores del Titicaca",
    meta: "Dias: 6 | Desde: $330 por persona",
    description:
      "Gastronomia local, mercados y clases con chefs andinos.",
    image:
      "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Ruta Fotografia",
    meta: "Dias: 6 | Desde: $390 por persona",
    description:
      "Luz dorada, paisajes abiertos y sesiones con guias expertos.",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
  }
];
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
	</head>
	<body class="min-h-screen bg-white text-gray-900">
		<main>
			<section class="bg-[#f5f0e9]">
				<div class="mx-auto w-full max-w-5xl px-6 py-16 md:py-24 lg:py-28">
					<h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4 md:mb-6 lg:mb-8 italic">
						{title}
					</h1>
					<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed mb-3 md:mb-4 lg:mb-6">
						{description}
					</p>
				</div>
			</section>
			<section class="bg-white">
				<div class="mx-auto w-full max-w-5xl px-6 py-10 md:py-12">
					<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed flex items-center gap-2">
						<span class="inline-block h-2 w-2 rounded-sm bg-orange-500"></span>
						<span>{ribbonText}</span>
					</p>
				</div>
			</section>
			<section class="bg-white">
				<div class="mx-auto w-full max-w-6xl px-6 pb-16 md:pb-20 lg:pb-24">
					<div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
						{packages.map((item) =>
							item.type === "quote" ? (
								<div class="flex min-h-[420px] items-center justify-center bg-slate-900 px-6 py-10 text-center text-white">
									<div>
										<p class="text-lg md:text-xl lg:text-2xl font-semibold italic leading-snug">
											&quot;{item.quote}&quot;
										</p>
										<p class="mt-6 text-sm md:text-base lg:text-lg font-semibold">
											{item.author}
										</p>
									</div>
								</div>
							) : (
								<article class="flex flex-col gap-4">
									<div class="aspect-[4/3] overflow-hidden bg-gray-100">
										<img
											src={item.image}
											alt={item.title}
											class="h-full w-full object-cover"
										/>
									</div>
									<div class="flex flex-col gap-2">
										<h3 class="text-base md:text-lg lg:text-xl font-semibold text-gray-700 leading-snug">
											{item.title}
										</h3>
										<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">
											{item.meta}
										</p>
										<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">
											{item.description}
										</p>
										<button
											type="button"
											class="mt-2 inline-flex w-fit items-center justify-center border border-gray-900 px-4 py-2 text-xs md:text-sm uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
										>
											Ver itinerario
										</button>
									</div>
								</article>
							)
						)}
					</div>
				</div>
			</section>
		</main>
	</body>
</html>
