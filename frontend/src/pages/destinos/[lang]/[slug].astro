---
import destinosDetailEs from "../../../data/destinos.detail.es.json";
import destinosDetailEn from "../../../data/destinos.detail.en.json";

export function getStaticPaths() {
  const esPaths = destinosDetailEs.destinations.map((item) => ({
    params: { lang: "es", slug: item.slug }
  }));
  const enPaths = destinosDetailEn.destinations.map((item) => ({
    params: { lang: "en", slug: item.slug }
  }));

  return [...esPaths, ...enPaths];
}

const { lang, slug } = Astro.params;
const targetLang = (lang ?? "es").toLowerCase();
const targetSlug = slug ?? "";
return Astro.redirect(`/${targetLang}/destinos/${targetSlug}`);
---
