---
import "../../../styles/global.css";
import destinosFallback from "../../../data/destinos.json";

export async function getStaticPaths() {
  return [
    { params: { lang: "es", slug: "puno" } },
    { params: { lang: "en", slug: "puno" } }
  ];
}

const { lang: rawLang, slug } = Astro.params;
const lang = (rawLang ?? "es").toLowerCase();
const canonical = `${Astro.url.origin}/destinos/${lang}/${slug ?? ""}`;
const isPuno = (slug ?? "").toLowerCase() === "puno";
const destinationName = (slug ?? "").trim();
const destinationLabel = destinationName
  ? destinationName.charAt(0).toUpperCase() + destinationName.slice(1)
  : "destinos";
const pageTitle = isPuno ? "Puno" : lang === "en" ? "Destination" : "Destino";
const pageDescription = isPuno
  ? "Puno, altiplano y cultura viva a orillas del Lago Titicaca."
  : lang === "en"
    ? "Destination page placeholder."
    : "Vista de destino en construccion.";
const ribbonText =
  destinosFallback.data?.attributes?.ribbonText ??
  `Mejores ventas en tours de ${destinationLabel}`;

const slides = [
  {
    id: "slide-1",
    image:
      "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=2000&q=80",
    title: "Puno",
    description: "Altiplano del Lago Titicaca, cultura viva y paisajes abiertos."
  },
  {
    id: "slide-2",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=2000&q=80",
    title: "Islas del Titicaca",
    description: "Uros, Taquile y Amantani: tradicion, tejido y vida lacustre."
  },
  {
    id: "slide-3",
    image:
      "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=2000&q=80",
    title: "Ritmo Andino",
    description: "Festividades, musica y panoramas que conectan con la sierra."
  }
];

const packages = [
  {
    type: "card",
    title: "Puno Iconico",
    meta: "Dias: 6 | Desde: $320 por persona",
    description:
      "Lago Titicaca, Uros y Sillustani con tiempos flexibles y vistas abiertas.",
    image:
      "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Titicaca Esencial",
    meta: "Dias: 5 | Desde: $280 por persona",
    description:
      "Ruta corta con Taquile y Amantani, ideal para la vida lacustre.",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "quote",
    quote:
      "Todo salio perfecto. El equipo entendio lo que buscaba y cada detalle se sintio pensado para mi.",
    author: "Susana B."
  },
  {
    type: "card",
    title: "Altiplano Privado",
    meta: "Dias: 7 | Desde: $460 por persona",
    description:
      "Experiencia premium con guias locales y alojamientos boutique.",
    image:
      "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Sillustani y Lampa",
    meta: "Dias: 4 | Desde: $240 por persona",
    description:
      "Arqueologia, miradores y pueblos que conservan su esencia.",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Aventuras en Kayak",
    meta: "Dias: 5 | Desde: $350 por persona",
    description:
      "Rutas activas por el lago con tardes libres para explorar.",
    image:
      "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Sabores del Titicaca",
    meta: "Dias: 6 | Desde: $330 por persona",
    description:
      "Gastronomia local, mercados y clases con chefs andinos.",
    image:
      "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Ruta Fotografia",
    meta: "Dias: 6 | Desde: $390 por persona",
    description:
      "Luz dorada, paisajes abiertos y sesiones con guias expertos.",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Caminos Sagrados",
    meta: "Dias: 5 | Desde: $310 por persona",
    description:
      "Travesias con paisajes andinos y comunidades vivas.",
    image:
      "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Amanecer en Taquile",
    meta: "Dias: 4 | Desde: $230 por persona",
    description:
      "Ritmos tranquilos, textiles y miradores del lago.",
    image:
      "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Ruta Cultural",
    meta: "Dias: 6 | Desde: $360 por persona",
    description:
      "Museos locales, festividades y sabores regionales.",
    image:
      "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
  },
  {
    type: "card",
    title: "Lago y Montanas",
    meta: "Dias: 7 | Desde: $410 por persona",
    description:
      "Miradores, caminatas suaves y estancias boutique.",
    image:
      "https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80"
  }
];
const initialVisibleCount = 8;
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={canonical} />
	</head>
	<body class="min-h-screen bg-white text-gray-900">
		<main>
			{isPuno ? (
				<section class="relative w-full bg-black overflow-hidden h-screen min-h-screen">
					<div id="destino-carousel" class="relative h-full w-full" data-carousel="slide">
						<div class="relative h-full w-full overflow-hidden">
							{slides.map((slide, index) => (
								<div
									class={`absolute inset-0 transition-opacity duration-700 ease-in-out ${
										index === 0 ? "opacity-100" : "opacity-0"
									}`}
									data-carousel-item
									data-index={index}
								>
									<img
										src={slide.image}
										alt={slide.title || "Destino"}
										class="absolute inset-0 h-full w-full object-cover object-center scale-[1.02]"
									/>
									<div class="absolute inset-0 bg-black/40"></div>
									<div class="absolute inset-0 z-10 flex h-full w-full items-center justify-center px-6 text-center">
										<div class="mx-auto max-w-2xl text-white">
											<div class="mb-5 flex justify-center">
												<svg
													width="54"
													height="54"
													viewBox="0 0 64 64"
													fill="none"
													aria-hidden="true"
												>
													<path
														d="M32 6L37 20L52 14L44 28L58 32L44 36L52 50L37 44L32 58L27 44L12 50L20 36L6 32L20 28L12 14L27 20L32 6Z"
														fill="white"
														fill-opacity="0.95"
													/>
												</svg>
											</div>
											{slide.title ? (
												<h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight mb-4 md:mb-6 lg:mb-8 italic drop-shadow-sm">
													{slide.title}
												</h1>
											) : null}
											{slide.description ? (
												<p class="text-sm md:text-base lg:text-lg text-white/90 leading-relaxed mb-3 md:mb-4 lg:mb-6">
													{slide.description}
												</p>
											) : null}
										</div>
									</div>
								</div>
							))}
						</div>

						<button
							type="button"
							class="absolute top-0 left-0 z-30 flex h-full items-center justify-center px-4 cursor-pointer group focus:outline-none"
							aria-label="Anterior"
							data-carousel-prev
						>
							<span class="inline-flex items-center justify-center text-white/90 group-hover:text-white">
								<svg class="w-5 h-5" viewBox="0 0 6 10" fill="none" aria-hidden="true">
									<path
										d="M5 1 1 5l4 4"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</span>
						</button>
						<button
							type="button"
							class="absolute top-0 right-0 z-30 flex h-full items-center justify-center px-4 cursor-pointer group focus:outline-none"
							aria-label="Siguiente"
							data-carousel-next
						>
							<span class="inline-flex items-center justify-center text-white/90 group-hover:text-white">
								<svg class="w-5 h-5" viewBox="0 0 6 10" fill="none" aria-hidden="true">
									<path
										d="m1 9 4-4-4-4"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</span>
						</button>
					</div>
				</section>
			) : null}
			{isPuno ? (
				<section class="bg-[#f5f0e9]">
					<div class="mx-auto grid w-full max-w-6xl gap-14 px-6 py-16 md:grid-cols-[1.2fr_1fr] md:py-24 lg:py-28">
						<div class="max-w-xl">
							<h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4 md:mb-6 lg:mb-8 italic">
								Explora Puno, hecho a tu medida
							</h2>
							<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed mb-3 md:mb-4 lg:mb-6">
								Nuestros especialistas conocen Puno de primera mano y crean itinerarios
								personalizados que combinan cultura viva, acompanamiento cercano y paisajes del
								<span class="underline decoration-1 decoration-gray-500 underline-offset-2">Lago Titicaca</span>.
							</p>
							<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed mb-3 md:mb-4 lg:mb-6">
								Descubre <span class="underline decoration-1 decoration-gray-500 underline-offset-2">los Uros</span>,
								<span class="underline decoration-1 decoration-gray-500 underline-offset-2">Taquile</span>,
								<span class="underline decoration-1 decoration-gray-500 underline-offset-2">Amantani</span> y miradores como
								<span class="underline decoration-1 decoration-gray-500 underline-offset-2">Sillustani</span>. Ajustamos cada ruta a tu
								ritmo, fechas e intereses.
							</p>
						</div>
						<div class="mx-auto w-full max-w-md">
							<div class="grid grid-cols-3 gap-x-8 gap-y-10 text-center">
								<div class="flex flex-col items-center gap-2">
									<div class="h-12 w-12 text-slate-900">
										<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
											<path d="M14 42c8-10 28-10 36 0" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M20 42c0 8 6 14 12 14s12-6 12-14" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M24 28h16" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										</svg>
									</div>
									<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">Gastronomia local</p>
								</div>
								<div class="flex flex-col items-center gap-2">
									<div class="h-12 w-12 text-slate-900">
										<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
											<path d="M10 28h44" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M12 38h40" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M18 18l4 6h-8l4-6z" stroke="currentColor" stroke-width="3" stroke-linejoin="round" />
										</svg>
									</div>
									<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">5 estrellas</p>
								</div>
								<div class="flex flex-col items-center gap-2">
									<div class="h-12 w-12 text-slate-900">
										<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
											<path d="M20 48c8-3 16-10 24-22" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M18 22l10 8-12 4" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</div>
									<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">Viajes responsables</p>
								</div>
								<div class="flex flex-col items-center gap-2">
									<div class="h-12 w-12 text-slate-900">
										<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
											<path d="M12 44h40" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M20 44V24h24v20" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
											<path d="M16 24l16-10 16 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</div>
									<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">Alojamientos boutique</p>
								</div>
								<div class="flex flex-col items-center gap-2">
									<div class="h-12 w-12 text-slate-900">
										<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
											<path d="M16 32h32" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M20 40h24" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M20 24h24" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										</svg>
									</div>
									<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">Resenas verificadas</p>
								</div>
								<div class="flex flex-col items-center gap-2">
									<div class="h-12 w-12 text-slate-900">
										<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
											<path d="M12 40c12-10 32-10 44 0" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M22 28c6 6 14 6 20 0" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
											<path d="M20 22l12-10 12 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										</svg>
									</div>
									<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">Guias locales expertos</p>
								</div>
							</div>
						</div>
					</div>
				</section>
			) : null}
			{isPuno ? (
				<section class="bg-white">
					<div class="mx-auto w-full max-w-6xl px-6 py-10 md:py-12">
						<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed flex items-center gap-2">
							<span class="inline-block h-2 w-2 rounded-sm bg-orange-500"></span>
							<span>{ribbonText}</span>
						</p>
					</div>
				</section>
			) : null}
			{isPuno ? (
				<section class="bg-white">
					<div class="mx-auto w-full max-w-7xl px-6 pb-14 md:pb-18 lg:pb-20">
						<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4" data-packages>
							{packages.map((item, index) =>
								item.type === "quote" ? (
									<div
										class={`flex min-h-[400px] items-center justify-center bg-[#0b2b3a] px-6 py-10 text-center text-white ${
											index >= initialVisibleCount ? "hidden" : ""
										}`}
										data-extra={index >= initialVisibleCount ? "true" : "false"}
									>
										<div>
											<p class="text-base md:text-lg lg:text-xl font-semibold italic leading-snug">
												&quot;{item.quote}&quot;
											</p>
											<p class="mt-5 text-xs md:text-sm lg:text-base font-semibold">
												{item.author}
											</p>
										</div>
									</div>
								) : (
									<article
										class={`flex flex-col ${index >= initialVisibleCount ? "hidden" : ""}`}
										data-extra={index >= initialVisibleCount ? "true" : "false"}
									>
										<div class="relative aspect-[4/3] overflow-hidden bg-gray-100 group">
											<img
												src={item.image}
												alt={item.title}
												class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
											/>
											<div class="absolute inset-0 bg-black/0 transition duration-300 group-hover:bg-black/40"></div>
										</div>
										<div class="mt-3 flex flex-col gap-0.5">
											<h3 class="text-sm md:text-base lg:text-lg font-semibold text-gray-900 leading-snug">
												{item.title}
											</h3>
											<p class="text-xs md:text-sm lg:text-base font-semibold text-gray-900 leading-relaxed">
												{item.meta}
											</p>
											<p class="text-xs md:text-sm lg:text-base text-gray-700 leading-relaxed mt-1">
												{item.description}
											</p>
											<button
												type="button"
												class="mt-3 inline-flex w-fit items-center justify-center border border-gray-900 px-4 py-2 text-[11px] md:text-xs uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
											>
												Ver itinerario
											</button>
										</div>
									</article>
								)
							)}
						</div>
						<div class="mt-12 flex flex-col items-center gap-3">
							<button
								type="button"
								class="inline-flex items-center justify-center border border-gray-900 px-6 py-2 text-xs md:text-sm uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
								data-show-more
								aria-expanded="false"
								aria-controls="destinos-more"
							>
								See More
							</button>
							<svg class="h-4 w-6 text-gray-900" viewBox="0 0 24 12" fill="none" aria-hidden="true">
								<path
									d="m2 2 10 8 10-8"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</div>
					</div>
				</section>
			) : null}
			{isPuno ? (
				<section class="bg-[#f5f0e9]">
					<div class="mx-auto w-full max-w-6xl px-6 py-10 md:py-12">
						<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed flex items-center gap-2">
							<span class="inline-block h-2 w-2 rounded-sm bg-orange-500"></span>
							<span>Destino de Puno</span>
						</p>
					</div>
				</section>
			) : null}
			{isPuno ? (
				<section class="bg-white">
					<div class="mx-auto w-full max-w-6xl px-6 py-16 md:py-20 lg:py-24">
						<div class="min-h-[220px] md:min-h-[280px] lg:min-h-[320px] border border-dashed border-gray-300 flex items-center justify-center text-xs md:text-sm text-gray-500 uppercase tracking-wide">
							Espacio para componente
						</div>
					</div>
				</section>
			) : null}
			{isPuno ? (
				<section class="bg-white">
					<div class="mx-auto w-full max-w-6xl px-6 py-12 md:py-14 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
						<h2 class="text-lg md:text-xl lg:text-2xl font-semibold text-gray-800 leading-snug italic">
							Por que viajar con Incas Paradise
						</h2>
						<button
							type="button"
							class="inline-flex items-center justify-center border border-gray-900 px-5 py-2 text-xs md:text-sm uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
						>
							10 razones para viajar con Incas Paradise
						</button>
					</div>
				</section>
			) : null}
		</main>
		<script is:inline>
			(() => {
				const slides = Array.from(document.querySelectorAll("[data-carousel-item]"));
				const prev = document.querySelector("[data-carousel-prev]");
				const next = document.querySelector("[data-carousel-next]");
				if (!slides.length) return;

				let index = 0;
				const show = (i) => {
					index = (i + slides.length) % slides.length;
					slides.forEach((slide, idx) => {
						slide.classList.toggle("opacity-100", idx === index);
						slide.classList.toggle("opacity-0", idx !== index);
						slide.classList.toggle("pointer-events-none", idx !== index);
					});
				};

				let timer = setInterval(() => show(index + 1), 3000);
				const resetTimer = () => {
					clearInterval(timer);
					timer = setInterval(() => show(index + 1), 3000);
				};

				prev?.addEventListener("click", () => {
					show(index - 1);
					resetTimer();
				});
				next?.addEventListener("click", () => {
					show(index + 1);
					resetTimer();
				});
			})();

			(() => {
				const toggle = document.querySelector("[data-show-more]");
				const extras = Array.from(document.querySelectorAll('[data-extra="true"]'));
				if (!toggle || !extras.length) return;

				let expanded = false;
				const update = () => {
					extras.forEach((item) => item.classList.toggle("hidden", !expanded));
					toggle.textContent = expanded ? "See Less" : "See More";
					toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
				};

				toggle.addEventListener("click", () => {
					expanded = !expanded;
					update();
				});

				update();
			})();
		</script>
	</body>
</html>
