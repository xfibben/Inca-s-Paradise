---
import { getTranslation } from "../../../i18n";
import "../../../styles/global.css";
import DestinationsGallery from "../../../components/LandingPage/DestinationsGallery.astro";
import destinosDetail from "../../../data/destinos.detail.es.json";

const STRAPI_BASE_URLS = Array.from(
  new Set([
    import.meta.env.PUBLIC_STRAPI_URL,
    import.meta.env.STRAPI_INTERNAL_URL,
    "http://backend:1337",
    "http://localhost:1337"
  ].filter(Boolean))
);
const STRAPI_LOCALES = ["es-PE", "es", null] as const;
const STRAPI_DETAIL_ENDPOINT = "/api/destino-detalles";

function localePrefix(locale: (typeof STRAPI_LOCALES)[number]) {
  return locale ? `locale=${encodeURIComponent(locale)}&` : "";
}

function normalizeRow(row: any) {
  return row?.attributes ?? row ?? null;
}

async function fetchStrapiDetailBySlug(slugValue: string) {
  for (const baseUrl of STRAPI_BASE_URLS) {
    for (const locale of STRAPI_LOCALES) {
      const localePart = localePrefix(locale);
      const url =
        `${baseUrl}${STRAPI_DETAIL_ENDPOINT}?${localePart}` +
        `filters[slug][$eq]=${encodeURIComponent(slugValue)}&pagination[pageSize]=1`;

      try {
        const res = await fetch(url);
        if (!res.ok) continue;

        const json = await res.json();
        const rows = Array.isArray(json?.data) ? json.data : [];
        const first = rows[0];
        const attrs = normalizeRow(first);
        if (attrs) return attrs;
      } catch {
        // Try next locale / URL.
      }
    }
  }

  return null;
}

export async function getStaticPaths() {
  const strapiBaseUrls = Array.from(
    new Set([
      import.meta.env.PUBLIC_STRAPI_URL,
      import.meta.env.STRAPI_INTERNAL_URL,
      "http://backend:1337",
      "http://localhost:1337"
    ].filter(Boolean))
  );
  const strapiLocales = ["es-PE", "es", null] as const;
  const fallbackSlugs = destinosDetail.destinations.map((destination) =>
    String(destination.slug).toLowerCase()
  );
  const strapiSlugs = new Set<string>();

  for (const baseUrl of strapiBaseUrls) {
    for (const locale of strapiLocales) {
      const localePart = locale ? `locale=${encodeURIComponent(locale)}&` : "";
      const url = `${baseUrl}/api/destino-detalles?${localePart}fields[0]=slug&pagination[pageSize]=200`;

      try {
        const res = await fetch(url);
        if (!res.ok) continue;

        const json = await res.json();
        const rows = Array.isArray(json?.data) ? json.data : [];
        rows.forEach((row: any) => {
          const attrs = row?.attributes ?? row;
          const value = String(attrs?.slug ?? "").toLowerCase();
          if (value) strapiSlugs.add(value);
        });

        if (strapiSlugs.size > 0) break;
      } catch {
        // Try next locale / URL.
      }
    }

    if (strapiSlugs.size > 0) break;
  }

  return Array.from(new Set([...fallbackSlugs, ...Array.from(strapiSlugs)])).map(
    (value) => ({
      params: { slug: value }
    })
  );
}

const { slug } = Astro.params;
const slugKey = String(slug ?? "").toLowerCase();
const fallbackDestination =
  destinosDetail.destinations.find(
    (item) => String(item.slug).toLowerCase() === slugKey
  ) ??
  destinosDetail.destinations[0];
const t = getTranslation("es");

if (!fallbackDestination) {
  return Astro.redirect("/es/destinos");
}

const {
  meta,
  hero,
  intro,
  ribbons,
  packages,
  seeMore,
  blogCta,
  initialVisibleCount = 8
} = fallbackDestination;

const strapiDetail = await fetchStrapiDetailBySlug(slugKey);

const pageTitle = strapiDetail?.title ?? meta?.title ?? "Destino";
const pageDescription =
  strapiDetail?.description ??
  meta?.description ??
  "Vista de destino en construccion.";
const canonical = `${Astro.url.origin}/es/destinos/${slugKey || ""}`;
const slides =
  Array.isArray(strapiDetail?.heroSlides) && strapiDetail.heroSlides.length > 0
    ? strapiDetail.heroSlides
    : hero?.slides ?? [];
const introTitle = strapiDetail?.introTitle ?? intro?.title ?? "Explora el destino";
const introParagraphs =
  Array.isArray(strapiDetail?.introParagraphs) &&
  strapiDetail.introParagraphs.length > 0
    ? strapiDetail.introParagraphs
    : intro?.paragraphs ?? [];
const introHighlights =
  Array.isArray(strapiDetail?.introHighlights) &&
  strapiDetail.introHighlights.length > 0
    ? strapiDetail.introHighlights
    : intro?.highlights ?? [];
const iconLabels =
  (Array.isArray(strapiDetail?.iconLabels) && strapiDetail.iconLabels.length > 0
    ? strapiDetail.iconLabels
    : intro?.iconLabels) ?? [
    "Gastronomia local",
    "5 estrellas",
    "Viajes responsables",
    "Alojamientos boutique",
    "Resenas verificadas",
    "Guias locales expertos"
  ];
const primaryRibbon =
  strapiDetail?.primaryRibbon ??
  ribbons?.primary ??
  `Mejores ventas en tours de ${pageTitle}`;
const secondaryRibbon =
  strapiDetail?.secondaryRibbon ??
  ribbons?.secondary ??
  `Destino de ${pageTitle}`;
const seeMoreLabel = seeMore?.label ?? "See More";
const seeLessLabel = seeMore?.collapseLabel ?? "See Less";
const blogTitle =
  strapiDetail?.blogTitle ??
  blogCta?.title ??
  "Por que viajar con Incas Paradise";
const blogButton =
  strapiDetail?.blogButton ??
  blogCta?.button ??
  "10 razones para viajar con Incas Paradise";

const highlightText = (text: string, words: string[] = []) => {
  let result = text;
  words.forEach((word) => {
    const safe = word.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    result = result.replace(
      new RegExp(`\\b${safe}\\b`, "g"),
      `<span class="underline decoration-1 decoration-gray-500 underline-offset-2">${word}</span>`
    );
  });
  return result;
};
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,500&display=swap" rel="stylesheet" />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={canonical} />
	</head>
	<body class="min-h-screen bg-white text-gray-900">
		<main>
			<section class="relative w-full bg-black overflow-hidden h-screen min-h-screen">
				<div id="destino-carousel" class="relative h-full w-full" data-carousel="slide">
					<div class="relative h-full w-full overflow-hidden">
						{slides.map((slide, index) => (
							<div
								class={`absolute inset-0 transition-opacity duration-700 ease-in-out ${
									index === 0 ? "opacity-100" : "opacity-0"
								}`}
								data-carousel-item
								data-index={index}
							>
								<img
									src={slide.image}
									alt={slide.title || pageTitle}
									class="absolute inset-0 h-full w-full object-cover object-center scale-[1.02]"
								/>
								<div class="absolute inset-0 bg-black/40"></div>
								<div class="absolute inset-0 z-10 flex h-full w-full items-center justify-center px-6 text-center">
									<div class="mx-auto max-w-2xl text-white">
										<div class="mb-5 flex justify-center">
											<svg
												width="54"
												height="54"
												viewBox="0 0 64 64"
												fill="none"
												aria-hidden="true"
											>
												<path
													d="M32 6L37 20L52 14L44 28L58 32L44 36L52 50L37 44L32 58L27 44L12 50L20 36L6 32L20 28L12 14L27 20L32 6Z"
													fill="white"
													fill-opacity="0.95"
												/>
											</svg>
										</div>
										{slide.title ? (
											<h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight mb-4 md:mb-6 lg:mb-8 italic drop-shadow-sm">
												{slide.title}
											</h1>
										) : null}
										{slide.description ? (
											<p class="text-sm md:text-base lg:text-lg text-white/90 leading-relaxed mb-3 md:mb-4 lg:mb-6">
												{slide.description}
											</p>
										) : null}
									</div>
								</div>
							</div>
						))}
					</div>

					<button
						type="button"
						class="absolute top-0 left-0 z-30 flex h-full items-center justify-center px-4 cursor-pointer group focus:outline-none"
						aria-label="Anterior"
						data-carousel-prev
					>
						<span class="inline-flex items-center justify-center text-white/90 group-hover:text-white">
							<svg class="w-5 h-5" viewBox="0 0 6 10" fill="none" aria-hidden="true">
								<path
									d="M5 1 1 5l4 4"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</span>
					</button>
					<button
						type="button"
						class="absolute top-0 right-0 z-30 flex h-full items-center justify-center px-4 cursor-pointer group focus:outline-none"
						aria-label="Siguiente"
						data-carousel-next
					>
						<span class="inline-flex items-center justify-center text-white/90 group-hover:text-white">
							<svg class="w-5 h-5" viewBox="0 0 6 10" fill="none" aria-hidden="true">
								<path
									d="m1 9 4-4-4-4"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</span>
					</button>
				</div>
			</section>

			<section class="bg-[#f5f0e9]">
				<div class="mx-auto grid w-full max-w-6xl gap-14 px-6 py-16 md:grid-cols-[1.2fr_1fr] md:py-24 lg:py-28">
					<div class="max-w-xl">
						<h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 leading-tight mb-4 md:mb-6 lg:mb-8 italic">
							{introTitle}
						</h2>
						{introParagraphs[0] ? (
							<p
								class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed mb-3 md:mb-4 lg:mb-6"
								set:html={highlightText(introParagraphs[0], introHighlights[0] ?? [])}
							></p>
						) : null}
						{introParagraphs[1] ? (
							<p
								class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed mb-3 md:mb-4 lg:mb-6"
								set:html={highlightText(introParagraphs[1], introHighlights[1] ?? [])}
							></p>
						) : null}
					</div>
					<div class="mx-auto w-full max-w-md">
						<div class="grid grid-cols-3 gap-x-8 gap-y-10 text-center">
							<div class="flex flex-col items-center gap-2">
								<div class="h-12 w-12 text-slate-900">
									<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
										<path d="M14 42c8-10 28-10 36 0" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M20 42c0 8 6 14 12 14s12-6 12-14" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M24 28h16" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
									</svg>
								</div>
								<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">{iconLabels[0]}</p>
							</div>
							<div class="flex flex-col items-center gap-2">
								<div class="h-12 w-12 text-slate-900">
									<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
										<path d="M10 28h44" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M12 38h40" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M18 18l4 6h-8l4-6z" stroke="currentColor" stroke-width="3" stroke-linejoin="round" />
									</svg>
								</div>
								<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">{iconLabels[1]}</p>
							</div>
							<div class="flex flex-col items-center gap-2">
								<div class="h-12 w-12 text-slate-900">
									<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
										<path d="M20 48c8-3 16-10 24-22" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M18 22l10 8-12 4" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</div>
								<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">{iconLabels[2]}</p>
							</div>
							<div class="flex flex-col items-center gap-2">
								<div class="h-12 w-12 text-slate-900">
									<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
										<path d="M12 44h40" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M20 44V24h24v20" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
										<path d="M16 24l16-10 16 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</div>
								<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">{iconLabels[3]}</p>
							</div>
							<div class="flex flex-col items-center gap-2">
								<div class="h-12 w-12 text-slate-900">
									<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
										<path d="M16 32h32" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M20 40h24" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M20 24h24" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
									</svg>
								</div>
								<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">{iconLabels[4]}</p>
							</div>
							<div class="flex flex-col items-center gap-2">
								<div class="h-12 w-12 text-slate-900">
									<svg viewBox="0 0 64 64" fill="none" class="h-full w-full">
										<path d="M12 40c12-10 32-10 44 0" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M22 28c6 6 14 6 20 0" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
										<path d="M20 22l12-10 12 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
									</svg>
								</div>
								<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed">{iconLabels[5]}</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="bg-white">
				<div class="mx-auto w-full max-w-6xl px-6 py-10 md:py-12">
					<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed flex items-center gap-2">
						<span class="inline-block h-2 w-2 rounded-sm bg-orange-500"></span>
						<span>{primaryRibbon}</span>
					</p>
				</div>
			</section>

			<section class="bg-white">
				<div class="mx-auto w-full max-w-7xl px-6 pb-14 md:pb-18 lg:pb-20">
					<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4" data-packages>
						{packages.map((item, index) =>
							item.type === "quote" ? (
								<div
									class={`flex min-h-[400px] items-center justify-center bg-[#0b2b3a] px-6 py-10 text-center text-white ${
										index >= initialVisibleCount ? "hidden" : ""
									}`}
									data-extra={index >= initialVisibleCount ? "true" : "false"}
								>
									<div>
										<p class="text-base md:text-lg lg:text-xl font-semibold italic leading-snug">
											&quot;{item.quote}&quot;
										</p>
										<p class="mt-5 text-xs md:text-sm lg:text-base font-semibold">
											{item.author}
										</p>
									</div>
								</div>
							) : (
								<article
									class={`flex flex-col ${index >= initialVisibleCount ? "hidden" : ""}`}
									data-extra={index >= initialVisibleCount ? "true" : "false"}
								>
									<div class="relative aspect-[4/3] overflow-hidden bg-gray-100 group">
										<img
											src={item.image}
											alt={item.title}
											class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
										/>
										<div class="absolute inset-0 bg-black/0 transition duration-300 group-hover:bg-black/40"></div>
									</div>
									<div class="mt-3 flex flex-col gap-0.5">
										<h3 class="text-sm md:text-base lg:text-lg font-semibold text-gray-900 leading-snug">
											{item.title}
										</h3>
										<p class="text-xs md:text-sm lg:text-base font-semibold text-gray-900 leading-relaxed">
											{item.meta}
										</p>
										<p class="text-xs md:text-sm lg:text-base text-gray-700 leading-relaxed mt-1">
											{item.description}
										</p>
										{item.tourSlug ? (
											<a
												href={`/es/destinos/${slugKey}/tours/${item.tourSlug}`}
												class="mt-3 inline-flex w-fit items-center justify-center border border-gray-900 px-4 py-2 text-[11px] md:text-xs uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
											>
												Ver itinerario
											</a>
										) : (
											<button
												type="button"
												class="mt-3 inline-flex w-fit items-center justify-center border border-gray-900 px-4 py-2 text-[11px] md:text-xs uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
											>
												Ver itinerario
											</button>
										)}
									</div>
								</article>
							)
						)}
					</div>
					<div class="mt-12 flex flex-col items-center gap-3">
						<button
							type="button"
							class="inline-flex items-center justify-center border border-gray-900 px-6 py-2 text-xs md:text-sm uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
							data-show-more
							data-label-more={seeMoreLabel}
							data-label-less={seeLessLabel}
							aria-expanded="false"
							aria-controls="destinos-more"
						>
							{seeMoreLabel}
						</button>
						<svg class="h-4 w-6 text-gray-900" viewBox="0 0 24 12" fill="none" aria-hidden="true">
							<path
								d="m2 2 10 8 10-8"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</div>
				</div>
			</section>

			<section class="bg-[#f5f0e9]">
				<div class="mx-auto w-full max-w-6xl px-6 py-10 md:py-12">
					<p class="text-sm md:text-base lg:text-lg text-gray-700 leading-relaxed flex items-center gap-2">
						<span class="inline-block h-2 w-2 rounded-sm bg-orange-500"></span>
						<span>{secondaryRibbon}</span>
					</p>
				</div>
			</section>

			<DestinationsGallery t={t} />

			<section class="bg-white">
				<div class="mx-auto w-full max-w-6xl px-6 py-12 md:py-14 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
					<h2 class="text-lg md:text-xl lg:text-2xl font-semibold text-gray-800 leading-snug italic">
						{blogTitle}
					</h2>
					<button
						type="button"
						class="inline-flex items-center justify-center border border-gray-900 px-5 py-2 text-xs md:text-sm uppercase tracking-wide text-gray-900 transition hover:bg-gray-900 hover:text-white"
					>
						{blogButton}
					</button>
				</div>
			</section>
		</main>
		<script is:inline>
			(() => {
				const slides = Array.from(document.querySelectorAll("[data-carousel-item]"));
				const prev = document.querySelector("[data-carousel-prev]");
				const next = document.querySelector("[data-carousel-next]");
				if (!slides.length) return;

				let index = 0;
				const show = (i) => {
					index = (i + slides.length) % slides.length;
					slides.forEach((slide, idx) => {
						slide.classList.toggle("opacity-100", idx === index);
						slide.classList.toggle("opacity-0", idx !== index);
						slide.classList.toggle("pointer-events-none", idx !== index);
					});
				};

				let timer = setInterval(() => show(index + 1), 3000);
				const resetTimer = () => {
					clearInterval(timer);
					timer = setInterval(() => show(index + 1), 3000);
				};

				prev?.addEventListener("click", () => {
					show(index - 1);
					resetTimer();
				});
				next?.addEventListener("click", () => {
					show(index + 1);
					resetTimer();
				});
			})();

			(() => {
				const toggle = document.querySelector("[data-show-more]");
				const extras = Array.from(document.querySelectorAll('[data-extra="true"]'));
				if (!toggle || !extras.length) return;

				let expanded = false;
				const update = () => {
					extras.forEach((item) => item.classList.toggle("hidden", !expanded));
					const moreLabel = toggle.dataset.labelMore || "See More";
					const lessLabel = toggle.dataset.labelLess || "See Less";
					toggle.textContent = expanded ? lessLabel : moreLabel;
					toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
				};

				toggle.addEventListener("click", () => {
					expanded = !expanded;
					update();
				});

				update();
			})();
		</script>
	</body>
</html>
